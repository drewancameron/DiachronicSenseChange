% glossmargin.sty — Margin glosses using \marginpar
%
% \marginpar handles collision avoidance natively.
% We accept minor overflow at page bottoms (~40pt) as a tradeoff
% for correct stacking and same-page placement.
%
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{glossmargin}[2026/04/07 marginpar glosses v9]

\RequirePackage{xcolor}

% === Configuration ===
\definecolor{glosscolor}{gray}{0.3}
\newcommand{\glossfont}{\fontsize{6.5pt}{8.5pt}\selectfont\color{glosscolor}\raggedright}

% Tight spacing between consecutive marginpars
\setlength{\marginparpush}{3pt}

% === Commands ===

\newcommand{\glossmerged}[2]{%
  \marginpar{\glossfont #2}%
  #1%
}

\newcommand{\gloss}[2]{%
  \marginpar{\glossfont\textbf{#1} #2}%
}

\endinput
