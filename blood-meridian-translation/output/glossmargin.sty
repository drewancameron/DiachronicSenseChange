% glossmargin.sty — Margin glosses for Ancient Greek reader editions
%
% Two-column layout with Python-computed vertical offsets.
% Font size and spacing tuned for 4.5cm margin width.
%
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{glossmargin}[2026/04/07 Margin glosses v3]

\RequirePackage{marginnote}
\RequirePackage{xcolor}

% === Configuration ===
\definecolor{glosscolor}{gray}{0.3}

\newcommand{\glossfont}{%
  \fontsize{6.5pt}{8.5pt}\selectfont\color{glosscolor}%
}

% === Two-column gloss block ===
% #1 = left column, #2 = right column, #3 = vertical offset in pt
\newcommand{\glossblock}[3]{%
  \marginnote{%
    \glossfont
    \begin{minipage}[t]{0.47\marginparwidth}%
      \raggedright #1%
    \end{minipage}%
    \hfill
    \begin{minipage}[t]{0.47\marginparwidth}%
      \raggedright #2%
    \end{minipage}%
  }[#3]%
}

% === Single-column gloss block ===
% #1 = content, #2 = vertical offset in pt
\newcommand{\glossblocksingle}[2]{%
  \marginnote{\glossfont #1}[#2]%
}

% === Inline gloss ===
\newcommand{\gloss}[2]{%
  \marginnote{\glossfont \textbf{#1}~#2}[0pt]%
  #1%
}

\endinput
