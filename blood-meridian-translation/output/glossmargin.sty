% glossmargin.sty — Margin glosses using \marginpar for collision avoidance
%
% \marginpar has BUILT-IN collision avoidance: LaTeX stacks margin notes
% vertically without overlap. The only limitation is float count (256 with
% e-TeX, sufficient for our use).
%
% We use \marginpar directly — no \marginnote, no manual offset tracking.
% LaTeX handles everything.
%
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{glossmargin}[2026/04/07 Margin glosses via marginpar v5]

\RequirePackage{xcolor}

% === Configuration ===
\definecolor{glosscolor}{gray}{0.3}
\newcommand{\glossfont}{\fontsize{6.5pt}{8.5pt}\selectfont\color{glosscolor}\raggedright}

% === Commands ===

% Two-column gloss block
\newcommand{\glossblock}[2]{%
  \marginpar{%
    \glossfont
    \begin{minipage}[t]{0.47\marginparwidth}%
      \raggedright #1%
    \end{minipage}%
    \hfill
    \begin{minipage}[t]{0.47\marginparwidth}%
      \raggedright #2%
    \end{minipage}%
  }%
}

% Single-column gloss block
\newcommand{\glossblocksingle}[1]{%
  \marginpar{\glossfont #1}%
}

% Inline gloss (single word)
\newcommand{\gloss}[2]{%
  \marginpar{\glossfont \textbf{#1}~#2}%
}

\endinput
