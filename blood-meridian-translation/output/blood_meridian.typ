  #mg(132.4pt)[δωματίῳ][\= μικρῷ οἰκήματι]
  #mg(143.4pt)[καπηλείου][\= οἴνου καὶ σίτου πωλητηρίου]
  #mg(163.4pt)[μυθῶδες][\= ἐκ μύθων, οὐκ ἀληθινόν]
  #mg(183.3pt)[καρπούς][\= ἐνταῦθα τὰ μέρη τῶν χειρῶν πρὸς ταῖς παλάμαις]
