        {
          "anchor": "καπηλείῳ",
          "note": "= tavern",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "πέτασον δ' ἐν χερσὶν ἔχων τότε μὲν ἦν, νῦν δ' ἐπὶ κεφαλῆς θεὶς πάλιν στραφεὶς ἔξω πυλῶν ἔβη.",
      "glosses": [
