{
  "sentences": [
    {
      "index": 0,
      "greek": "Κατῆλθε τὴν ἀποθήκην πρὸς τὸν σκευοθήκην καὶ ἔλαβε τὴν ἀθλίαν ἐφίππιον καὶ τὸν στρωματόδεσμον καὶ ἤνεγκεν αὐτὰ πάλιν.",
      "glosses": [
        {
          "anchor": "ἐφίππιον",
          "note": "ἐπὶ ἵππου τιθέμενον σάγμα",
          "rank": 1
        },
        {
          "anchor": "ἀθλίαν",
          "note": "= ταλαίπωρον ↔ εὐδαίμων",
          "rank": 1
        },
        {
          "anchor": "σκευοθήκην",
          "note": "σκευο·θήκη = τόπος σκευῶν",
          "rank": 1
        },
        {
          "anchor": "στρωματόδεσμον",
          "note": "στρωμάτων δεσμός",
          "rank": 1
        },
        {
          "anchor": "ἀποθήκην",
          "note": "ἀπο·θήκη = τόπος ἀποκειμένων",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Εὗρε τὸν ἡμίονον καὶ ἐξήγαγεν αὐτὸν ἐκ τοῦ σταθμοῦ καὶ ἐχαλίνωσεν αὐτὸν τῷ ὠμοβοείῳ χαλινῷ καὶ ἤγαγεν αὐτὸν πρὸς τὸν φραγμόν.",
      "glosses": [
        {
          "anchor": "ἐχαλίνωσεν",
          "note": "< χαλινός = χαλινὸν περιέθηκεν",
          "rank": 1
        },
        {
          "anchor": "ὠμοβοείῳ",
          "note": "< ὠμὸς βοῦς = ἐκ βοείου δέρματος",
          "rank": 1
        },
        {
          "anchor": "σταθμοῦ",
          "note": "σταθμός = τόπος ζῴων",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Προσέκλινε τῷ ζῴῳ τὸν ὦμον καὶ ἐπέθηκε τὴν ἐφίππιον καὶ ἔζωσεν, τοῦ ἡμιόνου πηδῶντος καὶ ἀποδιδράσκοντος καὶ παρατρέχοντος τὴν κεφαλὴν παρὰ τὸν φραγμόν.",
      "glosses": [
        {
          "anchor": "ἐφίππιον",
          "note": "ἐπὶ ἵππου τιθέμενον σάγμα",
          "rank": 1
        },
        {
          "anchor": "πηδῶντος",
          "note": "< πηδάω = ἅλλομαι",
          "rank": 1
        },
        {
          "anchor": "ἀποδιδράσκοντος",
          "note": "< ἀποδιδράσκω = φεύγω",
          "rank": 1
        },
        {
          "anchor": "παρατρέχοντος",
          "note": "< παρατρέχω = παρὰ τι τρέχω",
          "rank": 1
        },
        {
          "anchor": "ἔζωσεν",
          "note": "< ζώνη = ζώνῃ περιέδησεν",
          "rank": 1
        },
        {
          "anchor": "ἡμιόνου",
          "note": "ἡμίονος = ἐξ ἵππου καὶ ὄνου",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἤγαγεν αὐτὸν διὰ τοῦ χωρίου.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Ὁ ἡμίονος διετέλει σείων τὴν κεφαλὴν εἰς τὰ πλάγια ὥσπερ τι ἔχων ἐν τῷ ὠτί.",
      "glosses": [
        {
          "anchor": "ὠτί",
          "note": "οὖς = τὸ ἀκούον μέρος",
          "rank": 1
        },
        {
          "anchor": "πλάγια",
          "note": "= εἰς τὰ κάτω ↔ ὀρθά",
          "rank": 1
        }
      ]
    }
  ]
}