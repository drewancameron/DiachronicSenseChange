{
  "sentences": [
    {
      "index": 0,
      "greek": "Σκότος ἦν ὅτε εἰσῆλθεν εἰς τὴν πόλιν, κύνες ὑλακτοῦντες, πρόσωπα διίστοντα τὰ παραπετάσματα ἐν ταῖς θυρίσι λαμπαδηφόροις.",
      "glosses": [
        {
          "anchor": "ὑλακτοῦντες",
          "note": "< ὑλακτέω = κύνες φωνὰς ποιοῦντες",
          "rank": 1
        },
        {
          "anchor": "διίστοντα",
          "note": "< διΐστημι = ἀνοίγοντα, χωρίζοντα",
          "rank": 1
        },
        {
          "anchor": "λαμπαδηφόροις",
          "note": "λαμπάδ·ηφόροις = λαμπάδας φέρουσι",
          "rank": 1
        },
        {
          "anchor": "παραπετάσματα",
          "note": "= καλύμματα θυρῶν",
          "rank": 1
        },
        {
          "anchor": "θυρίσι",
          "note": "< θυρίς = θυρίδες, μικραὶ θύραι",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Κτύπος κοῦφος τῶν ὁπλῶν τοῦ ἡμιόνου ἠχῶν ἐν ταῖς στενωποῖς κεναῖς μικραῖς.",
      "glosses": [
        {
          "anchor": "ἡμιόνου",
          "note": "ἡμίονος = ζῷον ὑπὸ ἵππου καὶ ὄνου",
          "rank": 1
        },
        {
          "anchor": "ἠχῶν",
          "note": "< ἠχέω = ψόφον ποιῶν",
          "rank": 1
        },
        {
          "anchor": "στενωποῖς",
          "note": "στεν·ωπός = στεναὶ ὁδοί",
          "rank": 1
        },
        {
          "anchor": "κοῦφος",
          "note": "= ἐλαφρός ↔ βαρύς",
          "rank": 1
        },
        {
          "anchor": "μικραῖς",
          "note": "< μικρός = σμικραῖς ↔ μεγάλαις",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ ἡμίονος ὠσφραίνετο τὸν ἀέρα καὶ κατέστρεψεν εἰς στενωπὸν εἰς ἀγορὰν ὅπου εἱστήκει ὑπὸ τὸ ἀστροφέγγος φρέαρ, πύελος, δεσμωτήριον ἵππων.",
      "glosses": [
        {
          "anchor": "ὠσφραίνετο",
          "note": "< ὀσφραίνομαι = ὀδμὴν λαμβάνω",
          "rank": 1
        },
        {
          "anchor": "ἀστροφέγγος",
          "note": "ἄστρ·οφέγγος = ἄστρων φῶς ἔχων",
          "rank": 1
        },
        {
          "anchor": "πύελος",
          "note": "= σκάφη, ἀγγεῖον ὕδατος",
          "rank": 1
        },
        {
          "anchor": "στενωπὸν",
          "note": "στεν·ωπός = στενὴ ὁδός",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ὁ παῖς καθῆκε ἑαυτὸν ἠρέμα καὶ ἔλαβε τὸν κάδον ἀπὸ τοῦ λιθίνου κρηπιδώματος καὶ καθῆκεν εἰς τὸ φρέαρ.",
      "glosses": [
        {
          "anchor": "λιθίνου",
          "note": "< λίθος = ἐκ λίθων πεποιημένου",
          "rank": 1
        },
        {
          "anchor": "κρηπιδώματος",
          "note": "< κρηπίς = βάσεως λιθίνης",
          "rank": 1
        },
        {
          "anchor": "καθῆκε",
          "note": "< καθίημι = κάτω ἧκε",
          "rank": 1
        },
        {
          "anchor": "κάδον",
          "note": "κάδος = ἀγγεῖον ὕδατος",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ψόφος κοῦφος ὕδατος ἤχησεν.",
      "glosses": [
        {
          "anchor": "ἤχησεν",
          "note": "< ἠχέω = ψόφον ἐποίησε",
          "rank": 1
        },
        {
          "anchor": "Ψόφος",
          "note": "= ἦχος, κρότος",
          "rank": 1
        },
        {
          "anchor": "κοῦφος",
          "note": "= ἐλαφρός ↔ βαρύς",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ἀνέσπασε τὸν κάδον, ὕδωρ στάζον ἐν τῷ σκότει.",
      "glosses": [
        {
          "anchor": "Ἀνέσπασε",
          "note": "< ἀνασπάω = ἄνω εἵλκυσε",
          "rank": 1
        },
        {
          "anchor": "στάζον",
          "note": "< στάζω = κατὰ σταγόνας ῥέον",
          "rank": 1
        },
        {
          "anchor": "κάδον",
          "note": "κάδος = ἀγγεῖον ὕδατος",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ἔβαψε τὴν κολοκύνθην καὶ ἔπιε καὶ ὁ ἡμίονος ἔψαυε τοῦ ἀγκῶνος.",
      "glosses": [
        {
          "anchor": "κολοκύνθην",
          "note": "= σκεῦος πίνειν, φιάλη",
          "rank": 1
        },
        {
          "anchor": "Ἔβαψε",
          "note": "< βάπτω = εἰς ὕδωρ ἐνέβαλε",
          "rank": 1
        },
        {
          "anchor": "ἔψαυε",
          "note": "< ψαύω = ἥπτετο, θιγγάνω",
          "rank": 1
        },
        {
          "anchor": "ἔπιε",
          "note": "< πίνω = ἔπιε ὕδωρ",
          "rank": 1
        },
        {
          "anchor": "ἀγκῶνος",
          "note": "ἀγκών = καμπὴ βραχίονος",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ὅτε ἐτέλεσε κατέθηκε τὸν κάδον ἐν τῇ ὁδῷ καὶ ἐκάθητο ἐπὶ τοῦ κρηπιδώματος τοῦ φρέατος καὶ ἐθεώρει τὸν ἡμίονον πίνοντα ἐκ τοῦ κάδου.",
      "glosses": [
        {
          "anchor": "κρηπιδώματος",
          "note": "< κρηπίς = βάσεως λιθίνης",
          "rank": 1
        },
        {
          "anchor": "ἐτέλεσε",
          "note": "< τελέω = ἐπέρανε, ἤνυσε",
          "rank": 1
        },
        {
          "anchor": "κάδου",
          "note": "κάδος = ἀγγεῖον ὕδατος",
          "rank": 1
        },
        {
          "anchor": "κάδον",
          "note": "κάδος = ἀγγεῖον ὕδατος",
          "rank": 1
        }
      ]
    }
  ]
}