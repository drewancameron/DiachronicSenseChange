{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὁ παῖς ἀνεχώρησεν εἰς τὸ μέσον τοῦ οἰκήματος καὶ ὁ κάπηλος ἐμόχθει διὰ τοῦ ἐδάφους πρὸς αὐτὸν ὥσπερ ἀνὴρ πρός τι ἔργον πορευόμενος.",
      "glosses": [
        {
          "anchor": "ἐμόχθει",
          "note": "= ἐπόνει, μετὰ κόπου ἐκινεῖτο",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "= πωλητής, ἔμπορος",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Δὶς ἤρασσε τὸν παῖδα καὶ ὁ παῖς δὶς εἰς τὰ δεξιὰ παρέστη.",
      "glosses": [
        {
          "anchor": "ἤρασσε",
          "note": "= ἔκρουε, προσέβαλλε σώματι",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Εἶτα εἰς τοὔπισθεν παρέστη.",
      "glosses": [
        {
          "anchor": "τοὔπισθεν",
          "note": "= τὸ ὄπισθεν, εἰς τὰ ὀπίσω",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ὁ κάπηλος ἔστη ὥσπερ πεπηγώς.",
      "glosses": [
        {
          "anchor": "πεπηγώς",
          "note": "< πήγνυμι = ἐστηκώς, ἀκίνητος",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "= πωλητής, ἔμπορος",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ὁ παῖς κούφως ὑπὲρ τὸν ἄβακα ἑαυτὸν ἦρε καὶ ἀνείλετο τὸ πιστόλιον.",
      "glosses": [
        {
          "anchor": "ἄβακα",
          "note": "ἄβαξ = τράπεζα καπήλου",
          "rank": 1
        },
        {
          "anchor": "πιστόλιον",
          "note": "= σακκίδιον χρημάτων",
          "rank": 1
        },
        {
          "anchor": "κούφως",
          "note": "= ἐλαφρῶς, ἄνευ ψόφου",
          "rank": 1
        },
        {
          "anchor": "ἦρε",
          "note": "< αἴρω = ἀνέλαβε, ἤγειρε",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Οὐδεὶς ἐκινήθη.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Τὴν πυρείαν ἀνέῳξε πρὸς τῷ ἄβακι καὶ τὴν κόνιν ἐξέχεε καὶ τὸ πιστόλιον πάλιν κατέθηκεν.",
      "glosses": [
        {
          "anchor": "πιστόλιον",
          "note": "= σακκίδιον χρημάτων",
          "rank": 1
        },
        {
          "anchor": "πυρείαν",
          "note": "= θήκη ἐν ᾗ κόνις",
          "rank": 1
        },
        {
          "anchor": "ἄβακι",
          "note": "ἄβαξ = τράπεζα καπήλου",
          "rank": 1
        },
        {
          "anchor": "ἐξέχεε",
          "note": "< ἐκχέω = ἔξω κατέχεε",
          "rank": 1
        },
        {
          "anchor": "ἀνέῳξε",
          "note": "< ἀνοίγω = διήνοιξε",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Εἶτα δύο λαγύνους πλήρεις ἐκ τῶν ὀρόφων ὄπισθεν ἐξελέξατο καὶ περὶ τὸ ἄκρον τοῦ ἄβακος ἦλθε μίαν ἐν ἑκατέρᾳ χειρὶ ἔχων.",
      "glosses": [
        {
          "anchor": "λαγύνους",
          "note": "λάγυνος = ἀγγεῖον οἴνου",
          "rank": 1
        },
        {
          "anchor": "ὀρόφων",
          "note": "ὄροφος = ἄνω μέρος οἰκίας",
          "rank": 1
        },
        {
          "anchor": "ἄβακος",
          "note": "ἄβαξ = τράπεζα καπήλου",
          "rank": 1
        }
      ]
    }
  ]
}