{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἔχεις πῦρ;",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Ὁ παῖς ἠρεύνησε τοὺς κόλπους καὶ ἀνεῦρε τεθλασμένον καὶ κεκηλιδωμένον ξύλινον κιβώτιον.",
      "glosses": [
        {
          "anchor": "ἠρεύνησε",
          "note": "< ἐρευνάω = ἐζήτησε διὰ σπουδῆς",
          "rank": 1
        },
        {
          "anchor": "τεθλασμένον",
          "note": "< θλάω = συντετριμμένον",
          "rank": 1
        },
        {
          "anchor": "κεκηλιδωμένον",
          "note": "< κηλιδόω = μεμολυσμένον",
          "rank": 1
        },
        {
          "anchor": "κιβώτιον",
          "note": "< κιβωτός = μικρὸν ξύλινον ἀγγεῖον",
          "rank": 1
        },
        {
          "anchor": "ἀνεῦρε",
          "note": "< ἀνευρίσκω = ηὗρε",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ ἀνὴρ ἔλαβεν αὐτὸ παρ' αὐτοῦ.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Δεῖ ὕλης τινὸς ἐνταῦθα, ἔφη.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Κατέθραυε τὸ κιβώτιον καὶ ἔστιβε τὰ θραύσματα πρὸς τῇ θύρᾳ.",
      "glosses": [
        {
          "anchor": "Κατέθραυε",
          "note": "< καταθραύω = συνέτριψε",
          "rank": 1
        },
        {
          "anchor": "ἔστιβε",
          "note": "< στιβάω = συνεπίεσε",
          "rank": 1
        },
        {
          "anchor": "κιβώτιον",
          "note": "< κιβωτός = μικρὸν ξύλινον ἀγγεῖον",
          "rank": 1
        },
        {
          "anchor": "θραύσματα",
          "note": "< θραῦσμα = τὰ συντετριμμένα μέρη",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ἅψε πῦρ καὶ ἐνέπρησε τὰ θραύσματα.",
      "glosses": [
        {
          "anchor": "Ἅψε",
          "note": "< ἅπτω = ἐνέπρησε",
          "rank": 1
        },
        {
          "anchor": "θραύσματα",
          "note": "< θραῦσμα = τὰ συντετριμμένα μέρη",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ἔωσε τὸν μικρὸν σωρὸν τοῦ καιομένου ξύλου ὑπὸ τὴν θύραν καὶ προσέθηκε πλείονα πυρά.",
      "glosses": [
        {
          "anchor": "Ἔωσε",
          "note": "< ὠθέω = ἤλασε",
          "rank": 1
        },
        {
          "anchor": "καιομένου",
          "note": "< καίω = πυρὶ φλεγομένου",
          "rank": 1
        },
        {
          "anchor": "σωρὸν",
          "note": "σωρός = συγκείμενα πλῆθος",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ἔνδον ἐστίν;",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "ἔφη ὁ παῖς.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "Τοῦτο μέλλομεν ὁρᾶν.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "Μέλαινά τις ἕλιξ καπνοῦ ἀνῄει, κυανῆ φλὸξ καιομένης κόλλης.",
      "glosses": [
        {
          "anchor": "ἕλιξ",
          "note": "= στρόφιγξ, κύκλος",
          "rank": 1
        },
        {
          "anchor": "κυανῆ",
          "note": "< κύανος = μέλαινα μετὰ γλαυκότητος",
          "rank": 1
        },
        {
          "anchor": "κόλλης",
          "note": "κόλλα = ὕλη κολλητική",
          "rank": 1
        },
        {
          "anchor": "ἀνῄει",
          "note": "< ἄνειμι = ἄνω ἐπορεύετο",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Ὤκλαζον ἐν τῇ στοᾷ καὶ ἐθεῶντο.",
      "glosses": [
        {
          "anchor": "Ὤκλαζον",
          "note": "< ὀκλάζω = καθεζόμενοι ἦσαν",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Λεπταὶ φλόγες ἤρχοντο ἀνατρέχειν ὑπὲρ τὰς σανίδας καὶ πάλιν ἀποπηδᾶν.",
      "glosses": [
        {
          "anchor": "ἀνατρέχειν",
          "note": "< ἀνατρέχω = ἄνω θεῖν",
          "rank": 1
        },
        {
          "anchor": "ἀποπηδᾶν",
          "note": "< ἀποπηδάω = ἀπὸ τόπου ἅλλεσθαι",
          "rank": 1
        },
        {
          "anchor": "Λεπταὶ",
          "note": "< λεπτός = μικραὶ καὶ ἰσχναί ↔ παχεῖαι",
          "rank": 1
        },
        {
          "anchor": "φλόγες",
          "note": "φλόξ = πυρὸς φῶς κινούμενον",
          "rank": 1
        },
        {
          "anchor": "σανίδας",
          "note": "σανίς = ξύλινα πλατέα μακρά",
          "rank": 1
        }
      ]
    },
    {
      "index": 13,
      "greek": "Οἱ θεώμενοι ἐῴκεσαν μορφαῖς ἐκ τέλματος ἀνορυχθείσαις.",
      "glosses": [
        {
          "anchor": "τέλματος",
          "note": "τέλμα = λίμνη βορβορώδης",
          "rank": 1
        },
        {
          "anchor": "ἀνορυχθείσαις",
          "note": "< ἀνορύττω = ἐκ γῆς ἀνελθούσαις",
          "rank": 1
        },
        {
          "anchor": "θεώμενοι",
          "note": "< θεάομαι = βλεπόμενοι",
          "rank": 1
        },
        {
          "anchor": "μορφαῖς",
          "note": "μορφή = εἰδώλοις, σχήμασι",
          "rank": 1
        },
        {
          "anchor": "ἐῴκεσαν",
          "note": "< ἔοικα = ὅμοιοι ἦσαν",
          "rank": 1
        }
      ]
    }
  ]
}