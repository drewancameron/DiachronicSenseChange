{
  "sentences": [
    {
      "index": 0,
      "greek": "ὁ ναύαρχος ἐπένευσεν.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "χεῖρας συνέθηκε μεταξὺ γονάτων.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "τί νομίζεις περὶ τῶν σπονδῶν;",
      "glosses": [
        {
          "anchor": "νομίζεις",
          "note": "= think",
          "rank": 1
        },
        {
          "anchor": "σπονδῶν",
          "note": "= treaty",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "ἔφη.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "ὁ παῖς ἔβλεψε πρὸς τὸν ἄνδρα τὸν ἐπὶ θάκου πλησίον.",
      "glosses": [
        {
          "anchor": "παῖς",
          "note": "= son",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "ὀφθαλμοὺς ἔχων μεμυκότας.",
      "glosses": [
        {
          "anchor": "μεμυκότας",
          "note": "= closed, shut",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "κάτω εἰς δακτύλους ἑαυτοῦ ἔβλεψεν.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "οὐδὲν οἶδα περὶ τούτου, ἔφη.",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "δέδοικα μὴ τοῦτ᾽ ᾖ τὸ πάθος πολλῶν Ἀμερικανῶν, ἔφη ὁ ναύαρχος.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "πόθεν εἶ, ὦ παῖ;",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "Τεννεσσῆς.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "οὐ μετὰ τῶν ἐθελοντῶν ἦσθα ἐν Μοντερρῇ;",
      "glosses": [
        {
          "anchor": "ἐθελοντῶν",
          "note": "= volunteers",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "οὔ, κύριε.",
      "glosses": []
    },
    {
      "index": 13,
      "greek": "ἀνδρειοτάτους ὑπὸ πυρὶ οἷμαι πώποτ᾽ εἶδον.",
      "glosses": [
        {
          "anchor": "ἀνδρειοτάτους",
          "note": "= bravest",
          "rank": 1
        }
      ]
    },
    {
      "index": 14,
      "greek": "οἶμαι πλείονας ἄνδρας ἐκ Τεννεσσῆς ᾑμάχθαι τε καὶ τεθνάναι ἐπὶ πεδίῳ τῆς βορείου Μεξικοῦ ἢ ἐξ ἄλλης πολιτείας.",
      "glosses": [
        {
          "anchor": "πλείονας",
          "note": "= more",
          "rank": 1
        },
        {
          "anchor": "πολιτείας",
          "note": "= state",
          "rank": 1
        },
        {
          "anchor": "ᾑμάχθαι",
          "note": "= fought, battled",
          "rank": 1
        }
      ]
    },
    {
      "index": 15,
      "greek": "ἆρ᾽ ᾔδεις τοῦτο;",
      "glosses": []
    }
  ]
}