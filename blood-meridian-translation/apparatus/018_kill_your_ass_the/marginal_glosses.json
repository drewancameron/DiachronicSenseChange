{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἀποκτενῶ σε, εἶπεν ὁ ἀνήρ.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Ἐπλανῶντο ἐν τῷ σκότῳ τοῦ χώρου, ἐκπίπτοντες τῶν ἐμβάδων.",
      "glosses": [
        {
          "anchor": "ἐμβάδων",
          "note": "ἐμβάς, -άδος = ὑπόδημα",
          "rank": 1
        },
        {
          "anchor": "ἐκπίπτοντες",
          "note": "< ἐκπίπτω = ἐκ τόπου πίπτω",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ παῖς εἶχε νῦν τὴν μάχαιραν καὶ ἐκύκλουν καρκίνων δίκην καὶ ὅτε ὁ ἀνὴρ ἐπ' αὐτὸν ὥρμησεν διέτεμε τὸν χιτῶνα τοῦ ἀνδρός.",
      "glosses": [
        {
          "anchor": "διέτεμε",
          "note": "< διατέμνω = διὰ μέσου κόπτω",
          "rank": 1
        },
        {
          "anchor": "καρκίνων",
          "note": "κάρκινος = θαλάττιον ζῷον",
          "rank": 1
        },
        {
          "anchor": "ἐκύκλουν",
          "note": "< κυκλόω = κύκλῳ κινοῦμαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ὁ ἀνὴρ ἔρριψε τὸν αὐχένα τῆς λαγύνου καὶ ἐσπάσατο μεγίστην μάχαιραν ὄπισθεν τοῦ αὐχένος.",
      "glosses": [
        {
          "anchor": "λαγύνου",
          "note": "λάγυνος = ἀγγεῖον οἴνου",
          "rank": 1
        },
        {
          "anchor": "ἐσπάσατο",
          "note": "< σπάω = εἷλκε πρὸς ἑαυτόν",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ὁ πῖλος ἀπέπεσεν καὶ αἱ μέλαιναι καὶ σχοινοειδεῖς πλόκαμοι περὶ τὴν κεφαλὴν ἐσείοντο καὶ εἰς ἓν ῥῆμα ἀποκτενῶ τὰς ἀπειλὰς συνέστησεν ὥσπερ μανιώδη ἐπῳδήν.",
      "glosses": [
        {
          "anchor": "ἀπέπεσεν",
          "note": "< ἀποπίπτω = κάτω πίπτω",
          "rank": 1
        },
        {
          "anchor": "σχοινοειδεῖς",
          "note": "< σχοῖνος = σχοίνῳ ὅμοιοι",
          "rank": 1
        },
        {
          "anchor": "πλόκαμοι",
          "note": "= βόστρυχοι τῆς κόμης",
          "rank": 1
        },
        {
          "anchor": "μανιώδη",
          "note": "< μανία = μανίας πλήρης",
          "rank": 1
        },
        {
          "anchor": "ἐπῳδήν",
          "note": "= ᾆσμα μαγικόν",
          "rank": 1
        },
        {
          "anchor": "πῖλος",
          "note": "= κάλυμμα κεφαλῆς",
          "rank": 1
        },
        {
          "anchor": "ἐσείοντο",
          "note": "< σείω = κινοῦντο ἔνθα κἀκεῖσε",
          "rank": 1
        }
      ]
