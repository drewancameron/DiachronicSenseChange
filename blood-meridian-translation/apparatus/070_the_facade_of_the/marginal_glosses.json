{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἡ πρόσοψις τοῦ οἰκοδομήματος στοίχους ἁγίων ἐν ταῖς κόγχαις αὐτῶν ἔφερε καὶ κατεβάλλοντο ὑπὸ Ἀμερικανῶν στρατιωτῶν τὰ πυροβόλα αὐτῶν πειρωμένων, τὰ ἀγάλματα ὤτων καὶ ῥινῶν ἀποκεκαρμένα καὶ σκοτεινῶς κατάστικτα μολύβδου σημείοις ἐπὶ τοῦ λίθου ἰωμένοις.",
      "glosses": [
        {
          "anchor": "στοίχους",
          "note": "= σειρὰς λίθων ἢ ἀνδριάντων",
          "rank": 1
        },
        {
          "anchor": "κόγχαις",
          "note": "= κοίλοις τόποις ἐν τοίχῳ",
          "rank": 1
        },
        {
          "anchor": "κατεβάλλοντο",
          "note": "< κατα·βάλλω = πίπτειν ἐποίουν",
          "rank": 1
        },
        {
          "anchor": "Ἀμερικανῶν",
          "note": "= ἐκ τῆς νέας ἠπείρου",
          "rank": 1
        },
        {
          "anchor": "ἀποκεκαρμένα",
          "note": "< ἀπο·κείρω = ἀφῃρημένα, κεκομμένα",
          "rank": 1
        },
        {
          "anchor": "σκοτεινῶς",
          "note": "< σκότος = μὴ λαμπρῶς ↔ λαμπρῶς",
          "rank": 1
        },
        {
          "anchor": "κατάστικτα",
          "note": "< κατα·στίζω = σημείοις πεποικιλμένα",
          "rank": 1
        },
        {
          "anchor": "ῥινῶν",
          "note": "= μυκτήρων",
          "rank": 1
        },
        {
          "anchor": "μολύβδου",
          "note": "= βαρέος μετάλλου μέλανος",
          "rank": 1
        },
        {
          "anchor": "ἰωμένοις",
          "note": "< ἰόω = εἰς ἰὸν μεταβεβλημένοις",
          "rank": 1
        },
        {
          "anchor": "πυροβόλα",
          "note": "= ὅπλα πῦρ βάλλοντα",
          "rank": 1
        },
        {
          "anchor": "πρόσοψις",
          "note": "πρός·ὄψις = τὸ ἔμπροσθεν μέρος",
          "rank": 1
        },
        {
          "anchor": "οἰκοδομήματος",
          "note": "< οἰκοδομέω = οἰκίας ἢ ναοῦ",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Αἱ μέγισται γλυπταὶ καὶ σανιδωταὶ θύραι χάσκουσαι ἐκ τῶν στροφίγγων ἐκρέμαντο καὶ Παρθένος γλυπτὴ λιθίνη ἐν ταῖς ἀγκάλαις αὐτῆς ἀκέφαλον παιδίον εἶχεν.",
      "glosses": [
        {
          "anchor": "γλυπταὶ",
          "note": "< γλύφω = ἐν λίθῳ ἢ ξύλῳ κεκολαμμέναι",
          "rank": 1
        },
        {
          "anchor": "σανιδωταὶ",
          "note": "< σανίς = ἐκ σανίδων πεποιημέναι",
          "rank": 1
        },
        {
          "anchor": "χάσκουσαι",
          "note": "= διῳγμέναι, ἠνεῳγμέναι",
          "rank": 1
        },
        {
          "anchor": "στροφίγγων",
          "note": "= ἃς περὶ στρέφονται αἱ θύραι",
          "rank": 1
        },
        {
          "anchor": "γλυπτὴ",
          "note": "< γλύφω = ἐν λίθῳ κεκολαμμένη",
          "rank": 1
        },
        {
          "anchor": "ἐκρέμαντο",
          "note": "< κρεμάννυμι = ἐξ ὑψηλοῦ ἤρτηντο",
          "rank": 1
        },
        {
          "anchor": "ἀκέφαλον",
          "note": "< ἀ·κεφαλή = ἄνευ κεφαλῆς",
          "rank": 1
        },
        {
          "anchor": "μέγισται",
          "note": "< μέγας = μεγάλαι ὑπὲρ πάσας",
          "rank": 1
        },
        {
          "anchor": "λιθίνη",
          "note": "< λίθος = ἐκ λίθου πεποιημένη",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ἔστη σκαρδαμύσσων ἐν τῇ μεσημβρινῇ θάλψει.",
      "glosses": [
        {
          "anchor": "σκαρδαμύσσων",
          "note": "= τὰ βλέφαρα ταχέως κινῶν",
          "rank": 1
        },
        {
          "anchor": "μεσημβρινῇ",
          "note": "< μεσ·ημβρία = μέσης ἡμέρας",
          "rank": 1
        },
        {
          "anchor": "θάλψει",
          "note": "= θερμότητι ἡλίου",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Εἶτα τὰ ἴχνη τοῦ ἡμιόνου εἶδεν.",
      "glosses": [
        {
          "anchor": "ἡμιόνου",
          "note": "< ἡμι·ὄνος = ἐξ ἵππου καὶ ὄνου",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ἦν τῆς κόνεως ἡ ὠχροτάτη κίνησις καὶ ἐκ τῆς θύρας τοῦ ναοῦ ἐξῄει καὶ διὰ τοῦ χώρου πρὸς τὴν πύλην ἐν τῷ πρὸς ἕω τοίχῳ διέβαινεν.",
      "glosses": [
        {
          "anchor": "κόνεως",
          "note": "= χοῦς, λεπτὸς γῆς χοῦς",
          "rank": 1
        },
        {
          "anchor": "ὠχροτάτη",
          "note": "< ὠχρός = λευκοτάτη ὡς νοσούντων",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Τὸν ἐφίππιον ὑψοῦ ἐπὶ τὸν ὦμον ἦρε καὶ κατόπιν αὐτῶν ὥρμησεν.",
      "glosses": [
        {
          "anchor": "ἐφίππιον",
          "note": "< ἐπί·ἵππος = σάγμα ἵππου",
          "rank": 1
        },
        {
          "anchor": "ἦρε",
          "note": "< αἴρω = ἐπὶ τὸ ἄνω ἤνεγκεν",
          "rank": 1
        }
      ]
    }
  ]
}