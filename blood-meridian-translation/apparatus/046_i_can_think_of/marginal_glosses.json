{
  "sentences": [
    {
      "index": 0,
      "greek": "Δύναμαι κρειττόνων τόπων καὶ κρειττόνων τρόπων ἐννοεῖν.",
      "glosses": [
        {
          "anchor": "ἐννοεῖν",
          "note": "= διανοεῖσθαι, ἐν νῷ ἔχειν",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Δύνασαι τοῦτο ποιεῖν;",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "Οὔ.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Οὔ.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Μυστήριόν ἐστιν.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Ἄπορος ἄνθρωπος γνῶναι τὸν νοῦν αὑτοῦ ὅτι ὁ νοῦς ἐστιν ὅπερ ἔχει γνῶναι αὐτῷ.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Δύναται γνῶναι τὴν καρδίαν, ἀλλ' οὐ βούλεται.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "Ὀρθῶς.",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "Ἄριστον μὴ βλέπειν ἐκεῖ.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "Οὐκ ἔστιν καρδία ζῴου ἥτις δέδεται τῇ ὁδῷ ἣν ὁ θεὸς ἔταξεν αὐτῷ.",
      "glosses": [
        {
          "anchor": "δέδεται",
          "note": "< δεῖν = δεσμοῖς συνέχεσθαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Δύνασαι πονηρίαν εὑρεῖν ἐν τῷ ἐλαχίστῳ τῶν ζῴων, ἀλλ' ὅτε ὁ θεὸς ἐποίησεν ἄνθρωπον ὁ διάβολος πρὸς τῷ ἀγκῶνι ἦν.",
      "glosses": [
        {
          "anchor": "ἀγκῶνι",
          "note": "ἀγκών = μέρος βραχίονος μεταξὺ κερκίδος καὶ βραχίονος",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Ζῷον ὃ δύναται πάντα.",
      "glosses": []
    },
    {
      "index": 12,
      "greek": "Μηχανὴν ποιῆσαι.",
      "glosses": []
    },
    {
      "index": 13,
      "greek": "Καὶ μηχανὴν ποιῆσαι τὴν μηχανήν.",
      "glosses": []
    },
    {
      "index": 14,
      "greek": "Καὶ κακὸν ὃ δύναται αὐτὸ τρέχειν χιλίους ἐνιαυτούς, οὐδὲν δεῖ ἐπιμελεῖσθαι.",
      "glosses": [
        {
          "anchor": "τρέχειν",
          "note": "= θεῖν, ταχέως κινεῖσθαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 15,
      "greek": "Πιστεύεις τοῦτο;",
      "glosses": []
    }
  ]
