{
  "sentences": [
    {
      "index": 0,
      "greek": "Καταλελοίπει τὸν ἡμίονον παρά τινι Μεξικανῇ οἰκίᾳ ἥτις ἐβόσκει ζῷα πρὸς τῷ ἐσχάτῳ τῆς πόλεως καὶ ἀφίκετο ἐκεῖ ἄγριος τὴν ὄψιν καὶ ἄπνους.",
      "glosses": [
        {
          "anchor": "Καταλελοίπει",
          "note": "< καταλείπω = ἀπολείπει",
          "rank": 1
        },
        {
          "anchor": "Μεξικανῇ",
          "note": "= ἐκ Μεξίκου γῆς",
          "rank": 1
        },
        {
          "anchor": "ἐβόσκει",
          "note": "< βόσκω = ζῷα τρέφει",
          "rank": 1
        },
        {
          "anchor": "ἄπνους",
          "note": "= μὴ ἔχων πνεῦμα ↔ εὔπνους",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ἡ γυνὴ ἤνοιξε τὴν θύραν καὶ ἔβλεψεν αὐτόν.",
      "glosses": [
        {
          "anchor": "ἔβλεψεν",
          "note": "< βλέπω = εἶδεν",
          "rank": 1
        },
        {
          "anchor": "ἤνοιξε",
          "note": "< ἀνοίγω = διήνοιξε ↔ ἔκλεισε",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Δεῖ με λαβεῖν τὸν ἡμίονον, ἔφη ἀσθμαίνων.",
      "glosses": [
        {
          "anchor": "ἀσθμαίνων",
          "note": "= δυσκόλως πνέων",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἔβλεψεν αὐτὸν ἔτι, εἶτα ἐκάλεσε πρὸς τὰ ὄπισθεν τῆς οἰκίας.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Περιῆλθεν.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Ἦσαν ἵπποι δεδεμένοι ἐν τῷ χωρίῳ καὶ ἦν ἅμαξα πλατεῖα πρὸς τῷ φραγμῷ μετὰ μελεαγρίδων τινῶν καθημένων ἐπὶ τῷ χείλει βλεπουσῶν ἔξω.",
      "glosses": [
        {
          "anchor": "μελεαγρίδων",
          "note": "= ὀρνίθων μεγάλων",
          "rank": 1
        },
        {
          "anchor": "φραγμῷ",
          "note": "= τεῖχος περὶ χωρίον",
          "rank": 1
        },
        {
          "anchor": "χείλει",
          "note": "= ἄκρον μέρος",
          "rank": 1
        },
        {
          "anchor": "βλεπουσῶν",
          "note": "< βλέπω = ὁρωσῶν",
          "rank": 1
        },
        {
          "anchor": "ἅμαξα",
          "note": "= ὄχημα τετράκυκλον",
          "rank": 1
        },
        {
          "anchor": "καθημένων",
          "note": "< κάθημαι = ἡσυχαζόντων ↔ ἑστώτων",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ἡ γραῦς ἐληλύθει πρὸς τὴν ὀπισθίαν θύραν.",
      "glosses": [
        {
          "anchor": "ὀπισθίαν",
          "note": "= ἡ ὄπισθεν θύρα",
          "rank": 1
        },
        {
          "anchor": "γραῦς",
          "note": "= γυνὴ πρεσβῦτις ↔ κόρη",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Νίτο, ἐκάλεσεν.",
      "glosses": [
        {
          "anchor": "Νίτο",
          "note": "= ὄνομα κύριον",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Βένγα.",
      "glosses": [
        {
          "anchor": "Βένγα",
          "note": "= δεῦρο ἔρχου",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Ἄι οὖν καβαλλέρο ἀκί.",
      "glosses": [
        {
          "anchor": "καβαλλέρο",
          "note": "= ἱππεύς, ἀνὴρ εὐγενής",
          "rank": 1
        },
        {
          "anchor": "ἀκί",
          "note": "= ἐνθάδε",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Βένγα.",
      "glosses": [
        {
          "anchor": "Βένγα",
          "note": "= δεῦρο ἔρχου",
          "rank": 1
        }
      ]
    }
  ]
}