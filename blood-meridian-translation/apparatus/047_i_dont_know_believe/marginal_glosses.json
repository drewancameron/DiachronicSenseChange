{
  "sentences": [
    {
      "index": 0,
      "greek": "Οὐκ οἶδα.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Πίστευε τοῦτο.",
      "glosses": [
        {
          "anchor": "Πίστευε",
          "note": "< πιστεύω = ἀληθὲς νόμιζε",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὅτε τὰ σιτία τοῦ γέροντος ἐθερμάνθη διένειμεν αὐτά.",
      "glosses": [
        {
          "anchor": "ἐθερμάνθη",
          "note": "< θερμαίνω = θερμὸν ἐγένετο",
          "rank": 1
        },
        {
          "anchor": "διένειμεν",
          "note": "< διανέμω = μερίσας ἔδωκεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἤσθιον σιγῇ.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Βροντὴ πρὸς βορρᾶν ᾔει καὶ οὐ διὰ μακροῦ ὑπὲρ κεφαλῆς ἐβρόντα καὶ ἰοῦ μικρὰ κατὰ λεπτὸν ῥεῦμα κάτω διὰ τοῦ καπνοδόχου ἤρχετο.",
      "glosses": [
        {
          "anchor": "ἐβρόντα",
          "note": "< βροντή = βροντὴν ἐποίησεν",
          "rank": 1
        },
        {
          "anchor": "καπνοδόχου",
          "note": "καπνο·δόχος = καπνὸν δεχόμενον",
          "rank": 1
        },
        {
          "anchor": "Βροντὴ",
          "note": "= ψόφος ἐκ νεφῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ὑπὲρ τῶν πινάκων κύπτοντες.",
      "glosses": [
        {
          "anchor": "κύπτοντες",
          "note": "< κύπτω = κάτω κλίνοντες",
          "rank": 1
        },
        {
          "anchor": "πινάκων",
          "note": "πίναξ = πλαξ ἐσθίειν",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Τὸ λίπος τοῖς δακτύλοις ἐξέμασσον.",
      "glosses": [
        {
          "anchor": "ἐξέμασσον",
          "note": "< ἐκμάσσω = ἀπεκάθαιρον",
          "rank": 1
        },
        {
          "anchor": "λίπος",
          "note": "= στέαρ",
          "rank": 1
        },
        {
          "anchor": "δακτύλοις",
          "note": "δάκτυλος = μέρος χειρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ἐκ τῆς κολοκύνθης ἔπινον.",
      "glosses": [
        {
          "anchor": "κολοκύνθης",
          "note": "κολοκύνθη = εἶδος σίκυος",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Ὁ παῖς ἐξῆλθε.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "Τὴν κύλικα καὶ τὸν πίνακα ἐν τῇ ψάμμῳ ἔτριψε.",
      "glosses": [
        {
          "anchor": "ἔτριψε",
          "note": "< τρίβω = κατέτριψεν",
          "rank": 1
        },
        {
          "anchor": "ψάμμῳ",
          "note": "ψάμμος = ἄμμος λεπτή",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Ἐπανῆλθε τὰ κασσιτέρινα συγκρούων ὥσπερ ἀμυνόμενός τι φάσμα ἔξω ἐν τῷ σκότει.",
      "glosses": [
        {
          "anchor": "κασσιτέρινα",
          "note": "< κασσίτερος = ἐκ κασσιτέρου πεποιημένα",
          "rank": 1
        },
        {
          "anchor": "συγκρούων",
          "note": "< συγκρούω = ἀλλήλοις προσβάλλων",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Βρονταὶ πόρρω ὀρθαὶ τρέμουσαι πρὸς τὸν ἠλεκτρικὸν οὐρανόν.",
      "glosses": [
        {
          "anchor": "τρέμουσαι",
          "note": "< τρέμω = σειόμεναι",
          "rank": 1
        },
        {
          "anchor": "ἠλεκτρικὸν",
          "note": "< ἤλεκτρον = ἀστραπῆς πλήρης",
          "rank": 1
        },
        {
          "anchor": "ὀρθαὶ",
          "note": "< ὀρθός = εὐθεῖαι ↔ πλάγιαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Εἰς τὸ μέλαν αὖθις ἠφανίσθησαν.",
      "glosses": [
        {
          "anchor": "ἠφανίσθησαν",
          "note": "< ἀφανίζω = ἄδηλοι ἐγένοντο",
          "rank": 1
        }
      ]
    },
    {
      "index": 13,
      "greek": "Ὁ γέρων ἓν οὖς πρὸς τὴν ὠρυομένην ἔρημον ἔξω τείνων.",
      "glosses": [
        {
          "anchor": "ὠρυομένην",
          "note": "< ὠρύομαι = μεγάλῃ φωνῇ κραυγάζουσαν",
          "rank": 1
        },
        {
          "anchor": "τείνων",
          "note": "< τείνω = ἐκτείνων",
          "rank": 1
        }
      ]
    },
    {
      "index": 14,
      "greek": "Ὁ παῖς τὴν θύραν ἔκλεισεν.",
      "glosses": [
        {
          "anchor": "ἔκλεισεν",
          "note": "< κλείω = ἔθηκεν κλεῖθρον",
          "rank": 1
        }
      ]
    }
  ]
}