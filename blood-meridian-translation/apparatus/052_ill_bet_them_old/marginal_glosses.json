{
  "sentences": [
    {
      "index": 0,
      "greek": "Οἶμαι τοὺς γέροντας ἐκείνους ἐν Βέξαρι πίνειν τὸν νοῦν ἐκπίνοντας.",
      "glosses": [
        {
          "anchor": "Βέξαρι",
          "note": "πόλις τις",
          "rank": 1
        },
        {
          "anchor": "ἐκπίνοντας",
          "note": "< ἐκπίνω = διὰ πόσεως ἀπολλύντας",
          "rank": 1
        },
        {
          "anchor": "Βέξαρ",
          "note": "πόλις τις",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Οἶμαι τὸν γέροντα Λόννιον πάσας τὰς πόρνας τῆς πόλεως βεβηκέναι.",
      "glosses": [
        {
          "anchor": "Λόννιον",
          "note": "ὄνομα γέροντός τινος",
          "rank": 1
        },
        {
          "anchor": "βεβηκέναι",
          "note": "< βαίνω = μιγῆναι",
          "rank": 1
        },
        {
          "anchor": "πόρνας",
          "note": "γυναῖκες μισθοῦ μιγνύμεναι",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Πόσον ἀπέχει τὸ Βέξαρ;",
      "glosses": [
        {
          "anchor": "Βέξαρ",
          "note": "πόλις τις",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Περὶ δύο ἡμέραι.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Πορρωτέρω.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Μᾶλλον τέτταρας ἂν εἴποιμι.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Πῶς ἂν τις πορεύοιτο εἰ βούλοιτο;",
      "glosses": [
        {
          "anchor": "πορεύοιτο",
          "note": "< πορεύομαι = ὁδοιπορήσειεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Εὐθὺ πρὸς μεσημβρίαν τέμνων τὴν ὁδὸν ἂν τύχοις περὶ ἡμίσειαν ἡμέραν.",
      "glosses": [
        {
          "anchor": "τύχοις",
          "note": "< τυγχάνω = ἐνταῦθα = ἀφίκοιο",
          "rank": 1
        },
        {
          "anchor": "ἡμίσειαν",
          "note": "< ἥμισυς = τὸ ἥμισυ μέρος",
          "rank": 1
        },
        {
          "anchor": "τέμνων",
          "note": "< τέμνω = διακόπτων",
          "rank": 1
        },
        {
          "anchor": "Εὐθὺ",
          "note": "κατ' εὐθεῖαν ↔ καμπύλως",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Εἰς Βέξαρ πορεύῃ;",
      "glosses": [
        {
          "anchor": "Βέξαρ",
          "note": "πόλις τις",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Ἴσως.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "Ἐὰν τὸν γέροντα Λόννιον ἐκεῖ ἴδῃς εἰπὲ αὐτῷ μέρος ἐμοὶ λαβεῖν.",
      "glosses": [
        {
          "anchor": "Λόννιον",
          "note": "ὄνομα γέροντός τινος",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Εἰπὲ τὸν γέροντα Ὀρῆνα.",
      "glosses": [
        {
          "anchor": "Ὀρῆνα",
          "note": "ὄνομα γέροντός τινος",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Ποτὸν σοι ὠνήσεται εἰ μὴ πᾶν τὸ ἀργύριον ἀνήλωκεν.",
      "glosses": [
        {
          "anchor": "ὠνήσεται",
          "note": "< ὠνέομαι = ἀργυρίου ἀντάλλαξιν ποιήσεται",
          "rank": 1
        },
        {
          "anchor": "ἀνήλωκεν",
          "note": "< ἀναλίσκω = πᾶν κατεδαπάνησεν",
          "rank": 1
        }
      ]
    }
  ]
}