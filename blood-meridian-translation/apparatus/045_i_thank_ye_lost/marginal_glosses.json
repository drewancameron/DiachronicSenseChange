{
  "sentences": [
    {
      "index": 0,
      "greek": "Εὐχαριστῶ ὑμῖν.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Ἀπωλέσατε τὴν ὁδὸν ἐν τῷ σκότει, ἔφη ὁ γέρων.",
      "glosses": [
        {
          "anchor": "Ἀπωλέσατε",
          "note": "< ἀπόλλυμι = ἀφανίζω, οὐχὶ εὑρίσκω",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Τὸ πῦρ ἐκίνει, λεπτοὺς ὀδόντας ὀστέων ἐκ τῆς τέφρας ἱστάς.",
      "glosses": [
        {
          "anchor": "λεπτοὺς",
          "note": "= ἰσχνούς, μικροὺς ↔ παχεῖς",
          "rank": 1
        },
        {
          "anchor": "ἱστάς",
          "note": "< ἵστημι = ὀρθὸν ποιέω",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ὁ παῖς οὐκ ἀπεκρίνατο.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Ὁ γέρων τὴν κεφαλὴν ἔνθα καὶ ἔνθα ἔσεισε.",
      "glosses": [
        {
          "anchor": "ἔσεισε",
          "note": "< σείω = κινέω ἔνθα καὶ ἔνθα",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Σκληρὰ ἡ ὁδὸς τῶν παραβαινόντων.",
      "glosses": [
        {
          "anchor": "παραβαινόντων",
          "note": "< παραβαίνω = νόμον οὐ φυλάττω",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ὁ θεὸς τόνδε τὸν κόσμον ἐποίησεν, ἀλλ' οὐχὶ πᾶσιν ἁρμόττον ἐποίησεν, ἦ γάρ;",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "Οὐ νομίζω αὐτὸν πολὺ ἐμοῦ ἐφροντικέναι.",
      "glosses": [
        {
          "anchor": "ἐφροντικέναι",
          "note": "< φροντίζω = μέλει μοι",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Ναί, ἔφη ὁ γέρων.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "Ἀλλὰ πόθεν ἄνθρωπος τὰς δόξας λαμβάνει.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "Τίνα κόσμον εἶδεν ὃν μᾶλλον ἠγάπησεν;",
      "glosses": []
    }
  ]
}