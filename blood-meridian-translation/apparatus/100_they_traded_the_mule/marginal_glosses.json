        {
          "anchor": "ὑφαντοῦ",
          "note": "= woven",
          "rank": 1
        },
        {
          "anchor": "κεκονιμένου",
          "note": "= dusty",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "τέλος δὲ χρυσοῦ νομίσματος δύο ἡμίσεος δραχμῶν.",
      "glosses": [
        {
          "anchor": "χρυσοῦ",
          "note": "= gold",
          "rank": 1
        },
        {
          "anchor": "δραχμῶν",
          "note": "= coin",
          "rank": 1
        },
        {
          "anchor": "δραχμῶν",
          "note": "= of drachmas, currency",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "ὁ δὲ Τεξανὸς ἐς τὸ μικρὸν κέρμα ἐν θέναρι τοῦ παιδὸς βλέψας πλέον ἀργύριον ᾔτει·",
      "glosses": [
        {
          "anchor": "μικρὸν",
          "note": "= small ↔ μέγας",
          "rank": 1
        },
        {
          "anchor": "θέναρι",
          "note": "= palm",
          "rank": 1
