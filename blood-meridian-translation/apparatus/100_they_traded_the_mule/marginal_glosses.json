{
  "sentences": [
    {
      "index": 0,
      "greek": "τὴν ἡμίονον ὡς ἐκεκόσμητο ἤμειβον σάγματος Τεξανοῦ, γυμνοῦ ξύλου βυρσοδέτου·",
      "glosses": [
        {
          "anchor": "ἡμίονον",
          "note": "= mule",
          "rank": 1
        },
        {
          "anchor": "γυμνοῦ",
          "note": "= bare ↔ ὁπλιτοδρόμος",
          "rank": 1
        },
        {
          "anchor": "σάγματος",
          "note": "= tree",
          "rank": 1
        },
        {
          "anchor": "ἤμειβον",
          "note": "= they replied, answered",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "οὐ νέου, ἀρτίου δέ.",
