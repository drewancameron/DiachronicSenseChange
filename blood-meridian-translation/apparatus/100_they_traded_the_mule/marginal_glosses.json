        {
          "anchor": "χαλινοῦ",
          "note": "= bridle",
          "rank": 1
        },
        {
          "anchor": "ψαλίου",
          "note": "= bit",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "στρώματος ἐρεοῦ ὑφαντοῦ ἐκ Σαλτίλλου, κεκονιμένου, νέου ἢ μή.",
