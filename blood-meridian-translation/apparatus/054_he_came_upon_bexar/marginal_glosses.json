{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἀφίκετο εἰς Βηξὰρ ἑσπέρας τῆς τετάρτης ἡμέρας καὶ ἐκάθισε τὸν ῥακώδη ἡμίονον ἐπὶ λόφου ταπεινοῦ καὶ κατεῖδε τὴν πόλιν, τὰς ἡσύχους οἰκίας πλινθίνας, τὴν στοῖχον δρυῶν χλωρῶν καὶ αἰγείρων ἣ ἐσήμαινε τὴν ὁδὸν τοῦ ποταμοῦ, τὴν ἀγορὰν πλήρη ἁμαξῶν μετὰ τῶν καλυμμάτων ὀθονίνων καὶ τὰ κονιάματι λελευκωμένα δημόσια οἰκοδομήματα καὶ τὸν Μαυρουσίου θόλον τοῦ ναοῦ ἀνιστάμενον ἐκ τῶν δένδρων καὶ τὸ φρούριον καὶ τὸν ὑψηλὸν λίθινον πυριτοθήκην ἐν τῷ πόρρω.",
      "glosses": [
        {
          "anchor": "Βηξὰρ",
          "note": "πόλις τις",
          "rank": 1
        },
        {
          "anchor": "ἡσύχους",
          "note": "= ἠρέμους ↔ θορυβώδεις",
          "rank": 1
        },
        {
          "anchor": "πλινθίνας",
          "note": "< πλίνθος = ἐκ πλίνθων πεποιημένας",
          "rank": 1
        },
        {
          "anchor": "καλυμμάτων",
          "note": "= σκεπασμάτων",
          "rank": 1
        },
        {
          "anchor": "ὀθονίνων",
          "note": "< ὀθόνη = ἐξ ὀθόνης πεποιημένων",
          "rank": 1
        },
        {
          "anchor": "κονιάματι",
          "note": "= τιτάνῳ λευκῷ",
          "rank": 1
        },
        {
          "anchor": "λελευκωμένα",
          "note": "< λευκόω = λευκὰ πεποιημένα",
          "rank": 1
        },
        {
          "anchor": "Μαυρουσίου",
          "note": "= αἰθίοπος τινός",
          "rank": 1
        },
        {
          "anchor": "πυριτοθήκην",
          "note": "πυρῖτις·θήκη = τόπος πυρίτιδος",
          "rank": 1
        },
        {
          "anchor": "ῥακώδη",
          "note": "< ῥάκος = ῥάκεσι πλήρη",
          "rank": 1
        },
        {
          "anchor": "δρυῶν",
          "note": "= μεγάλων δένδρων",
          "rank": 1
        },
        {
          "anchor": "θόλον",
          "note": "= κυκλικὸν τέγος",
          "rank": 1
        },
        {
          "anchor": "αἰγείρων",
          "note": "= δένδρων παρὰ ὕδωρ",
          "rank": 1
        },
        {
          "anchor": "οἰκοδομήματα",
          "note": "< οἰκοδομέω = κτίσματα",
          "rank": 1
        },
        {
          "anchor": "στοῖχον",
          "note": "= τάξιν",
          "rank": 1
        },
        {
          "anchor": "χλωρῶν",
          "note": "= πρασίνων",
          "rank": 1
        },
        {
          "anchor": "τετάρτης",
          "note": "= δ'",
          "rank": 1
        },
        {
          "anchor": "ἀνιστάμενον",
          "note": "< ἀνίστημι = ἄνω αἰρόμενον",
          "rank": 1
        },
        {
          "anchor": "ἐσήμαινε",
          "note": "< σημαίνω = ἐδήλου",
          "rank": 1
        },
        {
          "anchor": "λίθινον",
          "note": "< λίθος = ἐκ λίθου πεποιημένον",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Αὔρα κούφη ἐκίνει τὰς ἄκρας τοῦ πέτασου αὐτοῦ, τὰς συμπεπλεγμένας λιπαρὰς τρίχας αὐτοῦ.",
      "glosses": [
        {
          "anchor": "πέτασου",
          "note": "= πίλου πλατέος",
          "rank": 1
        },
        {
          "anchor": "συμπεπλεγμένας",
          "note": "< συμπλέκω = ἀλλήλαις πεπλεγμένας",
          "rank": 1
        },
        {
          "anchor": "κούφη",
          "note": "= ἐλαφρά ↔ βαρεῖα",
          "rank": 1
        },
        {
          "anchor": "Αὔρα",
          "note": "= ἄνεμος ἠρέμος",
          "rank": 1
        },
        {
          "anchor": "λιπαρὰς",
          "note": "= ἐλαίῳ μεστάς",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Οἱ ὀφθαλμοὶ αὐτοῦ ἔκειντο σκοτεινοὶ καὶ κοῖλοι ἐν προσώπῳ σπηλαιώδει καὶ πεφοβημένῳ καὶ δυσωδία αἰσχρὰ ἀνέβαινεν ἐκ τῶν κοιλωμάτων τῶν ὑποδημάτων αὐτοῦ.",
      "glosses": [
        {
          "anchor": "σκοτεινοὶ",
          "note": "= σκότῳ πλήρεις ↔ λαμπροί",
          "rank": 1
        },
        {
          "anchor": "σπηλαιώδει",
          "note": "< σπήλαιον = σπηλαίῳ ὅμοιον",
          "rank": 1
        },
        {
          "anchor": "πεφοβημένῳ",
          "note": "< φοβέω = φόβον ἔχοντι",
          "rank": 1
        },
        {
          "anchor": "δυσωδία",
          "note": "= κακὴ ὀσμή ↔ εὐωδία",
          "rank": 1
        },
        {
          "anchor": "κοῖλοι",
          "note": "= βαθεῖς ↔ κυρτοί",
          "rank": 1
        },
        {
          "anchor": "κοιλωμάτων",
          "note": "< κοιλόω = κοίλων τόπων",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ὁ ἥλιος ἄρτι ἔδυ καὶ πρὸς ἑσπέραν ἔκειντο σκόπελοι νεφῶν αἱματωδῶν ἐξ ὧν ἀνίσταντο μικροὶ νυκτερινοὶ ἱέρακες ἐρήμου ὡς φυγάδες ἀπό τινος μεγάλου πυρὸς ἐπὶ τῷ πέρατι τῆς γῆς.",
      "glosses": [
        {
          "anchor": "αἱματωδῶν",
          "note": "< αἷμα = αἵματι ὁμοίων",
          "rank": 1
        },
        {
          "anchor": "νυκτερινοὶ",
          "note": "< νύξ = ἐν νυκτὶ ὄντες",
          "rank": 1
        },
        {
          "anchor": "σκόπελοι",
          "note": "= ὑψηλὰ πετρώματα",
          "rank": 1
        },
        {
          "anchor": "ἱέρακες",
          "note": "= ὄρνεα ἅρπαγα",
          "rank": 1
        },
        {
          "anchor": "πέρατι",
          "note": "= τέλει",
          "rank": 1
        },
        {
          "anchor": "ἀνίσταντο",
          "note": "< ἀνίστημι = ἄνω ᾔροντο",
          "rank": 1
        },
        {
          "anchor": "μικροὶ",
          "note": "= σμικροί ↔ μεγάλοι",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ἔπτυσε πτύελον ξηρὸν λευκόν καὶ ἔκρουσε τὰς ῥαγάδας ξυλίνας ἐπιβάδας πρὸς τὰς πλευρὰς τοῦ ἡμιόνου καὶ ἐσάλευσαν εἰς κίνησιν πάλιν.",
      "glosses": [
        {
          "anchor": "Ἔπτυσε",
          "note": "< πτύω = πτύελον ἐξέβαλε",
          "rank": 1
        },
        {
          "anchor": "ῥαγάδας",
          "note": "= σχιστὰς σανίδας",
          "rank": 1
        },
        {
          "anchor": "ἐπιβάδας",
          "note": "= βάσεις ποδῶν",
          "rank": 1
        },
        {
          "anchor": "ἔκρουσε",
          "note": "< κρούω = ἐπάταξε",
          "rank": 1
        },
        {
          "anchor": "ἐσάλευσαν",
          "note": "< σαλεύω = ἐκινήθησαν",
          "rank": 1
        },
        {
          "anchor": "πτύελον",
          "note": "= ὃ πτύουσι",
          "rank": 1
        },
        {
          "anchor": "ξυλίνας",
          "note": "< ξύλον = ἐκ ξύλου πεποιημένας",
          "rank": 1
        },
        {
          "anchor": "ἡμιόνου",
          "note": "= κτήνους ἐξ ὄνου καὶ ἵππου",
          "rank": 1
        }
      ]
    }
  ]
