{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὁ παῖς ἀνέστη καὶ ἔβλεψεν πρὸς τὴν θύραν.",
      "glosses": [
        {
          "anchor": "ἔβλεψεν",
          "note": "= εἶδεν, ὤφθη",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Εὑρήσω τι, ἔφη.",
      "glosses": [
        {
          "anchor": "Εὑρήσω",
          "note": "< εὑρίσκω = λήψομαι, καταλήψομαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ποῦ τὸ φρέαρ;",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Ἄνω τοῦ λόφου, ἀκολούθει τῇ ἀτραπῷ.",
      "glosses": [
        {
          "anchor": "ἀτραπῷ",
          "note": "= ἀτραπός, στενὴ ὁδός",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Σχεδὸν ἄγαν σκοτεινὸν ὁρᾶν ἐνταῦθα.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Βαθεῖα ἡ ἀτραπός.",
      "glosses": [
        {
          "anchor": "ἀτραπός",
          "note": "= στενὴ ὁδὸς ↔ πλατεῖα ὁδός",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ἀκολούθει τοῖς ποσίν.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "Ἀκολούθει τῷ ἡμιόνῳ.",
      "glosses": [
        {
          "anchor": "ἡμιόνῳ",
          "note": "= ἡμίονος, ζῷον ἐξ ὄνου καὶ ἵππου",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Οὐ δύναμαι ἰέναι.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "Ἐξῆλθεν εἰς τὸν ἄνεμον καὶ περιέβλεψεν τὸν ἡμίονον ἀλλ' οὐκ ἦν ὁ ἡμίονος.",
      "glosses": [
        {
          "anchor": "περιέβλεψεν",
          "note": "< περι·βλέπω = πάντῃ ἔβλεψεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Πόρρω πρὸς νότον ἀστραπὴ ἔλαμψεν σιγῇ.",
      "glosses": [
        {
          "anchor": "ἔλαμψεν",
          "note": "= ἔφανεν φῶς, ἤστραψεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Ἀνῆλθε τὴν ἀτραπὸν μεταξὺ τῶν σαλευομένων πόων καὶ εὗρε τὸν ἡμίονον ἑστῶτα πρὸς τῷ φρέατι.",
      "glosses": [
        {
          "anchor": "πόων",
          "note": "= πόα, χόρτος ἐν ἀγρῷ φυόμενος",
          "rank": 1
        },
        {
          "anchor": "Ἀνῆλθε",
          "note": "< ἀν·έρχομαι = ἄνω ἐπορεύθη ↔ κατῆλθε",
          "rank": 1
        },
        {
          "anchor": "σαλευομένων",
          "note": "< σαλεύω = κινουμένων ὑπὸ ἀνέμου",
          "rank": 1
        },
        {
          "anchor": "φρέατι",
          "note": "= φρέαρ, βαθὺ ὕδατος χωρίον",
          "rank": 1
        }
      ]
    }
  ]
}