{
  "sentences": [
    {
      "index": 0,
      "greek": "Φεύγει τὴν βασιλικὴν ὁδὸν φόβῳ τῶν πολιτῶν.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Οἱ μικροὶ τοῦ πεδίου λύκοι κλαίουσιν ὅλην τὴν νύκτα καὶ ἡ ἠὼς εὑρίσκει αὐτὸν ἐν ποώδει χάραδρι οἷ ἦλθε κρυφθῆναι τοῦ ἀνέμου.",
      "glosses": [
        {
          "anchor": "ποώδει",
          "note": "< πόα = πλήρει χόρτου",
          "rank": 1
        },
        {
          "anchor": "χάραδρι",
          "note": "= φάραγξ, κοίλη ὁδὸς ὑδάτων",
          "rank": 1
        },
        {
          "anchor": "κρυφθῆναι",
          "note": "< κρύπτω = κρυβῆναι, λαθεῖν",
          "rank": 1
        },
        {
          "anchor": "κλαίουσιν",
          "note": "= δάκρυα ῥέουσι, θρηνοῦσιν",
          "rank": 1
        },
        {
          "anchor": "μικροὶ",
          "note": "= σμικροί, βραχεῖς ↔ μεγάλοι",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ πεπεδημένος ἡμίονος ἕστηκεν ὑπὲρ αὐτοῦ καὶ σκοπεῖ τὴν ἕω φάους χάριν.",
      "glosses": [
        {
          "anchor": "πεπεδημένος",
          "note": "< πεδάω = δεσμοῖς κατεχόμενος",
          "rank": 1
        },
        {
          "anchor": "φάους",
          "note": "= φωτός, λαμπρότητος",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ὁ ἀνατέλλων ἥλιος χρῶμα σιδήρου.",
      "glosses": [
        {
          "anchor": "ἀνατέλλων",
          "note": "< ἀνατέλλω = ἀνιὼν ἐκ γῆς",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ἡ ἔφιππος σκιὰ αὐτοῦ πίπτει ἐπὶ μίλια πρὸ αὐτοῦ.",
      "glosses": [
        {
          "anchor": "μίλια",
          "note": "= μέτρα μακρᾶς ὁδοῦ",
          "rank": 1
        },
        {
          "anchor": "ἔφιππος",
          "note": "= ἐπὶ ἵππου, ἱππεύς",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Φορεῖ ἐπὶ τῆς κεφαλῆς πῖλον ὃν πεποίηκεν ἐκ φύλλων καὶ αὐχμηρὰ καὶ ἐρρωγότα ὑπὸ τοῦ ἡλίου καὶ ἔοικε ῥακοδύτῃ πεπλανημένῳ ἔκ τινος κήπου ἔνθα εἴωθε δειματοῦν ὄρνιθας.",
      "glosses": [
        {
          "anchor": "αὐχμηρὰ",
          "note": "= ξηρὰ ἐκ τοῦ μὴ ὕεσθαι ↔ ὑγρά",
          "rank": 1
        },
        {
          "anchor": "ἐρρωγότα",
          "note": "< ῥήγνυμι = διεσχισμένα, τετρημένα",
          "rank": 1
        },
        {
          "anchor": "ῥακοδύτῃ",
          "note": "ῥακο·δύτης = ῥάκη φορῶν ἄνθρωπος",
          "rank": 1
        },
        {
          "anchor": "δειματοῦν",
          "note": "< δεῖμα = φοβεῖν, τρέμειν ποιεῖν",
          "rank": 1
        },
        {
          "anchor": "πεπλανημένῳ",
          "note": "< πλανάω = πλαζομένῳ, οὐκ εἰδότι ὁδόν",
          "rank": 1
        },
        {
          "anchor": "πῖλον",
          "note": "= καλυπτήριον κεφαλῆς",
          "rank": 1
        },
        {
          "anchor": "Φορεῖ",
          "note": "= ἔχει ἐπὶ σώματι, φέρει",
          "rank": 1
        }
      ]
    }
  ]
}