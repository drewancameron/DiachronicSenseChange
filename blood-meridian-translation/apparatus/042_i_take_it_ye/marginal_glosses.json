{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὑπολαμβάνω ὑμᾶς ἀποπλανηθῆναι, ἔφη ὁ ἐρημίτης.",
      "glosses": [
        {
          "anchor": "ἀποπλανηθῆναι",
          "note": "< ἀποπλανάομαι = τῆς ὁδοῦ ἐκστῆναι",
          "rank": 1
        },
        {
          "anchor": "ἐρημίτης",
          "note": "< ἔρημος = ἐν ἐρήμῳ οἰκῶν",
          "rank": 1
        },
        {
          "anchor": "Ὑπολαμβάνω",
          "note": "ὑπό·λαμβάνω = ἐνταῦθα = οἴομαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Οὔ, εὐθὺς πρὸς τοῦτο ἦλθον.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "Ταχέως τῇ χειρὶ ἔνευσεν, ὁ γέρων.",
      "glosses": [
        {
          "anchor": "ἔνευσεν",
          "note": "< νεύω = τῇ κεφαλῇ ἐσήμηνεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Οὔ, οὔ, ἔφη.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Λέγω ὅτι ἀπεπλανήθητε ἐλθεῖν ἐνθάδε.",
      "glosses": [
        {
          "anchor": "ἀπεπλανήθητε",
          "note": "< ἀποπλανάομαι = τῆς ὁδοῦ ἐξέστητε",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ἦν ψαμμοθύελλα;",
      "glosses": [
        {
          "anchor": "ψαμμοθύελλα",
          "note": "ψάμμος·θύελλα = ἄνεμος ψάμμον φέρων",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ἀπεπλανήθητε τῆς ὁδοῦ νυκτός;",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "Λῃσταὶ ὑμῖν ἐπέθεντο;",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "Ὁ παῖς τοῦτο ἐσκέψατο.",
      "glosses": [
        {
          "anchor": "ἐσκέψατο",
          "note": "< σκέπτομαι = ἐν νῷ ἐβάλετο",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Ναί, ἔφη.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "Ἀπεπλανήθημεν τῆς ὁδοῦ τρόπῳ τινί.",
      "glosses": [
        {
          "anchor": "Ἀπεπλανήθημεν",
          "note": "< ἀποπλανάομαι = τῆς ὁδοῦ ἐξέστημεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Ἔγνων.",
      "glosses": []
    },
    {
      "index": 12,
      "greek": "Πόσον χρόνον ἐνθάδε εἶ;",
      "glosses": []
    },
    {
      "index": 13,
      "greek": "Ποῦ;",
      "glosses": []
    },
    {
      "index": 14,
      "greek": "Ὁ παῖς ἐπὶ τοῦ στρώματος ἐκάθητο πέραν τοῦ πυρὸς ἀπὸ τοῦ γέροντος.",
      "glosses": [
        {
          "anchor": "στρώματος",
          "note": "στρῶμα = ὃ ἐπὶ γῆς στορέννυται",
          "rank": 1
        }
      ]
    },
    {
      "index": 15,
      "greek": "Ἐνθάδε, ἔφη.",
      "glosses": []
    },
    {
      "index": 16,
      "greek": "Ἐν τῷ τόπῳ τούτῳ.",
      "glosses": []
    }
  ]
}