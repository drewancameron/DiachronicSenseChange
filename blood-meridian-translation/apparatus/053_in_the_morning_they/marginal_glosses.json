{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἕωθεν ἔφαγον πλακοῦντας μετὰ μέλιτος καὶ οἱ νομεῖς ἐπέσαξαν καὶ ἀπῆλθον.",
      "glosses": [
        {
          "anchor": "πλακοῦντας",
          "note": "πλακοῦς = ἄρτος πλατὺς μετὰ μέλιτος",
          "rank": 1
        },
        {
          "anchor": "ἐπέσαξαν",
          "note": "< σάττω = φορτίζω, ἐπιτίθημι φορτία",
          "rank": 1
        },
        {
          "anchor": "νομεῖς",
          "note": "νομεύς = ὁ βόσκων πρόβατα",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ὅτε τὸν ἡμίονον εὗρεν ἦν θύλακος μικρὸς ἐξ ἰνῶν δεδεμένος τῷ σχοινίῳ τοῦ ζῴου καὶ ἐντὸς τοῦ θυλάκου ἦν κοτύλη ξηρῶν κυάμων καὶ πέπερί τι καὶ μάχαιρα παλαιὰ ποτάμιος λαβὴν ἔχουσα ἐκ σπάρτου.",
      "glosses": [
        {
          "anchor": "θύλακος",
          "note": "θύλακος = σάκκος μικρὸς εἰς φυλάττειν",
          "rank": 1
        },
        {
          "anchor": "πέπερί",
          "note": "πέπερι = ἄρτυμα θερμὸν ἐκ τῆς Ἰνδίας",
          "rank": 1
        },
        {
          "anchor": "σπάρτου",
          "note": "σπάρτον = φυτὸν ἐξ οὗ σχοινία ποιοῦσι",
          "rank": 1
        },
        {
          "anchor": "ἰνῶν",
          "note": "ἴς = νεῦρα φυτῶν πρὸς ὕφανσιν",
          "rank": 1
        },
        {
          "anchor": "θυλάκου",
          "note": "θύλακος = σάκκος μικρὸς εἰς φυλάττειν",
          "rank": 1
        },
        {
          "anchor": "ξηρῶν",
          "note": "ξηρός = ἄνευ ὑγρότητος ↔ ὑγρός",
