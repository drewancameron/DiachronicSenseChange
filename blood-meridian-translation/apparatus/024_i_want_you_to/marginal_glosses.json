{
  "sentences": [
    {
      "index": 0,
      "greek": "Βούλομαί σε βλέπειν ὧδε, ἔφη.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Εἰς τὸν κατάρατον πῖλόν μου.",
      "glosses": [
        {
          "anchor": "κατάρατον",
          "note": "< κατ·αρά = ἐπάρατον μισητόν",
          "rank": 1
        },
        {
          "anchor": "πῖλόν",
          "note": "= σκέπασμα κεφαλῆς",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Οὐκ ἂν εἰδείης τί ἦν, νεκρόν τι.",
      "glosses": [
        {
          "anchor": "εἰδείης",
          "note": "< οἶδα = γινώσκοις ἄν",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἔσεισεν αὐτὸν καὶ κατέσπασεν ἐπὶ τὴν κεφαλὴν καὶ ἐπορεύετο καὶ ὁ παῖς εἵπετο.",
      "glosses": [
        {
          "anchor": "Ἔσεισεν",
          "note": "< σείω = ἐκίνησεν ἰσχυρῶς",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Τὸ καπηλεῖον μακρὸς στενός τε θάλαμος σανίσι γεγανωμέναις περιηλειμμένος.",
      "glosses": [
        {
          "anchor": "γεγανωμέναις",
          "note": "< γαίνω = λαμπραῖς πεποιημέναις",
          "rank": 1
        },
        {
          "anchor": "περιηλειμμένος",
          "note": "< περι·ἀλείφω = χρώματι κεκαλυμμένος",
          "rank": 1
        },
        {
          "anchor": "καπηλεῖον",
          "note": "< κάπηλος = τόπος πώλησις οἴνου",
          "rank": 1
        },
        {
          "anchor": "σανίσι",
          "note": "σανίς, σανίδος = ξύλινα πλατέα",
          "rank": 1
        },
        {
          "anchor": "μακρὸς",
          "note": "= μήκει μέγας ↔ βραχύς",
          "rank": 1
        },
        {
          "anchor": "στενός",
          "note": "= οὐ πλατύς ↔ εὐρύς",
          "rank": 1
        },
        {
          "anchor": "θάλαμος",
          "note": "= οἰκίσκος οἴκημα",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Τράπεζαι παρὰ τῷ τοίχῳ καὶ πτυστῆρες ἐπὶ τοῦ ἐδάφους.",
      "glosses": [
        {
          "anchor": "πτυστῆρες",
          "note": "< πτύω = σκεύη εἰς ἃ πτύουσιν",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Οὐδεὶς παρών.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "Ὁ κάπηλος ἀνέβλεψεν εἰσελθόντων καὶ Αἰθίοψ σαίρων τὸ ἔδαφος ἔστησε τὸν κάλαθον πρὸς τὸν τοῖχον καὶ ἐξῆλθεν.",
      "glosses": [
        {
          "anchor": "σαίρων",
          "note": "< σαίρω = καθαίρων σκόπῳ",
          "rank": 1
        },
        {
          "anchor": "κάλαθον",
          "note": "= πλεκτὸν ἀγγεῖον",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "= οἰνοπώλης πωλητής",
          "rank": 1
        },
        {
          "anchor": "εἰσελθόντων",
          "note": "< εἰς·έρχομαι = εἰσιόντων",
          "rank": 1
        }
      ]
    }
  ]
}