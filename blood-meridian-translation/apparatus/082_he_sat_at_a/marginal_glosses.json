{
  "sentences": [
    {
      "index": 0,
      "greek": "ἐκάθητο πρὸς πλεκτῇ τραπέζῃ γράφων ἐπιστολάς, ὁ ἄρχων.",
      "glosses": [
        {
          "anchor": "ἐκάθητο",
          "note": "= sat",
          "rank": 1
        },
        {
          "anchor": "πλεκτῇ",
          "note": "= wickerwork",
          "rank": 1
        },
        {
          "anchor": "γράφων",
          "note": "= writing",
          "rank": 1
        },
        {
          "anchor": "ἐπιστολάς",
          "note": "= letters",
          "rank": 1
        },
        {
          "anchor": "ἐπιστολάς",
          "note": "= sealing",
          "rank": 1
        },
        {
          "anchor": "ἄρχων",
          "note": "= chief magistrate or ruler",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "εἱστήκεσαν παριστάμενοι, ὁ τοῦ ἄρχοντος ἀνὴρ μέλανα πέτασον ἐν χερσὶν ἔχων.",
      "glosses": [
        {
          "anchor": "μέλανα",
          "note": "= black ↔ λευκός",
          "rank": 1
        },
        {
          "anchor": "πέτασον",
          "note": "= hat",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "ὁ δ' ἄρχων ἔγραφεν οὐδ' ἀνέβλεψεν.",
      "glosses": [
        {
          "anchor": "ἔγραφεν",
          "note": "= wrote",
          "rank": 1
        },
        {
          "anchor": "ἀνέβλεψεν",
          "note": "= look",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "ἔξωθεν ὁ παῖς ἤκουσε γυναικὸς Ἱσπανιστὶ λεγούσης.",
      "glosses": [
        {
          "anchor": "Ἱσπανιστὶ",
          "note": "= spanish",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "πλὴν τούτου ψόφος μόνον γραφίδος τοῦ ἄρχοντος.",
      "glosses": [
        {
          "anchor": "ψόφος",
          "note": "= scratching ↔ φωνή",
          "rank": 1
        },
        {
          "anchor": "γραφίδος",
          "note": "= pen",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "ἐπεὶ δ' ἐτέλεσε, κατέθηκε τὴν γραφίδα καὶ ἀνέβλεψεν.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "εἶδε τὸν ἑαυτοῦ ἄνδρα εἶτα τὸν παῖδα εἶτα κάτω νεύσας ἀνέγνω τὰ γεγραμμένα.",
      "glosses": [
        {
          "anchor": "γεγραμμένα",
          "note": "= written",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "ἔνευσε πρὸς ἑαυτὸν καὶ ἐκόνισε τὴν ἐπιστολὴν ψάμμῳ ἐκ μικρᾶς ὀνυχίνης λάρνακος καὶ συνέπτυξεν αὐτήν.",
      "glosses": [
        {
          "anchor": "μικρᾶς",
          "note": "= little ↔ μέγας",
          "rank": 1
        },
        {
          "anchor": "λάρνακος",
          "note": "= box",
          "rank": 1
        },
        {
          "anchor": "ἔνευσε",
          "note": "= nodded",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "λαβὼν πυρεῖον ἐκ θήκης αὐτῶν ἐπὶ τῆς τραπέζης ἧψεν αὐτὸ καὶ προσήνεγκε ῥάβδῳ κηροῦ σφραγιστικοῦ ἕως μικρὸν ἐρυθρὸν νόμισμα συνερρύη ἐπὶ τὸν χάρτην.",
      "glosses": [
        {
          "anchor": "ῥάβδῳ",
          "note": "= stick",
          "rank": 1
        },
        {
          "anchor": "ἐρυθρὸν",
          "note": "= red ↔ ὠχρός",
          "rank": 1
        },
        {
          "anchor": "χάρτην",
          "note": "= paper",
          "rank": 1
        },
        {
          "anchor": "σφραγιστικοῦ",
          "note": "= seal",
          "rank": 1
        },
        {
          "anchor": "πυρεῖον",
          "note": "= tower or beacon fire",
          "rank": 1
        },
        {
          "anchor": "νόμισμα",
          "note": "= coin or currency",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "ἀπέσεισε τὸ πυρεῖον, βραχὺ ἐμφυσήσας τῷ χάρτῃ ἔθλιψε τὴν σφραγῖδα τῷ δακτυλίῳ.",
      "glosses": [
        {
          "anchor": "δακτυλίῳ",
          "note": "= ring",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "εἶτα ἔστησε τὴν ἐπιστολὴν μεταξὺ δυοῖν βίβλων ἐπὶ τῆς τραπέζης καὶ ἀνακλιθεὶς ἐν τῷ δίφρῳ πάλιν εἶδε τὸν παῖδα.",
      "glosses": [
        {
          "anchor": "βίβλων",
          "note": "= books",
          "rank": 1
        },
        {
          "anchor": "δίφρῳ",
          "note": "= chair",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "ἔνευσε σεμνῶς.",
      "glosses": []
    },
    {
      "index": 12,
      "greek": "καθίζεσθε, ἔφη.",
      "glosses": [
        {
          "anchor": "καθίζεσθε",
          "note": "= take",
          "rank": 1
        }
      ]
    }
  ]
}