{
  "sentences": [
    {
      "index": 0,
      "greek": "ἀλλ' οἱ δὲ τὸν γέροντα ἐλοιδόρουν κἀπηρῶντο, ἕως ἀπῆλθε κατὰ τὸ καπηλεῖον τονθορύζων·",
      "glosses": [
        {
          "anchor": "καπηλεῖον",
          "note": "= cantina",
          "rank": 1
        },
        {
          "anchor": "ἐλοιδόρουν",
          "note": "= they were reviling",
          "rank": 1
        },
        {
          "anchor": "τονθορύζων",
          "note": "= buzzing/humming",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "πῶς δ' ἂν ἄλλως;",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "πῶς ταῦτα τελευτᾷ.",
      "glosses": [
        {
          "anchor": "τελευτᾷ",
          "note": "= end",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "ἐν συγχύσει καὶ ἀραῖς καὶ αἵματι.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "ἔπινον δ' ἔτι, ἄνεμος δ' ἔπνει κατὰ τὰς ὁδούς, τἀστρα δ' ἃ ὑπὲρ κεφαλῆς ἦν ταπεινὰ πρὸς ἑσπέραν ἔκειτο, οἵδε δ' οἱ νέοι ἄλλοις προσέκρουσαν, ῥήματα δ' ἐρρήθη ἃ οὐκέτι ὀρθοῦσθαι ἐδύνατο·",
      "glosses": [
        {
          "anchor": "ἔπινον",
          "note": "= drank",
          "rank": 1
        },
        {
          "anchor": "ἄνεμος",
          "note": "= wind",
          "rank": 1
        },
        {
          "anchor": "ἑσπέραν",
          "note": "= west",
          "rank": 1
        },
        {
          "anchor": "προσέκρουσαν",
          "note": "= they struck against",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "ἕῳ δ' ὁ παῖς καὶ ὁ δεύτερος λοχαγὸς προὐκάθηντο ὑπὲρ τοῦ ἐκ Μισσουρίου παιδός, ὃς Ἔαρλ ὠνομάζετο, καὶ τοὔνομ' αὐτοῦ ἐκάλουν, ὁ δ' οὐκέτι ἀντεφώνει.",
      "glosses": [
        {
          "anchor": "δεύτερος",
          "note": "= second",
          "rank": 1
        },
        {
          "anchor": "προὐκάθηντο",
          "note": "= they sat before",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "ἔκειτο ἐπὶ πλευρᾶς ἐν κόνει τῆς αὐλῆς.",
      "glosses": [
        {
          "anchor": "πλευρᾶς",
          "note": "= side ↔ κατὰ",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "οἱ μὲν ἄνδρες ᾤχοντο, αἱ δὲ πόρναι ᾤχοντο.",
      "glosses": [
        {
          "anchor": "πόρναι",
          "note": "= whores",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "γέρων τις ἔσαιρε τὸ πήλινον ἔδαφος ἔνδον τοῦ καπηλείου.",
      "glosses": [
        {
          "anchor": "ἔδαφος",
          "note": "= floor",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "ὁ παῖς ἔκειτο ῥαγέντος τοῦ κρανίου ἐν λίμνῃ αἵματος, οὐδεὶς δ' ᾔδει ὑπὸ τίνος.",
      "glosses": [
        {
          "anchor": "κρανίου",
          "note": "= skull",
          "rank": 1
        },
        {
          "anchor": "ῥαγέντος",
          "note": "= having been broken",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "τρίτος τις ἦλθε σὺν αὐτοῖς ἐν τῇ αὐλῇ.",
      "glosses": []
    }
  ]
}