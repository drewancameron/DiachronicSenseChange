{
  "sentences": [
    {
      "index": 0,
      "greek": "ὁ ἱερεὺς ἐπαύσατο τὸν λόγον παντελῶς.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "οὐκ ἦν ψόφος ἐν τῇ σκηνῇ.",
      "glosses": [
        {
          "anchor": "ψόφος",
          "note": "= κτύπος, φθόγγος ↔ σιγή",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "πάντες ἐθεώρουν τὸν ἄνδρα.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "διώρθωσε τὸν πέτασον καὶ εἶτα ἐώθει πρόσω μέχρι τοῦ βήματος ἐκ σανίδων ὅπου εἱστήκει ὁ ἱερεὺς καὶ ἐκεῖ ἐστράφη προσαγορεῦσαι τὸ ἐκκλησίασμα τοῦ ἱερέως.",
      "glosses": [
        {
          "anchor": "διώρθωσε",
          "note": "< ὀρθός = κατώρθου, ἐπανώρθου",
          "rank": 1
        },
        {
          "anchor": "ἐκκλησίασμα",
          "note": "< ἐκκλησία = σύνοδος, συναγωγή",
          "rank": 1
        },
        {
          "anchor": "πέτασον",
          "note": "= πῖλος, κυνῆ",
          "rank": 1
        },
        {
          "anchor": "ἐώθει",
          "note": "= ἐκίνει, ἤλαυνε",
          "rank": 1
        },
        {
          "anchor": "σανίδων",
          "note": "σανίς = δοκός, ξύλινον φύλλον",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "τὸ πρόσωπον αὐτοῦ γαληνόν τε καὶ παραδόξως παιδικόν.",
      "glosses": [
        {
          "anchor": "γαληνόν",
          "note": "= ἥσυχον, εἰρηνικόν ↔ ταραχῶδες",
          "rank": 1
        },
        {
          "anchor": "παραδόξως",
          "note": "< παράδοξος = θαυμασίως",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "αἱ χεῖρες αὐτοῦ μικραί.",
      "glosses": [
        {
          "anchor": "μικραί",
          "note": "= σμικραί, βραχεῖαι ↔ μεγάλαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "ἐξέτεινεν αὐτάς.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "κύριοι καὶ κυρίαι αἰσθάνομαι καθῆκόν μοι ὑμᾶς διδάξαι ὅτι ὁ ἀνὴρ ὁ ποιῶν ταύτην τὴν σύνοδον ἀλαζών ἐστιν.",
      "glosses": [
        {
          "anchor": "κυρίαι",
          "note": "κυρία = γυνὴ ἐλευθέρα",
          "rank": 1
        },
        {
          "anchor": "ἀλαζών",
          "note": "= κομπαστής, ψεύστης ↔ ἀληθής",
          "rank": 1
        },
        {
          "anchor": "αἰσθάνομαι",
          "note": "= γιγνώσκω, νομίζω",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "οὐκ ἔχει γράμματα θείων ἀπὸ οὐδενὸς καθιδρύματος ἀνεγνωρισμένου ἢ αὐτοσχεδίου.",
      "glosses": [
        {
          "anchor": "καθιδρύματος",
          "note": "καθίδρυμα = διδασκαλεῖον, σχολή",
          "rank": 1
        },
        {
          "anchor": "ἀνεγνωρισμένου",
          "note": "< γιγνώσκω = ἐπισήμου, δοκίμου",
          "rank": 1
        },
        {
          "anchor": "αὐτοσχεδίου",
          "note": "αὐτο·σχέδιος = μὴ ἐπίσημος",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "παντελῶς ἐστέρηται πάσης ἀξιώσεως πρὸς τὴν ἀρχὴν ἣν βεβίασται καὶ μόνον ἀπεμνημόνευσέ τινα τῶν ἐκ τῆς ἱερᾶς βίβλου πρὸς τὸ παρασχεῖν τοῖς κίβδηλοις λόγοις αὐτοῦ ἴχνος τι ἀμυδρὸν τῆς εὐσεβείας ἣν καταφρονεῖ.",
      "glosses": [
        {
          "anchor": "βεβίασται",
          "note": "< βιάζομαι = βίᾳ εἵλετο",
          "rank": 1
        },
        {
          "anchor": "κίβδηλοις",
          "note": "= ψευδέσι, νόθοις ↔ ἀληθέσι",
          "rank": 1
        },
        {
          "anchor": "ἀμυδρὸν",
          "note": "= ἀσθενές, ἀσαφές ↔ φανερόν",
          "rank": 1
        },
        {
          "anchor": "ἀξιώσεως",
          "note": "ἀξίωσις = δικαίωμα, ἐξουσία",
          "rank": 1
        },
        {
          "anchor": "ἀπεμνημόνευσέ",
          "note": "< μνήμη = ἀνεκάλεσε, ἐμνήσθη",
          "rank": 1
        },
        {
          "anchor": "ἐστέρηται",
          "note": "< στερέω = οὐκ ἔχει",
          "rank": 1
        },
        {
          "anchor": "βίβλου",
          "note": "βίβλος = γραφή, σύγγραμμα",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "τῇ ἀληθείᾳ ὁ ἀνὴρ ὁ ἑστὼς ἐνθάδε ἐνώπιον ὑμῶν σχηματιζόμενος διάκονον τοῦ κυρίου οὐ μόνον παντελῶς ἀγράμματός ἐστιν ἀλλὰ καὶ ζητεῖται ὑπὸ τοῦ νόμου ἐν ταῖς πολιτείαις Τεννεσσῆς, Κεντουκίας, Μισσισιππίου, καὶ Ἀρκανσάς.",
      "glosses": [
        {
          "anchor": "Τεννεσσῆς",
          "note": "πολιτεία τῆς Ἀμερικῆς",
          "rank": 1
        },
        {
          "anchor": "Κεντουκίας",
          "note": "πολιτεία τῆς Ἀμερικῆς",
          "rank": 1
        },
        {
          "anchor": "Μισσισιππίου",
          "note": "πολιτεία τῆς Ἀμερικῆς",
          "rank": 1
        },
        {
          "anchor": "Ἀρκανσάς",
          "note": "πολιτεία τῆς Ἀμερικῆς",
          "rank": 1
        },
        {
          "anchor": "σχηματιζόμενος",
          "note": "< σχῆμα = μιμούμενος, προσποιούμενος",
          "rank": 1
        },
        {
          "anchor": "ἀγράμματός",
          "note": "ἀ·γράμματος = ἀπαίδευτος ↔ πεπαιδευμένος",
          "rank": 1
        },
        {
          "anchor": "ζητεῖται",
          "note": "ἐνταῦθα = διώκεται ὑπὸ νόμου",
          "rank": 1
        },
        {
          "anchor": "διάκονον",
          "note": "διάκονος = ὑπηρέτης, λειτουργός",
          "rank": 1
        }
      ]
    }
  ]
}