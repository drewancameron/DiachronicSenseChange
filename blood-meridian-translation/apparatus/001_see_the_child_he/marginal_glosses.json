{
  "sentences": [
    {
      "index": 0,
      "greek": "ὅρα τὸν παῖδα.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "ὠχρὸς καὶ ἰσχνός, φορεῖ χιτωνίσκον λίνου λεπτὸν ῥακώδη τε.",
      "glosses": [
        {
          "anchor": "χιτωνίσκος",
          "note": "= short frock",
          "rank": 1
        },
        {
          "anchor": "ἰσχνός",
          "note": "= thin, lean ↔ παχύς",
          "rank": 1
        },
        {
          "anchor": "ῥακώδης",
          "note": "= ragged",
          "rank": 1
        },
        {
          "anchor": "καὶ",
          "note": "= and specially ↔ εἰ",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "σκαλεύει πῦρ μαγειρικόν.",
      "glosses": [
        {
          "anchor": "πῦρ",
          "note": "= fire ↔ χειμών",
          "rank": 1
        },
        {
          "anchor": "μαγειρεῖον",
          "note": "= butcherʼs shop, cook-shop",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "ἔξω κεῖνται ἀγροὶ μέλανες ἐστραμμένοι ῥάκεσι χιόνος, ὕλαι δὲ μελάντεραι πέρα, ἔτι λύκους ὀλίγους τελευταίους ἔχουσαι.",
      "glosses": [
        {
          "anchor": "μέλας",
          "note": "= black, dark ↔ λευκός",
          "rank": 1
        },
        {
          "anchor": "τελευταῖος",
          "note": "= oneʼs last day",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "τὸ μὲν γένος αὐτοῦ γινώσκεται ξυλοκόπων καὶ ὑδροφόρων, τῇ δ' ἀληθείᾳ ὁ πατὴρ διδάσκαλος γέγονεν.",
      "glosses": [
        {
          "anchor": "γένος",
          "note": "= race, stock, kin ↔ εἶδος",
          "rank": 1
        },
        {
          "anchor": "καὶ",
          "note": "= and specially ↔ εἰ",
          "rank": 1
        },
        {
          "anchor": "διδάσκαλος",
          "note": "= teacher, master",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "κεῖται ἐν μέθῃ, λέγει ἀπὸ ποιητῶν ὧν ὀνόματα νῦν ἀπόλωλεν.",
      "glosses": [
        {
          "anchor": "ἀπόλλυμι",
          "note": "= destroy utterly, kill",
          "rank": 1
        },
        {
          "anchor": "ποιητής",
          "note": "= workman",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "ὁ δὲ παῖς πτήσσει παρὰ τῷ πυρὶ καὶ θεᾶται αὐτόν.",
      "glosses": [
        {
          "anchor": "παῖς",
          "note": "= child, boy ↔ τέκνον",
          "rank": 1
        },
        {
          "anchor": "καὶ",
          "note": "= and specially ↔ εἰ",
          "rank": 1
        },
        {
          "anchor": "αὐτός",
          "note": "= self, myself, thyself",
          "rank": 1
        }
      ]
    }
  ]
}