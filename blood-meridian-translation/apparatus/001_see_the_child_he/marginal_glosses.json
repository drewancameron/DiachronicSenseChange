{
  "sentences": [
    {
      "index": 0,
      "greek": "ὅρα τὸν παῖδα.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "ὠχρὸς καὶ ἰσχνός·",
      "glosses": [
        {
          "anchor": "ἰσχνός",
          "note": "= thin, lean ↔ παχύς",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "χιτωνίσκον λεπτὸν ῥακώδη λίνεον φορεῖ.",
      "glosses": [
        {
          "anchor": "ῥακώδη",
          "note": "= ragged",
          "rank": 1
        },
        {
          "anchor": "χιτωνίσκον",
          "note": "= short frock",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "σκαλεύει πῦρ μαγειρικόν.",
      "glosses": [
        {
          "anchor": "σκαλεύει",
          "note": "= stokes",
          "rank": 1
        },
        {
          "anchor": "μαγειρικόν",
          "note": "= butcherʼs shop, cook-shop",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "ἔξω κεῖνται ἀγροὶ μέλανες ἐστραμμένοι ῥάκεσι χιόνος, ὗλαι δὲ μελάντεραι πέρα, αἳ ἔτι λύκους τινὰς ἐσχάτους κρύπτουσιν.",
      "glosses": [
        {
          "anchor": "μέλανες",
          "note": "= black, dark ↔ λευκός",
          "rank": 1
        },
        {
          "anchor": "ἐστραμμένοι",
          "note": "= turned",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "οἱ μὲν αὐτοῦ ξυλοτόμοι καὶ ὑδροφόροι νομίζονται·",
      "glosses": [
        {
          "anchor": "ξυλοτόμοι",
          "note": "= hewers of wood and drawers of water",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "τῇ δ' ἀληθείᾳ ὁ πατὴρ γραμματιστὴς γέγονεν.",
      "glosses": [
        {
          "anchor": "γραμματιστὴς",
          "note": "= schoolmaster",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "κεῖται μεθύων, λέγει δὲ ποιητῶν ὧν ὀνόματα νῦν ἀπόλωλεν.",
      "glosses": [
        {
          "anchor": "ποιητῶν",
          "note": "= workman",
          "rank": 1
        },
        {
          "anchor": "ἀπόλωλεν",
          "note": "= destroy utterly, kill",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "ὁ δὲ παῖς πτήσσει παρὰ τῷ πυρὶ καὶ αὐτὸν θεᾶται.",
      "glosses": [
        {
          "anchor": "πτήσσει",
          "note": "= crouches",
          "rank": 1
        }
      ]
    }
  ]
}