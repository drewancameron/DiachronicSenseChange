{
  "sentences": [
    {
      "index": 0,
      "greek": "ὅρα τὸν παῖδα.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "ὠχρὸς καὶ ἰσχνός·",
      "glosses": [
        {
          "anchor": "ἰσχνός",
          "note": "= thin ↔ παχύς",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "χιτωνίσκον χιτῶνα λεπτὸν λεπτόν, ῥακώδη, λίνεον φορεῖ.",
      "glosses": [
        {
          "anchor": "χιτωνίσκον",
          "note": "= shirt",
          "rank": 1
        },
        {
          "anchor": "χιτῶνα",
          "note": "= tunic or garment",
          "rank": 1
        },
        {
          "anchor": "λεπτὸν",
          "note": "= thin or fine",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "σκαλεύει πῦρ μαγειρεῖον.",
      "glosses": [
        {
          "anchor": "σκαλεύει",
          "note": "= stokes",
          "rank": 1
        },
        {
          "anchor": "μαγειρεῖον",
          "note": "= scullery",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "ἔξω κεῖνται ἀγροὶ μέλανες ἐστραμμένοι, χιόνος ῥάκη ἔχοντες, μελάντεραι δ' ὗλαι πέρα, αἳ λύκους ὀλίγους ἔτι τελευταίους τρέφουσιν τρέφουσιν.",
      "glosses": [
        {
          "anchor": "μέλανες",
          "note": "= dark ↔ λευκός",
          "rank": 1
        },
        {
          "anchor": "ἐστραμμένοι",
          "note": "= turned",
          "rank": 1
        },
        {
          "anchor": "τελευταίους",
          "note": "= last",
          "rank": 1
        },
        {
          "anchor": "τρέφουσιν",
          "note": "= they nourish or feed",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "τὸ μὲν γένος αὐτοῦ ξυλοκόποι καὶ ὑδροφόροι γιγνώσκονται·",
      "glosses": [
        {
          "anchor": "ξυλοκόποι",
          "note": "= hewers of wood and drawers of water",
          "rank": 1
        },
        {
          "anchor": "γιγνώσκονται",
          "note": "= known",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "ὁ δὲ πατὴρ τῇ ἀληθείᾳ διδάσκαλος ἦν.",
      "glosses": [
        {
          "anchor": "διδάσκαλος",
          "note": "= schoolmaster",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "κεῖται ἐν μέθῃ, λέγει δ' ἐκ ποιητῶν ὧν ὀνόματα νῦν ἀπόλωλεν.",
      "glosses": [
        {
          "anchor": "ποιητῶν",
          "note": "= poets",
          "rank": 1
        },
        {
          "anchor": "ἀπόλωλεν",
          "note": "= lost",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "ὁ παῖς πτήσσει παρὰ τῷ πυρὶ καὶ θεᾶται αὐτόν.",
      "glosses": [
        {
          "anchor": "πτήσσει",
          "note": "= crouches",
          "rank": 1
        }
      ]
    }
