{
  "sentences": [
    {
      "index": 0,
      "greek": "ὅρα τὸν παῖδα.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "ὠχρὸς καὶ ἰσχνός, χιτωνίσκον φορεῖ λεπτὸν ῥακώδη τε λίνεον.",
      "glosses": [
        {
          "anchor": "ἰσχνός",
          "note": "= thin ↔ παχύς",
          "rank": 1
        },
        {
          "anchor": "χιτωνίσκον",
          "note": "= shirt",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "σκαλεύει πῦρ μαγειρικόν.",
      "glosses": [
        {
          "anchor": "σκαλεύει",
          "note": "= stokes",
          "rank": 1
        },
        {
          "anchor": "μαγειρικόν",
          "note": "= scullery",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "ἔξω κεῖνται σκοτεινοὶ ἀγροὶ νεοστραφέντες ῥάκεσι χιόνος, πέρα δ' ὗλαι μελάντεραι ἔτι που λύκους ὑστάτους τρέφουσαι.",
      "glosses": [
        {
          "anchor": "σκοτεινοὶ",
          "note": "= dark ↔ λαμπρός",
          "rank": 1
        },
        {
          "anchor": "λύκους",
          "note": "= wolves",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "τὸ μὲν γένος αὐτοῦ ξυλοτόμοι καὶ ὑδροφόροι γνωστοί, τῇ δ' ἀληθείᾳ ὁ πατὴρ γραμματοδιδάσκαλος γέγονεν.",
      "glosses": [
        {
          "anchor": "ξυλοτόμοι",
          "note": "= hewers of wood and drawers of water",
          "rank": 1
        },
        {
          "anchor": "γένος",
          "note": "= folk ↔ εἶδος",
          "rank": 1
        },
        {
          "anchor": "γνωστοί",
          "note": "= known",
          "rank": 1
        },
        {
          "anchor": "γραμματοδιδάσκαλος",
          "note": "= schoolmaster",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "κεῖται μεθύων, λέγει δ' ἐκ ποιητῶν ὧν τὰ ὀνόματα νῦν ἀπώλετο.",
      "glosses": [
        {
          "anchor": "ποιητῶν",
          "note": "= poets",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "ὁ παῖς πτήσσει παρὰ πυρὶ καὶ αὐτὸν θεᾶται.",
      "glosses": [
        {
          "anchor": "πτήσσει",
          "note": "= crouches",
          "rank": 1
        },
        {
          "anchor": "θεᾶται",
          "note": "= watches",
          "rank": 1
        }
      ]
    }
  ]
