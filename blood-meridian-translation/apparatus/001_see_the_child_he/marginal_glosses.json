{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἴδε τὸν παῖδα.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "ὠχρός ἐστι καὶ ἰσχνός, φορεῖ λίνεον χιτῶνα λεπτὸν καὶ ἐρρωγότα.",
      "glosses": [
        {
          "anchor": "ἐρρωγότα",
          "note": "< ῥήγνυμι = διερρηγμένον",
          "rank": 1
        },
        {
          "anchor": "ὠχρός",
          "note": "= λευκὸς ὡς νοσῶν ↔ ἐρυθρός",
          "rank": 1
        },
        {
          "anchor": "λίνεον",
          "note": "< λίνον = ἐκ λίνου πεποιημένον",
          "rank": 1
        },
        {
          "anchor": "ἰσχνός",
          "note": "= λεπτός ↔ παχύς",
          "rank": 1
        },
        {
          "anchor": "φορεῖ",
          "note": "= φέρει",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "ὑποζωπυρεῖ τὸ πῦρ τῆς ἐσχάρας.",
      "glosses": [
        {
          "anchor": "ὑποζωπυρεῖ",
          "note": "= ὑπὸ τὸ πῦρ ζωπυρεῖ",
          "rank": 1
        },
        {
          "anchor": "ἐσχάρας",
          "note": "ἐσχάρα = τόπος τοῦ πυρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "ἔξω κεῖνται ἀγροὶ σκοτεινοὶ ἐστραμμένοι μετὰ ῥακῶν χιόνος καὶ σκοτεινότερα ἄλση ἐπέκεινα ἃ ἔτι τρέφει ὀλίγους ἐσχάτους λύκους.",
      "glosses": [
        {
          "anchor": "σκοτεινοὶ",
          "note": "< σκότος = σκότους πλήρεις",
          "rank": 1
        },
        {
          "anchor": "ἐστραμμένοι",
          "note": "< στρέφω = τετραμμένοι",
          "rank": 1
        },
        {
          "anchor": "ῥακῶν",
          "note": "ῥάκος = μικρὰ μόρια",
          "rank": 1
        },
        {
          "anchor": "σκοτεινότερα",
          "note": "< σκοτεινός = μᾶλλον σκοτεινά",
          "rank": 1
        },
        {
          "anchor": "κεῖνται",
          "note": "< κεῖμαι = ἵδρυνται",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "τὸ γένος αὐτοῦ γινώσκεται ὡς ξυλοκόποι καὶ ὑδροφόροι ἀλλὰ τῇ ἀληθείᾳ ὁ πατὴρ αὐτοῦ διδάσκαλος γέγονεν.",
      "glosses": [
        {
          "anchor": "ξυλοκόποι",
          "note": "ξυλο·κόποι = ξύλα κόπτοντες",
          "rank": 1
        },
        {
          "anchor": "ὑδροφόροι",
          "note": "ὑδρο·φόροι = ὕδωρ φέροντες",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "κεῖται ἐν μέθῃ, λέγει ἐκ ποιητῶν ὧν τὰ ὀνόματα νῦν ἀπόλωλεν.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "ὁ παῖς πτήσσει παρὰ τῷ πυρὶ καὶ θεωρεῖ αὐτόν.",
      "glosses": [
        {
          "anchor": "πτήσσει",
          "note": "= φοβεῖται καὶ συγκάμπτεται",
          "rank": 1
        }
      ]
    }
  ]
}