{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὁ παῖς ἔβλεψεν εἰς τὸν ἄνδρα.",
      "glosses": [
        {
          "anchor": "ἔβλεψεν",
          "note": "< βλέπω = εἶδεν, ἐθεάσατο",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ἡ κεφαλὴ αὐτοῦ παραδόξως στενὴ καὶ αἱ τρίχες πηλῷ κεκολλημέναι εἰς βάρβαρόν τι καὶ ἀρχαῖον σχῆμα.",
      "glosses": [
        {
          "anchor": "κεκολλημέναι",
          "note": "< κολλάω = συγκεκολλημέναι, προσκεκολλημέναι",
          "rank": 1
        },
        {
          "anchor": "παραδόξως",
          "note": "= θαυμασίως, ἀτόπως",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ἐπὶ τοῦ μετώπου κεκαυμένα τὰ γράμματα Η Τ καὶ κάτω καὶ σχεδὸν μεταξὺ τῶν ὀφθαλμῶν τὸ γράμμα Φ καὶ τὰ σημεῖα ταῦτα διέσπαστο καὶ λαμπρὰ ὡς εἰ ὁ σίδηρος ἄγαν πολὺν χρόνον προσμεμενηκώς.",
      "glosses": [
        {
          "anchor": "προσμεμενηκώς",
          "note": "< προσμένω = προσδεδεκώς, παραμείνας",
          "rank": 1
        },
        {
          "anchor": "κεκαυμένα",
          "note": "< καίω = πυρὶ τετυπωμένα",
          "rank": 1
        },
        {
          "anchor": "διέσπαστο",
          "note": "< διασπάω = διῃρημένα ἦν, κεχωρισμένα",
          "rank": 1
        },
        {
          "anchor": "μετώπου",
          "note": "= τὸ ἄνω μέρος προσώπου",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἐπεὶ ἐστράφη πρὸς τὸν παῖδα ὁ παῖς εἶδεν ὅτι ὦτα οὐκ εἶχεν.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Ἀνέστη καὶ κατέθετο τὴν μάχαιραν εἰς τὸν κολεὸν καὶ ἤρχετο ἄνω τὴν ὁδὸν τὰς ἐμβάδας ἐν τῇ χειρὶ ἔχων καὶ ὁ παῖς ἀναστὰς εἵπετο.",
      "glosses": [
        {
          "anchor": "ἐμβάδας",
          "note": "= ὑποδήματα, σανδάλια",
          "rank": 1
        },
        {
          "anchor": "κολεὸν",
          "note": "= θήκη μαχαίρας",
          "rank": 1
        },
        {
          "anchor": "κατέθετο",
          "note": "< κατατίθημι = ἔθηκε, κατέστησε",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ἡμίσεος τῆς ὁδοῦ πρὸς τὸ πανδοκεῖον ὁ ἀνὴρ ἔστη καὶ ἔβλεψεν εἰς τὸν πηλὸν εἶτα κατεκάθισεν ἐπὶ τὰς σανίδας καὶ ὑπεδήσατο τὰς ἐμβάδας αὐτῷ τῷ πηλῷ.",
      "glosses": [
        {
          "anchor": "κατεκάθισεν",
          "note": "< κατακαθίζω = κάτω ἐκαθέζετο",
          "rank": 1
        },
        {
          "anchor": "ἐμβάδας",
          "note": "= ὑποδήματα, σανδάλια",
          "rank": 1
        },
        {
          "anchor": "ὑπεδήσατο",
          "note": "< ὑποδέω = ὑποδήματα ἐνέδυ",
          "rank": 1
        },
        {
          "anchor": "ἔβλεψεν",
          "note": "< βλέπω = εἶδεν, ἐθεάσατο",
          "rank": 1
        },
        {
          "anchor": "πανδοκεῖον",
          "note": "= καταγώγιον, ξενών",
          "rank": 1
        },
        {
          "anchor": "Ἡμίσεος",
          "note": "< ἥμισυς = τοῦ ἡμίσους μέρους",
          "rank": 1
        },
        {
          "anchor": "σανίδας",
          "note": "= ξύλινα στρώματα, δοκούς",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Εἶτα ἀναστὰς ἐβάδιζε διὰ τοῦ χωρίου ἀναιρησόμενός τι.",
      "glosses": [
        {
          "anchor": "ἀναιρησόμενός",
          "note": "< ἀναιρέω = λαβεῖν μέλλων",
          "rank": 1
        }
      ]
    }
  ]
}