{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὁ παῖς περιέβλεψεν ἀτενῶς εἰς τὴν ἡμέραν.",
      "glosses": [
        {
          "anchor": "περιέβλεψεν",
          "note": "< περιβλέπω = πάντῃ βλέπω",
          "rank": 1
        },
        {
          "anchor": "ἀτενῶς",
          "note": "= σφόδρα προσέχων",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ποῦ μου αἱ ἐμβάδες;",
      "glosses": [
        {
          "anchor": "ἐμβάδες",
          "note": "= ὑποδήματα",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "εἶπεν.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Ὁ ἀνὴρ ὑπέβλεψεν αὐτόν.",
      "glosses": [
        {
          "anchor": "ὑπέβλεψεν",
          "note": "< ὑποβλέπω = ἄνω βλέπω",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Λεπίδες ξηροῦ πηλοῦ κατέπιπτον ἀπὸ τοῦ προσώπου αὐτοῦ.",
      "glosses": [
        {
          "anchor": "κατέπιπτον",
          "note": "< καταπίπτω = κάτω πίπτω",
          "rank": 1
        },
        {
          "anchor": "Λεπίδες",
          "note": "= μικρὰ τεμάχια",
          "rank": 1
        },
        {
          "anchor": "ξηροῦ",
          "note": "= μὴ ὑγροῦ ↔ ὑγροῦ",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ἀποκτενῶ τινα κατάρατον εἰ ἔχουσι τὰς ἐμβάδας μου.",
      "glosses": [
        {
          "anchor": "ἐμβάδα",
          "note": "= ὑπόδημα",
          "rank": 1
        },
        {
          "anchor": "κατάρατον",
          "note": "= ὃν θεοὶ μισοῦσι",
          "rank": 1
        },
        {
          "anchor": "ἐμβάδας",
          "note": "= ὑποδήματα",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ἐκεῖ φαίνεται μία αὐτῶν.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "Ὁ παῖς ἐμόχθησε διὰ τοῦ πηλοῦ καὶ ἀνεῖλε μίαν ἐμβάδα.",
      "glosses": [
        {
          "anchor": "ἐμόχθησε",
          "note": "< μοχθέω = μετὰ πόνου πορεύομαι",
          "rank": 1
        },
        {
          "anchor": "ἐμβάδα",
          "note": "= ὑπόδημα",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Ἐβάδιζε βαρέως περὶ τὴν αὐλὴν ψηλαφῶν εἰκότας βώλους πηλοῦ.",
      "glosses": [
        {
          "anchor": "εἰκότας",
          "note": "< εἰκάζω = ὁμοίας",
          "rank": 1
        },
        {
          "anchor": "ψηλαφῶν",
          "note": "< ψηλαφάω = ταῖς χερσὶ ζητέω",
          "rank": 1
        },
        {
          "anchor": "βώλους",
          "note": "= μικρὰ τεμάχια γῆς",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Σὴ αὕτη μάχαιρα;",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "εἶπεν.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "Ὁ ἀνὴρ ὑπέβλεψεν αὐτόν.",
      "glosses": [
        {
          "anchor": "ὑπέβλεψεν",
          "note": "< ὑποβλέπω = ἄνω βλέπω",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Ἔοικεν, εἶπεν.",
      "glosses": []
    },
    {
      "index": 13,
      "greek": "Ὁ παῖς ἔρριψεν αὐτὴν αὐτῷ καὶ κύψας ἀνείλετο καὶ ἀπέμαξε τὴν μεγάλην λάμην τῷ σκέλει τῶν ἀναξυρίδων.",
      "glosses": [
        {
          "anchor": "ἀπέμαξε",
          "note": "< ἀπομάσσω = καθαρὸν ποιέω",
          "rank": 1
        },
        {
          "anchor": "λάμην",
          "note": "= πηλὸς ὑγρός",
          "rank": 1
        },
        {
          "anchor": "ἀναξυρίδων",
          "note": "= ἱματίων τὰ σκέλη σκέποντα",
          "rank": 1
        },
        {
          "anchor": "σκέλει",
          "note": "= μέρει τοῦ σώματος",
          "rank": 1
        }
      ]
    },
    {
      "index": 14,
      "greek": "Ὤιμην τινὰ κεκλοφέναι σε, εἶπε τῇ μαχαίρᾳ.",
      "glosses": [
        {
          "anchor": "Ὤιμην",
          "note": "< οἴομαι = ἐνόμιζον",
          "rank": 1
        },
        {
          "anchor": "κεκλοφέναι",
          "note": "< κλέπτω = κλέψαι",
          "rank": 1
        }
      ]
    }
  ]
}