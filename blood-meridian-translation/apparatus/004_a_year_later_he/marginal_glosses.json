{
  "sentences": [
    {
      "index": 0,
      "greek": "ἔτει δ' ὑστέρῳ ἐν ἁγίῳ Λουίς.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "εἰς Νέαν Ὀρλεάνην ἀναίρεται σχεδίᾳ.",
      "glosses": [
        {
          "anchor": "σχεδίᾳ",
          "note": "= flatboat",
          "rank": 1
        },
        {
          "anchor": "ἀναίρεται",
          "note": "= innocent",
          "rank": 1
        },
        {
          "anchor": "ἀναίρεται",
          "note": "= is lifted up",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "τεσσαράκοντα δύο ἡμέραι ποταμῷ.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "νυκτὸς δὲ τὰ ἀτμόπλοια κλάζει καὶ στείχει παρὰ μέλασιν ὕδασιν, πάντα λάμποντα ὡς πόλεις πλανώμεναι.",
      "glosses": [
        {
          "anchor": "ἀτμόπλοια",
          "note": "= steamboats",
          "rank": 1
        },
        {
          "anchor": "μέλασιν",
          "note": "= black ↔ λευκός",
          "rank": 1
        },
        {
          "anchor": "λάμποντα",
          "note": "= alight",
          "rank": 1
        },
        {
          "anchor": "στείχει",
          "note": "= walks, goes",
          "rank": 1
        },
        {
          "anchor": "πλανώμεναι",
          "note": "= wandering, straying",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "διαλύουσι τὴν σχεδίαν, πωλοῦσι τὴν ὕλην.",
      "glosses": [
        {
          "anchor": "ὕλην",
          "note": "= lumber ↔ ἐντελέχεια",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "αὐτὸς δ' ἐν ὁδοῖς βαδίζων γλώσσας ἀκούει ἃς οὐ πρόσθεν ἤκουσεν.",
      "glosses": [
        {
          "anchor": "ἤκουσεν",
          "note": "= heard",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "οἰκεῖ δ' ἐν οἰκήματι ὑπὲρ αὐλῆς ὄπισθεν καπηλείου, καταβαίνει δὲ νυκτὸς ὥσπερ τι θηρίον μυθικὸν ναύταις μαχόμενος.",
      "glosses": [
        {
          "anchor": "καπηλείου",
          "note": "= tavern",
          "rank": 1
        },
        {
          "anchor": "μυθικὸν",
          "note": "= fairybook",
          "rank": 1
        },
        {
          "anchor": "καταβαίνει",
          "note": "= lie",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "οὐ μέγας, ἀλλὰ καρποὶ μεγάλοι, χεῖρες μεγάλαι.",
      "glosses": [
        {
          "anchor": "καρποὶ",
          "note": "= wrists",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "ὦμοι πυκνοὶ συνεστῶτες.",
      "glosses": [
        {
          "anchor": "πυκνοὶ",
          "note": "= close ↔ ἀραιός",
          "rank": 1
        },
        {
          "anchor": "συνεστῶτες",
          "note": "= standing together",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "τὸ τοῦ παιδὸς πρόσωπον θαυμαστῶς ἄθικτον ὄπισθεν οὐλῶν, ὀφθαλμοὶ ἀτόπως ἀκέραιοι.",
      "glosses": [
        {
          "anchor": "θαυμαστῶς",
          "note": "= wonderfully, marvelously",
          "rank": 1
        },
        {
          "anchor": "ἀκέραιοι",
          "note": "= uninjured, whole",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "μάχονται πυξί, ποσίν, λαγύνοις ἢ μαχαίραις.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "πάντα φῦλα, πᾶσαι γενεαί.",
      "glosses": [
        {
          "anchor": "φῦλα",
          "note": "= races",
          "rank": 1
        },
        {
          "anchor": "γενεαί",
          "note": "= breeds",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "ἄνδρες ὧν λόγος φθέγγεται ὥσπερ πιθήκων γρυλισμός.",
      "glosses": [
        {
          "anchor": "γρυλισμός",
          "note": "= snarling, grunting",
          "rank": 1
        }
      ]
    },
    {
      "index": 13,
      "greek": "ἄνδρες ἐκ γαιῶν οὕτω πόρρω καὶ ἀλλοκότων ὥστ' αὐτοῖς ἐφεστὼς ἔνθα κεῖνται αἱμάσσοντες ἐν πηλῷ, αὐτὸν τὸν ἄνθρωπον δεδικαιῶσθαι νομίζει.",
      "glosses": [
        {
          "anchor": "αἱμάσσοντες",
          "note": "= bleeding",
          "rank": 1
        },
        {
          "anchor": "ἄνθρωπον",
          "note": "= mankind",
          "rank": 1
        },
        {
          "anchor": "ἀλλοκότων",
          "note": "= strange, unusual",
          "rank": 1
        },
        {
          "anchor": "αἱμάσσοντες",
          "note": "= staining with blood",
          "rank": 1
        },
        {
          "anchor": "δεδικαιῶσθαι",
          "note": "= has justified",
          "rank": 1
        },
        {
          "anchor": "νομίζει",
          "note": "= thinks, believes",
          "rank": 1
        }
      ]
    }
  ]
}