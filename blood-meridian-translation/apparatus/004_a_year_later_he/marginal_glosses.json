{
  "sentences": [
    {
      "index": 0,
      "greek": "ἐνιαυτῷ ὕστερον ἐν Ἁγίῳ Λουδοβίκῳ ἐστίν.",
      "glosses": [
        {
          "anchor": "Λουδοβίκῳ",
          "note": "ὄνομα ἀνδρὸς καὶ πόλεως",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "λαμβάνεται εἰς Νέαν Ὀρλεάνην ἐπὶ πλατέος πλοίου.",
      "glosses": [
        {
          "anchor": "Ὀρλεάνην",
          "note": "ὄνομα πόλεως",
          "rank": 1
        },
        {
          "anchor": "πλατέος",
          "note": "= εὐρὺς ↔ στενός",
          "rank": 1
        },
        {
          "anchor": "λαμβάνεται",
          "note": "ἐνταῦθα = πορεύεται",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "δύο καὶ τεσσαράκοντα ἡμέραι ἐπὶ τοῦ ποταμοῦ.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "νυκτὸς τὰ ἀτμόπλοια βοᾷ καὶ βαδίζει παρερχόμενα διὰ τῶν μελάνων ὑδάτων πάντα φωτεινὰ ὡς πόλεις πλανώμεναι.",
      "glosses": [
        {
          "anchor": "ἀτμόπλοια",
          "note": "ἀτμός·πλοῖα = πλοῖα ἀτμῷ κινούμενα",
          "rank": 1
        },
        {
          "anchor": "πλανώμεναι",
          "note": "< πλανάομαι = περιέρχομαι ↔ μένω",
          "rank": 1
        },
        {
          "anchor": "παρερχόμενα",
          "note": "παρά + ἔρχομαι = πάρειμι",
          "rank": 1
        },
        {
          "anchor": "φωτεινὰ",
          "note": "< φῶς = φῶς ἔχοντα ↔ σκοτεινά",
          "rank": 1
        },
        {
          "anchor": "μελάνων",
          "note": "= μαύρων ↔ λευκῶν",
          "rank": 1
        },
        {
          "anchor": "βοᾷ",
          "note": "= μεγάλῃ φωνῇ κράζει",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "διαλύουσι τὴν σχεδίαν καὶ πωλοῦσι τὰ ξύλα καὶ βαδίζει ἐν ταῖς ὁδοῖς καὶ ἀκούει γλώσσας ἃς οὐ πρότερον ἤκουσεν.",
      "glosses": [
        {
          "anchor": "διαλύουσι",
          "note": "διά + λύω = λύω εἰς μέρη",
          "rank": 1
        },
        {
          "anchor": "σχεδίαν",
          "note": "σχεδία = πλοῖον ἐκ ξύλων",
          "rank": 1
        },
        {
          "anchor": "πωλοῦσι",
          "note": "< πωλέω = ἀποδίδωμι χρημάτων",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "οἰκεῖ ἐν οἰκήματι ὑπὲρ αὐλῆς ὄπισθεν καπηλείου καὶ καταβαίνει νυκτὸς ὡς θηρίον τι μυθῶδες μάχεσθαι τοῖς ναύταις.",
      "glosses": [
        {
          "anchor": "καπηλείου",
          "note": "καπήλειον = οἰκία καπήλου",
          "rank": 1
        },
        {
          "anchor": "καταβαίνει",
          "note": "κατά + βαίνω = ἄνωθεν βαίνω",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "οὐ μέγας ἐστὶν ἀλλὰ μεγάλους καρποὺς ἔχει, μεγάλας χεῖρας.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "οἱ ὦμοι αὐτοῦ ἐγγὺς ἀλλήλων.",
      "glosses": [
        {
          "anchor": "ὦμοι",
          "note": "ὦμος = μέρος σώματος μεταξὺ βραχίονος",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "τὸ τοῦ παιδὸς πρόσωπον ἀτόπως ἄθικτον ὄπισθεν τῶν οὐλῶν, οἱ ὀφθαλμοὶ ἀτόπως ἄκακοι.",
      "glosses": [
        {
          "anchor": "οὐλῶν",
          "note": "οὐλή = σημεῖον τραύματος",
          "rank": 1
        },
        {
          "anchor": "ἄκακοι",
          "note": "ἀ + κακός = οὐ κακοί",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "μάχονται πυγμαῖς, ποσί, λαγύνοις ἢ μαχαίραις.",
      "glosses": [
        {
          "anchor": "λαγύνοις",
          "note": "λάγυνος = ἀγγεῖον οἴνου μέγα",
          "rank": 1
        },
        {
          "anchor": "πυγμαῖς",
          "note": "πυγμή = χεὶρ συμπεπλεγμένη",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "πᾶν γένος, πᾶν φῦλον.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "ἄνδρες ὧν ἡ φωνὴ ὡς πιθήκων γρυλισμὸς ἠχεῖ.",
      "glosses": [
        {
          "anchor": "γρυλισμὸς",
          "note": "< γρυλίζω = φωνὴ ὑῶν",
          "rank": 1
        },
        {
          "anchor": "ἠχεῖ",
          "note": "= φθέγγεται",
          "rank": 1
        },
        {
          "anchor": "πιθήκων",
          "note": "πίθηκος = ζῷον ἀνθρώπῳ ὅμοιον",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "ἄνδρες ἐκ χωρῶν οὕτω μακρῶν καὶ ἀτόπων ὥστε ἐφεστὼς αὐτοῖς οὗ κεῖνται αἱμάσσοντες ἐν τῷ πηλῷ αἰσθάνεται αὐτὸ τὸ ἀνθρώπινον γένος δεδικαιωμένον.",
      "glosses": [
        {
          "anchor": "αἱμάσσοντες",
          "note": "< αἱμάσσω = αἷμα ῥέω",
          "rank": 1
        },
        {
          "anchor": "δεδικαιωμένον",
          "note": "< δικαιόω = δίκαιον ποιῶ",
          "rank": 1
        },
        {
          "anchor": "κεῖνται",
          "note": "< κεῖμαι = ἐπὶ γῆς εἰμι",
          "rank": 1
        },
        {
          "anchor": "ἐφεστὼς",
          "note": "< ἐφίστημι = ἐπὶ τινι ἑστώς",
          "rank": 1
        }
      ]
    }
  ]
}