{
  "sentences": [
    {
      "index": 0,
      "greek": "Οὐκ ἔχω ἀργύριον ἀλλὰ δέομαι πότου.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Ἐξοίσω τὰ ἀπόρριμματα ἢ σαρῶ τὸ ἔδαφος ἢ ὅ τι δή.",
      "glosses": [
        {
          "anchor": "ἀπόρριμματα",
          "note": "τὰ ἀπορριπτόμενα, σκύβαλα",
          "rank": 1
        },
        {
          "anchor": "σαρῶ",
          "note": "καθαίρω σαίρῃ",
          "rank": 1
        },
        {
          "anchor": "Ἐξοίσω",
          "note": "ἔξω οἴσω, φέρω",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ κάπηλος ἐπέβλεψε διὰ τοῦ οἰκήματος οὗ δύο ἄνδρες ἔπαιζον κύβους ἐπὶ τραπέζης.",
      "glosses": [
        {
          "anchor": "ἐπέβλεψε",
          "note": "εἶδε, κατενόησε",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "πωλῶν οἶνον ἐν καπηλείῳ",
          "rank": 1
        },
        {
          "anchor": "ἔπαιζον",
          "note": "παίζω = παιδιὰν ποιοῦμαι",
          "rank": 1
        },
        {
          "anchor": "κύβους",
          "note": "κύβος = τετράγωνος λίθος παιγνίου",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Πάππε, εἶπεν.",
      "glosses": [
        {
          "anchor": "Πάππε",
          "note": "ὦ πάππα, κλητικὴ γέροντος",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ὁ γεραίτερος τοῖν δυοῖν ἦρε τὴν κεφαλήν.",
      "glosses": [
        {
          "anchor": "γεραίτερος",
          "note": "πρεσβύτερος ἡλικίᾳ",
          "rank": 1
        },
        {
          "anchor": "ἦρε",
          "note": "ἤγειρε, ἄνω ἐποίησε",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Τί λέγει ὁ μειράκιον.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Ὁ γέρων εἶδε τὸν παῖδα καὶ ἐπέστρεψε πρὸς τοὺς κύβους.",
      "glosses": [
        {
          "anchor": "κύβους",
          "note": "κύβος = τετράγωνος λίθος παιγνίου",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ὁ κάπηλος ἀνέσεισε τοὺς ὤμους.",
      "glosses": [
        {
          "anchor": "ἀνέσεισε",
          "note": "ἐκίνησεν ἄνω καὶ κάτω",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "πωλῶν οἶνον ἐν καπηλείῳ",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Ὁ παῖς ἐστράφη πρὸς τὸν γέροντα.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "Λαλεῖς Ἀμερικανά;",
      "glosses": [
        {
          "anchor": "Ἀμερικανά",
          "note": "ἡ τῶν Ἀμερικανῶν διάλεκτος",
          "rank": 1
        },
        {
          "anchor": "Λαλεῖς",
          "note": "φθέγγῃ, λέγεις",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "εἶπεν.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "Ὁ γέρων ἀνέβλεψεν ἐκ τοῦ παιγνίου.",
      "glosses": [
        {
          "anchor": "παιγνίου",
          "note": "παίγνιον = παιδιὰ κύβων",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Κατενόει τὸν παῖδα ἀπροσώπως.",
      "glosses": [
        {
          "anchor": "Κατενόει",
          "note": "βλέπει προσεχῶς",
          "rank": 1
        },
        {
          "anchor": "ἀπροσώπως",
          "note": "οὐδὲν δηλοῦντι τῷ προσώπῳ",
          "rank": 1
        }
      ]
    },
    {
      "index": 13,
      "greek": "Εἰπὲ αὐτῷ ὅτι ἐργάσομαι ἀντὶ πότου.",
      "glosses": [
        {
          "anchor": "ἐργάσομαι",
          "note": "ἐργάζομαι, ἔργον ποιήσω",
          "rank": 1
        }
      ]
    },
    {
      "index": 14,
      "greek": "Οὐκ ἔχω ἀργύριον.",
      "glosses": []
    },
    {
      "index": 15,
      "greek": "Ὁ γέρων προὔτεινε τὸ γένειον καὶ ἐποίησε κλυγμὸν τῇ γλώττῃ.",
      "glosses": [
        {
          "anchor": "κλυγμὸν",
          "note": "ψόφος γλώττης ὑγρός",
          "rank": 1
        },
        {
          "anchor": "προὔτεινε",
          "note": "ἐξέτεινε πρόσω",
          "rank": 1
        }
      ]
    },
    {
      "index": 16,
      "greek": "Ὁ παῖς ἔβλεψε τὸν κάπηλον.",
      "glosses": [
        {
          "anchor": "ἔβλεψε",
          "note": "εἶδε, τοὺς ὀφθαλμοὺς ἐπέστρεψε",
          "rank": 1
        },
        {
          "anchor": "κάπηλον",
          "note": "κάπηλος = πωλῶν οἶνον",
          "rank": 1
        }
      ]
    },
    {
      "index": 17,
      "greek": "Ὁ γέρων ἐποίησε πυγμὴν τοῦ μὲν ἀντίχειρος ἄνω τοῦ δὲ μικροῦ δακτύλου κάτω καὶ ἀνέκλινε τὴν κεφαλὴν καὶ κατέχεε πόμα οὐκ ὂν κατὰ τοῦ λαιμοῦ.",
      "glosses": [
        {
          "anchor": "ἀντίχειρος",
          "note": "ὁ παχὺς δάκτυλος τῆς χειρός",
          "rank": 1
        },
        {
          "anchor": "ἀνέκλινε",
          "note": "ὀπίσω ἔκλινε",
          "rank": 1
        },
        {
          "anchor": "κατέχεε",
          "note": "ἔχεε κάτω ὡς ὕδωρ",
          "rank": 1
        },
        {
          "anchor": "λαιμοῦ",
          "note": "λαιμός = τράχηλος ἔσωθεν",
          "rank": 1
        },
        {
          "anchor": "δακτύλου",
          "note": "δάκτυλος = μέλος χειρὸς μικρόν",
          "rank": 1
        },
        {
          "anchor": "πυγμὴν",
          "note": "κλειστὴ χείρ",
          "rank": 1
        },
        {
          "anchor": "πόμα",
          "note": "τὸ πινόμενον",
          "rank": 1
        }
      ]
    },
    {
      "index": 18,
      "greek": "Βούλεται πιεῖν, εἶπεν.",
      "glosses": []
    },
    {
      "index": 19,
      "greek": "Ἀλλ' οὐ δύναται διδόναι τιμήν.",
      "glosses": []
    }
  ]
}