{
  "sentences": [
    {
      "index": 0,
      "greek": "ὁ λοχαγὸς Τράμμελ ἐποίησεν;",
      "glosses": [
        {
          "anchor": "Τράμμελ",
          "note": "= trammel",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "οὐδέποτε ὑπεσχόμην αὐτῷ ἐφίππιον, ἔφη ὁ λοχαγός.",
      "glosses": [
        {
          "anchor": "ἐφίππιον",
          "note": "= saddle",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "πορισόμεθά σοι ἐφίππιον.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "εἶπον δὴ αὐτῷ ὡς εὕροιμεν ἄν τινα ἱμάτια, ὦ ταξίαρχε.",
      "glosses": [
        {
          "anchor": "ταξίαρχε",
          "note": "= captain",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "εὖ γε.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "εἰ καὶ ἄτακτοί ἐσμεν, οὐ βουλόμεθα φαίνεσθαι κολόβουροι, ἦ γάρ;",
      "glosses": [
        {
          "anchor": "βουλόμεθα",
          "note": "= 'll",
          "rank": 1
        },
        {
          "anchor": "κολόβουροι",
          "note": "= mutilated tailed men",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "οὐ δῆτα, κύριε.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "οὐδ' ἔχομεν ἔτι δεδαμασμένους ἵππους, ἔφη ὁ λοχαγός.",
      "glosses": [
        {
          "anchor": "δεδαμασμένους",
          "note": "= tamed, subdued",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "δάμασον οὖν ἕνα.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "ἐκεῖνος ὁ γέρων ὁ δεινὸς ὢν δαμάζειν αὐτοὺς ἄχρηστός ἐστιν.",
      "glosses": [
        {
          "anchor": "δαμάζειν",
          "note": "= break",
          "rank": 1
        },
        {
          "anchor": "ἄχρηστός",
          "note": "= useless, worthless",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "οἶδα τοῦτο.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "λαβὲ ἄλλον τινά.",
      "glosses": []
    },
    {
      "index": 12,
      "greek": "μάλιστα.",
      "glosses": []
    },
    {
      "index": 13,
      "greek": "ἴσως οὗτος ὁ ἀνὴρ δύναται δαμάζειν ἵππους.",
      "glosses": []
    },
    {
      "index": 14,
      "greek": "πώποτε ἐδάμασας ἵππους;",
      "glosses": []
    },
    {
      "index": 15,
      "greek": "οὔ, κύριε.",
      "glosses": []
    },
    {
      "index": 16,
      "greek": "οὐ δεῖ με κυριεύειν.",
      "glosses": []
    },
    {
      "index": 17,
      "greek": "μάλιστα, κύριε.",
      "glosses": []
    },
    {
      "index": 18,
      "greek": "λοχαγέ, εἶπεν ὁ ταξίαρχος, καθιεὶς ἑαυτὸν ἀπὸ τοῦ γραφείου.",
      "glosses": [
        {
          "anchor": "γραφείου",
          "note": "= writing office",
          "rank": 1
        }
      ]
    },
    {
      "index": 19,
      "greek": "μάλιστα.",
      "glosses": []
    },
    {
      "index": 20,
      "greek": "κατάγραψον τόνδε τὸν ἄνδρα.",
      "glosses": []
    },
    {
      "index": 21,
      "greek": "τὸ στρατόπεδον ἦν ἀναποτάμιον πρὸς ἄκρῳ τῷ ἄστει.",
      "glosses": [
        {
          "anchor": "ἀναποτάμιον",
          "note": "= treasury official",
          "rank": 1
        }
      ]
    },
    {
      "index": 22,
      "greek": "σκηνὴ ἐκ παλαιοῦ ἁμαξικοῦ λίνου συνερραμμένη, ὀλίγαι καλύβαι θαμνίτιδες, πέραν δ' αὐτῶν αὔλιον ὀκτόσχημον ὁμοίως ἐκ θάμνων πεποιημένον, ἔνθα μικροὶ βαλιοὶ πῶλοι εἱστήκεσαν σκυθρωπάζοντες ἐν ἡλίῳ.",
      "glosses": [
        {
          "anchor": "σκηνὴ",
          "note": "= tent ↔ χορός",
          "rank": 1
        },
        {
          "anchor": "θάμνων",
          "note": "= brush",
          "rank": 1
        },
        {
          "anchor": "μικροὶ",
          "note": "= small ↔ μέγας",
          "rank": 1
        },
        {
          "anchor": "συνερραμμένη",
          "note": "= sewn together",
          "rank": 1
        },
        {
          "anchor": "καλύβαι",
          "note": "= huts, cabins",
          "rank": 1
        },
        {
          "anchor": "αὔλιον",
          "note": "= courtyard, enclosure",
          "rank": 1
        },
        {
          "anchor": "σκυθρωπάζοντες",
          "note": "= frowning, scowling",
          "rank": 1
        }
      ]
    }
  ]
}