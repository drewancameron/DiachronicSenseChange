          "anchor": "ὀπὰς",
          "note": "= holes in the earth",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "ἡ ἅμαξα κατεάγη.",
      "glosses": [
        {
          "anchor": "κατεάγη",
          "note": "< κατάγνυμι (ἀόρ. παθ.) = break in pieces, shatter",
          "rank": 1
        },
        {
          "anchor": "ἅμαξα",
          "note": "< ἄμαξα = frame-work, ‘châssis’ ↔ πείρινς",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "ἡ μήτηρ τεθνηκυῖα τεσσαρεσκαίδεκα ἔτη ἔθαλπεν ἐν τῷ ἰδίῳ κόλπῳ τὸ θηρίον ὃ αὐτὴν ἀποίσοι.",
      "glosses": [
        {
          "anchor": "τεθνηκυῖα",
          "note": "< θνήσκω (παρακ. μτχ. ἐν.) = be dead",
          "rank": 1
        },
        {
          "anchor": "ἔθαλπεν",
          "note": "< θάλπω (πρτ. ἐν.) = heat, soften by heat",
          "rank": 1
        },
        {
          "anchor": "ἀποίσοι",
          "note": "= carry off",
          "rank": 1
        },
        {
          "anchor": "τεσσαρεσκαίδεκα",
          "note": "= fourteen",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "ὁ πατὴρ οὐδέποτε λέγει τοὔνομα αὐτῆς, ὁ παῖς οὐκ οἶδεν αὐτό.",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "ἔχει ἀδελφὴν ἐν τῷδε τῷ κόσμῳ ἣν οὐκέτι ὄψεται.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "σκοπεῖ, ὠχρὸς καὶ ἄνιπτος.",
      "glosses": [
        {
          "anchor": "ἄνιπτος",
          "note": "= unwashen",
          "rank": 1
        },
        {
          "anchor": "ὠχρὸς",
          "note": "= pale, wan ↔ ἐρυθρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "οὔτε ἀναγινώσκειν οὔτε γράφειν οἶδε καὶ ἐν αὐτῷ ἤδη φύεται ὄρεξις βίας ἀνοήτου.",
      "glosses": [
        {
          "anchor": "ὄρεξις",
          "note": "= appetency, conation ↔ φυγή",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "πᾶσα ἱστορία πάρεστιν ἐν τῷ προσώπῳ, ὁ παῖς πατὴρ τοῦ ἀνδρός.",
      "glosses": []
    }
  ]
