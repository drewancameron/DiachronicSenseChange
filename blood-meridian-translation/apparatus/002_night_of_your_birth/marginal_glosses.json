{
  "sentences": [
    {
      "index": 0,
      "greek": "νὺξ τῆς γενέσεώς σου.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "τριάκοντα τρεῖς.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "Λεονίδαι ἐκαλοῦντο.",
      "glosses": [
        {
          "anchor": "Λεονίδαι",
          "note": "= υἱοὶ Λεωνίδου",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "θεοί, ὡς ἔπιπτον οἱ ἀστέρες.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "ἐζήτουν μελανίαν, ὀπὰς ἐν τοῖς οὐρανοῖς.",
      "glosses": [
        {
          "anchor": "μελανίαν",
          "note": "< μέλας = μαύρη χρόα ↔ λευκότης",
          "rank": 1
        },
        {
          "anchor": "ὀπὰς",
          "note": "= τρῆμα, χάσμα ↔ στερέωμα",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "ἡ ἅμαξα κατεάγη.",
      "glosses": [
        {
          "anchor": "κατεάγη",
          "note": "< κατάγνυμι = συνετρίβη",
          "rank": 1
        },
        {
          "anchor": "ἅμαξα",
          "note": "= ὄχημα τετράκυκλον",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "ἡ μήτηρ τεθνηκυῖα τεσσαρεσκαίδεκα ἔτη ἔθαλπεν ἐν τῷ ἰδίῳ κόλπῳ τὸ θηρίον ὃ αὐτὴν ἀποίσοι.",
      "glosses": [
        {
          "anchor": "τεθνηκυῖα",
          "note": "< θνῄσκω = ἀποθανοῦσα ↔ ζῶσα",
          "rank": 1
        },
        {
          "anchor": "ἔθαλπεν",
          "note": "< θάλπω = θερμαίνω καὶ τρέφω",
          "rank": 1
        },
        {
          "anchor": "ἀποίσοι",
          "note": "< ἀποφέρω = ἀπάγοι",
          "rank": 1
        },
        {
          "anchor": "τεσσαρεσκαίδεκα",
          "note": "= τέτταρες καὶ δέκα = ιδ΄",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "ὁ πατὴρ οὐδέποτε λέγει τοὔνομα αὐτῆς, ὁ παῖς οὐκ οἶδεν αὐτό.",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "ἔχει ἀδελφὴν ἐν τῷδε τῷ κόσμῳ ἣν οὐκέτι ὄψεται.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "σκοπεῖ, ὠχρὸς καὶ ἄνιπτος.",
      "glosses": [
        {
          "anchor": "ἄνιπτος",
          "note": "= οὐ πεπλυμένος ↔ καθαρός",
          "rank": 1
        },
        {
          "anchor": "ὠχρὸς",
          "note": "= λευκὸς ὡς νοσῶν ↔ ἐρυθρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "οὔτε ἀναγινώσκειν οὔτε γράφειν οἶδε καὶ ἐν αὐτῷ ἤδη φύεται ὄρεξις βίας ἀνοήτου.",
      "glosses": [
        {
          "anchor": "ὄρεξις",
          "note": "< ὀρέγομαι = ἐπιθυμία τινός",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "πᾶσα ἱστορία πάρεστιν ἐν τῷ προσώπῳ, ὁ παῖς πατὴρ τοῦ ἀνδρός.",
      "glosses": []
    }
  ]
}