{
  "sentences": [
    {
      "index": 0,
      "greek": "νυκτί τινι ναύκληρος Μελιταῖος βάλλει αὐτὸν κατὰ νώτου πιστολίῳ μικρῷ.",
      "glosses": [
        {
          "anchor": "Μελιταῖος",
          "note": "= ἐκ Μελίτης νήσου",
          "rank": 1
        },
        {
          "anchor": "πιστολίῳ",
          "note": "= μικρὸν ὅπλον βάλλον σφαίρας",
          "rank": 1
        },
        {
          "anchor": "ναύκληρος",
          "note": "= ὁ πλοίου κύριος",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "στρεφόμενος πρὸς τὸν ἄνδρα βάλλεται αὖθις ὑπὸ τὴν καρδίαν.",
      "glosses": [
        {
          "anchor": "στρεφόμενος",
          "note": "< στρέφω = περιάγω",
          "rank": 1
        },
        {
          "anchor": "βάλλεται",
          "note": "ἐνταῦθα = τιτρώσκεται πιστολίῳ",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "ὁ ἀνὴρ φεύγει καὶ αὐτὸς ἐρείδεται πρὸς τὸν κάπηλον τοῦ αἵματος ῥέοντος ἐκ τοῦ χιτῶνος.",
      "glosses": [
        {
          "anchor": "κάπηλον",
          "note": "= καπηλεῖον, οἰνοπώλιον",
          "rank": 1
        },
        {
          "anchor": "ἐρείδεται",
          "note": "= ἐπερείδεται, στηρίζεται",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "οἱ ἄλλοι ἀποβλέπουσι.",
      "glosses": [
        {
          "anchor": "ἀποβλέπουσι",
          "note": "< ἀποβλέπω = εἰς τι βλέπω",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "μετὰ χρόνον κάθηται ἐπὶ τοῦ ἐδάφους.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "κεῖται ἐν κλίνῃ ἐν τῷ ὑπερῴῳ δύο ἑβδομάδας τῆς τοῦ καπήλου γυναικὸς θεραπευούσης αὐτόν.",
      "glosses": [
        {
          "anchor": "θεραπευούσης",
          "note": "< θεραπεύω = ἰατρεύω",
          "rank": 1
        },
        {
          "anchor": "καπήλου",
          "note": "= ὁ οἶνον πωλῶν",
          "rank": 1
        },
        {
          "anchor": "ὑπερῴῳ",
          "note": "= δωμάτιον ἄνω",
          "rank": 1
        },
        {
          "anchor": "ἑβδομάδας",
          "note": "= ἑπτὰ ἡμέρας",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "φέρει τὰ σιτία αὐτοῦ, ἐκφέρει τὰ λύματα αὐτοῦ.",
      "glosses": [
        {
          "anchor": "λύματα",
          "note": "= ἀκάθαρτα ῥύπου",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "γυνὴ σκληρὰ τὴν ὄψιν σῶμα ἔχουσα νευρῶδες ὥσπερ ἀνδρός.",
      "glosses": [
        {
          "anchor": "νευρῶδες",
          "note": "< νεῦρον = νεύρων πλῆρες",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "ὅτε ὑγιὴς γέγονεν οὐκ ἔχει ἀργύριον ἀποδοῦναι αὐτῇ καὶ ἀπέρχεται νυκτὸς καὶ καθεύδει παρὰ τὴν ὄχθην ἕως ἂν εὕρῃ πλοῖον ὃ δέξεται αὐτόν.",
      "glosses": [
        {
          "anchor": "ὄχθην",
          "note": "= αἰγιαλὸς ποταμοῦ",
          "rank": 1
        },
        {
          "anchor": "ἀπέρχεται",
          "note": "< ἀπέρχομαι = ἄπειμι λάθρᾳ",
          "rank": 1
        },
        {
          "anchor": "καθεύδει",
          "note": "= ὕπνῳ δέδεται",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "τὸ πλοῖον πλεῖ εἰς Τέξας.",
      "glosses": [
        {
          "anchor": "Τέξας",
          "note": "= χώρα τῆς Ἀμερικῆς",
          "rank": 1
        },
        {
          "anchor": "πλεῖ",
          "note": "= ναυτίλλεται",
          "rank": 1
        }
      ]
    }
  ]
}