{
  "sentences": [
    {
      "index": 0,
      "greek": "νυκτί τινι ναύκληρος Μελιταῖος βάλλει αὐτὸν κατὰ νώτου πιστολίῳ μικρῷ.",
      "glosses": [
        {
          "anchor": "ναύκληρος",
          "note": "= skipper, sailing-master ↔ ἔμπορος",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "στρεφόμενος πρὸς τὸν ἄνδρα βάλλεται αὖθις ὑπὸ τὴν καρδίαν.",
      "glosses": [
        {
          "anchor": "στρεφόμενος",
          "note": "< στρέφω (ἐνεστ. μτχ. μέσ.) = turn about",
          "rank": 1
        },
        {
          "anchor": "βάλλεται",
          "note": "= throw",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "ὁ ἀνὴρ φεύγει καὶ αὐτὸς ἐρείδεται πρὸς τὸν κάπηλον τοῦ αἵματος ῥέοντος ἐκ τοῦ χιτῶνος.",
      "glosses": [
        {
          "anchor": "κάπηλον",
          "note": "= tavern-keeper ↔ ἔμπορος",
          "rank": 1
        },
        {
          "anchor": "ἐρείδεται",
          "note": "= cause to lean, prop",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "οἱ ἄλλοι ἀποβλέπουσι.",
      "glosses": [
        {
          "anchor": "ἀποβλέπουσι",
          "note": "< ἀποβλέπω (ἐνεστ. μτχ. ἐν.) = look away",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "μετὰ χρόνον κάθηται ἐπὶ τοῦ ἐδάφους.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "κεῖται ἐν κλίνῃ ἐν τῷ ὑπερῴῳ δύο ἑβδομάδας τῆς τοῦ καπήλου γυναικὸς θεραπευούσης αὐτόν.",
      "glosses": [
        {
          "anchor": "θεραπευούσης",
          "note": "< θεραπεύω (ἐνεστ. μτχ. ἐν.) = be an attendant, do service",
          "rank": 1
        },
        {
          "anchor": "καπήλου",
          "note": "< κάπηλος (γεν.) = tavern-keeper ↔ ἔμπορος",
          "rank": 1
        },
        {
          "anchor": "ὑπερῴῳ",
          "note": "= upper part of the house",
          "rank": 1
        },
        {
          "anchor": "ἑβδομάδας",
          "note": "= number seven",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "φέρει τὰ σιτία αὐτοῦ, ἐκφέρει τὰ λύματα αὐτοῦ.",
      "glosses": [
        {
          "anchor": "λύματα",
          "note": "< λῦμα (πλ.) = ruin",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "γυνὴ σκληρὰ τὴν ὄψιν σῶμα ἔχουσα νευρῶδες ὥσπερ ἀνδρός.",
      "glosses": [
        {
          "anchor": "νευρῶδες",
          "note": "< νευρώδης = sinewy",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "ὅτε ὑγιὴς γέγονεν οὐκ ἔχει ἀργύριον ἀποδοῦναι αὐτῇ καὶ ἀπέρχεται νυκτὸς καὶ καθεύδει παρὰ τὴν ὄχθην ἕως ἂν εὕρῃ πλοῖον ὃ δέξεται αὐτόν.",
      "glosses": [
        {
          "anchor": "ὄχθην",
          "note": "< ὀχθέω (πρτ. ἐν.) = be sorely angered, vexed in spirit",
          "rank": 1
        },
        {
          "anchor": "ἀπέρχεται",
          "note": "= go away, depart",
          "rank": 1
        },
        {
          "anchor": "καθεύδει",
          "note": "= lie down to sleep, sleep ↔ ἀγρυπνέω",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "τὸ πλοῖον πλεῖ εἰς Τέξας.",
      "glosses": [
        {
          "anchor": "πλεῖ",
          "note": "= sail, go by sea",
          "rank": 1
        }
      ]
    }
  ]
}