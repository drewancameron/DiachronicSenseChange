{
  "sentences": [
    {
      "index": 0,
      "greek": "πώποτε εἶδες τοιοῦτον τόπον ὑετοῦ;",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "ὁ παῖς ἐθεώρει τὸν ἱερέα.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "ἐστράφη πρὸς τὸν ἄνδρα τὸν λαλήσαντα.",
      "glosses": [
        {
          "anchor": "λαλήσαντα",
          "note": "< λαλέω (ἀόρ. μτχ. ἐν.) = talk ↔ λέγω",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "ἐφόρει μύστακας μακροὺς κατὰ τρόπον ἁρματηλατῶν καὶ ἐφόρει πέτασον εὐρύστομον μετὰ στεφάνης ταπεινῆς στρογγύλης.",
      "glosses": [
        {
          "anchor": "μύστακας",
          "note": "= upper lip",
          "rank": 1
        },
        {
          "anchor": "εὐρύστομον",
          "note": "= wide-mouthed",
          "rank": 1
        },
        {
          "anchor": "ταπεινῆς",
          "note": "= humbled, abased in power, pride ↔ ὑψηλός",
          "rank": 1
        },
        {
          "anchor": "στρογγύλης",
          "note": "= round, spherical ↔ πλατύς",
          "rank": 1
        },
        {
          "anchor": "ἁρματηλατῶν",
          "note": "= charioteer",
          "rank": 1
        },
        {
          "anchor": "πέτασον",
          "note": "= broad-brimmed felt hat",
          "rank": 1
        },
        {
          "anchor": "στεφάνης",
          "note": "= brim",
          "rank": 1
        },
        {
          "anchor": "μακροὺς",
          "note": "= long ↔ βραχύς",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "ἦν μικρὸν διάστροφος τοὺς ὀφθαλμοὺς καὶ ἐθεώρει τὸν παῖδα σπουδαίως ὡς εἰδὼς ἂν αὐτοῦ τὴν γνώμην περὶ τοῦ ὑετοῦ.",
      "glosses": [
        {
          "anchor": "διάστροφος",
          "note": "= twisted, distorted",
          "rank": 1
        },
        {
          "anchor": "σπουδαίως",
          "note": "< σπουδαῖος = earnest, serious ↔ φαῦλος",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "ἄρτι ἦλθον ἐνθάδε, εἶπεν ὁ παῖς.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "ἀλλὰ νικᾷ πάντα ἃ πώποτε εἶδον.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "ὁ παῖς ἐπένευσεν.",
      "glosses": [
        {
          "anchor": "ἐπένευσεν",
          "note": "< ἐπινεύω (ἀόρ. ἐν.) = nod ↔ ἀνανεύω",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "ἀνὴρ πελώριος ἐνδεδυμένος χιτῶνα ἔλαιον εἰσῆλθεν εἰς τὴν σκηνὴν καὶ ἀφείλετο τὸν πῖλον.",
      "glosses": [
        {
          "anchor": "πῖλον",
          "note": "= wool",
          "rank": 1
        },
        {
          "anchor": "πελώριος",
          "note": "= mighty things",
          "rank": 1
        },
        {
          "anchor": "ἐνδεδυμένος",
          "note": "< ἐνδύω (παρακ. μτχ. μέσ.) = put",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "ἦν φαλακρὸς ὡς λίθος καὶ οὐκ εἶχεν ἴχνος πώγωνος καὶ οὐκ εἶχεν ὀφρῦς τοῖς ὀφθαλμοῖς οὐδὲ βλεφαρίδας αὐτοῖς.",
      "glosses": [
        {
          "anchor": "βλεφαρίδας",
          "note": "= eyelash",
          "rank": 1
        },
        {
          "anchor": "φαλακρὸς",
          "note": "= baldheaded",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "ἦν ἐγγὺς ἑπτὰ ποδῶν τὸ ὕψος καὶ εἱστήκει καπνίζων κίγαρον καὶ ἐν ταύτῃ τῇ νομαδικῇ οἰκίᾳ τοῦ θεοῦ καὶ ἐδόκει ἀφῃρηκέναι τὸν πῖλον μόνον ἵνα ἐκβάλῃ τὸν ὑετὸν ἀπ' αὐτοῦ νῦν γὰρ ἐπέθετο αὐτὸν πάλιν.",
      "glosses": [
        {
          "anchor": "καπνίζων",
          "note": "< καπνίζω (ἐνεστ. μτχ. ἐν.) = make smoke",
          "rank": 1
        },
        {
          "anchor": "νομαδικῇ",
          "note": "< νομαδικός = of",
          "rank": 1
        },
        {
          "anchor": "ἀφῃρηκέναι",
          "note": "< ἀφαιρέω (παρακ. ἀπρ. ἐν.) = take away",
          "rank": 1
        },
        {
          "anchor": "πῖλον",
          "note": "= wool",
          "rank": 1
        }
      ]
    }
  ]
}