{
  "sentences": [
    {
      "index": 0,
      "greek": "πώποτε εἶδες τοιοῦτον τόπον ὑετοῦ;",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "ὁ παῖς ἐθεώρει τὸν ἱερέα.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "ἐστράφη πρὸς τὸν ἄνδρα τὸν λαλήσαντα.",
      "glosses": [
        {
          "anchor": "λαλήσαντα",
          "note": "< λαλέω = εἰπόντα",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "ἐφόρει μύστακας μακροὺς κατὰ τρόπον ἁρματηλατῶν καὶ ἐφόρει πέτασον εὐρύστομον μετὰ στεφάνης ταπεινῆς στρογγύλης.",
      "glosses": [
        {
          "anchor": "μύστακας",
          "note": "= τρίχας ὑπὸ ῥινί",
          "rank": 1
        },
        {
          "anchor": "εὐρύστομον",
          "note": "εὐρύ·στομον = πλατὺ τὸ στόμα ἔχον",
          "rank": 1
        },
        {
          "anchor": "ταπεινῆς",
          "note": "= μικρᾶς ↔ ὑψηλῆς",
          "rank": 1
        },
        {
          "anchor": "στρογγύλης",
          "note": "= κυκλοειδοῦς",
          "rank": 1
        },
        {
          "anchor": "ἁρματηλατῶν",
          "note": "ἅρματα·ἐλατῶν = ἵππους ἐλαυνόντων",
          "rank": 1
        },
        {
          "anchor": "πέτασον",
          "note": "= πῖλος πλατύς",
          "rank": 1
        },
        {
          "anchor": "στεφάνης",
          "note": "= ταινίας κυκλικῆς",
          "rank": 1
        },
        {
          "anchor": "μακροὺς",
          "note": "= μεγάλους ↔ βραχεῖς",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "ἦν μικρὸν διάστροφος τοὺς ὀφθαλμοὺς καὶ ἐθεώρει τὸν παῖδα σπουδαίως ὡς εἰδὼς ἂν αὐτοῦ τὴν γνώμην περὶ τοῦ ὑετοῦ.",
      "glosses": [
        {
          "anchor": "διάστροφος",
          "note": "διά·στροφος = μὴ εὐθύς",
          "rank": 1
        },
        {
          "anchor": "σπουδαίως",
          "note": "< σπουδή = μετὰ προσοχῆς",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "ἄρτι ἦλθον ἐνθάδε, εἶπεν ὁ παῖς.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "ἀλλὰ νικᾷ πάντα ἃ πώποτε εἶδον.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "ὁ παῖς ἐπένευσεν.",
      "glosses": [
        {
          "anchor": "ἐπένευσεν",
          "note": "ἐπι·νεύω = κεφαλὴν κάτω κινέω",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "ἀνὴρ πελώριος ἐνδεδυμένος χιτῶνα ἔλαιον εἰσῆλθεν εἰς τὴν σκηνὴν καὶ ἀφείλετο τὸν πῖλον.",
      "glosses": [
        {
          "anchor": "πῖλον",
          "note": "= κάλυμμα κεφαλῆς",
          "rank": 1
        },
        {
          "anchor": "πελώριος",
          "note": "= μέγιστος",
          "rank": 1
        },
        {
          "anchor": "ἐνδεδυμένος",
          "note": "< ἐνδύω = ἐσθῆτα φορῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "ἦν φαλακρὸς ὡς λίθος καὶ οὐκ εἶχεν ἴχνος πώγωνος καὶ οὐκ εἶχεν ὀφρῦς τοῖς ὀφθαλμοῖς οὐδὲ βλεφαρίδας αὐτοῖς.",
      "glosses": [
        {
          "anchor": "βλεφαρίδας",
          "note": "= τρίχας βλεφάρων",
          "rank": 1
        },
        {
          "anchor": "φαλακρὸς",
          "note": "= ἄτριχος τὴν κεφαλήν",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "ἦν ἐγγὺς ἑπτὰ ποδῶν τὸ ὕψος καὶ εἱστήκει καπνίζων κίγαρον καὶ ἐν ταύτῃ τῇ νομαδικῇ οἰκίᾳ τοῦ θεοῦ καὶ ἐδόκει ἀφῃρηκέναι τὸν πῖλον μόνον ἵνα ἐκβάλῃ τὸν ὑετὸν ἀπ' αὐτοῦ νῦν γὰρ ἐπέθετο αὐτὸν πάλιν.",
      "glosses": [
        {
          "anchor": "καπνίζων",
          "note": "< καπνός = καπνὸν ποιῶν",
          "rank": 1
        },
        {
          "anchor": "κίγαρον",
          "note": "= καπνιστὸν φύλλον τετυλιγμένον",
          "rank": 1
        },
        {
          "anchor": "νομαδικῇ",
          "note": "< νομάς = κινητῇ",
          "rank": 1
        },
        {
          "anchor": "ἀφῃρηκέναι",
          "note": "< ἀφαιρέω = ἀπεσκυλκέναι",
          "rank": 1
        },
        {
          "anchor": "πῖλον",
          "note": "= κάλυμμα κεφαλῆς",
          "rank": 1
        }
      ]
    }
  ]
}