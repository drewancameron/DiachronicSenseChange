{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἄνδαλε, εἶπεν.",
      "glosses": [
        {
          "anchor": "Ἄνδαλε",
          "note": "= φεῦγε, ἄπιθι",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Κίνησιν ἀποδιωκτικὴν τῷ ὀπισθίῳ τῆς χειρὸς ἐποίησεν.",
      "glosses": [
        {
          "anchor": "ἀποδιωκτικὴν",
          "note": "< ἀποδιώκω = ἀπελαύνουσα",
          "rank": 1
        },
        {
          "anchor": "ὀπισθίῳ",
          "note": "= τῷ ὄπισθεν μέρει ↔ ἔμπροσθεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Τὸ πρόσωπον τοῦ παιδὸς ἐσκοτώθη.",
      "glosses": [
        {
          "anchor": "ἐσκοτώθη",
          "note": "< σκοτόω = σκοτεινὸς ἐγένετο",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Υἱὲ κυνός, εἶπεν.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Ἤρξατο κατὰ τὸν οἰνοπώλην.",
      "glosses": [
        {
          "anchor": "οἰνοπώλην",
          "note": "οἰνο·πώλης = οἶνον πωλῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ἡ ὄψις τοῦ οἰνοπώλου οὐ μετέβαλεν.",
      "glosses": [
        {
          "anchor": "οἰνοπώλου",
          "note": "οἰνο·πώλης = οἶνον πωλῶν",
          "rank": 1
        },
        {
          "anchor": "μετέβαλεν",
          "note": "< μεταβάλλω = ἠλλοίωσε",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ἀνήνεγκεν ὑποκάτωθεν τοῦ οἰνοπωλείου πιστόλιον ἀρχαῖόν τι στρατιωτικὸν πυρίτου κλείθρῳ καὶ ἀνέωσε τὸν κόρακα τῇ πτέρνῃ τῆς χειρός.",
      "glosses": [
        {
          "anchor": "οἰνοπωλείου",
          "note": "οἰνο·πωλεῖον = τόπος πωλήσεως οἴνου",
          "rank": 1
        },
        {
          "anchor": "πιστόλιον",
          "note": "= βέλος πυρίτου μικρόν",
          "rank": 1
        },
        {
          "anchor": "πυρίτου",
          "note": "= πῦρ ποιῶν λίθος",
          "rank": 1
        },
        {
          "anchor": "κλείθρῳ",
          "note": "= μοχλὸς κλειόμενος",
          "rank": 1
        },
        {
          "anchor": "ἀνέωσε",
          "note": "< ἀνωθέω = ἄνω ὤθησε",
          "rank": 1
        },
        {
          "anchor": "πτέρνῃ",
          "note": "= δάκτυλος μέγας χειρός",
          "rank": 1
        },
        {
          "anchor": "κόρακα",
          "note": "ἐνταῦθα = παῖς κακός",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Κτύπος μέγας ξύλινος ἐν τῇ σιγῇ.",
      "glosses": [
        {
          "anchor": "ξύλινος",
          "note": "< ξύλον = ἐκ ξύλου πεποιημένος",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Κρότος ὑέλων κατὰ πᾶν τὸ οἰνοπωλεῖον.",
      "glosses": [
        {
          "anchor": "οἰνοπωλεῖον",
          "note": "οἰνο·πωλεῖον = τόπος πωλήσεως οἴνου",
          "rank": 1
        },
        {
          "anchor": "ὑέλων",
          "note": "ὕαλος = διαφανὲς σκεῦος",
          "rank": 1
        },
        {
          "anchor": "Κρότος",
          "note": "= ψόφος συντριβομένων",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Εἶτα ψόφος δίφρων ὠθουμένων ὑπὸ τῶν παικτῶν παρὰ τῷ τοίχῳ.",
      "glosses": [
        {
          "anchor": "παικτῶν",
          "note": "παίκτης = παίζων ἄνθρωπος",
          "rank": 1
        },
        {
          "anchor": "ψόφος",
          "note": "= ἦχος κινουμένων",
          "rank": 1
        },
        {
          "anchor": "δίφρων",
          "note": "δίφρος = καθέδρα τετράπους",
          "rank": 1
        }
      ]
    }
  ]
}