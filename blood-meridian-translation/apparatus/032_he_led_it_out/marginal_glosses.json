{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἐξήγαγεν αὐτὸν εἰς τὴν ὁδόν.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Παρερχομένου αὐτοῦ τὴν οἰκίαν ἡ γυνὴ ἐξῆλθε βαδίζουσα κατόπιν αὐτοῦ.",
      "glosses": [
        {
          "anchor": "Παρερχομένου",
          "note": "< παρέρχομαι = παρὰ ἰόντος",
          "rank": 1
        },
        {
          "anchor": "βαδίζουσα",
          "note": "= πορευομένη βραδέως",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ἰδοῦσα αὐτὸν τιθέντα τὸν πόδα εἰς τὴν ἀναβάθραν ἤρξατο τρέχειν.",
      "glosses": [
        {
          "anchor": "ἀναβάθραν",
          "note": "= βαθμὸς εἰς ἵππον ἀναβαίνειν",
          "rank": 1
        },
        {
          "anchor": "τιθέντα",
          "note": "< τίθημι = βάλλοντα",
          "rank": 1
        },
        {
          "anchor": "τρέχειν",
          "note": "= ταχέως ἰέναι ↔ βαδίζειν",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἀναπηδήσας εἰς τὸ κατεαγὸς ἐφίππιον ὥρμησε τὸν ἡμίονον πρόσω.",
      "glosses": [
        {
          "anchor": "κατεαγὸς",
          "note": "< κατάγνυμι = συντετριμμένον",
          "rank": 1
        },
        {
          "anchor": "ἐφίππιον",
          "note": "= σέλμα ἵππου",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ἔστη πρὸς τῇ πύλῃ θεωροῦσα αὐτὸν ἀπιόντα.",
      "glosses": [
        {
          "anchor": "θεωροῦσα",
          "note": "< θεωρέω = βλέπουσα",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Οὐκ ἐπέστρεψεν.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Διελθόντος αὐτοῦ πάλιν διὰ τῆς πόλεως τὸ πανδοκεῖον ἐκαίετο καὶ ἄνδρες εἱστήκεσαν κύκλῳ θεωροῦντες, ἔνιοι κενὰ ἄγγη ἔχοντες.",
      "glosses": [
        {
          "anchor": "εἱστήκεσαν",
          "note": "< ἵστημι = ἑστῶτες ἦσαν",
          "rank": 1
        },
        {
          "anchor": "ἄγγη",
          "note": "= σκεύη ὕδατος φέρειν",
          "rank": 1
        },
        {
          "anchor": "πανδοκεῖον",
          "note": "= οἰκία ξένων",
          "rank": 1
        },
        {
          "anchor": "ἐκαίετο",
          "note": "< καίω = πυρὶ ἠφανίζετο",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ὀλίγοι ἐφ' ἵππων ἐκάθηντο θεωροῦντες τὰς φλόγας καὶ εἷς τούτων ὁ κριτής.",
      "glosses": [
        {
          "anchor": "φλόγας",
          "note": "= πῦρ λαμπρόν",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Παρελαύνοντος τοῦ παιδὸς ὁ κριτὴς ἐπέστρεψε καὶ ἐθεώρει αὐτόν.",
      "glosses": [
        {
          "anchor": "Παρελαύνοντος",
          "note": "< παρελαύνω = παρὰ ἐλαύνοντος",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Ἔστρεψε τὸν ἵππον, ὥσπερ καὶ τὸ ζῷον θεωρεῖν βουλόμενος.",
      "glosses": [
        {
          "anchor": "Ἔστρεψε",
          "note": "< στρέφω = περιήγαγεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Ἐπιστρέψαντος τοῦ παιδὸς ὁ κριτὴς ἐμειδίασεν.",
      "glosses": [
        {
          "anchor": "ἐμειδίασεν",
          "note": "= ἐγέλασεν ἡδέως",
          "rank": 1
        },
        {
          "anchor": "Ἐπιστρέψαντος",
          "note": "< ἐπιστρέφω = πάλιν στραφέντος",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Ὁ παῖς ἐπέτρεψε τὸν ἡμίονον καὶ ἐξῆλθον παρὰ τὸ παλαιὸν λίθινον φρούριον κατὰ τὴν ὁδὸν τὴν πρὸς ἑσπέραν.",
      "glosses": [
        {
          "anchor": "λίθινον",
          "note": "< λίθος = ἐκ λίθων πεποιημένον",
          "rank": 1
        }
      ]
    }
  ]
}