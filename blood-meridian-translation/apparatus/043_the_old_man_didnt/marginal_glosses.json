{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὁ γέρων οὐκ ἀπεκρίνατο.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Τὴν κεφαλὴν ἐξαίφνης παρέκλινε καὶ τὴν ῥῖνα μεταξὺ τοῦ ἀντίχειρος καὶ τοῦ λιχανοῦ λαβὼν δίδυμα μύξης ῥεύματα εἰς τὸ ἔδαφος ἐξέπνευσε καὶ τοὺς δακτύλους εἰς τὴν ῥαφὴν τῶν ἀναξυρίδων ἀπέμαξεν.",
      "glosses": [
        {
          "anchor": "ἀντίχειρος",
          "note": "ἀντι·χείρ = μέγας δάκτυλος",
          "rank": 1
        },
        {
          "anchor": "λιχανοῦ",
          "note": "λιχανός = δάκτυλος μετὰ τὸν ἀντίχειρα",
          "rank": 1
        },
        {
          "anchor": "ἀναξυρίδων",
          "note": "ἀναξυρίδες = βαρβαρικὰ περισκελῆ ἱμάτια",
          "rank": 1
        },
        {
          "anchor": "ἀπέμαξεν",
          "note": "ἀπο·μάσσω = καθαίρω ἀπομορττόμενος",
          "rank": 1
        },
        {
          "anchor": "παρέκλινε",
          "note": "παρα·κλίνω = εἰς πλάγιον κινεῖ",
          "rank": 1
        },
        {
          "anchor": "μύξης",
          "note": "μύξα = ῥόη ἐκ ῥινῶν",
          "rank": 1
        },
        {
          "anchor": "ἐξέπνευσε",
          "note": "ἐκ·πνέω = πνεῦμα ἐκβάλλω",
          "rank": 1
        },
        {
          "anchor": "ῥαφὴν",
          "note": "ῥαφή = συρραφὴ ὑφάσματος",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ἐκ Μισισιππίου ἥκω.",
      "glosses": [
        {
          "anchor": "Μισισιππίου",
          "note": "Μισισίππιος = μέγας ποταμὸς Ἀμερικῆς",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἀνδραποδιστὴς ἦν, οὐ βούλομαι λέγειν.",
      "glosses": [
        {
          "anchor": "Ἀνδραποδιστὴς",
          "note": "ἀνδραπόδ·ιστης = δούλους πωλῶν ἔμπορος",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Χρηστὸν ἀργύριον ἐκτησάμην.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Οὐδέποτε ἑάλων.",
      "glosses": [
        {
          "anchor": "ἑάλων",
          "note": "ἁλίσκομαι = συλλαμβάνομαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ἀπέκαμον μόνον.",
      "glosses": [
        {
          "anchor": "Ἀπέκαμον",
          "note": "ἀπο·κάμνω = κόπῳ παύομαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ἀπέκαμον δούλων.",
      "glosses": [
        {
          "anchor": "Ἀπέκαμον",
          "note": "ἀπο·κάμνω = κόπῳ παύομαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Μεῖνον ἕως τί σοι δείξω.",
      "glosses": [
        {
          "anchor": "Μεῖνον",
          "note": "μένω = αὐτοῦ ἵσταμαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Στραφεὶς ἐν ταῖς βύρσαις ἐσκάλευσε καὶ διὰ τῶν φλοίων μικρόν τι μέλαν ὤρεξεν.",
      "glosses": [
        {
          "anchor": "βύρσαις",
          "note": "βύρσα = δέρμα βοὸς ἐργασμένον",
          "rank": 1
        },
        {
          "anchor": "ἐσκάλευσε",
          "note": "σκάλλω = ὀρύσσω, σκάπτω",
          "rank": 1
        },
        {
          "anchor": "φλοίων",
          "note": "φλοιός = φλοῖσβος δένδρου",
          "rank": 1
        },
        {
          "anchor": "ὤρεξεν",
          "note": "ὀρέγω = τείνω, δίδωμι",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Ὁ παῖς αὐτὸ ἐν τῇ χειρὶ μετέστρεφεν.",
      "glosses": [
        {
          "anchor": "μετέστρεφεν",
          "note": "μετα·στρέφω = πάλιν στρέφω",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Ἀνδρός τινος καρδία, ξηρὰ καὶ μεμελαμμένη.",
      "glosses": [
        {
          "anchor": "μεμελαμμένη",
          "note": "< μελαίνω = μέλαινα γενομένη",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Ἀπέδωκε καὶ ὁ γέρων ἐν τῇ παλάμῃ ὥσπερ σταθμώμενος εἶχεν.",
      "glosses": [
        {
          "anchor": "σταθμώμενος",
          "note": "σταθμάω = ἵστημι ἐν ζυγῷ",
          "rank": 1
        },
        {
          "anchor": "παλάμῃ",
          "note": "παλάμη = μέσον τῆς χειρός",
          "rank": 1
        }
      ]
    }
  ]
}