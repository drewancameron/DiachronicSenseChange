{
  "sentences": [
    {
      "index": 0,
      "greek": "Χάριν οἶδά σοι τοῦ ὕδατος, ἐβόησεν.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Ὁ ἐρημίτης σκοτεινὸς ἐφάνη ἐν τῇ θύρᾳ.",
      "glosses": [
        {
          "anchor": "ἐρημίτης",
          "note": "< ἔρημος = ἐν ἐρημίᾳ μόνος ζῶν",
          "rank": 1
        },
        {
          "anchor": "σκοτεινὸς",
          "note": "< σκότος = οὐ φαεινός ↔ λαμπρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Μεῖνον μετ' ἐμοῦ, ἔφη.",
      "glosses": [
        {
          "anchor": "Μεῖνον",
          "note": "< μένω = μὴ ἄπιθι",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Καλῶς ἔχει.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Ἄριστον μένειν.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Χειμὼν μέλλει.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Οἴει;",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "Οἶμαι καὶ ὀρθῶς οἶμαι.",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "Εἶεν.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "Φέρε τὴν εὐνήν.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "Φέρε τὰ σκεύη.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "Ἔλυσε καὶ κατέρριψε τὸ σάγμα καὶ συνέδησε τὸν ἡμίονον σκέλος πρόσθεν πρὸς ὄπισθεν καὶ εἰσήνεγκε τὸ στρῶμα.",
      "glosses": [
        {
          "anchor": "κατέρριψε",
          "note": "< κατα·ρίπτω = κάτω ἔρριψε",
          "rank": 1
        },
        {
          "anchor": "σάγμα",
          "note": "= φορτίον ἵππου ἢ ἡμιόνου",
          "rank": 1
        },
        {
          "anchor": "συνέδησε",
          "note": "< συν·δέω = ὁμοῦ ἔδησε",
          "rank": 1
        },
        {
          "anchor": "στρῶμα",
          "note": "= ὃ στρώννυται εἰς κοίτην",
          "rank": 1
        },
        {
          "anchor": "εἰσήνεγκε",
          "note": "< εἰσ·φέρω = ἔσω ἤνεγκε",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Οὐδὲν φῶς πλὴν τὸ πῦρ καὶ ὁ γέρων παρ' αὐτὸ ἐκάθητο σκυτεύς.",
      "glosses": [
        {
          "anchor": "σκυτεύς",
          "note": "= ὑποδήματα ποιῶν",
          "rank": 1
        }
      ]
    }
  ]
