{
  "sentences": [
    {
      "index": 0,
      "greek": "Θεοῖς ἐχθρός, ἔφη ὁ ἀνήρ.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Οὐ δὴ ἄνω ἀναβεβηκὼς δένδρου εἶ;",
      "glosses": [
        {
          "anchor": "δένδρου",
          "note": "= tree",
          "rank": 1
        },
        {
          "anchor": "ἀναβεβηκὼς",
          "note": "= having gone up",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Τί οὐκ ἄπει μ' ἐάσων μόνον;",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Λέξαι σοι μόνον ἤθελον.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Οὐκ ἐβουλόμην ὀργίσαι σε.",
      "glosses": [
        {
          "anchor": "ὀργίσαι",
          "note": "= to make angry",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ὤργισάς με.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Σὺ ἦσθ' ὁ τὴν κεφαλὴν τοῦ Μεξικανοῦ συντρίψας χθὲς ἑσπέρας;",
      "glosses": [
        {
          "anchor": "κεφαλὴν",
          "note": "= head ↔ οὐρά",
          "rank": 1
        },
        {
          "anchor": "ἑσπέρας",
          "note": "= evenin",
          "rank": 1
        },
        {
          "anchor": "Μεξικανοῦ",
          "note": "= mexicans",
          "rank": 1
        },
        {
          "anchor": "συντρίψας",
          "note": "= having broken/crushed",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Οὐκ εἰμὶ ἄρχων.",
      "glosses": [
        {
          "anchor": "ἄρχων",
          "note": "= ruler/magistrate",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Τίς εἰδέναι βούλεται;",
      "glosses": [
        {
          "anchor": "βούλεται",
          "note": "= intend",
          "rank": 1
        },
        {
          "anchor": "εἰδέναι",
          "note": "= know",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Στρατηγὸς Λευκός.",
      "glosses": [
        {
          "anchor": "Στρατηγὸς",
          "note": "= general/military commander",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Βούλεται τὸν ἄνδρα καταλέξαι εἰς στρατόν.",
      "glosses": [
        {
          "anchor": "στρατόν",
          "note": "= army ↔ οἱ",
          "rank": 1
        },
        {
          "anchor": "καταλέξαι",
          "note": "= to enlist/muster",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Στρατόν;",
      "glosses": []
    },
    {
      "index": 12,
      "greek": "Ναί.",
      "glosses": []
    },
    {
      "index": 13,
      "greek": "Ποῖον στρατόν;",
      "glosses": []
    },
    {
      "index": 14,
      "greek": "Λόχος ὑπὸ Στρατηγῷ Λευκῷ.",
      "glosses": [
        {
          "anchor": "Λόχος",
          "note": "= military unit/company",
          "rank": 1
        }
      ]
    },
    {
      "index": 15,
      "greek": "Μέλλομεν κρατῆσαι Μεξικανῶν.",
      "glosses": [
        {
          "anchor": "κρατῆσαι",
          "note": "= to seize/hold",
          "rank": 1
        }
      ]
    },
    {
      "index": 16,
      "greek": "Πέπαυται ὁ πόλεμος.",
      "glosses": []
    },
    {
      "index": 17,
      "greek": "Οὔ φησι πεπαῦσθαι.",
      "glosses": []
    },
    {
      "index": 18,
      "greek": "Ποῦ εἶ;",
      "glosses": []
    },
    {
      "index": 19,
      "greek": "Ἀναστὰς τὰς ἀναξυρίδας καθεῖλεν οὗ ἐκρέμασεν αὐτάς, ἐνέδυ τε.",
      "glosses": [
        {
          "anchor": "ἀναξυρίδας",
          "note": "= breeches",
          "rank": 1
        },
        {
          "anchor": "ἐκρέμασεν",
          "note": "= he hung up",
          "rank": 1
        }
      ]
    },
    {
      "index": 20,
      "greek": "Ὑποδησάμενος τὰς ἐμβάδας, τὴν μάχαιραν εἰς τὴν δεξιὰν κνημῖδα θέμενος, ἐκ τῶν ἰτεῶν ἐξῆλθε τὸν χιτωνίσκον ἐνδυόμενος.",
      "glosses": [
        {
          "anchor": "ἐμβάδας",
          "note": "= boots",
          "rank": 1
        },
        {
          "anchor": "δεξιὰν",
          "note": "= right ↔ ἀριστερός",
          "rank": 1
        },
        {
          "anchor": "χιτωνίσκον",
          "note": "= shirt",
          "rank": 1
        },
        {
          "anchor": "κνημῖδα",
          "note": "= greave/leg armor",
          "rank": 1
        }
      ]
    }
  ]
}