{
  "sentences": [
    {
      "index": 0,
      "greek": "Μέγας τις τόπος.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Ἐκόρει ἐν ταῖς γωνίαις οὗ δένδρα ἐν ὀστρακίνοις σιωπῇ εἱστήκει ἐν τῷ σκότει.",
      "glosses": [
        {
          "anchor": "Ἐκόρει",
          "note": "= σκοπεῖν, βλέπειν",
          "rank": 1
        },
        {
          "anchor": "ὀστρακίνοις",
          "note": "< ὄστρακον = ἐξ ὀστράκου πεποιημένοις",
          "rank": 1
        },
        {
          "anchor": "γωνίαις",
          "note": "= κέρασι, τόποις συμβολῆς",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ἐκόρει περὶ τὰ πτύελα καὶ ἐκόρει περὶ τοὺς παίκτας παρὰ τῇ τραπέζῃ καὶ ἐκόρει περὶ τὸν κύνα.",
      "glosses": [
        {
          "anchor": "Ἐκόρει",
          "note": "= σκοπεῖν, βλέπειν",
          "rank": 1
        },
        {
          "anchor": "πτύελα",
          "note": "= σίαλον ἐκπτυόμενον",
          "rank": 1
        },
        {
          "anchor": "παίκτας",
          "note": "= παίζοντας, κυβεύοντας",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἐκόρει κατὰ τὸ πρόσωπον τοῦ καπηλείου καὶ ὅτε ἀφίκετο οὗ οἱ πίνοντες εἱστήκεσαν ὠρθώθη καὶ ἐπερείσατο τῷ κορήματι καὶ εἰς αὐτοὺς ἔβλεψεν.",
      "glosses": [
        {
          "anchor": "Ἐκόρει",
          "note": "= σκοπεῖν, βλέπειν",
          "rank": 1
        },
        {
          "anchor": "ἐπερείσατο",
          "note": "= προσέκλινε σῶμα",
          "rank": 1
        },
        {
          "anchor": "κορήματι",
          "note": "= σκόπρῳ, ῥάβδῳ καθαίρουσι",
          "rank": 1
        },
        {
          "anchor": "καπηλείου",
          "note": "= τόπου οἴνου πωλήσεως",
          "rank": 1
        },
        {
          "anchor": "εἱστήκεσαν",
          "note": "< ἵστημι = ἑστῶτες ἦσαν",
          "rank": 1
        },
        {
          "anchor": "ὠρθώθη",
          "note": "< ὀρθόω = εἰς ὀρθὸν ἐγένετο",
          "rank": 1
        },
        {
          "anchor": "ἔβλεψεν",
          "note": "= εἰς αὐτοὺς ὤφθαλμον ἔτρεψε",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Διελέγοντο σιγῇ πρὸς ἀλλήλους καὶ τέλος εἷς τὸ ἔκπωμα ἀπὸ τοῦ καπηλείου λαβὼν ἀπέστη.",
      "glosses": [
        {
          "anchor": "καπηλείου",
          "note": "= τόπου οἴνου πωλήσεως",
          "rank": 1
        },
        {
          "anchor": "ἔκπωμα",
          "note": "= ποτήριον πίνειν",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Οἱ ἄλλοι εἵποντο.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Ὁ παῖς παρεκόρησεν αὐτοὺς πρὸς τὴν θύραν.",
      "glosses": [
        {
          "anchor": "παρεκόρησεν",
          "note": "= παρεσκόπησε, παρετήρησε",
          "rank": 1
        }
      ]
    }
  ]
}