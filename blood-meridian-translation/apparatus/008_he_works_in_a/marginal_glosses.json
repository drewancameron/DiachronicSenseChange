{
  "sentences": [
    {
      "index": 0,
      "greek": "ἐργάζεται ἐν πριστηρίῳ, ἐργάζεται ἐν οἴκῳ διφθερίτιδος.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "λαμβάνει μισθὸν παρὰ γεωργοῦ ἡμίονον γηραιόν.",
      "glosses": [
        {
          "anchor": "γεωργοῦ",
          "note": "= be a husbandman, farmer",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "καὶ ἐπὶ τοῦ ζῴου τούτου ἔαρος ὄντος τοῦ ἔτους χιλίου ὀκτακοσίου τεσσαράκοντα ἐνάτου ἱππεύει ἄνω διὰ τῆς νεωστὶ δημοκρατίας Φρεδωνίας εἰς τὴν πόλιν Νακογδόχης.",
      "glosses": [
        {
          "anchor": "χιλίου",
          "note": "< χίλιος (γεν.)",
          "rank": 1
        },
        {
          "anchor": "ἱππεύει",
          "note": "= rides",
          "rank": 1
        },
        {
          "anchor": "ἐνάτου",
          "note": "< ἔνατος (γεν.) = ninth",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "ὁ αἰδέσιμος Γρῆνος ἐδίδασκε πλήρους οἰκίας καθ' ἡμέραν ὅσον χρόνον ὁ ὑετὸς ἔπιπτε.",
      "glosses": [
        {
          "anchor": "αἰδέσιμος",
          "note": "= exciting shame",
          "rank": 1
        },
        {
          "anchor": "ἔπιπτε",
          "note": "< πίπτω (πρτ. ἐν.) = fall down",
          "rank": 1
        },
        {
          "anchor": "πλήρους",
          "note": "= make full",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "καὶ ὁ ὑετὸς ἔπιπτε δύο ἑβδομάδας.",
      "glosses": [
        {
          "anchor": "ἔπιπτε",
          "note": "< πίπτω (πρτ. ἐν.) = fall down",
          "rank": 1
        },
        {
          "anchor": "ἑβδομάδας",
          "note": "= period of seven days, week",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "ὅτε ὁ παῖς ὑπεισῆλθεν εἰς τὴν ῥακώδη σκηνὴν λινῆν ἦν στάσις παρὰ τοὺς τοίχους, τόπος εἷς ἢ δύο, καὶ ὀδμή τις βαρεῖα τῶν ὑγρῶν καὶ ἀλούτων ὥστε αὐτοὶ ἐξῄεσαν εἰς τὸν ὄμβρον ἄλλοτε καὶ ἄλλοτε ἀέρος καθαροῦ χάριν πρὶν ὁ ὑετὸς εἰσήλαυνεν αὐτοὺς πάλιν.",
      "glosses": [
        {
          "anchor": "ὑπεισῆλθεν",
          "note": "< ὑπεισέρχομαι (ἀόρ. ἐν.) = enter upon secretly",
          "rank": 1
        },
        {
          "anchor": "ἀλούτων",
          "note": "< ἄλουτος (γεν. πλ.) = unwashen",
          "rank": 1
        },
        {
          "anchor": "ῥακώδη",
          "note": "< ῥακώδης = ragged",
          "rank": 1
        },
        {
          "anchor": "εἰσήλαυνεν",
          "note": "= drive",
          "rank": 1
        },
        {
          "anchor": "λινῆν",
          "note": "< λίνεος (αἰτ.) = flax, linen",
          "rank": 1
        },
        {
          "anchor": "ἐξῄεσαν",
          "note": "< ἔξειμι (πρτ. ἐν.) = come forth",
          "rank": 1
        },
        {
          "anchor": "ὀδμή",
          "note": "< ὀσμή = smell, odour",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "ἵστατο μετ' ἄλλων ὁμοίων παρὰ τὸν ὄπισθεν τοῖχον.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "τὸ μόνον ὃ ἂν διέκρινεν αὐτὸν ἐν τῷ ὄχλῳ ἐκείνῳ ὅτι οὐκ ἦν ὡπλισμένος.",
      "glosses": [
        {
          "anchor": "ὡπλισμένος",
          "note": "< ὁπλίζω (παρακ. μτχ. μέσ.) = equip, arm",
          "rank": 1
        },
        {
          "anchor": "διέκρινεν",
          "note": "< διακρίνω (ἀόρ. παθ.) = distinguish ↔ συγκρίνω",
          "rank": 1
        }
      ]
    }
  ]
}