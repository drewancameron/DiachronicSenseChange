{
  "sentences": [
    {
      "index": 0,
      "greek": "ἐργάζεται ἐν πριστηρίῳ, ἐργάζεται ἐν οἴκῳ διφθερίτιδος.",
      "glosses": [
        {
          "anchor": "πριστηρίῳ",
          "note": "= ἐργαστήριον ξύλων κοπῆς",
          "rank": 1
        },
        {
          "anchor": "διφθερίτιδος",
          "note": "< δίφθερα = τέχνη δερμάτων ποιήσεως",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "λαμβάνει μισθὸν παρὰ γεωργοῦ ἡμίονον γηραιόν.",
      "glosses": [
        {
          "anchor": "γεωργοῦ",
          "note": "< γεωργός = γῆν ἐργαζόμενος",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "καὶ ἐπὶ τοῦ ζῴου τούτου ἔαρος ὄντος τοῦ ἔτους χιλίου ὀκτακοσίου τεσσαράκοντα ἐνάτου ἱππεύει ἄνω διὰ τῆς νεωστὶ δημοκρατίας Φρεδωνίας εἰς τὴν πόλιν Νακογδόχης.",
      "glosses": [
        {
          "anchor": "χιλίου",
          "note": "= ἀριθμὸς χίλιοι μία",
          "rank": 1
        },
        {
          "anchor": "ὀκτακοσίου",
          "note": "= ὀκτὼ ἑκατοντάδες",
          "rank": 1
        },
        {
          "anchor": "Φρεδωνίας",
          "note": "= ὄνομα χώρας",
          "rank": 1
        },
        {
          "anchor": "Νακογδόχης",
          "note": "= ὄνομα πόλεως",
          "rank": 1
        },
        {
          "anchor": "ἱππεύει",
          "note": "< ἱππεύω = ἐφ' ἵππου πορεύομαι",
          "rank": 1
        },
        {
          "anchor": "ἐνάτου",
          "note": "< ἔνατος = ἀριθμὸς μετὰ ὄγδοον",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "ὁ αἰδέσιμος Γρῆνος ἐδίδασκε πλήρους οἰκίας καθ' ἡμέραν ὅσον χρόνον ὁ ὑετὸς ἔπιπτε.",
      "glosses": [
        {
          "anchor": "αἰδέσιμος",
          "note": "= σεβαστὸς καὶ τίμιος",
          "rank": 1
        },
        {
          "anchor": "Γρῆνος",
          "note": "= ὄνομα ἀνδρός",
          "rank": 1
        },
        {
          "anchor": "ἔπιπτε",
          "note": "< πίπτω = κάτω φέρεται",
          "rank": 1
        },
        {
          "anchor": "πλήρους",
          "note": "< πλήρης = πάντῃ γέμων ↔ κενός",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "καὶ ὁ ὑετὸς ἔπιπτε δύο ἑβδομάδας.",
      "glosses": [
        {
          "anchor": "ἔπιπτε",
          "note": "< πίπτω = κάτω φέρεται",
          "rank": 1
        },
        {
          "anchor": "ἑβδομάδας",
          "note": "< ἑβδομάς = ἑπτὰ ἡμέραι",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "ὅτε ὁ παῖς ὑπεισῆλθεν εἰς τὴν ῥακώδη σκηνὴν λινῆν ἦν στάσις παρὰ τοὺς τοίχους, τόπος εἷς ἢ δύο, καὶ ὀδμή τις βαρεῖα τῶν ὑγρῶν καὶ ἀλούτων ὥστε αὐτοὶ ἐξῄεσαν εἰς τὸν ὄμβρον ἄλλοτε καὶ ἄλλοτε ἀέρος καθαροῦ χάριν πρὶν ὁ ὑετὸς εἰσήλαυνεν αὐτοὺς πάλιν.",
      "glosses": [
        {
          "anchor": "ὑπεισῆλθεν",
          "note": "< ὑπεισέρχομαι = λάθρᾳ εἰσέρχομαι",
          "rank": 1
        },
        {
          "anchor": "ἀλούτων",
          "note": "< ἄλουτος = μὴ λελουμένων ↔ καθαρῶν",
          "rank": 1
        },
        {
          "anchor": "ῥακώδη",
          "note": "< ῥάκος = ῥάκεσι πλήρης",
          "rank": 1
        },
        {
          "anchor": "εἰσήλαυνεν",
          "note": "< εἰσελαύνω = βίᾳ εἰσάγω",
          "rank": 1
        },
        {
          "anchor": "λινῆν",
          "note": "< λίνον = ἐκ λίνου πεποιημένη",
          "rank": 1
        },
        {
          "anchor": "ἐξῄεσαν",
          "note": "< ἔξειμι = ἐκπορεύονται",
          "rank": 1
        },
        {
          "anchor": "ὀδμή",
          "note": "= ὃ διὰ ῥινῶν αἰσθανόμεθα",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "ἵστατο μετ' ἄλλων ὁμοίων παρὰ τὸν ὄπισθεν τοῖχον.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "τὸ μόνον ὃ ἂν διέκρινεν αὐτὸν ἐν τῷ ὄχλῳ ἐκείνῳ ὅτι οὐκ ἦν ὡπλισμένος.",
      "glosses": [
        {
          "anchor": "ὡπλισμένος",
          "note": "< ὁπλίζω = ὅπλα φέρων",
          "rank": 1
        },
        {
          "anchor": "διέκρινεν",
          "note": "< διακρίνω = διαφορὰν ποιεῖ",
          "rank": 1
        }
      ]
    }
  ]
}