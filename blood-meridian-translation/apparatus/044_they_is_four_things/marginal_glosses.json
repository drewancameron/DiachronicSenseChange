{
  "sentences": [
    {
      "index": 0,
      "greek": "Τέσσαρά ἐστι τὰ δυνάμενα τὴν γῆν διαφθεῖραι, ἔφη.",
      "glosses": [
        {
          "anchor": "δυνάμενα",
          "note": "< δύναμαι = ἰσχύω ποιεῖν",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Γυναῖκες, οἶνος, ἀργύριον, καὶ μέλανες.",
      "glosses": [
        {
          "anchor": "μέλανες",
          "note": "μέλας = χρῶμα σκοτεινόν ↔ λευκός",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ἐν σιγῇ ἐκάθηντο.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Ὁ ἄνεμος ἔστενεν ἐν τῷ τμήματι τοῦ καπνοδόχου ὃς διὰ τῆς στέγης ὑπὲρ αὐτῶν διήκει τὸν τόπον καπνοῦ ἀπαλλάξαι.",
      "glosses": [
        {
          "anchor": "τμήματι",
          "note": "τμῆμα = μέρος τι τετμημένον",
          "rank": 1
        },
        {
          "anchor": "καπνοδόχου",
          "note": "καπνο·δόχος = καπνὸν δεχόμενον",
          "rank": 1
        },
        {
          "anchor": "ἔστενεν",
          "note": "< στένω = ψόφον ποιέω",
          "rank": 1
        },
        {
          "anchor": "διήκει",
          "note": "< διήκω = διὰ παντὸς ἔρχομαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Μετὰ χρόνον ὁ γέρων τὴν καρδίαν ἀπέθετο.",
      "glosses": [
        {
          "anchor": "ἀπέθετο",
          "note": "< ἀποτίθημι = παύομαι φέρων",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Τοῦτο τὸ πρᾶγμά μοι διακοσίους στατῆρας ἐστάθη, ἔφη.",
      "glosses": [
        {
          "anchor": "στατῆρας",
          "note": "στατήρ = νόμισμα χρυσοῦν",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Διακοσίους στατῆρας δέδωκας ὑπὲρ αὐτοῦ;",
      "glosses": [
        {
          "anchor": "στατῆρας",
          "note": "στατήρ = νόμισμα χρυσοῦν",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Δέδωκα, τοῦτο γὰρ τὸ τίμημα ὃ ἐπέθεσαν τῷ μέλανι υἱῷ πόρνης ἐν ᾧ ἐνέκειτο.",
      "glosses": [
        {
          "anchor": "ἐπέθεσαν",
          "note": "< ἐπιτίθημι = ἐνταῦθα = τιμὴν ὁρίζω",
          "rank": 1
        },
        {
          "anchor": "μέλανι",
          "note": "μέλας = ἐνταῦθα = δοῦλος Αἰθίοψ",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Ἐκινήθη ἐν τῇ γωνίᾳ καὶ παλαιὸν σκοτεινὸν χαλκοῦν λέβητα ἀνέλαβεν, τὸ πῶμα ἦρε καὶ ἑνὶ δακτύλῳ ἔνδον ἔψησε.",
      "glosses": [
        {
          "anchor": "ἔψησε",
          "note": "< ψάω = ἅπτομαι δακτύλῳ",
          "rank": 1
        },
        {
          "anchor": "ἦρε",
          "note": "< αἴρω = ἄνω κινέω",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Τὰ λείψανα ἑνὸς τῶν ἰσχνῶν πεδίων λαγῶν ἐν ψυχρῷ στέατι τεθαμμένα καὶ λεπτῇ κυανέῃ εὐρῶτι τεθηλότα.",
      "glosses": [
        {
          "anchor": "ἰσχνῶν",
          "note": "ἰσχνός = λεπτός ↔ παχύς",
          "rank": 1
        },
        {
          "anchor": "τεθαμμένα",
          "note": "< θάπτω = κατορύττω",
          "rank": 1
        },
        {
          "anchor": "εὐρῶτι",
          "note": "εὐρώς = σῆψις ἐπὶ ὑγρῶν",
          "rank": 1
        },
        {
          "anchor": "τεθηλότα",
          "note": "< θάλλω = αὐξάνομαι πρασίνως",
          "rank": 1
        },
        {
          "anchor": "στέατι",
          "note": "στέαρ = πῖμελη ζῴων",
          "rank": 1
        },
        {
          "anchor": "λαγῶν",
          "note": "λαγώς = θηρίον ταχὺ μακρόπουν",
          "rank": 1
        },
        {
          "anchor": "κυανέῃ",
          "note": "κυάνεος = χρῶμα θαλάσσης",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Τὸ πῶμα αὖθις ἐπὶ τὸν λέβητα ἐπέθηκε καὶ ἐν ταῖς φλοξὶν ἔθετο.",
      "glosses": [
        {
          "anchor": "φλοξὶν",
          "note": "φλόξ = πῦρ κινούμενον",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Οὐ πολύ ἀλλὰ μεταδώσομεν, ἔφη.",
      "glosses": [
        {
          "anchor": "μεταδώσομεν",
          "note": "< μεταδίδωμι = κοινῇ παρέχω",
          "rank": 1
        }
      ]
    }
  ]
}