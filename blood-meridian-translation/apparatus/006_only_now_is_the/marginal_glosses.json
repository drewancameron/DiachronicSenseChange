{
  "sentences": [
    {
      "index": 0,
      "greek": "νῦν δὴ μόνον ὁ παῖς τέλος ἀποδύεται πάντα ἃ ἦν.",
      "glosses": [
        {
          "anchor": "ἀποδύεται",
          "note": "= ἐκδύεται, ἱμάτια ἀφαιρεῖται",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "αἱ ἀρχαὶ αὐτοῦ πόρρω γεγόνασιν ὥσπερ ἡ μοῖρα αὐτοῦ καὶ οὐκέτι ἐν πάσῃ τῇ τοῦ κόσμου περιτροπῇ ἔσονται χῶραι οὕτως ἄγριαι καὶ βάρβαροι πειρᾶσαι εἰ τὸ τῆς γενέσεως πλάσμα δύναται πρὸς ἀνθρώπου βούλησιν σχηματίζεσθαι ἢ εἰ ἡ αὐτοῦ καρδία οὐχ ἕτερόν τι γένος πηλοῦ ἐστιν.",
      "glosses": [
        {
          "anchor": "σχηματίζεσθαι",
          "note": "= μορφὴν λαμβάνειν, πλάττεσθαι",
          "rank": 1
        },
        {
          "anchor": "ἄγριαι",
          "note": "= ἀνήμεροι ↔ ἥμεροι",
          "rank": 1
        },
        {
          "anchor": "περιτροπῇ",
          "note": "= κύκλῳ στροφῇ, περιόδῳ",
          "rank": 1
        },
        {
          "anchor": "βούλησιν",
          "note": "= θέλησιν, ἐπιθυμίαν",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "οἱ ἐπιβάται ὀκνηρόν τι χρῆμα.",
      "glosses": [
        {
          "anchor": "ὀκνηρόν",
          "note": "= βραδύ, ἀργόν ↔ σπουδαῖον",
          "rank": 1
        },
        {
          "anchor": "ἐπιβάται",
          "note": "= οἱ ἐν πλοίῳ πλέοντες",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "δεσμεύουσι τὰ ὄμματα καὶ οὐδεὶς ἐρωτᾷ ἄλλον τί τὸ ἄγον αὐτὸν δεῦρο.",
      "glosses": [
        {
          "anchor": "δεσμεύουσι",
          "note": "= δεσμοῖς δέουσι, κατέχουσι",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "καθεύδει ἐπὶ τοῦ καταστρώματος, προσκυνητὴς μετ' ἄλλων.",
      "glosses": [
        {
          "anchor": "προσκυνητὴς",
          "note": "= ὁ ἱερὰ χωρία ἐπισκεπτόμενος",
          "rank": 1
        },
        {
          "anchor": "καθεύδει",
          "note": "= ὑπνοῖ ↔ ἐγρήγορε",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "θεᾶται τὴν ἀμυδρὰν αἰγιαλὸν αἰρομένην καὶ πίπτουσαν.",
      "glosses": [
        {
          "anchor": "πίπτουσαν",
          "note": "< πίπτω = κάτω φερομένην",
          "rank": 1
        },
        {
          "anchor": "αἰρομένην",
          "note": "< αἴρω = ἄνω φερομένην ↔ πίπτουσαν",
          "rank": 1
        },
        {
          "anchor": "ἀμυδρὰν",
          "note": "= ἀσαφῆ, οὐ φανεράν ↔ σαφῆ",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "φαιοὶ θαλάττιοι ὄρνιθες χασκάζοντες.",
      "glosses": [
        {
          "anchor": "φαιοὶ",
          "note": "= πολιοί, οὐ λευκοὶ οὐδὲ μέλανες",
          "rank": 1
        },
        {
          "anchor": "θαλάττιοι",
          "note": "< θάλαττα = ἐν θαλάττῃ διαιτώμενοι",
          "rank": 1
        },
        {
          "anchor": "χασκάζοντες",
          "note": "= τὸ στόμα ἀνοίγοντες",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "πτήσεις πελεκάνων παρ' αἰγιαλὸν ὑπὲρ τῶν φαιῶν κυμάτων.",
      "glosses": [
        {
          "anchor": "πτήσεις",
          "note": "= τὸ πέτεσθαι, ὀρνίθων κίνησις",
          "rank": 1
        },
        {
          "anchor": "πελεκάνων",
          "note": "= μεγάλων ὑδατίων ὀρνίθων",
          "rank": 1
        },
        {
          "anchor": "φαιῶν",
          "note": "= πολιῶν, οὐ λευκῶν οὐδὲ μελάνων",
          "rank": 1
        }
      ]
    }
  ]
}