{
  "passage_id": "009_reverend_green_tent",
  "style": "Ørberg",
  "sentences": [
    {
      "index": 0,
      "greek": "Ὁ αἰδεσιμώτατος Γρῆνος πρὸς πλήρη οἶκον καθ' ἡμέραν ἐδίδασκε, ὅσον χρόνον ὁ ὑετὸς κατέπιπτε·",
      "glosses": [
        {
          "anchor": "αἰδεσιμώτατος",
          "note": "< αἰδέομαι = σεβαστός, τίμιος (ὑπερτ.) ↔ ἄτιμος"
        },
        {
          "anchor": "Γρῆνος",
          "note": "κύριον ὄνομα· Green (Ἀγγλικόν)"
        }
      ]
    },
    {
      "index": 1,
      "greek": "ὁ δὲ ὑετὸς δύο ἑβδομάδας κατέπιπτεν.",
      "glosses": [
        {
          "anchor": "ἑβδομάδας",
          "note": "< ἑπτά· = χρόνος ἑπτὰ ἡμερῶν"
        }
      ]
    },
    {
      "index": 2,
      "greek": "ὅτε ὁ παῖς εἰσέδυ εἰς τὴν ῥυπαρὰν λινῆν σκηνήν, ἦν στάσιμος τόπος παρὰ τοὺς τοίχους, χῶρος ἢ δύο, καὶ τοιαύτη ὀδμὴ βαρεῖα τῶν ὑγρῶν καὶ ἀλούτων ὥστε αὐτοὶ ἐξῄεσαν εἰς τὸν ὄμβρον ἐνίοτε πρὸς καθαρὸν ἀέρα πρὶν ὁ ὑετὸς αὐτοὺς εἴσω πάλιν ἤλαυνεν.",
      "glosses": [
        {
          "anchor": "ῥυπαρὰν",
          "note": "< ῥύπος = μιαρά, βρωμώδης ↔ καθαρά"
        },
        {
          "anchor": "στάσιμος",
          "note": "< ἵστημι· = τόπος εἰς στάσιν (οὐχὶ καθέδρας)"
        },
        {
          "anchor": "ὀδμὴ",
          "note": "= εὐωδία ἢ δυσωδία· ἐνταῦθα βρῶμος ↔ ἄοσμον"
        }
      ]
    },
    {
      "index": 3,
      "greek": "ἔστη μετὰ ἄλλων τοῦ αὐτοῦ γένους παρὰ τὸν ὄπισθεν τοῖχον.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "τὸ μόνον ὃ ἂν διέκρινεν αὐτὸν ἐν ἐκείνῳ τῷ ὄχλῳ ἦν ὅτι οὐκ ἦν ὡπλισμένος.",
      "glosses": [
        {
          "anchor": "ὡπλισμένος",
          "note": "< ὅπλον (παρακ. μτχ. παθ.)· = ἔχων ὅπλα μάχης ↔ ἄοπλος"
        }
      ]
    },
    {
      "index": 5,
      "greek": "Γείτονες, ἔφη ὁ αἰδεσιμώτατος, οὐκ ἠδύνατο ἔξω μένειν τούτων τῶν *γεέννης, *γεέννης, *γεεννοτόπων ἐνθάδε αὐτῶν ἐν Νακογδόχῃ.",
      "glosses": [
        {
          "anchor": "γεέννης",
          "note": "ἡ γέεννα (Ἑβρ.)· = τόπος κολάσεως, ᾅδης (Ματθ.)"
        },
        {
          "anchor": "γεεννοτόπων",
          "note": "γέεννα·τόπος · = χῶροι κακίας, πορνεῖα"
        },
        {
          "anchor": "Νακογδόχῃ",
          "note": "κύριον ὄνομα πόλεως (Ἀμερικανῆς)"
        }
      ]
    },
    {
      "index": 6,
      "greek": "εἶπον αὐτῷ, εἶπον·",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "ἄξεις τὸν υἱὸν τοῦ θεοῦ ἐκεῖ μεθ' ἑαυτοῦ;",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "καὶ εἶπεν·",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "ὦ οὔ.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "οὔ, οὐκ ἄξω.",
      "glosses": [
        {
          "anchor": "ἄξω",
          "note": "< ἄγω (μέλλ.)· = ὁδηγήσω, συμπαραλήψομαι"
        }
      ]
    },
    {
      "index": 11,
      "greek": "καὶ εἶπον·",
      "glosses": []
    },
    {
      "index": 12,
      "greek": "οὐκ οἶσθα ὅτι εἶπεν ἀκολουθήσω σοι ἀεὶ καὶ μέχρι τοῦ τέλους τῆς ὁδοῦ;",
      "glosses": [
        {
          "anchor": "ἀεὶ",
          "note": "= πάντοτε, διὰ παντός ↔ οὐδέποτε"
        }
      ]
    },
    {
      "index": 13,
      "greek": "εὖ, εἶπεν, οὐκ αἰτῶ οὐδένα πορεύεσθαι οὐδαμοῦ.",
      "glosses": []
    },
    {
      "index": 14,
      "greek": "καὶ εἶπον·",
      "glosses": []
    },
    {
      "index": 15,
      "greek": "γεῖτον, οὐ δεῖ σε αἰτεῖν.",
      "glosses": []
    },
    {
      "index": 16,
      "greek": "πορεύσεται ἐκεῖ μετὰ σοῦ πᾶν βῆμα τῆς ὁδοῦ εἴτε αἰτεῖς εἴτε μή.",
      "glosses": [
        {
          "anchor": "εἴτε",
          "note": "= ἐάν... ἐάν, ἢ... ἢ (διζευκτικόν)"
        }
      ]
    },
    {
      "index": 17,
      "greek": "εἶπον·",
      "glosses": []
    },
    {
      "index": 18,
      "greek": "γεῖτον, οὐ δύνασαι ἀπαλλαγῆναι αὐτοῦ.",
      "glosses": []
    },
    {
      "index": 19,
      "greek": "νῦν.",
      "glosses": []
    },
    {
      "index": 20,
      "greek": "ἕλξεις αὐτόν, αὐτόν, εἰς ἐκεῖνον τὸν *γεεννότοπον ἐκεῖ;",
      "glosses": [
        {
          "anchor": "γεεννότοπον",
          "note": "γέεννα·τόπος · = χῶρος κακίας καὶ κολάσεως"
        }
      ]
    }
  ]
}