{
  "sentences": [
    {
      "index": 0,
      "greek": "Τί;",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "εἶπεν ὁ παῖς.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "Εἶπον εἰ παύῃ;",
      "glosses": [
        {
          "anchor": "παύῃ",
          "note": "< παύω = λήγω, παύομαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Παύομαι;",
      "glosses": [
        {
          "anchor": "Παύομαι",
          "note": "< παύω = λήγω",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Παύῃ.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Εἰ γὰρ ἔτι τι ἐμοῦ βούλει πάνυ δὴ ἕξεις.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Ἔβλεψεν εἰς τὸν οὐρανόν.",
      "glosses": [
        {
          "anchor": "Ἔβλεψεν",
          "note": "< βλέπω = ὁράω",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Μάλα ὑψοῦ, μάλα μικρός, γύψ.",
      "glosses": [
        {
          "anchor": "γύψ",
          "note": "= μέγας ὄρνις",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Ἔβλεψεν τὸν ἄνθρωπον.",
      "glosses": [
        {
          "anchor": "Ἔβλεψεν",
          "note": "< βλέπω = ὁράω",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Ἦ κατέαγέ μου ὁ αὐχήν;",
      "glosses": [
        {
          "anchor": "κατέαγέ",
          "note": "< κατάγνυμι = συντρίβω",
          "rank": 1
        },
        {
          "anchor": "αὐχήν",
          "note": "= τράχηλος",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "εἶπεν.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "Ὁ ἀνὴρ περιέβλεψεν τὸν χῶρον καὶ ἔπτυσεν καὶ ἔβλεψεν τὸν παῖδα πάλιν.",
      "glosses": [
        {
          "anchor": "περιέβλεψεν",
          "note": "περι·βλέπω = πάντῃ σκοπέω",
          "rank": 1
        },
        {
          "anchor": "ἔπτυσεν",
          "note": "< πτύω = σίαλον ἐκβάλλω",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Οὐ δύνασαι ἀναστῆναι;",
      "glosses": []
    },
    {
      "index": 13,
      "greek": "Οὐκ οἶδα.",
      "glosses": []
    },
    {
      "index": 14,
      "greek": "Οὔπω ἐπειράθην.",
      "glosses": [
        {
          "anchor": "ἐπειράθην",
          "note": "< πειράω = δοκιμάζω, πεῖραν λαμβάνω",
          "rank": 1
        }
      ]
    },
    {
      "index": 15,
      "greek": "Οὔποτε ἤθελον καταγνύναι σου τὸν αὐχένα.",
      "glosses": [
        {
          "anchor": "καταγνύναι",
          "note": "κατα·γνύω = συντρίβω",
          "rank": 1
        },
        {
          "anchor": "Οὔποτε",
          "note": "οὐ·ποτε = οὐδέποτε",
          "rank": 1
        }
      ]
    },
    {
      "index": 16,
      "greek": "Οὔ.",
      "glosses": []
    },
    {
      "index": 17,
      "greek": "Ἤθελον ἀποκτεῖναι σε.",
      "glosses": []
    },
    {
      "index": 18,
      "greek": "Οὐδείς πω τοῦτο πεποίηκεν.",
      "glosses": []
    },
    {
      "index": 19,
      "greek": "Ἔδρυψε τὸν πηλὸν καὶ ἑαυτὸν ἦρεν.",
      "glosses": [
        {
          "anchor": "Ἔδρυψε",
          "note": "< δρύπτω = κνάω, ξύω",
          "rank": 1
        }
      ]
    },
    {
      "index": 20,
      "greek": "Ὁ ἀνὴρ ἐκάθητο ἐπὶ τῶν σανίδων τὰς ἐμβάδας παρ' αὑτῷ ἔχων.",
      "glosses": [
        {
          "anchor": "ἐμβάδας",
          "note": "ἐμβάς, -άδος = ὑπόδημα",
          "rank": 1
        },
        {
          "anchor": "σανίδων",
          "note": "σανίς, -ίδος = ξύλινον δάπεδον",
          "rank": 1
        }
      ]
    },
    {
      "index": 21,
      "greek": "Οὐδέν σοί ἐστι κακόν, εἶπεν.",
      "glosses": []
    }
  ]
}