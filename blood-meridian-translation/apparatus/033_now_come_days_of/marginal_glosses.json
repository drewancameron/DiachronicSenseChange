{
  "sentences": [
    {
      "index": 0,
      "greek": "Νῦν ἔρχονται ἡμέραι πτωχείας, ἡμέραι κλοπῆς.",
      "glosses": [
        {
          "anchor": "πτωχείας",
          "note": "= πενίας ↔ πλούτου",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ἡμέραι ἱππασίας ὅπου οὐδεὶς ἵππευσε πλὴν αὐτοῦ.",
      "glosses": [
        {
          "anchor": "ἵππευσε",
          "note": "< ἵππος = ἐφ' ἵππου ἐπορεύθη",
          "rank": 1
        },
        {
          "anchor": "ἱππασίας",
          "note": "< ἵππος = τοῦ ἱππεύειν",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Καταλέλοιπε τὴν πευκώδη χώραν καὶ ὁ ἑσπέριος ἥλιος καταδύεται πρὸ αὐτοῦ πέραν ἀπεράντου κοίλης καὶ σκότος πίπτει ὧδε ὥσπερ βροντὴ καὶ ψυχρὸς ἄνεμος τὰς βοτάνας εἰς τρυγμὸν καθίστησιν.",
      "glosses": [
        {
          "anchor": "πευκώδη",
          "note": "< πεύκη = πεύκας ἔχουσα",
          "rank": 1
        },
        {
          "anchor": "ἀπεράντου",
          "note": "= ἀτελευτήτου, μεγάλου ↔ πεπερασμένου",
          "rank": 1
        },
        {
          "anchor": "τρυγμὸν",
          "note": "= καρπῶν συλλογήν",
          "rank": 1
        },
        {
          "anchor": "βοτάνας",
          "note": "= φυτὰ τὰ βοσκόμενα",
          "rank": 1
        },
        {
          "anchor": "καταδύεται",
          "note": "= κάτω δύνει",
          "rank": 1
        },
        {
          "anchor": "Καταλέλοιπε",
          "note": "= ἀπολέλοιπε, κατέλιπε",
          "rank": 1
        },
        {
          "anchor": "ἑσπέριος",
          "note": "= δυτικός, ἑσπερινός ↔ ἠῷος",
          "rank": 1
        },
        {
          "anchor": "βροντὴ",
          "note": "= ψόφος ἐκ νεφῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ὁ νύκτιος οὐρανὸς οὕτως ἀστέρων πεπλήρωται ὥστε ὀλίγος τόπος μέλανος εἶναι καὶ πίπτουσι πᾶσαν νύκτα ἐν πικραῖς ἁψῖσι καὶ οὕτως ἐστὶν ὥστε ὁ ἀριθμὸς αὐτῶν οὐκ ἐλάττων.",
      "glosses": [
        {
          "anchor": "νύκτιος",
          "note": "< νύξ = τῆς νυκτὸς ↔ ἡμερινός",
          "rank": 1
        },
        {
          "anchor": "πικραῖς",
          "note": "= ὀξείαις, δριμείαις ↔ γλυκείαις",
          "rank": 1
        },
        {
          "anchor": "ἁψῖσι",
          "note": "= ἀκτῖσι φωτός",
          "rank": 1
        },
        {
          "anchor": "πίπτουσι",
          "note": "= κάτω φέρονται",
          "rank": 1
        },
        {
          "anchor": "πεπλήρωται",
          "note": "< πληρόω = πλήρης γέγονε",
          "rank": 1
        }
      ]
    }
  ]
}