{
  "sentences": [
    {
      "index": 0,
      "greek": "Οἱ ὀρχησταὶ ἀπεληλύθεσαν, ἡ μουσική.",
      "glosses": [
        {
          "anchor": "ὀρχησταὶ",
          "note": "< ὀρχέομαι = οἱ ὀρχούμενοι",
          "rank": 1
        },
        {
          "anchor": "ἀπεληλύθεσαν",
          "note": "< ἀπέρχομαι = ᾤχοντο",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Πέραν τῆς ὁδοῦ ἐκάθητό τις ἐπὶ βάθρου ἀμυδρῶς φωτιζόμενος ἐκ τοῦ φωτὸς τῆς θύρας τοῦ καπηλείου.",
      "glosses": [
        {
          "anchor": "ἀμυδρῶς",
          "note": "= οὐ σαφῶς, ἀσθενῶς ↔ λαμπρῶς",
          "rank": 1
        },
        {
          "anchor": "φωτιζόμενος",
          "note": "< φῶς = φῶς λαμβάνων",
          "rank": 1
        },
        {
          "anchor": "βάθρου",
          "note": "= καθέδρα λιθίνη, ἕδρα",
          "rank": 1
        },
        {
          "anchor": "καπηλείου",
          "note": "= τόπος ἔνθα πωλεῖται οἶνος",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ ἡμίονος εἱστήκει ὅπου αὐτὸν ἔδησεν.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Ἔκρουσε τῷ σαρώθρῳ ἐπὶ τοῖς βαθμοῖς καὶ πάλιν εἰσῆλθε καὶ τὸ σάρωθρον πρὸς τὴν γωνίαν ἤνεγκεν ὅθεν ὁ κάπηλος αὐτὸ εἰλήφει.",
      "glosses": [
        {
          "anchor": "σαρώθρῳ",
          "note": "= σκοῦπα, ἐργαλεῖον καθαίρειν",
          "rank": 1
        },
        {
          "anchor": "βαθμοῖς",
          "note": "= βασίλεια, κλίμακες πρὸ θυρῶν",
          "rank": 1
        },
        {
          "anchor": "σάρωθρον",
          "note": "= σκοῦπα, ἐργαλεῖον καθαίρειν",
          "rank": 1
        },
        {
          "anchor": "Ἔκρουσε",
          "note": "= ἔτυψε, ἐπάταξε",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "= ὁ οἶνον πωλῶν",
          "rank": 1
        },
        {
          "anchor": "γωνίαν",
          "note": "= τόπος ἔνθα δύο τοῖχοι συμβάλλουσι",
          "rank": 1
        },
        {
          "anchor": "εἰλήφει",
          "note": "< λαμβάνω = ἐλήφει πρότερον",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Εἶτα πρὸς τὸ καπηλεῖον ἦλθε καὶ ἔστη.",
      "glosses": [
        {
          "anchor": "καπηλεῖον",
          "note": "= τόπος ἔνθα πωλεῖται οἶνος",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ὁ κάπηλος αὐτὸν παρεῖδεν.",
      "glosses": [
        {
          "anchor": "παρεῖδεν",
          "note": "= παρώρα, οὐχὶ προσέσχε",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "= ὁ οἶνον πωλῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ὁ παῖς τοῖς κονδύλοις ἔκρουσεν.",
      "glosses": [
        {
          "anchor": "κονδύλοις",
          "note": "= ἄρθρα δακτύλων συγκεκαμμένων",
          "rank": 1
        },
        {
          "anchor": "ἔκρουσεν",
          "note": "= ἔτυψε, ἐπάταξε",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ὁ κάπηλος ἐπεστράφη καὶ τὴν χεῖρα ἐπὶ τὸ ἰσχίον ἔθηκε καὶ τὰ χείλη συνέσπασεν.",
      "glosses": [
        {
          "anchor": "συνέσπασεν",
          "note": "= συνήγαγε, συνεστάλη",
          "rank": 1
        },
        {
          "anchor": "ἰσχίον",
          "note": "= ἰσχύς, μέρος σώματος ἔνθα κόξ",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "= ὁ οἶνον πωλῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Τί δὲ τὸ ποτὸν νῦν;",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "εἶπεν ὁ παῖς.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "Ὁ κάπηλος εἱστήκει.",
      "glosses": [
        {
          "anchor": "κάπηλος",
          "note": "= ὁ οἶνον πωλῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Ὁ παῖς τὰς κινήσεις τοῦ πίνειν ἐποίησεν ἃς ὁ γέρων πεποιήκει καὶ ὁ κάπηλος τὸ χειρόμακτρον ἀργῶς πρὸς αὐτὸν ἔσεισεν.",
      "glosses": [
        {
          "anchor": "πεποιήκει",
          "note": "< ποιέω = ἐπεποιήκει πρότερον",
          "rank": 1
        },
        {
          "anchor": "χειρόμακτρον",
          "note": "χειρ·ὸς μάκτρον = πανίον ἀπομάσσειν",
          "rank": 1
        },
        {
          "anchor": "ἔσεισεν",
          "note": "= ἐκίνησε τάχα καὶ μικρά",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "= ὁ οἶνον πωλῶν",
          "rank": 1
        }
      ]
    }
  ]
}