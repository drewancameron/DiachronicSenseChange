{
  "sentences": [
    {
      "index": 0,
      "greek": "Κατέβη ὁδὸν στενὴν ψαμμώδη καὶ πορευόμενος συνήντησεν ἅμαξαν νεκρῶν ἐξιοῦσαν φορτίον νεκρῶν ἄγουσαν, κώδων μικρὸς κρούων τὴν ὁδὸν καὶ λύχνος σαλευόμενος ἐκ τῆς πύλης.",
      "glosses": [
        {
          "anchor": "ψαμμώδη",
          "note": "< ψάμμος = ψάμμου πλήρης",
          "rank": 1
        },
        {
          "anchor": "ἐξιοῦσαν",
          "note": "< ἔξειμι = ἐκπορευομένη",
          "rank": 1
        },
        {
          "anchor": "κώδων",
          "note": "= χαλκοῦς ἦχος ποιῶν",
          "rank": 1
        },
        {
          "anchor": "σαλευόμενος",
          "note": "< σαλεύω = κινούμενος",
          "rank": 1
        },
        {
          "anchor": "κρούων",
          "note": "< κρούω = τύπτων",
          "rank": 1
        },
        {
          "anchor": "στενὴν",
          "note": "= οὐ πλατεῖα ↔ εὐρεῖα",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Τρεῖς ἄνδρες ἐπὶ τοῦ δίφρου ἐκάθηντο οὐχ ἑτεροῖοι αὐτῶν τῶν νεκρῶν ἢ νεκυδαίμονες οὕτω λευκοὶ τιτάνῳ καὶ σχεδὸν φωσφόροι ἐν τῷ κνέφει.",
      "glosses": [
        {
          "anchor": "ἑτεροῖοι",
          "note": "= διάφοροι ↔ ὅμοιοι",
          "rank": 1
        },
        {
          "anchor": "νεκυδαίμονες",
          "note": "νεκρο·δαίμονες = νεκροῖς ὅμοιοι",
          "rank": 1
        },
        {
          "anchor": "τιτάνῳ",
          "note": "= λευκὴ γῆ πρὸς χρῶσιν",
          "rank": 1
        },
        {
          "anchor": "φωσφόροι",
          "note": "φῶς·φόροι = φῶς φέροντες",
          "rank": 1
        },
        {
          "anchor": "κνέφει",
          "note": "= σκότος ↔ φῶς",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ζεῦγος ἵππων εἷλκε τὴν ἅμαξαν καὶ ἀνῆλθον τὴν ὁδὸν ἐν ἀμυδρῷ μιάσματι καὶ ἀπῆλθον ἐξ ὄψεως.",
      "glosses": [
        {
          "anchor": "ἀμυδρῷ",
          "note": "= ἀσαφεῖ ↔ σαφεῖ",
          "rank": 1
        },
        {
          "anchor": "μιάσματι",
          "note": "< μιαίνω = μολυσμός",
          "rank": 1
        },
        {
          "anchor": "ἀνῆλθον",
          "note": "< ἀνέρχομαι = ἄνω ἐπορεύθησαν",
          "rank": 1
        },
        {
          "anchor": "εἷλκε",
          "note": "< ἕλκω = ἦγε",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Στραφεὶς ἐθεᾶτο αὐτοὺς ἀπιόντας.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Οἱ γυμνοὶ πόδες τῶν νεκρῶν ἐσείοντο σκληρῶς ἐπὶ τὰ πλάγια.",
      "glosses": [
        {
          "anchor": "ἐσείοντο",
          "note": "< σείω = ἐκινοῦντο",
          "rank": 1
        },
        {
          "anchor": "σκληρῶς",
          "note": "< σκληρός = βιαίως",
          "rank": 1
        },
        {
          "anchor": "πλάγια",
          "note": "= εἰς τὰ πλευρά",
          "rank": 1
        }
      ]
    }
  ]
}