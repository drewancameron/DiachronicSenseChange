{
  "sentences": [
    {
      "index": 0,
      "greek": "Μεσούσης ἡμέρας πάλιν ἐπὶ τοῦ πεδίου ἦν καὶ ἡ κόνις πρὸς βορρᾶν παρὰ τὸ πέρας τῆς γῆς ἐτέτατο.",
      "glosses": [
        {
          "anchor": "ἐτέτατο",
          "note": "< τείνω = διετέτατο, ἐξετέτατο",
          "rank": 1
        },
        {
          "anchor": "κόνις",
          "note": "= χοῦς λεπτὸς ἐν ἀέρι αἰρόμενος",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ἑσπέρας τὰ πρῶτα βοῶν ἀγέλης εἰς ὄψιν ἦλθε.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "Θηρία μακρὰ καὶ ἄγρια κέρασι μεγάλοις.",
      "glosses": [
        {
          "anchor": "κέρασι",
          "note": "< κέρας = ὀστέα ἐκ κεφαλῆς θηρίων",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἐκείνῃ τῇ νυκτὶ ἐν τῇ αὐλῇ τῶν νομέων ἐκάθητο καὶ κυάμους καὶ ἄρτον ἤσθιε καὶ περὶ βίου ἐν ὁδῷ ἤκουε.",
      "glosses": [
        {
          "anchor": "νομέων",
          "note": "< νομεύς = οἱ βοσκήματα νέμοντες",
          "rank": 1
        },
        {
          "anchor": "κυάμους",
          "note": "καρποὶ φυτῶν βρώσιμοι",
          "rank": 1
        },
        {
          "anchor": "ἤσθιε",
          "note": "< ἐσθίω = κατήσθιεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ἀπὸ Ἀβιληνῆς κατέβαινον, τεσσαράκοντα ἡμέρας ὁδόν, πρὸς ἀγορὰς ἐν Λουισιάνῃ.",
      "glosses": [
        {
          "anchor": "Ἀβιληνῆς",
          "note": "πόλις ἐν Τεξάνῃ",
          "rank": 1
        },
        {
          "anchor": "Λουισιάνῃ",
          "note": "χώρα παρὰ τὸν Μεξικανὸν κόλπον",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Εἵποντο λύκων ἀγέλαι, θῶες, βάρβαροι.",
      "glosses": [
        {
          "anchor": "θῶες",
          "note": "= θῆρες ἄγριοι τετράποδες κυνώδεις",
          "rank": 1
        },
        {
          "anchor": "ἀγέλαι",
          "note": "= σύνοδοι ζῴων ὁμοίων",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Βόες περὶ αὐτοὺς σταδίους πολλοὺς ἐν τῷ σκότει ἐμυκῶντο.",
      "glosses": [
        {
          "anchor": "ἐμυκῶντο",
          "note": "< μυκάομαι = φωνὴν ἀφίεσαν ὡς βόες",
          "rank": 1
        }
      ]
    }
  ]
}