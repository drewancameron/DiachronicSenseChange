{
  "sentences": [
    {
      "index": 0,
      "greek": "Τοῦτο τέτμηται, εἶπέ τις τῶν ἀνδρῶν τῶν ἑστώτων παρὰ τὴν ὁδὸν θεωμένων.",
      "glosses": [
        {
          "anchor": "τέτμηται",
          "note": "< τέμνω = κεκομμένον ἐστί",
          "rank": 1
        },
        {
          "anchor": "ἑστώτων",
          "note": "< ἵστημι = τῶν στηκότων",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Κτεῖνε κτεῖνε ἐσίαλε ὁ ἀνὴρ διαβαίνων πρόσω.",
      "glosses": [
        {
          "anchor": "ἐσίαλε",
          "note": "< σίαλον = πτύειν ἔποιει",
          "rank": 1
        },
        {
          "anchor": "διαβαίνων",
          "note": "< διαβαίνω = πορευόμενος διά",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ἀλλά τις ἄλλος κατήιει διὰ τοῦ χωρίου, μεγάλους βεβαίους ῥοιβδήσεως ψόφους ποιῶν ὥσπερ βοῦς.",
      "glosses": [
        {
          "anchor": "κατήιει",
          "note": "< κάτειμι = κάτω ἤρχετο",
          "rank": 1
        },
        {
          "anchor": "ῥοιβδήσεως",
          "note": "= ἰσχυροῦ κτύπου γενικὴ πτῶσις",
          "rank": 1
        },
        {
          "anchor": "ψόφους",
          "note": "= κτύπων ἤχους",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἔφερε μέγιστον ῥόπαλον.",
      "glosses": [
        {
          "anchor": "ῥόπαλον",
          "note": "= ξύλον μαχίμου παχύ",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Πρὸς τὸν παῖδα πρῶτον ἀφίκετο καὶ ὅτε ἔπαισε τῷ ξύλῳ ὁ παῖς κατέπεσεν ἐπὶ πρόσωπον εἰς τὸν πηλόν.",
      "glosses": [
        {
          "anchor": "κατέπεσεν",
          "note": "< καταπίπτω = χαμαὶ ἔπεσεν",
          "rank": 1
        },
        {
          "anchor": "ἔπαισε",
          "note": "< παίω = ἐκτύπησεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Τέθνηκεν ἂν εἰ μή τις αὐτὸν ὑπέστρεψεν.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Ὅτε ἠγέρθη ἡμέρα ἦν καὶ ὁ ὄμβρος πέπαυτο καὶ ἀνέβλεπεν εἰς πρόσωπον ἀνδρὸς μακρὰς τρίχας ἔχοντος ὃς ὅλος πηλῷ κεκάλυπτο.",
      "glosses": [
        {
          "anchor": "πέπαυτο",
          "note": "< παύω = λήγειν ἐπεποιήκει",
          "rank": 1
        },
        {
          "anchor": "ἀνέβλεπεν",
          "note": "< ἀναβλέπω = ἄνω τοὺς ὀφθαλμοὺς ἔτρεπεν",
          "rank": 1
        },
        {
          "anchor": "κεκάλυπτο",
          "note": "< καλύπτω = κρυπτὸς ἐγεγόνει",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ὁ ἀνὴρ ἔλεγέ τι αὐτῷ.",
      "glosses": []
    }
  ]
}