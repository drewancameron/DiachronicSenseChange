{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὁ κυβερνήτης δωμάτιον εἶχεν ἐν πανδοκείῳ τινὶ ἐπὶ πλατείᾳ, οὗ δένδρα ἦν καὶ μικρὰ χλωρὰ σκηνὴ σὺν βάθροις.",
      "glosses": [
        {
          "anchor": "κυβερνήτης",
          "note": "= captain",
          "rank": 1
        },
        {
          "anchor": "πλατείᾳ",
          "note": "= plaza",
          "rank": 1
        },
        {
          "anchor": "δένδρα",
          "note": "= trees",
          "rank": 1
        },
        {
          "anchor": "μικρὰ",
          "note": "= small ↔ μέγας",
          "rank": 1
        },
        {
          "anchor": "χλωρὰ",
          "note": "= green ↔ αὖος",
          "rank": 1
        },
        {
          "anchor": "σκηνὴ",
          "note": "= gazebo ↔ χορός",
          "rank": 1
        },
        {
          "anchor": "βάθροις",
          "note": "= pedestals or bases",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Σιδηρᾶ πύλη πρὸ τοῦ πανδοκείου ἀνέῳγεν εἰς δίοδον, αὐλὴ δ' ἦν κατόπιν.",
      "glosses": [
        {
          "anchor": "ἀνέῳγεν",
          "note": "= opened",
          "rank": 1
        },
        {
          "anchor": "δίοδον",
          "note": "= passageway",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Τὰ τείχη κεκονιαμένα, μικραῖς τε κεραμίσι ποικίλαις κεκοσμημένα.",
      "glosses": [
        {
          "anchor": "κεραμίσι",
          "note": "= tiles",
          "rank": 1
        },
        {
          "anchor": "κεκονιαμένα",
          "note": "= adorned or decorated",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ὁ τοῦ κυβερνήτου ὑπηρέτης ἐμβάδας γλυπτὰς ἐφόρει, πτέρναις ὑψηλαῖς, αἳ καλῶς ἤχουν ἐπί τε κεραμίσι καὶ ἀναβαθμοῖς ἐκ τῆς αὐλῆς πρὸς τἄνω οἰκήματα ἀνιοῦσιν.",
      "glosses": [
        {
          "anchor": "ἐμβάδας",
          "note": "= boots",
          "rank": 1
        },
        {
          "anchor": "πτέρναις",
          "note": "= heels",
          "rank": 1
        },
        {
          "anchor": "ἀναβαθμοῖς",
          "note": "= stairs",
          "rank": 1
        },
        {
          "anchor": "ἀναβαθμοῖς",
          "note": "= ascending",
          "rank": 1
        },
        {
          "anchor": "ὑπηρέτης",
          "note": "= servant or attendant",
          "rank": 1
        },
        {
          "anchor": "γλυπτὰς",
          "note": "= carved or sculptured",
          "rank": 1
        },
        {
          "anchor": "ἀνιοῦσιν",
          "note": "= they go up",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ἐν τῇ αὐλῇ χλωρὰ φυτὰ ἐφύετο, νεωστὶ ἠρδευμένα καὶ ἀτμίζοντα.",
      "glosses": [
        {
          "anchor": "ἠρδευμένα",
          "note": "= watered",
          "rank": 1
        },
        {
          "anchor": "ἀτμίζοντα",
          "note": "= steaming",
          "rank": 1
        },
        {
          "anchor": "ἐφύετο",
          "note": "= grew or was produced",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ὁ τοῦ κυβερνήτου ἄνθρωπος κατὰ τὴν μακρὰν στοὰν ἐβάδιζε καὶ ὀξέως ἔκοψε τὴν ἐπὶ τέλει θύραν.",
      "glosses": [
        {
          "anchor": "μακρὰν",
          "note": "= long ↔ βραχύς",
          "rank": 1
        },
        {
          "anchor": "ἄνθρωπος",
          "note": "= human or person",
          "rank": 1
        },
        {
          "anchor": "ἐβάδιζε",
          "note": "= walked or marched",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Φωνή τις αὐτοὺς εἰσιέναι ἐκέλευσεν.",
      "glosses": [
        {
          "anchor": "ἐκέλευσεν",
          "note": "= commanded or ordered",
          "rank": 1
        }
      ]
    }
  ]
}