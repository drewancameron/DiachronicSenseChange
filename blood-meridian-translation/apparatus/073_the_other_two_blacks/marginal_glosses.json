{
  "sentences": [
    {
      "index": 0,
      "greek": "Οἱ δύο ἄλλοι μέλανες ἐγέλασαν.",
      "glosses": [
        {
          "anchor": "ἐγέλασαν",
          "note": "< γελάω = γέλωτα ἐποιήσαντο",
          "rank": 1
        },
        {
          "anchor": "μέλανες",
          "note": "= οὐ λευκοί ↔ λευκοί",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ὁ παῖς κάτω κατὰ τὸν ποταμὸν ἀπέβλεψεν.",
      "glosses": [
        {
          "anchor": "ἀπέβλεψεν",
          "note": "< ἀποβλέπω = βλέμμα ἀπέστρεψεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ἔπτυσεν καὶ κατὰ τὴν ἀτραπὸν διὰ τῶν ἰτιῶν καὶ τῶν ἑλῶν τῆς πόας ἀπῆλθεν.",
      "glosses": [
        {
          "anchor": "ἰτιῶν",
          "note": "ἰτέα = δένδρον παρὰ ποταμοῖς",
          "rank": 1
        },
        {
          "anchor": "Ἔπτυσεν",
          "note": "< πτύω = ἐκ στόματος ἐξέβαλεν",
          "rank": 1
        },
        {
          "anchor": "πόας",
          "note": "= χλόη τῇ γῇ ἐμφυομένη",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Εὗρεν αὐτὸ ὡσεὶ ἑκατὸν ὀργυιὰς κάτω τοῦ ποταμοῦ.",
      "glosses": [
        {
          "anchor": "ὀργυιὰς",
          "note": "= μέτρον ἓξ ποδῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ὑγρὸν ἦν μέχρι τῆς γαστρὸς καὶ πρὸς αὐτὸν ἀνέβλεψεν καὶ εἶτα τὴν κεφαλὴν πάλιν εἰς τὴν πίειραν ποταμίαν πόαν κατέθηκεν.",
      "glosses": [
        {
          "anchor": "ποταμίαν",
          "note": "< ποταμός = παρὰ ποταμὸν οὖσα",
          "rank": 1
        },
        {
          "anchor": "πίειραν",
          "note": "= παχεῖαν, πολλήν ↔ λεπτή",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Τὸν ἐφίππιον κατέβαλεν καὶ τὸ ἑλκόμενον σχοινίον ἀνέλαβεν καὶ τὸ ζῷον πρὸς κλάδον ἔδησεν καὶ αὐτὸ ἡμιθελῶς ἐλάκτισεν.",
      "glosses": [
        {
          "anchor": "ἐφίππιον",
          "note": "< ἵππος = ἐπὶ ἵππου τιθέμενον",
          "rank": 1
        },
        {
          "anchor": "ἡμιθελῶς",
          "note": "< ἥμισυς + θέλω = οὐ παντελῶς",
          "rank": 1
        },
        {
          "anchor": "ἐλάκτισεν",
          "note": "< λακτίζω = ποσὶν ἔπαισεν",
          "rank": 1
        },
        {
          "anchor": "κατέβαλεν",
          "note": "< καταβάλλω = κάτω ἔρριψεν",
          "rank": 1
        },
        {
          "anchor": "κλάδον",
          "note": "= μέρος δένδρου φύλλα φέρον",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ὀλίγον εἰς τὸ πλάγιον μετέστη καὶ νέμεσθαι διετέλει.",
      "glosses": [
        {
          "anchor": "πλάγιον",
          "note": "= οὐκ εὐθύ, παρὰ τὸ πλέον",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ἐπὶ τῆς κεφαλῆς ἥψατο ἀλλὰ τὸν μαινόμενον πέτασον που ἀπολωλέκει.",
      "glosses": [
        {
          "anchor": "ἀπολωλέκει",
          "note": "< ἀπόλλυμι = οὐκέτι εὑρίσκει",
          "rank": 1
        },
        {
          "anchor": "πέτασον",
          "note": "= πλατὺς πῖλος κεφαλῆς χάριν",
          "rank": 1
        },
        {
          "anchor": "μαινόμενον",
          "note": "< μαίνομαι = οὐ σωφρονοῦντα",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Διὰ τῶν δένδρων κατῆλθεν καὶ τὰ ψυχρὰ ῥεόμενα ὕδατα βλέπων ἔστη.",
      "glosses": [
        {
          "anchor": "ῥεόμενα",
          "note": "< ῥέω = ὅσα ὑδάτων δίκην κινεῖται",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Εἶτα εἰς τὸν ποταμὸν ὡς παντελῶς ἄθλιός τις βαπτιζόμενος ἐνέβη.",
      "glosses": [
        {
          "anchor": "βαπτιζόμενος",
          "note": "< βάπτω = εἰς ὕδωρ δυόμενος",
          "rank": 1
        },
        {
          "anchor": "ἄθλιός",
          "note": "= ταλαίπωρος, κακοδαίμων ↔ εὐδαίμων",
          "rank": 1
        },
        {
          "anchor": "ἐνέβη",
          "note": "< ἐμβαίνω = εἰσῆλθεν, ἐσέβη",
          "rank": 1
        }
      ]
    }
  ]
}