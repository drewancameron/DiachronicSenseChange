{
  "sentences": [
    {
      "index": 0,
      "greek": "ἀποβαίνουσιν ἐπὶ πορθμείου, ἄποικοι σὺν τοῖς κτήμασιν, πάντες σκοποῦντες τὴν χαμηλὴν ἀκτήν, τὸν λεπτὸν μυχὸν ψάμμου καὶ πίτυς ἀγρίας ἐν τῇ ἀχλύι νηχομένας.",
      "glosses": [
        {
          "anchor": "πορθμείου",
          "note": "= πλοίου διὰ πόρου ἄγοντος",
          "rank": 1
        },
        {
          "anchor": "χαμηλὴν",
          "note": "= ταπεινήν ↔ ὑψηλή",
          "rank": 1
        },
        {
          "anchor": "ἀχλύι",
          "note": "= ὁμίχλῃ, νεφέλῃ λεπτῇ",
          "rank": 1
        },
        {
          "anchor": "ἀποβαίνουσιν",
          "note": "= ἀπὸ πλοίου καταβαίνουσιν",
          "rank": 1
        },
        {
          "anchor": "νηχομένας",
          "note": "< νήχω = ἐν ὕδατι πλεούσας",
          "rank": 1
        },
        {
          "anchor": "ἀγρίας",
          "note": "= ἀκαλλιεργήτου ↔ ἥμερος",
          "rank": 1
        },
        {
          "anchor": "κτήμασιν",
          "note": "= οὐσίᾳ, χρήμασιν",
          "rank": 1
        },
        {
          "anchor": "σκοποῦντες",
          "note": "= βλέποντες, θεώμενοι",
          "rank": 1
        },
        {
          "anchor": "μυχὸν",
          "note": "= τόπον κρυπτόν, ἔσχατον",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "βαδίζει διὰ τῶν στενῶν ὁδῶν τοῦ λιμένος.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "ὁ ἀὴρ ὄζει ἁλὸς καὶ ξύλου νεοπρίστου.",
      "glosses": [
        {
          "anchor": "νεοπρίστου",
          "note": "< πρίω = νεωστὶ πεπρισμένου",
          "rank": 1
        },
        {
          "anchor": "ὄζει",
          "note": "= ὀσμὴν παρέχει",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "νυκτὸς αἱ πόρναι καλοῦσιν αὐτὸν ἐκ τοῦ σκότους ὥσπερ ψυχαὶ ἐνδεεῖς.",
      "glosses": [
        {
          "anchor": "πόρναι",
          "note": "= γυναῖκες μισθοῦ συγγινόμεναι",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "ἑβδομὰς καὶ πάλιν πορεύεται, ἀργύριόν τι ἐν τῷ βαλλαντίῳ ὃ εἴργασται, βαδίζων τὰς ψαμμώδεις ὁδοὺς τῆς νοτίου νυκτὸς μόνος, αἱ χεῖρες πεπυγμέναι ἐν ταῖς βυσσίναις θυλάκοις τοῦ εὐτελοῦς χιτῶνος.",
      "glosses": [
        {
          "anchor": "ψαμμώδεις",
          "note": "< ψάμμος = ψάμμου πλήρεις",
          "rank": 1
        },
        {
          "anchor": "πεπυγμέναι",
          "note": "< πήγνυμι = κρύει συνεστῶσαι",
          "rank": 1
        },
        {
          "anchor": "βυσσίναις",
          "note": "< βύσσος = ἐκ βύσσου πεποιημέναις",
          "rank": 1
        },
        {
          "anchor": "βαλλαντίῳ",
          "note": "= θυλάκῳ ἀργυρίου",
          "rank": 1
        },
        {
          "anchor": "νοτίου",
          "note": "= ἀπὸ νότου πνεούσης",
          "rank": 1
        },
        {
          "anchor": "εἴργασται",
          "note": "< ἐργάζομαι = πεποίηται δι' ἔργου",
          "rank": 1
        },
        {
          "anchor": "θυλάκοις",
          "note": "= μικροῖς σάκκοις",
          "rank": 1
        },
        {
          "anchor": "ἑβδομὰς",
          "note": "= χρόνος ἑπτὰ ἡμερῶν",
          "rank": 1
        },
        {
          "anchor": "εὐτελοῦς",
          "note": "= φαύλου, μὴ πολυτελοῦς",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "γεφύραι πήλιναι διὰ τῶν ἑλῶν.",
      "glosses": [
        {
          "anchor": "πήλιναι",
          "note": "< πηλός = ἐκ πηλοῦ πεποιημέναι",
          "rank": 1
        },
        {
          "anchor": "γεφύραι",
          "note": "= ὁδοὶ διὰ ὕδατος",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "ἐρωδιοὶ ἐν ταῖς καλιαῖς λευκοὶ ὡς λαμπάδες ἐν τῷ βρύῳ.",
      "glosses": [
        {
          "anchor": "ἐρωδιοὶ",
          "note": "= ὄρνιθες μακρόποδες ἐν ὕδατι",
          "rank": 1
        },
        {
          "anchor": "καλιαῖς",
          "note": "= νεοττιαῖς, οἰκίσκοις ὀρνίθων",
          "rank": 1
        },
        {
          "anchor": "βρύῳ",
          "note": "= φυτῷ λεπτῷ ἐπὶ γῆς",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "ὁ ἄνεμος ὠμὸν ἔχει καὶ φύλλα σκιρτᾷ παρὰ τὴν ὁδὸν καὶ σκεδάννυται ἐν τοῖς νυκτερινοῖς ἀγροῖς.",
      "glosses": [
        {
          "anchor": "σκιρτᾷ",
          "note": "= πηδᾷ, κινεῖται ὀξέως",
          "rank": 1
        },
        {
          "anchor": "σκεδάννυται",
          "note": "= διασπείρεται, διαχωρίζεται",
          "rank": 1
        },
        {
          "anchor": "νυκτερινοῖς",
          "note": "< νύξ = νυκτὸς οὖσιν",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "πορεύεται πρὸς βορρᾶν διὰ μικρῶν κατοικιῶν καὶ ἀγρῶν, ἐργαζόμενος μισθοῦ ἐφημέρου καὶ τροφῆς.",
      "glosses": [
        {
          "anchor": "κατοικιῶν",
          "note": "= οἰκημάτων μικρῶν",
          "rank": 1
        },
        {
          "anchor": "ἐφημέρου",
          "note": "= ἡμερησίου, βραχυχρονίου",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "ὁρᾷ πατραλοίαν κρεμάμενον ἐν κώμῃ τριόδῳ καὶ οἱ φίλοι τοῦ ἀνδρὸς προδραμόντες ἕλκουσι τὰ σκέλη καὶ κρέμαται νεκρὸς ἀπὸ τοῦ σχοινίου, οὖρον δὲ μελαίνει τὰς ἀναξυρίδας.",
      "glosses": [
        {
          "anchor": "πατραλοίαν",
          "note": "= πατέρα κτείναντα",
          "rank": 1
        },
        {
          "anchor": "τριόδῳ",
          "note": "= τόπῳ τριῶν ὁδῶν",
          "rank": 1
        },
        {
          "anchor": "σχοινίου",
          "note": "= σπάρτου, καλῴδους",
          "rank": 1
        },
        {
          "anchor": "μελαίνει",
          "note": "= μέλανα ποιεῖ",
          "rank": 1
        },
        {
          "anchor": "προδραμόντες",
          "note": "< προτρέχω = πρότερον δραμόντες",
          "rank": 1
        },
        {
          "anchor": "κρέμαται",
          "note": "= ἐξ ὕψους ἤρτηται",
          "rank": 1
        },
        {
          "anchor": "ἀναξυρίδας",
          "note": "= σκέλεα περιβάλλοντα ἱμάτια",
          "rank": 1
        }
      ]
    }
  ]
}