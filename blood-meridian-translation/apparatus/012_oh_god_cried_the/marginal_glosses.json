{
  "sentences": [
    {
      "index": 0,
      "greek": "ὦ θεέ, ἐβόησεν ὁ ἱερεύς.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "ψεύδη, ψεύδη.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "ἤρξατο ἀναγινώσκειν πυρετωδῶς ἐκ τῆς ἀνεῳγμένης βίβλου.",
      "glosses": [
        {
          "anchor": "πυρετωδῶς",
          "note": "< πυρετός = ὡς ἐν πυρετῷ, σφοδρῶς",
          "rank": 1
        },
        {
          "anchor": "ἀνεῳγμένης",
          "note": "< ἀνοίγω = ἠνοιγμένης",
          "rank": 1
        },
        {
          "anchor": "βίβλου",
          "note": "= βίβλος, γραπτὸν σύγγραμμα",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "ἐπὶ ποικίλαις αἰτίαις ὧν ἡ νεωτάτη περιεῖχε κόρην ἑνδεκαετῆ—εἶπον ἕνδεκα—ἥτις ἦλθε πρὸς αὐτὸν πιστεύουσα καὶ ἣν κατελήφθη βιάζων ἐνδεδυμένος αὐτὴν τὴν στολὴν τοῦ θεοῦ αὐτοῦ.",
      "glosses": [
        {
          "anchor": "περιεῖχε",
          "note": "< περιέχω = ἐν ἑαυτῷ εἶχε",
          "rank": 1
        },
        {
          "anchor": "ἑνδεκαετῆ",
          "note": "= ἕνδεκα ἔτη γεγονυῖαν",
          "rank": 1
        },
        {
          "anchor": "πιστεύουσα",
          "note": "< πιστεύω = πίστιν ἔχουσα",
          "rank": 1
        },
        {
          "anchor": "βιάζων",
          "note": "< βιάζω = βίᾳ χρώμενος",
          "rank": 1
        },
        {
          "anchor": "νεωτάτη",
          "note": "< νέος = πλεῖστον νέα",
          "rank": 1
        },
        {
          "anchor": "κατελήφθη",
          "note": "< καταλαμβάνω = ἐν τῷ ἔργῳ εὑρέθη",
          "rank": 1
        },
        {
          "anchor": "ἐνδεδυμένος",
          "note": "< ἐνδύω = ἐσθῆτα φορῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "στεναγμὸς διῆλθε διὰ τοῦ ὄχλου.",
      "glosses": [
        {
          "anchor": "στεναγμὸς",
          "note": "= βαρὺ πνεῦμα ἐκ λύπης",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "γυνή τις κατέπεσεν ἐπὶ τὰ γόνατα.",
      "glosses": [
        {
          "anchor": "κατέπεσεν",
          "note": "< καταπίπτω = ἔπεσε κάτω",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "οὗτός ἐστιν, ἐβόησεν ὁ ἱερεύς, δακρύων.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "οὗτός ἐστιν.",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "ὁ διάβολος.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "ὧδε ἕστηκεν.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "κρεμάσωμεν τὸν κόπρον, ἐκάλεσεν αἰσχρός τις κακοῦργος ἐκ τοῦ ὑπερῴου ὄπισθεν.",
      "glosses": [
        {
          "anchor": "κρεμάσωμεν",
          "note": "< κρεμάννυμι = ἀποκτείνωμεν κρεμάσαντες",
          "rank": 1
        },
        {
          "anchor": "κακοῦργος",
          "note": "= κακὰ ἐργαζόμενος ↔ ἀγαθοεργός",
          "rank": 1
        },
        {
          "anchor": "ὑπερῴου",
          "note": "= ὑπερῷον, ἄνω οἴκημα",
          "rank": 1
        },
        {
          "anchor": "αἰσχρός",
          "note": "= κακός, μιαρός ↔ καλός",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "οὐ τρεῖς ἑβδομάδας πρὸ τούτου ἐξηλάθη ἐκ τοῦ Φορτὶ Σμὶθ τῆς Ἀρκάνσας διὰ τὸ συγγίγνεσθαι αἰγί.",
      "glosses": [
        {
          "anchor": "ἐξηλάθη",
          "note": "< ἐξελαύνω = ἐκβληθεὶς ἀπῆλθε",
          "rank": 1
        },
        {
          "anchor": "Φορτὶ",
          "note": "= πόλις τις ἐν Ἀμερικῇ",
          "rank": 1
        },
        {
          "anchor": "Σμὶθ",
          "note": "= μέρος ὀνόματος πόλεως",
          "rank": 1
        },
        {
          "anchor": "Ἀρκάνσας",
          "note": "= χώρα τις ἐν Ἀμερικῇ",
          "rank": 1
        },
        {
          "anchor": "αἰγί",
          "note": "= αἴξ, θῆλυ ζῷον",
          "rank": 1
        },
        {
          "anchor": "ἑβδομάδας",
          "note": "= ἑβδομάς, ἑπτὰ ἡμέραι",
          "rank": 1
        },
        {
          "anchor": "συγγίγνεσθαι",
          "note": "< συγγίγνομαι = μίγνυσθαι ἀφροδισίως",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "ναί, γύναι, τοῦτο εἶπον.",
      "glosses": []
    },
    {
      "index": 13,
      "greek": "αἰγί.",
      "glosses": [
        {
          "anchor": "αἰγί",
          "note": "= αἴξ, θῆλυ ζῷον",
          "rank": 1
        }
      ]
    }
  ]
}