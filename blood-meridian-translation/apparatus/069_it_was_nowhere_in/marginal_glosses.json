{
  "sentences": [
    {
      "index": 0,
      "greek": "Οὐδαμοῦ ὁρατὸν ἦν.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Ἡ μονὴ ὀκτὼ ἢ δέκα ἄρουρας περιτειχισμένης γῆς κατεῖχε, χῶρον ἄγονον ὃς ὀλίγας αἶγας καὶ ὄνους εἶχεν.",
      "glosses": [
        {
          "anchor": "περιτειχισμένης",
          "note": "< περιτειχίζω = τείχει περιβεβλημένης",
          "rank": 1
        },
        {
          "anchor": "ἄγονον",
          "note": "= ἄκαρπον ↔ εὔκαρπον",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ἐν τοῖς πηλίνοις τείχεσι τοῦ περιβόλου φάτναι ὑπὸ οἰκιῶν παροίκων οἰκούμεναι καὶ ὀλίγα πυρὰ μαγειρικὰ λεπτῶς ἐκάπνιζεν ἐν τῷ ἡλίῳ.",
      "glosses": [
        {
          "anchor": "πηλίνοις",
          "note": "< πηλός = ἐκ πηλοῦ πεποιημένοις",
          "rank": 1
        },
        {
          "anchor": "μαγειρικὰ",
          "note": "< μάγειρος = πρὸς μαγείρευσιν",
          "rank": 1
        },
        {
          "anchor": "ἐκάπνιζεν",
          "note": "< καπνίζω = καπνὸν ἀφίει",
          "rank": 1
        },
        {
          "anchor": "φάτναι",
          "note": "= τόποι τροφῆς ζῴων",
          "rank": 1
        },
        {
          "anchor": "οἰκούμεναι",
          "note": "< οἰκέω = κατοικούμεναι",
          "rank": 1
        },
        {
          "anchor": "λεπτῶς",
          "note": "< λεπτός = ὀλίγως",
          "rank": 1
        },
        {
          "anchor": "περιβόλου",
          "note": "< περιβάλλω = τείχους περικυκλοῦντος",
          "rank": 1
        },
        {
          "anchor": "παροίκων",
          "note": "< πάροικος = ἐν παροικίᾳ οἰκούντων",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Περιῆλθε παρὰ τὸ πλευρὸν τοῦ ναοῦ καὶ εἰς τὸ διακονικὸν εἰσῆλθεν.",
      "glosses": [
        {
          "anchor": "διακονικὸν",
          "note": "< διάκονος = οἴκημα διακόνων",
          "rank": 1
        },
        {
          "anchor": "πλευρὸν",
          "note": "= πλάγιον μέρος",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Γῦπες ἀπεχώρησαν διὰ τῶν ἀχύρων καὶ τοῦ κονιάματος ὥσπερ ὄρνιθες αὐλῆς πελώριοι.",
      "glosses": [
        {
          "anchor": "πελώριοι",
          "note": "= μεγάλοι τέρατα",
          "rank": 1
        },
        {
          "anchor": "ἀχύρων",
          "note": "= καλάμων ξηρῶν",
          "rank": 1
        },
        {
          "anchor": "κονιάματος",
          "note": "< κονία = ὕλης τειχοποιίας",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Αἱ θολωταὶ ἁψῖδες ὕπερθεν πεπληρωμέναι ἦσαν σκοτεινῷ δασεῖ ὄγκῳ ὃς μετεκινεῖτο καὶ ἔπνει καὶ ἐτρύζε.",
      "glosses": [
        {
          "anchor": "θολωταὶ",
          "note": "< θόλος = κυκλοτερεῖς",
          "rank": 1
        },
        {
          "anchor": "μετεκινεῖτο",
          "note": "< μετακινέω = ἐνθένδε κἀκεῖσε ἐκινεῖτο",
          "rank": 1
        },
        {
          "anchor": "ἐτρύζε",
          "note": "= ψόφον ἐποίει ὡς ὄρνιθες",
          "rank": 1
        },
        {
          "anchor": "ἁψῖδες",
          "note": "= καμπυλαὶ ὀροφαί",
          "rank": 1
        },
        {
          "anchor": "δασεῖ",
          "note": "< δασύς = παχεῖ τριχώδει",
          "rank": 1
        },
        {
          "anchor": "ἔπνει",
          "note": "< πνέω = ἀναπνεῖ",
          "rank": 1
        },
        {
          "anchor": "σκοτεινῷ",
          "note": "< σκότος = σκότους πλήρει ↔ φωτεινῷ",
          "rank": 1
        },
        {
          "anchor": "πεπληρωμέναι",
          "note": "< πληρόω = πλήρεις γεγενημέναι",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ἐν τῷ οἰκήματι τράπεζα ξυλίνη μετὰ ὀλίγων ὀστρακίνων ἀγγείων καὶ παρὰ τὸν ὄπισθεν τοῖχον ἔκειτο λείψανα πλειόνων σωμάτων, ἓν παιδός.",
      "glosses": [
        {
          "anchor": "ὀστρακίνων",
          "note": "< ὄστρακον = ἐξ ὀστράκων πεποιημένων",
          "rank": 1
        },
        {
          "anchor": "ξυλίνη",
          "note": "< ξύλον = ἐκ ξύλου πεποιημένη",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Διῆλθε διὰ τοῦ διακονικοῦ εἰς τὸν ναὸν πάλιν καὶ τὴν ἐφίππιον ἔλαβεν.",
      "glosses": [
        {
          "anchor": "διακονικοῦ",
          "note": "< διάκονος = οἰκήματος διακόνων",
          "rank": 1
        },
        {
          "anchor": "ἐφίππιον",
          "note": "< ἵππος = σκεῦος ἱππικόν",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Τὸ λοιπὸν τῆς λαγύνου ἔπιε καὶ τὴν ἐφίππιον ἐπὶ τὸν ὦμον θέμενος ἐξῆλθεν.",
      "glosses": [
        {
          "anchor": "ἐφίππιον",
          "note": "< ἵππος = σκεῦος ἱππικόν",
          "rank": 1
        },
        {
          "anchor": "λαγύνου",
          "note": "= ἀγγεῖον οἴνου",
          "rank": 1
        },
        {
          "anchor": "ἔπιε",
          "note": "< πίνω = ἔπινεν",
          "rank": 1
        }
      ]
    }
  ]
}