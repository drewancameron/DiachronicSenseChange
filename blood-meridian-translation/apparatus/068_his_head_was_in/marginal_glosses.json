{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἡ κεφαλὴ αὐτοῦ ἐν βασάνῳ ἦν καὶ ἡ γλῶττα ὑπὸ δίψους πεφυσημένη.",
      "glosses": [
        {
          "anchor": "πεφυσημένη",
          "note": "< φυσάω = οἰδοῦσα, μεγάλη γεγονυῖα",
          "rank": 1
        },
        {
          "anchor": "βασάνῳ",
          "note": "= ὀδύνη, πόνος",
          "rank": 1
        },
        {
          "anchor": "γλῶττα",
          "note": "= τὸ ἐν τῷ στόματι μέλος",
          "rank": 1
        },
        {
          "anchor": "δίψους",
          "note": "= πόθος πιεῖν ↔ κόρος",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ἀνεκάθισε καὶ περιέβλεψεν.",
      "glosses": [
        {
          "anchor": "Ἀνεκάθισε",
          "note": "< ἀνακαθίζω = ἀνέστη καθήμενος",
          "rank": 1
        },
        {
          "anchor": "περιέβλεψεν",
          "note": "< περιβλέπω = πάντῃ εἶδε",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Τὴν λάγυνον ὑπὸ τὴν σέλλαν τεθεικὼς ἦν καὶ εὑρὼν αὐτὴν ἦρε καὶ ἔσεισε καὶ τὸν φελλὸν ἐξέσπασε καὶ ἔπιεν.",
      "glosses": [
        {
          "anchor": "σέλλαν",
          "note": "= καθέδρα, θᾶκος",
          "rank": 1
        },
        {
          "anchor": "ἔσεισε",
          "note": "< σείω = ἐκίνησε",
          "rank": 1
        },
        {
          "anchor": "φελλὸν",
          "note": "= κῶμα λαγύνου",
          "rank": 1
        },
        {
          "anchor": "λάγυνον",
          "note": "= ἀγγεῖον οἴνου",
          "rank": 1
        },
        {
          "anchor": "τεθεικὼς",
          "note": "< τίθημι = θείς",
          "rank": 1
        },
        {
          "anchor": "ἐξέσπασε",
          "note": "< ἐκσπάω = βίᾳ ἐξείλετο",
          "rank": 1
        },
        {
          "anchor": "ἦρε",
          "note": "< αἴρω = ἀνέλαβε",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἐκάθητο τοὺς ὀφθαλμοὺς μύσας, ὁ ἱδρὼς ἐπὶ τοῦ μετώπου σταγόνες.",
      "glosses": [
        {
          "anchor": "μύσας",
          "note": "< μύω = κλείσας τοὺς ὀφθαλμούς",
          "rank": 1
        },
        {
          "anchor": "σταγόνες",
          "note": "= μικραὶ ῥανίδες ὑγροῦ",
          "rank": 1
        },
        {
          "anchor": "μετώπου",
          "note": "= τὸ ἄνω μέρος τοῦ προσώπου",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Εἶτα τοὺς ὀφθαλμοὺς ἤνοιξε καὶ πάλιν ἔπιεν.",
      "glosses": [
        {
          "anchor": "ἤνοιξε",
          "note": "< ἀνοίγω = διήνοιξε ↔ ἔκλεισε",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Οἱ γῦπες εἷς καθ' εἷς κατέβησαν καὶ δρόμῳ εἰς τὸ ἱερόν.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Μετὰ χρόνον τινὰ ἀνέστη καὶ ἐξῆλθε τὸν ἡμίονον ζητήσων.",
      "glosses": [
        {
          "anchor": "ζητήσων",
          "note": "< ζητέω = μέλλων εὑρεῖν",
          "rank": 1
        }
      ]
    }
  ]
}