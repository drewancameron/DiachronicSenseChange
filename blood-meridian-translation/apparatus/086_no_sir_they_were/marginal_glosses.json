{
  "sentences": [
    {
      "index": 0,
      "greek": "οὔ, κύριε.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "προὐδόθησαν.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "ἐμάχοντο κἀπέθανον κάτω ἐκεῖ ἐν τῇ ἐρήμῳ, εἶτα προὐδόθησαν ὑπὸ τῆς ἰδίας πατρίδος.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "ὁ παῖς ἐκάθητο σιωπῇ.",
      "glosses": [
        {
          "anchor": "ἐκάθητο",
          "note": "= sat",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "ὁ στρατηγὸς προσέκλινεν.",
      "glosses": [
        {
          "anchor": "προσέκλινεν",
          "note": "= leaned",
          "rank": 1
        },
        {
          "anchor": "στρατηγὸς",
          "note": "= military commander",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "ἡμεῖς ὑπὲρ αὐτῆς ἠγωνισάμεθα.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "φίλους τε καὶ ἀδελφοὺς ἀπωλέσαμεν ἐκεῖ κάτω.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "εἶτα νὴ τοὺς θεοὺς εἰ μὴ ἀπεδώκαμεν αὐτήν.",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "ἀπεδώκαμεν βαρβάροις τισίν, οὓς καὶ οἱ μάλιστα εὔνοι αὐτοῖς ὁμολογήσουσιν οὐδεμίαν ἔχειν ἔννοιαν οὔτε τιμῆς οὔτε δίκης οὔτε δημοκρατίας.",
      "glosses": [
        {
          "anchor": "ὁμολογήσουσιν",
          "note": "= admit",
          "rank": 1
        },
        {
          "anchor": "δημοκρατίας",
          "note": "= republican",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "δῆμον οὕτω δειλὸν ὥστε φόρον τετελεκέναι ἑκατὸν ἔτη φύλοις ἀγρίων γυμνῶν.",
      "glosses": [
        {
          "anchor": "δειλὸν",
          "note": "= cowardly ↔ ἀνδρεῖος",
          "rank": 1
        },
        {
          "anchor": "φόρον",
          "note": "= tribute",
          "rank": 1
        },
        {
          "anchor": "γυμνῶν",
          "note": "= naked ↔ ὁπλιτοδρόμος",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "παραδεδωκότας καρποὺς καὶ βοσκήματα.",
      "glosses": [
        {
          "anchor": "βοσκήματα",
          "note": "= livestock",
          "rank": 1
        },
        {
          "anchor": "παραδεδωκότας",
          "note": "= having handed over",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "μέταλλα κέκλεισται.",
      "glosses": []
    },
    {
      "index": 12,
      "greek": "κῶμαι ὅλαι ἐγκαταλέλειπται.",
      "glosses": [
        {
          "anchor": "κῶμαι",
          "note": "= villages",
          "rank": 1
        },
        {
          "anchor": "ἐγκαταλέλειπται",
          "note": "= abandoned",
          "rank": 1
        }
      ]
    },
    {
      "index": 13,
      "greek": "ὄχλος δὲ βαρβάρων ἱππεύει διὰ τῆς χώρας ληϊζόμενος καὶ φονεύων ἀτιμωρητί.",
      "glosses": [
        {
          "anchor": "χώρας",
          "note": "= country",
          "rank": 1
        },
        {
          "anchor": "ὄχλος",
          "note": "= crowd, mob",
          "rank": 1
        },
        {
          "anchor": "ληϊζόμενος",
          "note": "= plundering, pillaging",
          "rank": 1
        },
        {
          "anchor": "ἀτιμωρητί",
          "note": "= unpunished, with impunity",
          "rank": 1
        }
      ]
    },
    {
      "index": 14,
      "greek": "οὐδεμία χεὶρ ἐπ' αὐτοὺς ἦρται.",
      "glosses": []
    },
    {
      "index": 15,
      "greek": "ποῖοί τινές εἰσιν οὗτοι;",
      "glosses": []
    },
    {
      "index": 16,
      "greek": "οὐδ' οἱ Ἀπάχαι τοξεύουσιν αὐτούς.",
      "glosses": []
    },
    {
      "index": 17,
      "greek": "ἦ οἶσθα τοῦτο;",
      "glosses": []
    },
    {
      "index": 18,
      "greek": "λίθοις ἀποκτείνουσιν αὐτούς.",
      "glosses": [
        {
          "anchor": "ἀποκτείνουσιν",
          "note": "= kill",
          "rank": 1
        }
      ]
    },
    {
      "index": 19,
      "greek": "ὁ στρατηγὸς ἔσεισε τὴν κεφαλήν.",
      "glosses": [
        {
          "anchor": "κεφαλήν",
          "note": "= head ↔ οὐρά",
          "rank": 1
        }
      ]
    },
    {
      "index": 20,
      "greek": "ἐφαίνετο λυπεῖσθαι ὑφ' ὧν ἔδει λέγειν.",
      "glosses": []
    }
  ]
}