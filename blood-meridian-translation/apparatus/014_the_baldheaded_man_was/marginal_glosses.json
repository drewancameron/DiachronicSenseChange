{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὁ φαλακρὸς ἤδη παρὰ τῷ ἀβακίῳ εἰσιόντων αὐτῶν.",
      "glosses": [
        {
          "anchor": "ἀβακίῳ",
          "note": "ἄβαξ = τράπεζα μικρά",
          "rank": 1
        },
        {
          "anchor": "φαλακρὸς",
          "note": "= ἄτριχος τὴν κεφαλήν ↔ κομήτης",
          "rank": 1
        },
        {
          "anchor": "εἰσιόντων",
          "note": "< εἰσέρχομαι = εἰσερχομένων",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ἐπὶ τοῦ ἐστιλβωμένου ξύλου πρὸ αὐτοῦ δύο πῖλοι καὶ διπλαῖ χεῖρες ἀργυρίου.",
      "glosses": [
        {
          "anchor": "ἐστιλβωμένου",
          "note": "< στίλβω = λαμπρῶς πεποιημένου",
          "rank": 1
        },
        {
          "anchor": "διπλαῖ",
          "note": "= δισσαί ↔ ἁπλαῖ",
          "rank": 1
        },
        {
          "anchor": "πῖλοι",
          "note": "= κύαθοι οἴνου",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ἦρε τὸ ποτήριον ἀλλ' οὐ πρὸς αὐτούς.",
      "glosses": [
        {
          "anchor": "Ἦρε",
          "note": "< αἴρω = ἀνέλαβεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Παρέστησαν τῷ ἀβακίῳ καὶ ᾔτησαν οἴνους καὶ ὁ παῖς κατέθηκε τὸ ἀργύριον ἀλλ' ὁ οἰνοχόος ἀπώσατο τῷ δακτύλῳ καὶ ἐπένευσεν.",
      "glosses": [
        {
          "anchor": "ἀβακίῳ",
          "note": "ἄβαξ = τράπεζα μικρά",
          "rank": 1
        },
        {
          "anchor": "ἐπένευσεν",
          "note": "< νεύω = κατένευσεν",
          "rank": 1
        },
        {
          "anchor": "οἴνους",
          "note": "= οἶνον",
          "rank": 1
        },
        {
          "anchor": "ᾔτησαν",
          "note": "< αἰτέω = ἠξίωσαν",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ταῦτα παρὰ τοῦ κριτοῦ, ἔφη.",
      "glosses": [
        {
          "anchor": "κριτοῦ",
          "note": "κριτής = ὁ δικάζων",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ἔπιον.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Ὁ ἡνίοχος κατέθηκε τὸ ποτήριον καὶ ἔβλεψεν εἰς τὸν παῖδα ἢ ἐδόκει, οὐκ ἂν σαφῶς εἰδείης τὸ ὄμμα.",
      "glosses": [
        {
          "anchor": "ἔβλεψεν",
          "note": "< βλέπω = εἶδεν",
          "rank": 1
        },
        {
          "anchor": "εἰδείης",
          "note": "< οἶδα = γνοίης",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ὁ παῖς κατέβλεψε τὸ ἀβάκιον ὅπου εἱστήκει ὁ κριτής.",
      "glosses": [
        {
          "anchor": "κατέβλεψε",
          "note": "< βλέπω = κάτω εἶδεν",
          "rank": 1
        },
        {
          "anchor": "ἀβάκιον",
          "note": "= ἄβαξ μικρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Τὸ ἀβάκιον οὕτως ὑψηλὸν οὐ πᾶς ἂν καὶ τοὺς ἀγκῶνας ἐπιθείη ἀλλὰ τῷ κριτῇ μέχρι τῆς ὀσφύος καὶ εἱστήκει τὰς χεῖρας πλατείας ἐπὶ τοῦ ξύλου τεθεικώς, μικρὸν ἐπικλινόμενος, ὡς μέλλων αὖθις λέγειν.",
      "glosses": [
        {
          "anchor": "ἐπικλινόμενος",
          "note": "< κλίνω = ἐπὶ τι κάμπτων",
          "rank": 1
        },
        {
          "anchor": "ἀβάκιον",
          "note": "= ἄβαξ μικρός",
          "rank": 1
        },
        {
          "anchor": "ἐπιθείη",
          "note": "< τίθημι = ἐπὶ θείη",
          "rank": 1
        },
        {
          "anchor": "τεθεικώς",
          "note": "< τίθημι = θείς",
          "rank": 1
        },
        {
          "anchor": "ἀγκῶνας",
          "note": "= κάμψεις βραχιόνων",
          "rank": 1
        },
        {
          "anchor": "κριτῇ",
          "note": "κριτής = ὁ δικάζων",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Ἤδη ἄνδρες διὰ τῆς θύρας εἰσέπιπτον, αἱμάσσοντες, πηλῷ κεκαλυμμένοι, ἀρώμενοι.",
      "glosses": [
        {
          "anchor": "εἰσέπιπτον",
          "note": "< πίπτω = εἰσεσπεύδοσαν",
          "rank": 1
        },
        {
          "anchor": "αἱμάσσοντες",
          "note": "< αἷμα = αἵματι ῥεόμενοι",
          "rank": 1
        },
        {
          "anchor": "ἀρώμενοι",
          "note": "< ἄρνυμι = κινούμενοι ταχέως",
          "rank": 1
        },
        {
          "anchor": "κεκαλυμμένοι",
          "note": "< καλύπτω = σκεπασμένοι",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Περὶ τὸν κριτὴν συνήχθησαν.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "Λόχος συνελέγετο διώξων τὸν κήρυκα.",
      "glosses": [
        {
          "anchor": "διώξων",
          "note": "< διώκω = μέλλων μετελθεῖν",
          "rank": 1
        },
        {
          "anchor": "συνελέγετο",
          "note": "< συλλέγω = συνήγετο",
          "rank": 1
        }
      ]
    }
  ]
}