{
  "passage_id": "012_judge_bar_scene",
  "style": "Ørberg",
  "sentences": [
    {
      "index": 0,
      "greek": "ἔπιον.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "ὁ ζευγηλάτης κατέθηκε τὸ ποτήριον καὶ ἔβλεψε πρὸς τὸ παιδίον ἢ ἐδόκει, οὐκ ἂν ἦν βέβαιος τῆς ὄψεως αὐτοῦ.",
      "glosses": [
        {
          "anchor": "ζευγηλάτης",
          "note": "< ζεῦγμα· = ἡνίοχος, ὁ τὰ ὑποζύγια ἐλαύνων"
        },
        {
          "anchor": "κατέθηκε",
          "note": "< κατατίθημι (ἀόρ.)· = ἔθηκε κάτω ↔ αἴρω"
        },
        {
          "anchor": "ἔβλεψε",
          "note": "< βλέπω (ἀόρ.)· = εἰς ὄψιν ἦλθε, προσέσχε τῷ ὁράματι"
        }
      ]
    },
    {
      "index": 2,
      "greek": "τὸ παιδίον ἔβλεψε κατὰ τὸ ξύλον ὅπου ὁ κριτὴς εἱστήκει.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "τὸ ξύλον οὕτως ὑψηλὸν ἦν οὐ πᾶς ἀνὴρ δύναιτ᾽ ἂν οὐδὲ τοὺς ἀγκῶνας ἐπιθεῖναι ἀλλὰ τῷ κριτῇ πρὸς τὴν ὀσφὺν μόνον ἧκεν καὶ εἱστήκει τὰς χεῖρας πλατείας ἐπὶ τὸ ξύλον τεθεικώς, μικρὸν προκλινόμενος, ὡς μέλλων ἄλλην ῥῆσιν ποιεῖσθαι.",
      "glosses": [
        {
          "anchor": "δύναιτ᾽",
          "note": "< δύναμαι (εὐκτ.)· = ἰσχύοι ἄν, οἷός τ᾽ εἴη"
        },
        {
          "anchor": "τεθεικώς",
          "note": "< τίθημι (παρακ. μτχ.)· = πεποιηκὼς ἐπὶ τόπῳ"
        },
        {
          "anchor": "προκλινόμενος",
          "note": "< προκλίνω (μτχ.)· = πρὸς τὸ ἔμπροσθεν νεύων"
        }
      ]
    },
    {
      "index": 4,
      "greek": "ἤδη ἄνδρες διὰ τῆς θύρας εἰσέπιπτον, αἱμάσσοντες, πηλῷ κεκαλυμμένοι, καταρώμενοι.",
      "glosses": [
        {
          "anchor": "εἰσέπιπτον",
          "note": "< εἰσπίπτω (παρατ.)· = ἔσπευδον εἴσω, κατὰ σπουδὴν εἰσῇσαν"
        },
        {
          "anchor": "αἱμάσσοντες",
          "note": "< αἱμάσσω (μτχ.)· = αἵματι ῥέοντες, τετρωμένοι"
        }
      ]
    },
    {
      "index": 5,
      "greek": "περὶ τὸν κριτὴν συνήχθησαν.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "λόχος συνείλεκτο τὸν ἱερέα διώξων.",
      "glosses": [
        {
          "anchor": "συνείλεκτο",
          "note": "< συλλέγω (ὑπερσ.)· = συνήχθη, συνεκροτήθη"
        }
      ]
    },
    {
      "index": 7,
      "greek": "κριτά, πῶς ἔσχες τὰ κατὰ τοῦ οὐδενὸς ἀξίου ἐκείνου;",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "τὰ κατὰ;",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "εἶπεν ὁ κριτής.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "πότε ἦσθα ἐν *Φὸρτ Σμίθ;",
      "glosses": [
        {
          "anchor": "Φὸρτ",
          "note": "(Ἀγγλ. Fort)· = φρούριον, ὀχυρὸς τόπος στρατιωτικός"
        }
      ]
    },
    {
      "index": 11,
      "greek": "*Φὸρτ Σμίθ;",
      "glosses": []
    },
    {
      "index": 12,
      "greek": "ποῦ ἔγνως αὐτὸν ὥστε πάντα ταῦτα περὶ αὐτοῦ εἰδέναι;",
      "glosses": []
    },
    {
      "index": 13,
      "greek": "τὸν αἰδέσιμον *Γρὴν λέγεις;",
      "glosses": [
        {
          "anchor": "Γρὴν",
          "note": "(Ἀγγλ. Green)· = ὄνομα κύριον, ἐπωνυμία ἀνθρώπου"
        }
      ]
    },
    {
      "index": 14,
      "greek": "ναί, κύριε.",
      "glosses": []
    },
    {
      "index": 15,
      "greek": "οἶμαί σε ἐν *Φὸρτ Σμὶθ γεγονέναι πρὶν ἐνθάδε ἐλθεῖν.",
      "glosses": []
    },
    {
      "index": 16,
      "greek": "οὐδέποτε ἐν *Φὸρτ Σμὶθ ἤμην κατὰ τὸν βίον.",
      "glosses": [
        {
          "anchor": "οὐδέποτε",
          "note": "= οὐ πώποτε, οὐδαμῶς χρόνῳ τινί ↔ ἀεί, ποτέ"
        }
      ]
    },
    {
      "index": 17,
      "greek": "ἀμφιβάλλω εἰ κἀκεῖνος ἦν.",
      "glosses": []
    },
    {
      "index": 18,
      "greek": "ἔβλεπον ἀπ᾽ ἀλλήλων.",
      "glosses": []
    },
    {
      "index": 19,
      "greek": "ποῦ οὖν συνέτυχες αὐτῷ;",
      "glosses": []
    },
    {
      "index": 20,
      "greek": "οὐδέποτε ὄψιν ἐπέβαλον τῷ ἀνδρὶ πρὸ τῆς σήμερον.",
      "glosses": [
        {
          "anchor": "ὄψιν",
          "note": "ἐνταῦθα = θέαν, ὁρᾶν· ὄψιν ἐπιβάλλω = σκοπέω"
        }
      ]
    },
    {
      "index": 21,
      "greek": "οὐδὲ ἤκουσα περὶ αὐτοῦ.",
      "glosses": []
    },
    {
      "index": 22,
      "greek": "ἦρε τὸ ποτήριον καὶ ἔπιεν.",
      "glosses": []
    },
    {
      "index": 23,
      "greek": "ξένη σιγὴ ἦν ἐν τῷ οἴκῳ.",
      "glosses": [
        {
          "anchor": "ξένη",
          "note": "ἐνταῦθα = παράδοξος, ἀσύνηθες ↔ εἰωθυῖα"
        }
      ]
    },
    {
      "index": 24,
      "greek": "οἱ ἄνδρες πηλίνοις εἰδώλοις ἐῴκεσαν.",
      "glosses": []
    },
    {
      "index": 25,
      "greek": "τέλος τις ἤρξατο γελᾶν.",
      "glosses": []
    },
    {
      "index": 26,
      "greek": "εἶτα ἄλλος.",
      "glosses": []
    },
    {
      "index": 27,
      "greek": "ταχὺ πάντες ὁμοῦ ἐγέλων.",
      "glosses": [
        {
          "anchor": "ἐγέλων",
          "note": "< γελάω (παρατ.)· = εὐφραίνοντο, γέλωτα εἶχον"
        }
      ]
    },
    {
      "index": 28,
      "greek": "τις τῷ κριτῇ ποτὸν ἠγόρασεν.",
      "glosses": []
    }
  ]
}