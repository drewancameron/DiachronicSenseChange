{
  "sentences": [
    {
      "index": 0,
      "greek": "Κριτά, πῶς ἔσχες τὰ κατ' ἐκείνου τοῦ οὐδενός;",
      "glosses": [
        {
          "anchor": "Κριτά",
          "note": "κριτής (voc.) = ὁ κρίνων",
          "rank": 1
        },
        {
          "anchor": "ἔσχες",
          "note": "< ἔχω = ἐκτήσω, ἐλάμβανες",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Τὰ κατ' αὐτοῦ;",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "ἔφη ὁ κριτής.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Πότε ἦσθα ἐν τῷ Φρουρίῳ Σμίθ;",
      "glosses": [
        {
          "anchor": "Σμίθ",
          "note": "ὄνομα φρουρίου",
          "rank": 1
        },
        {
          "anchor": "Φρουρίῳ",
          "note": "φρουρίον = τεῖχος, ἀκρόπολις",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Τῷ Φρουρίῳ Σμίθ;",
      "glosses": [
        {
          "anchor": "Σμίθ",
          "note": "ὄνομα φρουρίου",
          "rank": 1
        },
        {
          "anchor": "Φρουρίῳ",
          "note": "φρουρίον = τεῖχος, ἀκρόπολις",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Πόθεν ἔγνως αὐτὸν ὥστε εἰδέναι πάντα ταῦτα περὶ αὐτοῦ;",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Τὸν ἱερέα Γρῆν λέγεις;",
      "glosses": [
        {
          "anchor": "Γρῆν",
          "note": "ὄνομα ἱερέως",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ναί κύριε.",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "Οἴομαι ἦσθα ἐν τῷ Φρουρίῳ Σμίθ πρὶν δεῦρο ἐλθεῖν.",
      "glosses": [
        {
          "anchor": "Σμίθ",
          "note": "ὄνομα φρουρίου",
          "rank": 1
        },
        {
          "anchor": "Φρουρίῳ",
          "note": "φρουρίον = τεῖχος, ἀκρόπολις",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Οὐπώποτε ἐγενόμην ἐν τῷ Φρουρίῳ Σμίθ τὸν βίον.",
      "glosses": [
        {
          "anchor": "Σμίθ",
          "note": "ὄνομα φρουρίου",
          "rank": 1
        },
        {
          "anchor": "Οὐπώποτε",
          "note": "οὐδέποτε = οὐ πώποτε",
          "rank": 1
        },
        {
          "anchor": "Φρουρίῳ",
          "note": "φρουρίον = τεῖχος, ἀκρόπολις",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Ἀμφιβάλλω εἰ κἀκεῖνος.",
      "glosses": [
        {
          "anchor": "Ἀμφιβάλλω",
          "note": "ἀμφι·βάλλω = ἀμφισβητῶ, ἀπορῶ",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Ἔβλεπον ἄλλος εἰς ἄλλον.",
      "glosses": [
        {
          "anchor": "Ἔβλεπον",
          "note": "< βλέπω = ἑώρων",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Ποῦ οὖν ἐνέτυχες αὐτῷ;",
      "glosses": [
        {
          "anchor": "ἐνέτυχες",
          "note": "< ἐντυγχάνω = συναντῶ",
          "rank": 1
        }
      ]
    },
    {
      "index": 13,
      "greek": "Οὐπώποτε εἶδον τὸν ἄνθρωπον πρὸ τῆσδε τῆς ἡμέρας.",
      "glosses": [
        {
          "anchor": "Οὐπώποτε",
          "note": "οὐδέποτε = οὐ πώποτε",
          "rank": 1
        }
      ]
    },
    {
      "index": 14,
      "greek": "Οὐδ' ἤκουσα περὶ αὐτοῦ.",
      "glosses": []
    },
    {
      "index": 15,
      "greek": "Ἦρε τὸ ποτήριον καὶ ἔπιεν.",
      "glosses": [
        {
          "anchor": "Ἦρε",
          "note": "< αἴρω = ἀνέλαβε",
          "rank": 1
        }
      ]
    },
    {
      "index": 16,
      "greek": "Σιγὴ ἄτοπος ἦν ἐν τῷ οἴκῳ.",
      "glosses": []
    },
    {
      "index": 17,
      "greek": "Οἱ ἄνδρες ὡς πήλινα ἀγάλματα.",
      "glosses": [
        {
          "anchor": "πήλινα",
          "note": "< πηλός = ἐκ πηλοῦ πεποιημένα",
          "rank": 1
        }
      ]
    },
    {
      "index": 18,
      "greek": "Τέλος τις ἤρξατο γελᾶν.",
      "glosses": []
    },
    {
      "index": 19,
      "greek": "Εἶτα ἄλλος.",
      "glosses": []
    },
    {
      "index": 20,
      "greek": "Ταχὺ πάντες ὁμοῦ γελῶντες.",
      "glosses": [
        {
          "anchor": "γελῶντες",
          "note": "< γελάω = οἱ γέλωτα ποιούμενοι",
          "rank": 1
        }
      ]
    },
    {
      "index": 21,
      "greek": "Ἠγόρασέ τις τῷ κριτῇ πόμα.",
      "glosses": [
        {
          "anchor": "Ἠγόρασέ",
          "note": "< ἀγοράζω = ὠνήσατο",
          "rank": 1
        },
        {
          "anchor": "πόμα",
          "note": "= ποτόν",
          "rank": 1
        },
        {
          "anchor": "κριτῇ",
          "note": "κριτής (dat.) = τῷ κρίνοντι",
          "rank": 1
        }
      ]
    }
  ]
}