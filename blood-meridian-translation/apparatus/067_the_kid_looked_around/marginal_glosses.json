{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὁ παῖς περιέβλεψε τὸ οἴκημα.",
      "glosses": [
        {
          "anchor": "περιέβλεψε",
          "note": "περι·βλέπω = κύκλῳ βλέπω",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Τινὲς τῶν ἀνδρῶν πιστόλια ἐν ταῖς ζώναις ἐφόρουν ἀλλ' οὐδεὶς ἐκινήθη.",
      "glosses": [
        {
          "anchor": "πιστόλια",
          "note": "ὅπλα μικρὰ χειρός",
          "rank": 1
        },
        {
          "anchor": "ζώναις",
          "note": "ζώνη = δέσμα περὶ μέσον",
          "rank": 1
        },
        {
          "anchor": "ἐφόρουν",
          "note": "< φορέω = συνεχῶς φέρω",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ παῖς τὸν πότον ὑπερήλατο καὶ ἄλλην λάγυνον λαβὼν ὑπὸ μάλην ἔθηκε καὶ διὰ τῆς θύρας ἐξῆλθε.",
      "glosses": [
        {
          "anchor": "μάλην",
          "note": "μασχάλη = ὑπὸ τὸν βραχίονα",
          "rank": 1
        },
        {
          "anchor": "ὑπερήλατο",
          "note": "ὑπερ·ελαύνω = παρὰ πίνων διέρχομαι",
          "rank": 1
        },
        {
          "anchor": "λάγυνον",
          "note": "ἀγγεῖον οἴνου",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ὁ κύων ἄπην.",
      "glosses": [
        {
          "anchor": "ἄπην",
          "note": "οὐ παρῆν ↔ παρῆν",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ὁ ἐπὶ τοῦ βάθρου ἀνὴρ καὶ αὐτὸς ἄπην.",
      "glosses": [
        {
          "anchor": "βάθρου",
          "note": "βάθρον = λίθος καθέδρας",
          "rank": 1
        },
        {
          "anchor": "ἄπην",
          "note": "οὐ παρῆν ↔ παρῆν",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Τὸν ἡμίονον λύσας διὰ τῆς ἀγορᾶς ἦγε.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Ἐξηγέρθη ἐν νηῷ ἐρημώδει, πρὸς τὴν ἁψῖδα βλέπων καὶ τοὺς ὑψηλοὺς τοίχους μετὰ τῶν ἀμυδρῶν γραφῶν.",
      "glosses": [
        {
          "anchor": "ἐρημώδει",
          "note": "< ἔρημος = ἔρημος ὤν",
          "rank": 1
        },
        {
          "anchor": "ἁψῖδα",
          "note": "κάμπτον μέρος οἰκοδομῆς",
          "rank": 1
        },
        {
          "anchor": "ἀμυδρῶν",
          "note": "οὐ σαφῶν ↔ λαμπρῶν",
          "rank": 1
        },
        {
          "anchor": "Ἐξηγέρθη",
          "note": "ἐξ·εγείρω = ἐκ ὕπνου ἀνίσταμαι",
          "rank": 1
        },
        {
          "anchor": "ὑψηλοὺς",
          "note": "μακροὺς ἄνω ↔ χθαμαλούς",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Τὸ ἔδαφος τοῦ νεὼς βαθὺ ξηρᾷ κόπρῳ καὶ βολίτοις βοῶν τε καὶ προβάτων.",
      "glosses": [
        {
          "anchor": "βολίτοις",
          "note": "κόπρος βοῶν",
          "rank": 1
        },
        {
          "anchor": "κόπρῳ",
          "note": "ἀκαθαρσία ζῴων",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Πέλειαι διὰ στύλων κονιορτοῦ φωτὸς ἐπέτοντο καὶ τρεῖς γῦπες περὶ ὀστέα γυμνὰ ζῴου τινὸς ἐν τῷ ἀδύτῳ τεθνεῶτος ἐβάδιζον χωλαίνοντες.",
      "glosses": [
        {
          "anchor": "χωλαίνοντες",
          "note": "< χωλός = χωλῶς βαδίζοντες",
          "rank": 1
        },
        {
          "anchor": "Πέλειαι",
          "note": "πέλεια = ὄρνις οἰκεῖος",
          "rank": 1
        },
        {
          "anchor": "ἀδύτῳ",
          "note": "μυχὸς ἱεροῦ",
          "rank": 1
        },
        {
          "anchor": "ἐπέτοντο",
          "note": "< πέτομαι = ἐν ἀέρι κινοῦμαι",
          "rank": 1
        },
        {
          "anchor": "κονιορτοῦ",
          "note": "κονιορτός = ξηρὰ γῆ ἐν ἀέρι",
          "rank": 1
        }
      ]
    }
  ]
}