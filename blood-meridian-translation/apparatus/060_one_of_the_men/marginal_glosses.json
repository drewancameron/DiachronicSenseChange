{
  "sentences": [
    {
      "index": 0,
      "greek": "Εἷς τῶν ἀνδρῶν τῶν παρὰ τῷ οἰνοπωλίῳ εἶπέ τι Ἱσπανιστί.",
      "glosses": [
        {
          "anchor": "οἰνοπωλίῳ",
          "note": "οἰνο·πωλίῳ = τόπος οὗ οἶνον πωλοῦσι",
          "rank": 1
        },
        {
          "anchor": "Ἱσπανιστί",
          "note": "= τῇ Ἱσπανῶν γλώττῃ",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ὁ παῖς ὑπέβλεψεν αὐτούς.",
      "glosses": [
        {
          "anchor": "ὑπέβλεψεν",
          "note": "< ὑπο·βλέπω = κρύφα ἢ ὑπὸ τῶν ὀφρύων βλέπω",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Διενεύσαντο ἀλλήλοις, ἀνέλαβον τὰ ποτήρια.",
      "glosses": [
        {
          "anchor": "Διενεύσαντο",
          "note": "< δια·νεύω = νεύματι ἀλλήλοις σημαίνω",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἐπέστρεψε πρὸς τὸν κάπηλον πάλιν.",
      "glosses": [
        {
          "anchor": "κάπηλον",
          "note": "= τὸν πωλοῦντα οἶνον",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Οἱ ὀφθαλμοὶ αὐτοῦ μέλανες καὶ στενοί.",
      "glosses": [
        {
          "anchor": "στενοί",
          "note": "= μικροὶ ↔ πλατεῖς",
          "rank": 1
        },
        {
          "anchor": "μέλανες",
          "note": "= μαῦροι ↔ λευκοί",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Κόρει τὸ ἔδαφος, εἶπεν.",
      "glosses": [
        {
          "anchor": "Κόρει",
          "note": "< κορέω = καθαίρω, κόπρον ἀφαιρῶ",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ὁ κάπηλος ἔπταρεν.",
      "glosses": [
        {
          "anchor": "ἔπταρεν",
          "note": "= ἐκ ῥινὸς βιαίως ἀέρα ἐξέπεμψε",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "= ὁ πωλῶν οἶνον",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ὁ παῖς ὑπεχώρησε καὶ ἐποίησε σχήματα κορήματος, μίμημα ὃ κατέκαμψε τοὺς πίνοντας ἐν σιωπηλῷ γέλωτι.",
      "glosses": [
        {
          "anchor": "κορήματος",
          "note": "< κόρημα = ὄργανον κορεῖν",
          "rank": 1
        },
        {
          "anchor": "κατέκαμψε",
          "note": "< κατα·κάμπτω = ἔκαμψεν εἰς γέλωτα",
          "rank": 1
        },
        {
          "anchor": "σιωπηλῷ",
          "note": "< σιωπή = ἄνευ φωνῆς",
          "rank": 1
        },
        {
          "anchor": "ὑπεχώρησε",
          "note": "< ὑπο·χωρέω = ὀπίσω ἐχώρησε",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Κόρει, εἶπεν, δεικνὺς τὸ ἔδαφος.",
      "glosses": [
        {
          "anchor": "Κόρει",
          "note": "< κορέω = καθαίρω, κόπρον ἀφαιρῶ",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "No esta sucio, εἶπεν ὁ κάπηλος.",
      "glosses": [
        {
          "anchor": "κάπηλος",
          "note": "= ὁ πωλῶν οἶνον",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Ἐκόρησε πάλιν.",
      "glosses": [
        {
          "anchor": "Ἐκόρησε",
          "note": "< κορέω = ἐκαθήρατο",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Κόρει, πρὸς θεῶν, εἶπεν.",
      "glosses": [
        {
          "anchor": "Κόρει",
          "note": "< κορέω = καθαίρω, κόπρον ἀφαιρῶ",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Ὁ κάπηλος ἀνέσεισε τοὺς ὤμους.",
      "glosses": [
        {
          "anchor": "ἀνέσεισε",
          "note": "< ἀνα·σείω = ἄνω καὶ κάτω κινέω",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "= ὁ πωλῶν οἶνον",
          "rank": 1
        }
      ]
    },
    {
      "index": 13,
      "greek": "Ἦλθεν ἐπὶ τὸ ἄκρον τοῦ οἰνοπωλίου καὶ ἔλαβε κόρημα καὶ ἤνεγκεν αὐτό.",
      "glosses": [
        {
          "anchor": "οἰνοπωλίου",
          "note": "οἰνο·πωλίου = τόπου οὗ οἶνον πωλοῦσι",
          "rank": 1
        },
        {
          "anchor": "κόρημα",
          "note": "= ὄργανον κορεῖν",
          "rank": 1
        }
      ]
    },
    {
      "index": 14,
      "greek": "Ὁ παῖς ἔλαβεν αὐτὸ καὶ ἀπῆλθεν εἰς τὰ ὄπισθεν τοῦ οἰκήματος.",
      "glosses": []
    }
  ]
}