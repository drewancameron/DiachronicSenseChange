{
  "sentences": [
    {
      "index": 0,
      "greek": "Ποῦ Σιδνεῖος;",
      "glosses": [
        {
          "anchor": "Σιδνεῖος",
          "note": "κύριον ὄνομα ἀνδρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "εἶπεν ὁ ἀνὴρ ἐν τῇ πηλίνῃ στολῇ.",
      "glosses": [
        {
          "anchor": "πηλίνῃ",
          "note": "< πηλός = ἐκ πηλοῦ πεποιημένη",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ἐν τῇ κλίνῃ οἶμαι.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Ἐπορεύοντο.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Τοάδουιν, ἐκάλεσεν ὁ κάπηλος.",
      "glosses": [
        {
          "anchor": "Τοάδουιν",
          "note": "κύριον ὄνομα παιδός",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "ὁ οἶνον καὶ σῖτον πωλῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ὁ παῖς ἐπέστρεψεν.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Ὁ κάπηλος ἐξελήλυθεν ὄπισθεν τοῦ βήματος καὶ ἐσκόπει αὐτούς.",
      "glosses": [
        {
          "anchor": "κάπηλος",
          "note": "ὁ οἶνον καὶ σῖτον πωλῶν",
          "rank": 1
        },
        {
          "anchor": "ἐξελήλυθεν",
          "note": "< ἐξέρχομαι = ἔξω προῆλθεν",
          "rank": 1
        },
        {
          "anchor": "ἐσκόπει",
          "note": "< σκοπέω = ὀφθαλμοῖς ἐθεώρει",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Διέβησαν ἀπὸ τῆς θύρας διὰ τῆς αὐλῆς τοῦ πανδοκείου πρὸς τὴν κλίμακα καταλιπόντες ποικίλα εἴδη πηλοῦ ἐπὶ τοῦ ἐδάφους.",
      "glosses": [
        {
          "anchor": "πανδοκείου",
          "note": "πᾶς·δέχομαι = τόπος ξένων καταγωγῆς",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Ἀρχομένων δ' αὐτῶν ἀναβαίνειν τὴν κλίμακα ὁ γραμματεὺς ἐπὶ τῷ πίνακι προκύψας ἐκάλεσεν αὐτούς.",
      "glosses": [
        {
          "anchor": "προκύψας",
          "note": "< προκύπτω = κεφαλὴν προβαλών",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Τοάδουιν.",
      "glosses": [
        {
          "anchor": "Τοάδουιν",
          "note": "κύριον ὄνομα παιδός",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Ἔστη καὶ ἐπέστρεψεν.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "Βαλεῖ σε.",
      "glosses": [
        {
          "anchor": "Βαλεῖ",
          "note": "< βάλλω = τύπτω, παίω",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Ὁ γέρων Σιδνεῖος;",
      "glosses": [
        {
          "anchor": "Σιδνεῖος",
          "note": "κύριον ὄνομα ἀνδρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 13,
      "greek": "Ὁ γέρων Σιδνεῖος.",
      "glosses": [
        {
          "anchor": "Σιδνεῖος",
          "note": "κύριον ὄνομα ἀνδρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 14,
      "greek": "Ἀνέβησαν τὴν κλίμακα.",
      "glosses": []
    },
    {
      "index": 15,
      "greek": "Ἐπ' ἄκρῳ τῷ ἀναβαθμῷ μακρὸς δρόμος φωταγωγὸν ἐπὶ τέλει.",
      "glosses": [
        {
          "anchor": "ἀναβαθμῷ",
          "note": "ὁ ἄνω τόπος κλίμακος",
          "rank": 1
        },
        {
          "anchor": "φωταγωγὸν",
          "note": "φῶς·ἀγωγόν = φῶς εἰσάγον",
          "rank": 1
        },
        {
          "anchor": "μακρὸς",
          "note": "μήκει μέγας ↔ βραχύς",
          "rank": 1
        }
      ]
    },
    {
      "index": 16,
      "greek": "Θύραι γεγανωμέναι κατὰ τοὺς τοίχους οὕτως πυκναὶ ὥστε ταμιεῖα εἶναι.",
      "glosses": [
        {
          "anchor": "γεγανωμέναι",
          "note": "< γαίνω = στίλβουσαι, λαμπραί",
          "rank": 1
        },
        {
          "anchor": "ταμιεῖα",
          "note": "< ταμίας = μικρὰ δωμάτια",
          "rank": 1
        },
        {
          "anchor": "πυκναὶ",
          "note": "πολλαὶ καὶ σύνεγγυς ↔ ἀραιαί",
          "rank": 1
        }
      ]
    },
    {
      "index": 17,
      "greek": "Τοάδουιν προὔβαινεν ἕως ἦλθεν εἰς τὸ πέρας τοῦ δρόμου.",
      "glosses": [
        {
          "anchor": "Τοάδουιν",
          "note": "κύριον ὄνομα παιδός",
          "rank": 1
        },
        {
          "anchor": "προὔβαινεν",
          "note": "< προβαίνω = πρόσω ἐπορεύετο",
          "rank": 1
        }
      ]
    },
    {
      "index": 18,
      "greek": "Ὠτακούστησεν παρὰ τῇ τελευταίᾳ θύρᾳ καὶ ἔβλεψεν εἰς τὸν παῖδα.",
      "glosses": [
        {
          "anchor": "Ὠτακούστησεν",
          "note": "ὠτός·ἀκούω = διὰ τῶν ὤτων ἤκουσεν",
          "rank": 1
        },
        {
          "anchor": "ἔβλεψεν",
          "note": "< βλέπω = ὀφθαλμοὺς ἐπέστρεψεν",
          "rank": 1
        }
      ]
    }
  ]
}