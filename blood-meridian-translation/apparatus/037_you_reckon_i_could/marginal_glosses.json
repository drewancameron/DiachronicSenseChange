{
  "sentences": [
    {
      "index": 0,
      "greek": "Οἴει ἄν με δύνασθαι ποτίσαι τὸν γέροντα ἡμίονον ἐκεῖ;",
      "glosses": [
        {
          "anchor": "ποτίσαι",
          "note": "= πιεῖν δοῦναι",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ὁ γέρων ἤρξατο τύπτειν τὴν παλάμην πυγμῇ μιᾷ καὶ διαφέρειν τοὺς ὀφθαλμούς.",
      "glosses": [
        {
          "anchor": "παλάμην",
          "note": "= χεῖρα",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Γαυριῴην ἂν εἰσενεγκεῖν καινόν τι.",
      "glosses": [
        {
          "anchor": "Γαυριῴην",
          "note": "< γαυριάω = μεγαλύνομαι, σεμνύνομαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Μόνον εἰπέ μοι ποῦ ἐστιν.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Τίνι μέλλεις ποτίζειν αὐτόν;",
      "glosses": [
        {
          "anchor": "ποτίζειν",
          "note": "= πιεῖν διδόναι",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ὁ παῖς ἔβλεψεν εἰς τὸν κάδον καὶ περιέβλεψεν ἐν τῇ ἀμυδρᾷ καλύβῃ.",
      "glosses": [
        {
          "anchor": "περιέβλεψεν",
          "note": "= πάντῃ ἔβλεψεν",
          "rank": 1
        },
        {
          "anchor": "καλύβῃ",
          "note": "= μικρᾷ οἰκίᾳ",
          "rank": 1
        },
        {
          "anchor": "ἔβλεψεν",
          "note": "= εἶδεν",
          "rank": 1
        },
        {
          "anchor": "κάδον",
          "note": "= ἀγγεῖον ὕδατος",
          "rank": 1
        },
        {
          "anchor": "ἀμυδρᾷ",
          "note": "= σκοτεινῇ ↔ λαμπρᾷ",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Οὐ πίνω μετὰ ἡμίονον, εἶπεν ὁ ἐρημίτης.",
      "glosses": [
        {
          "anchor": "ἐρημίτης",
          "note": "< ἔρημος = ὁ ἐν ἐρήμῳ μόνος ζῶν",
          "rank": 1
        },
        {
          "anchor": "πίνω",
          "note": "= ὑγρὸν δέχομαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Οὐκ ἔχεις παλαιόν τινα κάδον οὐδ' ἄλλο τι;",
      "glosses": [
        {
          "anchor": "κάδον",
          "note": "= ἀγγεῖον ὕδατος",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Οὔ, ἐβόησεν ὁ ἐρημίτης.",
      "glosses": [
        {
          "anchor": "ἐρημίτης",
          "note": "< ἔρημος = ὁ ἐν ἐρήμῳ μόνος ζῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Οὔ.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "Οὐκ ἔχω.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "Συνέκρουε τὰς πτέρνας τῶν πεπυγμένων χειρῶν πρὸς τὸ στῆθος.",
      "glosses": [
        {
          "anchor": "πεπυγμένων",
          "note": "< πυγμή = συνεσφιγμένων εἰς πυγμήν",
          "rank": 1
        },
        {
          "anchor": "Συνέκρουε",
          "note": "= συνεπάταξεν",
          "rank": 1
        },
        {
          "anchor": "πτέρνας",
          "note": "= τὰ ὀπίσθια τῶν ποδῶν",
          "rank": 1
        }
      ]
    }
  ]
}