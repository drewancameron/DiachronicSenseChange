{
  "sentences": [
    {
      "index": 0,
      "greek": "Εἶδες καπνόν, εἶπεν ὁ παῖς.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Ἐνόμιζον ἂν δοίης ἀνδρὶ ῥοφὴν ὕδατος.",
      "glosses": [
        {
          "anchor": "ῥοφὴν",
          "note": "= πόσιν μικράν",
          "rank": 1
        },
        {
          "anchor": "δοίης",
          "note": "< δίδωμι = δῴης, ὀπτατικὸς δόσεως",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ γέρων ἐρημίτης ἔκναισε τὰς ῥυπαρὰς τρίχας καὶ ἔβλεψεν εἰς τὴν γῆν.",
      "glosses": [
        {
          "anchor": "ἐρημίτης",
          "note": "= μόνος ἐν ἐρήμῳ ζῶν",
          "rank": 1
        },
        {
          "anchor": "ἔκναισε",
          "note": "< κναίω = ἔξυσε, ἐκόμισε",
          "rank": 1
        },
        {
          "anchor": "ῥυπαρὰς",
          "note": "= μιαράς, οὐ καθαράς ↔ καθαραί",
          "rank": 1
        },
        {
          "anchor": "ἔβλεψεν",
          "note": "< βλέπω = ἴδε, κατεῖδεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἐστράφη καὶ εἰσῆλθεν εἰς τὴν καλύβην καὶ ὁ παῖς ἠκολούθησεν.",
      "glosses": [
        {
          "anchor": "καλύβην",
          "note": "= οἰκίσκον μικρόν",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ἔνδον σκότος καὶ ὀσμὴ γῆς.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Μικρὸν πῦρ ἐκαίετο ἐπὶ τοῦ χαμαὶ πηλοῦ καὶ τὰ μόνα σκεύη σωρὸς δερμάτων ἐν γωνίᾳ τινί.",
      "glosses": [
        {
          "anchor": "σωρὸς",
          "note": "= σωρεία, πλῆθος ἐπισωρευμένον",
          "rank": 1
        },
        {
          "anchor": "ἐκαίετο",
          "note": "< καίω = ἐφλέγετο",
          "rank": 1
        },
        {
          "anchor": "δερμάτων",
          "note": "= δέρμα, δέρματος = ζῴων σκεπάσματα",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ὁ γέρων ὑπεχώρει διὰ τοῦ ζόφου, κύπτουσαν τὴν κεφαλήν, ὑπὸ τὴν χθαμαλὴν ὀροφὴν πεπλεγμένων κλάδων καὶ πηλοῦ.",
      "glosses": [
        {
          "anchor": "κύπτουσαν",
          "note": "< κύπτω = κάτω κλίνουσαν",
          "rank": 1
        },
        {
          "anchor": "χθαμαλὴν",
          "note": "= ταπεινήν, οὐχὶ ὑψηλήν ↔ ὑψηλή",
          "rank": 1
        },
        {
          "anchor": "πεπλεγμένων",
          "note": "< πλέκω = συμπεπλοκότων",
          "rank": 1
        },
        {
          "anchor": "ὑπεχώρει",
          "note": "< ὑποχωρέω = ἐπορεύετο ὑπό τι",
          "rank": 1
        },
        {
          "anchor": "ὀροφὴν",
          "note": "= στέγην οἰκίας ↔ ἔδαφος",
          "rank": 1
        },
        {
          "anchor": "ζόφου",
          "note": "= σκότους βαθέος ↔ φῶς",
          "rank": 1
        },
        {
          "anchor": "κλάδων",
          "note": "= κλάδος, κλάδου = ἀπὸ δένδρων ῥάβδοι",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ἔδειξε κάτω οὗ κάδος εἱστήκει ἐν τῷ πηλῷ.",
      "glosses": [
        {
          "anchor": "κάδος",
          "note": "= ἀγγεῖον ὕδατος",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Ὁ παῖς κύψας ἀνείλετο τὴν κολοκύνθην ἐκεῖ ἐπιπλέουσαν καὶ βάψας ἔπιεν.",
      "glosses": [
        {
          "anchor": "κολοκύνθην",
          "note": "= σκεῦος σφαιροειδὲς ἐκ καρποῦ",
          "rank": 1
        },
        {
          "anchor": "ἐπιπλέουσαν",
          "note": "< ἐπιπλέω = ἐπάνω τοῦ ὕδατος φερομένην",
          "rank": 1
        },
        {
          "anchor": "βάψας",
          "note": "< βάπτω = εἰς ὕδωρ ἐμβαλών",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Τὸ ὕδωρ ἁλμυρόν, θειῶδες.",
      "glosses": [
        {
          "anchor": "θειῶδες",
          "note": "< θεῖον = θείου ὀσμὴν ἔχον",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Ἔπινεν.",
      "glosses": []
    }
  ]
}