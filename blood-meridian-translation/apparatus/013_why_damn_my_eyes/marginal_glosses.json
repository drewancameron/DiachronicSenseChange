        {
          "anchor": "πανδοκεῖον",
          "note": "= inn",
          "rank": 1
        },
        {
          "anchor": "κατέδυσαν",
          "note": "< καταδύω (ἀόρ. ἐν.) = duck",
          "rank": 1
        },
        {
          "anchor": "ἰλύος",
          "note": "= mud, slime",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "ἤδη βολαὶ πανταχοῦ ἐντὸς τῆς σκηνῆς καὶ δώδεκα ἔξοδοι τετμημέναι διὰ τῶν λινῶν τοίχων καὶ ἄνθρωποι ἐξέρρεον, γυναῖκες βοῶσαι, τινὲς σφαλλόμενοι, τινὲς καταπατούμενοι ἐν τῇ ἰλύι.",
      "glosses": [
        {
          "anchor": "λινῶν",
          "note": "< λίνεος (γεν. πλ.) = flax, linen",
          "rank": 1
        },
        {
          "anchor": "ἐξέρρεον",
          "note": "< ἐκρέω (πρτ. ἐν.) = flow out",
          "rank": 1
        },
        {
          "anchor": "καταπατούμενοι",
