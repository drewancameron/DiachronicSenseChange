{
  "sentences": [
    {
      "index": 0,
      "greek": "τί μά τὸν Δία εἰ μὴ βαλῶ τὸν κύνα, εἶπεν ἀνήρ τις ἀνιστάμενος ἐν τῷ πέρατι τῆς σκηνῆς, καὶ ἐκ τῆς κρηπῖδος σπάσας πιστόλιον ἐπεστόχασε καὶ ἔβαλεν.",
      "glosses": [
        {
          "anchor": "σπάσας",
          "note": "< σπάω (ἐνεστ. μτχ. ἐν.) = having their ↔ λάπτω",
          "rank": 1
        },
        {
          "anchor": "κρηπῖδος",
          "note": "= manʼs high boot",
          "rank": 1
        },
        {
