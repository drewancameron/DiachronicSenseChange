{
  "sentences": [
    {
      "index": 0,
      "greek": "τί μὴ τοὺς ὀφθαλμούς μου ἀράσομαι εἰ μὴ βαλῶ τὸν κύνα, εἶπεν ἀνὴρ ἀνιστάμενος ἐκ τοῦ πέρα μέρους τῆς σκηνῆς, καὶ σπάσας πιστόλιον ἐκ τῆς ὑποδήματος ἰθύνας ἔβαλεν.",
      "glosses": [
        {
          "anchor": "ἀράσομαι",
          "note": "< αἴρω = ἐκβάλλω",
          "rank": 1
        },
        {
          "anchor": "πιστόλιον",
          "note": "= μικρὸν ὅπλον πυρός",
          "rank": 1
        },
        {
          "anchor": "ἰθύνας",
          "note": "< ἰθύνω = εὐθὺς ποιήσας",
          "rank": 1
        },
        {
          "anchor": "σπάσας",
          "note": "< σπάω = ἐξελκύσας",
          "rank": 1
        },
        {
          "anchor": "ὑποδήματος",
          "note": "= τὸ ποδῶν σκέπασμα",
          "rank": 1
        },
        {
          "anchor": "βαλῶ",
          "note": "< βάλλω = ἀκοντίσω",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "ὁ νέος ζευγίτης εὐθὺς μάχαιραν ἐκ τῆς ἐσθῆτος προενεγκὼν διέρρηξε τὴν σκηνὴν καὶ ἔξω ἔστη εἰς τὸν ὑετόν.",
      "glosses": [
        {
          "anchor": "ζευγίτης",
          "note": "= στρατιώτης μέσος",
          "rank": 1
        },
        {
          "anchor": "προενεγκὼν",
          "note": "< προφέρω = πρότερον ἐξενεγκών",
          "rank": 1
        },
        {
          "anchor": "διέρρηξε",
          "note": "< διαρρήγνυμι = εἰς δύο ἔσχισε",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "ὁ παῖς εἵπετο.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "κύψαντες ἔθεον διὰ τοῦ πηλοῦ πρὸς τὸ πανδοκεῖον.",
      "glosses": [
        {
          "anchor": "πανδοκεῖον",
          "note": "= καταγωγὴ ξένων",
          "rank": 1
        },
        {
          "anchor": "κύψαντες",
          "note": "< κύπτω = κεφαλὴν κάτω ποιήσαντες",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "ἤδη βολαὶ πανταχοῦ ἐν τῇ σκηνῇ καὶ δώδεκα ἔξοδοι διὰ τοῦ λίνου κεκομμέναι καὶ ἄνθρωποι ἐκχεόμενοι, γυναῖκες κραυγάζουσαι, τινὲς πταίοντες, τινὲς καταπατούμενοι ἐν τῷ πηλῷ.",
      "glosses": [
        {
          "anchor": "κεκομμέναι",
          "note": "< κόπτω = τετμημέναι",
          "rank": 1
        },
        {
          "anchor": "ἐκχεόμενοι",
          "note": "< ἐκχέω = ἔξω ῥέοντες",
          "rank": 1
        },
        {
          "anchor": "κραυγάζουσαι",
          "note": "< κραυγάζω = μεγάλῃ φωνῇ βοῶσαι",
          "rank": 1
        },
        {
          "anchor": "καταπατούμενοι",
          "note": "< καταπατέω = ποσὶ βιαίως πατούμενοι",
          "rank": 1
        },
        {
          "anchor": "βολαὶ",
          "note": "= τρύματα ἐκ βελῶν",
          "rank": 1
        },
        {
          "anchor": "πταίοντες",
          "note": "< πταίω = πίπτοντες",
          "rank": 1
        },
        {
          "anchor": "ἔξοδοι",
          "note": "= ὁδοὶ ἐξιέναι",
          "rank": 1
        },
        {
          "anchor": "λίνου",
          "note": "= φυτοῦ ἐξ οὗ ὀθόνη",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "ὁ παῖς καὶ ὁ ἑταῖρος εἰς τὴν στοὰν τοῦ πανδοκείου ἀφικόμενοι τὸ ὕδωρ ἀπὸ τῶν ὀφθαλμῶν ἀπομάξαντες ἐπεστράφησαν θεᾶσθαι.",
      "glosses": [
        {
          "anchor": "ἀπομάξαντες",
          "note": "< ἀπομάσσω = ἀφελόντες σπόγγῳ",
          "rank": 1
        },
        {
          "anchor": "πανδοκείου",
          "note": "= καταγωγῆς ξένων",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "ὡς δὲ ταῦτα ἡ σκηνὴ σαλεύεσθαι ἤρξατο καὶ κυρτοῦσθαι καὶ ὥσπερ μέδουσά τις μεγάλη καὶ τραυματίας ἠρέμα εἰς γῆν καθίζετο ῥάκη λίνου καὶ σχοινία σαθρὰ κατὰ γῆς ἕλκουσα.",
      "glosses": [
        {
          "anchor": "κυρτοῦσθαι",
          "note": "= κυρτὸν γίγνεσθαι",
          "rank": 1
        },
        {
          "anchor": "μέδουσά",
          "note": "= θαλάσσιον θηρίον μαλακόν",
          "rank": 1
        },
        {
          "anchor": "καθίζετο",
          "note": "< καθίζω = εἰς γῆν ἐκάθητο",
          "rank": 1
        },
        {
          "anchor": "ἕλκουσα",
          "note": "< ἕλκω = σύρουσα",
          "rank": 1
        },
        {
          "anchor": "σαλεύεσθαι",
          "note": "= κινεῖσθαι ὧδε κἀκεῖσε",
          "rank": 1
        },
        {
          "anchor": "ῥάκη",
          "note": "= ἐσθὴς διερρηγμένη",
          "rank": 1
        },
        {
          "anchor": "σαθρὰ",
          "note": "= σαπρά, ἀσθενῆ ↔ ἰσχυρά",
          "rank": 1
        },
        {
          "anchor": "λίνου",
          "note": "= φυτοῦ ἐξ οὗ ὀθόνη",
          "rank": 1
        }
      ]
    }
  ]
}