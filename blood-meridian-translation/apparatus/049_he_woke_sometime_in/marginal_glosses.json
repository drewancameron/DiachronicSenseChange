{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἠγέρθη ποτε ἐν τῇ νυκτὶ τῆς καλύβης ἐν σχεδὸν παντελεῖ σκότει οὔσης καὶ τοῦ ἐρημίτου ἐπ' αὐτὸν κεκυφότος καὶ σχεδὸν ἐν τῇ κλίνῃ αὐτοῦ.",
      "glosses": [
        {
          "anchor": "ἐρημίτου",
          "note": "ἐρημίτης = μόνος ἐν ἐρήμῳ βιούς",
          "rank": 1
        },
        {
          "anchor": "κεκυφότος",
          "note": "< κύπτω = κύψας, κεκλιμένος πρός τι",
          "rank": 1
        },
        {
          "anchor": "παντελεῖ",
          "note": "= ὁλοκλήρῳ, τελείῳ",
          "rank": 1
        },
        {
          "anchor": "καλύβη",
          "note": "= οἰκίσκος μικρός",
          "rank": 1
        },
        {
          "anchor": "καλύβης",
          "note": "καλύβη = οἰκίσκος μικρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Τί βούλει;",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "εἶπεν.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Ὁ δὲ ἐρημίτης ἀπέρπυσεν καὶ πρωὶ ὅτε ἠγέρθη ἡ καλύβη κενὴ ἦν καὶ τὰ ἑαυτοῦ λαβὼν ἀπῆλθεν.",
      "glosses": [
        {
          "anchor": "ἐρημίτης",
          "note": "= μόνος ἐν ἐρήμῳ βιούς",
          "rank": 1
        },
        {
          "anchor": "ἀπέρπυσεν",
          "note": "= κρύφα ἀπῆλθεν",
          "rank": 1
        },
        {
          "anchor": "καλύβη",
          "note": "= οἰκίσκος μικρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Πᾶσαν τὴν ἡμέραν ἐκείνην πρὸς βορρᾶν λεπτὴν κόνεως γραμμὴν ἐθεᾶτο.",
      "glosses": [
        {
          "anchor": "κόνεως",
          "note": "κόνις = λεπτὸς χοῦς",
          "rank": 1
        },
        {
          "anchor": "λεπτὴν",
          "note": "= στενήν ↔ παχεῖαν",
          "rank": 1
        },
        {
          "anchor": "γραμμὴν",
          "note": "= μικρὰν εὐθεῖαν γραφήν",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Οὐδὲ κινεῖσθαι ἐδόκει καὶ ὀψία ἑσπέρα ἦν πρὶν ἰδεῖν ὅτι πρὸς αὐτὸν ἤρχετο.",
      "glosses": [
        {
          "anchor": "ὀψία",
          "note": "= ἑσπέρα βαθεῖα",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Διὰ δρυμῶνος δρυῶν αἰειθαλῶν διῆλθεν καὶ παρὰ ῥεῦμα ἐπότισεν καὶ ἐν τῷ κνέφει προῆλθεν καὶ ἄπυρον στρατόπεδον ἐποίησεν.",
      "glosses": [
        {
          "anchor": "δρυμῶνος",
          "note": "= δάσος δένδρων",
          "rank": 1
        },
        {
          "anchor": "αἰειθαλῶν",
          "note": "= ἀεὶ θάλλοντα, ἀεὶ χλωρά",
          "rank": 1
        },
        {
          "anchor": "κνέφει",
          "note": "= σκότος ἑσπερινόν",
          "rank": 1
        },
        {
          "anchor": "δρυῶν",
          "note": "δρῦς = δένδρον μέγα",
          "rank": 1
        },
        {
          "anchor": "ἄπυρον",
          "note": "= χωρὶς πυρός ↔ πυρφόρον",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ὄρνιθες αὐτὸν ἤγειραν ἐν ξηρᾷ καὶ κονιορτώδει ὕλῃ κείμενον.",
      "glosses": [
        {
          "anchor": "κονιορτώδει",
          "note": "< κόνις = κονίεως πλήρης",
          "rank": 1
        }
      ]
    }
  ]
}