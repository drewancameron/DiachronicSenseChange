{
  "passage_id": "006_maltese_boatswain",
  "style": "Ørberg",
  "sentences": [
    {
      "index": 0,
      "greek": "νυκτὶ δή τινι Μελιταῖος κυβερνήτης βάλλει αὐτὸν εἰς τὰ νῶτα μικρῷ πιστολίῳ.",
      "glosses": [
        {
          "anchor": "Μελιταῖος",
          "note": "< Μελίτη (νῆσος Μεσογείου)· = ἐκ Μάλτης"
        },
        {
          "anchor": "πιστολίῳ",
          "note": "= βραχὺ πυροβόλον ὅπλον (νεώτερον)"
        }
      ]
    },
    {
      "index": 1,
      "greek": "στραφεὶς πρὸς τὸν ἄνδρα βάλλεται πάλιν ὑπὸ τὴν καρδίαν.",
      "glosses": [
        {
          "anchor": "στραφεὶς",
          "note": "< στρέφω (ἀόρ. μτχ.)· = ἐπιστραφείς"
        }
      ]
    },
    {
      "index": 2,
      "greek": "ὁ μὲν ἀνὴρ φεύγει, ὁ δὲ προσκλίνεται πρὸς τὸν δοκὸν τοῦ αἵματος ἐκ τοῦ χιτῶνος ῥέοντος.",
      "glosses": [
        {
          "anchor": "προσκλίνεται",
          "note": "προς·κλίνω = ἐρείδεται πρός + αἰτ. ↔ ἀφίσταται"
        },
        {
          "anchor": "ῥέοντος",
          "note": "< ῥέω (μτχ.)· = ἐκχεομένου ↔ ἱσταμένου"
        }
      ]
    },
    {
      "index": 3,
      "greek": "οἱ ἄλλοι ἀποβλέπουσιν.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "μετὰ χρόνον τινὰ κάθηται ἐν τῷ δαπέδῳ.",
      "glosses": [
        {
          "anchor": "δαπέδῳ",
          "note": "= ἔδαφος οἰκίας, χθὼν ἔνδον (δοτ.)"
        }
      ]
    },
    {
      "index": 5,
      "greek": "κεῖται ἐν κλίνῃ ἐν τῷ ὑπερῴῳ δύο ἑβδομάδας, τῆς τοῦ καπήλου γυναικὸς θεραπευούσης αὐτόν.",
      "glosses": [
        {
          "anchor": "καπήλου",
          "note": "= πανδοκεύς, οἰνοπώλης ↔ ξένος"
        }
      ]
    },
    {
      "index": 6,
      "greek": "φέρει τὰ δεῖπνα, ἐκφέρει τὰ λύματα.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "σκληρὰ γυνὴ νευρῶδες σῶμα ἔχουσα ὥσπερ ἀνδρός.",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "ἐπεὶ δὲ ἰᾶται οὐκ ἔχει ἀργύριον ἀποδοῦναι αὐτῇ καὶ ἀπέρχεται νυκτὸς καὶ καθεύδει παρὰ τὴν ὄχθην τοῦ ποταμοῦ ἕως ἂν εὕρῃ πλοῖον ὃ δέξεται αὐτόν.",
      "glosses": [
        {
          "anchor": "ὄχθην",
          "note": "= παραποτάμιος αἰγιαλός, χεῖλος ποταμοῦ (αἰτ.)"
        }
      ]
    },
    {
      "index": 9,
      "greek": "τὸ πλοῖον πλεῖ εἰς *Τέξας.",
      "glosses": []
    }
  ]
}