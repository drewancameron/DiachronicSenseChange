{
  "sentences": [
    {
      "index": 0,
      "greek": "γείτονες, εἶπεν ὁ αἰδέσιμος, οὐκ ἠδύνατο ἀπέχεσθαι τῶνδε, τῶνδε τῶν βαράθρων αὐτοῦ ἐνθάδε ἐν Νακογδόχῃ.",
      "glosses": [
        {
          "anchor": "αἰδέσιμος",
          "note": "= σεβαστός, τίμιος",
          "rank": 1
        },
        {
          "anchor": "βαράθρων",
          "note": "βάραθρον = χάσμα βαθύ, ἄβυσσος",
          "rank": 1
        },
        {
          "anchor": "Νακογδόχῃ",
          "note": "ἴδιον ὄνομα τόπου",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "εἶπον αὐτῷ, εἶπον·",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "μέλλεις ἄγειν τὸν υἱὸν τοῦ θεοῦ ἐκεῖσε μετὰ σοῦ;",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "καὶ εἶπεν·",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "οὐ μά.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "οὐ μέλλω.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "καὶ εἶπον·",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "οὐκ οἶδας ὅτι εἶπεν ἀκολουθήσω σοι ἀεὶ καὶ μέχρι τέλους τῆς ὁδοῦ;",
      "glosses": [
        {
          "anchor": "ἀκολουθήσω",
          "note": "< ἀκολουθέω = ἕπομαι, μετέρχομαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "εἶεν, εἶπεν, οὐ κελεύω οὐδένα ἰέναι οὐδαμοῖ.",
      "glosses": [
        {
          "anchor": "οὐδαμοῖ",
          "note": "= οὐδαμοῦ = εἰς οὐδένα τόπον",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "καὶ εἶπον·",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "γεῖτον, οὐ δεῖ σε κελεύειν.",
      "glosses": [
        {
          "anchor": "γεῖτον",
          "note": "= γείτων, ὁ πλησίον οἰκῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "μέλλει εἶναι ἐκεῖ μετὰ σοῦ πᾶν βῆμα τῆς ὁδοῦ εἴτε αἰτεῖς εἴτε μή.",
      "glosses": [
        {
          "anchor": "αἰτεῖς",
          "note": "< αἰτέω = δέομαι, ἐρωτάω",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "εἶπον·",
      "glosses": []
    },
    {
      "index": 13,
      "greek": "γεῖτον, οὐ δύνασαι ἀπαλλαγῆναι αὐτοῦ.",
      "glosses": [
        {
          "anchor": "γεῖτον",
          "note": "= γείτων, ὁ πλησίον οἰκῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 14,
      "greek": "νῦν.",
      "glosses": []
    },
    {
      "index": 15,
      "greek": "μέλλεις ἕλκειν αὐτόν, αὐτὸν εἰς ἐκεῖνο τὸ βάραθρον;",
      "glosses": []
    }
