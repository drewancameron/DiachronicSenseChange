{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὁ παῖς οὐκ ἔμελλε τοῦτο ποιεῖν καὶ οὐδὲν χρήσιμον ἑώρα ἐν τῷ διαλέγεσθαι.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Ἐλάκτισε τὸν ἄνθρωπον εἰς τὴν γνάθον.",
      "glosses": [
        {
          "anchor": "Ἐλάκτισε",
          "note": "= ποδὶ ἔπαισε",
          "rank": 1
        },
        {
          "anchor": "γνάθον",
          "note": "= τὸ κάτω μέρος προσώπου",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ ἄνθρωπος κατέπεσεν καὶ πάλιν ἀνέστη.",
      "glosses": [
        {
          "anchor": "κατέπεσεν",
          "note": "= εἰς γῆν ἔπεσε",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Εἶπεν·",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Ἀποκτενῶ σε.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Ἔπληξε τῇ λαγύνῳ καὶ ὁ παῖς ὑπέδυ καὶ πάλιν ἔπαισεν καὶ ὁ παῖς ὑπεχώρησεν.",
      "glosses": [
        {
          "anchor": "λαγύνῳ",
          "note": "= ἀγγεῖον οἴνου",
          "rank": 1
        },
        {
          "anchor": "ὑπέδυ",
          "note": "= ὑπὸ κάτω ἔδυ",
          "rank": 1
        },
        {
          "anchor": "Ἔπληξε",
          "note": "= ἔπαισε, ἔκοψε",
          "rank": 1
        },
        {
          "anchor": "ὑπεχώρησεν",
          "note": "= ὀπίσω ἀπῆλθε",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ὅτε ὁ παῖς αὐτὸν ἔπληξεν ὁ ἄνθρωπος τὴν λάγυνον κατέαξε πρὸς τὴν πλευρὰν τῆς κεφαλῆς.",
      "glosses": [
        {
          "anchor": "ἔπληξεν",
          "note": "= ἔπαισε, ἔκοψε",
          "rank": 1
        },
        {
          "anchor": "λάγυνον",
          "note": "= ἀγγεῖον οἴνου",
          "rank": 1
        },
        {
          "anchor": "κατέαξε",
          "note": "= συνέτριψε",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ἀπῆλθεν ἀπὸ τῶν σανίδων εἰς τὸν πηλὸν καὶ ὁ ἄνθρωπος ὥρμησεν κατ' αὐτοῦ μετὰ τοῦ τεθραυσμένου τραχήλου καὶ ἐπειρᾶτο εἰς τὸν ὀφθαλμὸν αὐτοῦ ἐμβαλεῖν.",
      "glosses": [
        {
          "anchor": "τεθραυσμένου",
          "note": "< θραύω = κατεαγότος",
          "rank": 1
        },
        {
          "anchor": "σανίδων",
          "note": "= ξύλων πλατέων",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Ὁ παῖς ἀπήμυνε ταῖς χερσὶν αἵτινες ὀλισθηραὶ ἦσαν αἵματι.",
      "glosses": [
        {
          "anchor": "ἀπήμυνε",
          "note": "= ἠμύνατο, ἀπεκρούσατο",
          "rank": 1
        },
        {
          "anchor": "ὀλισθηραὶ",
          "note": "= ἄστατοι, μὴ βεβαῖαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Αἰεὶ ἐπειρᾶτο εἰς τὴν ὑποδήματα ὀρέγεσθαι ἐπὶ τὴν μάχαιραν.",
      "glosses": [
        {
          "anchor": "ὀρέγεσθαι",
          "note": "= χεῖρα ἐκτείνειν πρός τι",
          "rank": 1
        }
      ]
    }
  ]
}