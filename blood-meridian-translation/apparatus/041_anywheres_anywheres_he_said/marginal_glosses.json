{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὁπουδήποτε, ὁπουδήποτε, ἔφη.",
      "glosses": [
        {
          "anchor": "Ὁπουδήποτε",
          "note": "= εὖ, συγχωρῶ",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ποῦ ἡ σέλλα σου;",
      "glosses": [
        {
          "anchor": "σέλλα",
          "note": "= ἕδρα ἵππου",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ παῖς ἔνευσε τῷ γενείῳ.",
      "glosses": [
        {
          "anchor": "ἔνευσε",
          "note": "< νεύω = τῇ κεφαλῇ ἔδειξε",
          "rank": 1
        },
        {
          "anchor": "γενείῳ",
          "note": "γένειον = πώγων ἀνδρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Μὴ ἀφῇς αὐτὴν ἔξω·",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "φάγεταί τι αὐτήν.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Πεινῶσα χώρα αὕτη.",
      "glosses": [
        {
          "anchor": "Πεινῶσα",
          "note": "< πεινάω = σιτίου δεομένη",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ἐξῆλθε καὶ περιέτυχε τῷ ἡμιόνῳ ἐν τῷ σκότει.",
      "glosses": [
        {
          "anchor": "περιέτυχε",
          "note": "< περι·τυγχάνω = συνήντησε",
          "rank": 1
        },
        {
          "anchor": "ἡμιόνῳ",
          "note": "ἡμίονος = ζῷον ἐξ ὄνου καὶ ἵππου",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Εἱστήκει βλέπων εἰς τὸ πῦρ.",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "Ἄπελθε, ἠλίθιε, ἔφη.",
      "glosses": [
        {
          "anchor": "ἠλίθιε",
          "note": "= μῶρε, ἄφρων",
          "rank": 1
        },
        {
          "anchor": "Ἄπελθε",
          "note": "< ἀπ·έρχομαι = χώρει ἐντεῦθεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Ἀνέλαβε τὴν σέλλαν καὶ πάλιν εἰσῆλθεν.",
      "glosses": [
        {
          "anchor": "σέλλαν",
          "note": "σέλλα = ἕδρα ἵππου",
          "rank": 1
        },
        {
          "anchor": "σέλλα",
          "note": "= ἕδρα ἵππου",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Νῦν ἕλκε τὴν θύραν πρὶν ἀποπνευσθῆναι, εἶπεν ὁ γέρων.",
      "glosses": [
        {
          "anchor": "ἀποπνευσθῆναι",
          "note": "< ἀπο·πνέω = παύσασθαι πνέοντα",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Ἡ θύρα πλῆθος σανίδων ἐπὶ σκυτίνων στροφέων.",
      "glosses": [
        {
          "anchor": "σκυτίνων",
          "note": "< σκῦτος = ἐκ δέρματος πεποιημένων",
          "rank": 1
        },
        {
          "anchor": "στροφέων",
          "note": "στροφεύς = ὁ περιστρεφόμενος",
          "rank": 1
        },
        {
          "anchor": "σανίδων",
          "note": "σανίς = ξύλον πλατύ",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Εἵλκυσεν αὐτὴν διὰ τῆς κόνεως καὶ ἔδησε τῷ σκυτίνῳ ὄχει.",
      "glosses": [
        {
          "anchor": "κόνεως",
          "note": "κόνις = χοῦς λεπτή",
          "rank": 1
        },
        {
          "anchor": "σκυτίνῳ",
          "note": "< σκῦτος = ἐκ δέρματος πεποιημένῳ",
          "rank": 1
        },
        {
          "anchor": "ὄχει",
          "note": "ὀχεύς = δεσμὸς στερεός",
          "rank": 1
        },
        {
          "anchor": "Εἵλκυσεν",
          "note": "< ἕλκω = ἐσπάσατο",
          "rank": 1
        }
      ]
    }
  ]
}