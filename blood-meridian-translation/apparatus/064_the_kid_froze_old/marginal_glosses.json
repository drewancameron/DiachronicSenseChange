{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὁ παῖς ἐπάγη.",
      "glosses": [
        {
          "anchor": "ἐπάγη",
          "note": "πήγνυμι = στερεῶς ἵστημι, ἐνταῦθα = ἵσταμαι φοβούμενος",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Γέρον, εἶπεν.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "Ὁ γέρων οὐκ ἀπεκρίνατο.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Οὐδεμία φωνὴ ἐν τῷ καπηλείῳ.",
      "glosses": [
        {
          "anchor": "καπηλείῳ",
          "note": "καπηλεῖον < κάπηλος = οἰκία πωλήσεως οἴνου",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ὁ παῖς ἐστράφη ζητῶν αὐτὸν τοῖς ὀφθαλμοῖς.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Esta borracho, εἶπεν ὁ γέρων.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Ὁ παῖς ἐθεᾶτο τοὺς ὀφθαλμοὺς τοῦ κάπηλου.",
      "glosses": [
        {
          "anchor": "κάπηλου",
          "note": "κάπηλος = οἶνον πωλῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ὁ κάπηλος ἔσεισε τὸ πιστόλιον πρὸς τὴν θύραν.",
      "glosses": [
        {
          "anchor": "ἔσεισε",
          "note": "σείω = κινέω ἔνθα κἀκεῖσε",
          "rank": 1
        },
        {
          "anchor": "πιστόλιον",
          "note": "μικρὸν ὅπλον βάλλον",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "οἶνον πωλῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Ὁ γέρων ἔλεξε τῷ οἴκῳ Ἱσπανιστί.",
      "glosses": [
        {
          "anchor": "Ἱσπανιστί",
          "note": "τῇ Ἱσπάνων γλώττῃ",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Εἶτα ἔλεξε τῷ καπήλῳ.",
      "glosses": [
        {
          "anchor": "καπήλῳ",
          "note": "κάπηλος = οἶνον πωλῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Εἶτα ἐπιθέμενος τὸν πέτασον ἐξῆλθεν.",
      "glosses": [
        {
          "anchor": "πέτασον",
          "note": "πλατὺς πῖλος κεφαλῆς",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Τὸ πρόσωπον τοῦ κάπηλου ἐξέλιπεν.",
      "glosses": [
        {
          "anchor": "κάπηλου",
          "note": "κάπηλος = οἶνον πωλῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Ὅτε περιῆλθε τὸ ἄκρον τοῦ ἀβακίου τὸ πιστόλιον κατατεθεικὼς ἦν καὶ σφῆνα ἔφερεν ἐν τῇ χειρί.",
      "glosses": [
        {
          "anchor": "πιστόλιον",
          "note": "μικρὸν ὅπλον βάλλον",
          "rank": 1
        },
        {
          "anchor": "ἀβακίου",
          "note": "ἀβάκιον = μικρὸς ἄβαξ, τράπεζα",
          "rank": 1
        },
        {
          "anchor": "κατατεθεικὼς",
          "note": "κατατίθημι = κάτω τίθημι",
          "rank": 1
        },
        {
          "anchor": "σφῆνα",
          "note": "ὀξὺ σιδήριον εἰς κόπτειν",
          "rank": 1
        }
      ]
    }
  ]
}