{
  "sentences": [
    {
      "index": 0,
      "greek": "Οὐ φέρεις καπνὸν μετὰ σεαυτοῦ, ἦ γάρ;",
      "glosses": [
        {
          "anchor": "φέρεις",
          "note": "φέρω: ἔχω μετὰ ἐμαυτοῦ",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Οὔ, εἶπεν ὁ παῖς.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "Οὐκ ᾤμην γε.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Οἴει ὕσειν;",
      "glosses": [
        {
          "anchor": "ὕσειν",
          "note": "ὕω: ὑετὸν ἀπὸ τοῦ οὐρανοῦ πέμπειν",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Πᾶσα πρόφασις.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Εἰκὸς οὐχί.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Ὁ παῖς τὸ πῦρ ἐθεᾶτο.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "Ἤδη ἐνεύσταζε.",
      "glosses": [
        {
          "anchor": "ἐνεύσταζε",
          "note": "νυστάζω: τοὺς ὀφθαλμοὺς κλείειν ὑπὸ ὕπνου",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Τέλος ἀνίστη καὶ τὴν κεφαλὴν ἔσεισε.",
      "glosses": [
        {
          "anchor": "ἔσεισε",
          "note": "σείω: κινέω ἔνθα καὶ ἔνθα",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Ὁ ἐρημίτης αὐτὸν ὑπὲρ τὰς σβεννυμένας φλόγας ἐθεώρει.",
      "glosses": [
        {
          "anchor": "ἐρημίτης",
          "note": "< ἔρημος: ὁ μόνος ἐν ἐρήμῳ ζῶν",
          "rank": 1
        },
        {
          "anchor": "σβεννυμένας",
          "note": "σβέννυμι: παύω καίοντα",
          "rank": 1
        },
        {
          "anchor": "φλόγας",
          "note": "φλόξ, φλογός: τὸ καῖον μέρος πυρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Ἴθι καὶ εὐνὴν κόσμει, εἶπεν.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "Ἐποίησεν.",
      "glosses": []
    },
    {
      "index": 12,
      "greek": "Στρώματα ἐπὶ τοῦ πεπιλημένου πηλοῦ πετάσας καὶ τὰς δυσώδεις ἐμβάδας ἀποδύς.",
      "glosses": [
        {
          "anchor": "πεπιλημένου",
          "note": "πιλέω: πυκνόω πατοῦσα",
          "rank": 1
        },
        {
          "anchor": "πετάσας",
          "note": "πετάννυμι: ἐκτείνω καὶ στρώννυμι",
          "rank": 1
        },
        {
          "anchor": "ἐμβάδας",
          "note": "ἐμβάς, ἐμβάδος: ὑπόδημα ↔ ἀνυπόδετος",
          "rank": 1
        },
        {
          "anchor": "δυσώδεις",
          "note": "δυσ·ώδης: κακὴν ὀσμὴν ἔχων",
          "rank": 1
        },
        {
          "anchor": "ἀποδύς",
          "note": "ἀποδύω: ἱμάτια ἀφαιρέω",
          "rank": 1
        }
      ]
    },
    {
      "index": 13,
      "greek": "Ὁ καπνοδόχος ᾤμωξε καὶ τὸν ἡμίονον ἔξω κτυποῦντα καὶ φρυάττοντα ἤκουσε καὶ ἐν τῷ ὕπνῳ ἠγωνίζετο καὶ ἐτονθόρυζεν ὥσπερ κύων ὀνειρώττων.",
      "glosses": [
        {
          "anchor": "καπνοδόχος",
          "note": "καπνο·δόχος: ὁδὸς καπνοῦ ἀνὰ τεῖχος",
          "rank": 1
        },
        {
          "anchor": "ᾤμωξε",
          "note": "οἰμώζω: φωνὴν λύπης ἀφίημι",
          "rank": 1
        },
        {
          "anchor": "κτυποῦντα",
          "note": "κτυπέω: ψόφον ποδῶν ποιέω",
          "rank": 1
        },
        {
          "anchor": "φρυάττοντα",
          "note": "φρυάττω: ἦχον διὰ μυκτήρων ἀφίημι",
          "rank": 1
        },
        {
          "anchor": "ἐτονθόρυζεν",
          "note": "τονθορύζω: ἀσαφῶς μυκάομαι",
          "rank": 1
        },
        {
          "anchor": "ὀνειρώττων",
          "note": "ὀνειρώττω: ὀνείρατα ὁρῶ",
          "rank": 1
        },
        {
          "anchor": "ἠγωνίζετο",
          "note": "ἀγωνίζομαι: ἐνταῦθα = μάχομαι ἐν ὕπνῳ",
          "rank": 1
        }
      ]
    }
  ]
}