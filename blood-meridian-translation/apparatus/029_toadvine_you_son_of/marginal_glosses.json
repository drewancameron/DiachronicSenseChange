{
  "sentences": [
    {
      "index": 0,
      "greek": "Τοαδβίνη, υἱὲ κυνός, ἔφη.",
      "glosses": [
        {
          "anchor": "Τοαδβίνη",
          "note": "ὄνομα ἀνδρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ὁ Τοαδβίνης τέτταρας βαθμοὺς ἦν ὑπὲρ αὐτοῦ καὶ ὅτε ἐλάκτισεν αὐτὸν ἔβαλεν εἰς τὸν λαιμόν.",
      "glosses": [
        {
          "anchor": "Τοαδβίνη",
          "note": "ὄνομα ἀνδρός",
          "rank": 1
        },
        {
          "anchor": "Τοαδβίνης",
          "note": "ὄνομα ἀνδρός",
          "rank": 1
        },
        {
          "anchor": "ἐλάκτισεν",
          "note": "< λακτίζω = ποσὶν ἔπαισεν",
          "rank": 1
        },
        {
          "anchor": "βαθμοὺς",
          "note": "κλίμακες λίθιναι",
          "rank": 1
        },
        {
          "anchor": "λαιμόν",
          "note": "μέρος σώματος μεταξὺ κεφαλῆς καὶ στήθους",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ γραμματεὺς ἐκάθισεν ἐπὶ τοὺς βαθμούς.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Ὅτε ὁ παῖς παρῆλθεν ἔπαισεν αὐτὸν κατὰ τὸ πλευρὸν τῆς κεφαλῆς καὶ ὁ γραμματεὺς κατέπεσεν καὶ ἤρξατο ὀλισθάνειν πρὸς τὴν βάσιν.",
      "glosses": [
        {
          "anchor": "κατέπεσεν",
          "note": "< καταπίπτω = χαμαὶ ἔπεσεν",
          "rank": 1
        },
        {
          "anchor": "ὀλισθάνειν",
          "note": "λείως κατὰ γῆς φέρεσθαι",
          "rank": 1
        },
        {
          "anchor": "πλευρὸν",
          "note": "μέρος πλάγιον",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ὁ παῖς ὑπερέβη αὐτὸν καὶ κατέβη εἰς τὴν αὐλὴν καὶ διῆλθεν πρὸς τὴν θύραν τὴν ἔξω.",
      "glosses": [
        {
          "anchor": "ὑπερέβη",
          "note": "< ὑπερβαίνω = διῆλθεν ὑπεράνω",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ὁ Τοαδβίνης ἔθει κατὰ τὴν ὁδὸν σείων τὰς πυγμὰς ὑπὲρ τῆς κεφαλῆς μαινομένως καὶ γελῶν.",
      "glosses": [
        {
          "anchor": "Τοαδβίνη",
          "note": "ὄνομα ἀνδρός",
          "rank": 1
        },
        {
          "anchor": "Τοαδβίνης",
          "note": "ὄνομα ἀνδρός",
          "rank": 1
        },
        {
          "anchor": "πυγμὰς",
          "note": "χεῖρες συνεσφιγμέναι πρὸς μάχην",
          "rank": 1
        },
        {
          "anchor": "μαινομένως",
          "note": "< μαίνομαι = ὡς μανιώδης",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ἐῴκει μεγάλῳ πηλίνῳ ἀγάλματι ἐμψυχωθέντι καὶ ὁ παῖς ἄλλῳ.",
      "glosses": [
        {
          "anchor": "ἐμψυχωθέντι",
          "note": "< ἐμψυχόω = ψυχὴν λαβόντι",
          "rank": 1
        },
        {
          "anchor": "πηλίνῳ",
          "note": "< πηλός = ἐκ πηλοῦ πεποιημένῳ",
          "rank": 1
        },
        {
          "anchor": "ἀγάλματι",
          "note": "εἰκὼν λιθίνη θεῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ὄπισθεν αὐτῶν φλόγες περιέλειχον τὴν ἄνω γωνίαν τοῦ πανδοκείου καὶ νέφη μέλανος καπνοῦ ἀνέβαινεν εἰς τὸν θερμὸν ὄρθρον τοῦ Τέξας.",
      "glosses": [
        {
          "anchor": "περιέλειχον",
          "note": "< περιλείχω = κύκλῳ ἐλείχοντο",
          "rank": 1
        },
        {
          "anchor": "Τέξας",
          "note": "ὄνομα χώρας",
          "rank": 1
        },
        {
          "anchor": "πανδοκείου",
          "note": "οἶκος ξένων δεχόμενος",
          "rank": 1
        },
        {
          "anchor": "γωνίαν",
          "note": "τόπος ὅπου δύο τοῖχοι συμβάλλουσι",
          "rank": 1
        },
        {
          "anchor": "φλόγες",
          "note": "πῦρ καιόμενον",
          "rank": 1
        }
      ]
    }
  ]
}