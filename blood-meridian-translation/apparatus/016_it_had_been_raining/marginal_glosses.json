{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἑκκαίδεκα ἡμέρας ὗεν ὅτε τῷ Τοαδβίνῃ συνέβαλε καὶ ἔτι ὗεν.",
      "glosses": [
        {
          "anchor": "ὗεν",
          "note": "< ὕω (πρτ. ἐν.) = fall down in rain, in a shower",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ἔτι ἵστατο ἐν τῷ αὐτῷ καπηλείῳ καὶ κατεπεπώκει πᾶν τὸ ἀργύριον πλὴν δυοῖν στατήρων.",
      "glosses": [
        {
          "anchor": "κατεπεπώκει",
          "note": "< καταπίνω (ὑπερσ. ἐν.) = gulp, swallow down",
          "rank": 1
        },
        {
          "anchor": "καπηλείῳ",
          "note": "= shop",
          "rank": 1
        },
        {
          "anchor": "στατήρων",
          "note": "< στατήρ = one who owes money, debtor",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ ἡνίοχος ᾤχετο, τὸ οἴκημα σχεδὸν κενόν.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Ἡ θύρα ἀνέῳκτο καὶ ἦν ἰδεῖν τὸν ὑετὸν πίπτοντα εἰς τὸ κενὸν χωρίον ὄπισθεν τοῦ πανδοκείου.",
      "glosses": [
        {
          "anchor": "πανδοκείου",
          "note": "= inn",
          "rank": 1
        },
        {
          "anchor": "ἀνέῳκτο",
          "note": "< ἀνοίγνυμι (ὑπερσ. μέσ.) = open",
          "rank": 1
        },
        {
          "anchor": "πίπτοντα",
          "note": "< πίπτω (ἐνεστ. μτχ. ἐν.) = fall down",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ἐξέπινε τὴν κύλικα καὶ ἐξῆλθεν.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Σανίδες ἔκειντο διὰ τῆς ἰλύος καὶ εἵπετο τῇ ὠχρᾷ ταινίᾳ φωτὸς θυρῶν κάτω πρὸς τοὺς σανιδωτοὺς ἀφέδρωνας ἐν τῷ πυθμένι τοῦ χωρίου.",
      "glosses": [
        {
          "anchor": "σανιδωτοὺς",
          "note": "= planked, boarded over",
          "rank": 1
        },
        {
          "anchor": "ὠχρᾷ",
          "note": "= yellow ochre",
          "rank": 1
        },
        {
          "anchor": "ταινίᾳ",
          "note": "= band, fillet",
          "rank": 1
        },
        {
          "anchor": "πυθμένι",
          "note": "= bottom",
          "rank": 1
        },
        {
          "anchor": "ἰλύος",
          "note": "= mud, slime",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ἄλλος ἀνὴρ ἀνῄει ἐκ τῶν ἀφεδρώνων καὶ συνήντησαν μέσῳ ἐπὶ ταῖς στεναῖς σανίσιν.",
      "glosses": [
        {
          "anchor": "ἀφεδρώνων",
          "note": "= privy",
          "rank": 1
        },
        {
          "anchor": "στεναῖς",
          "note": "= narrow ↔ εὐρύς",
          "rank": 1
        },
        {
          "anchor": "σανίσιν",
          "note": "= door",
          "rank": 1
        },
        {
          "anchor": "ἀνῄει",
          "note": "< ἄνειμι (πρτ. ἐν.) = go up",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ὁ πρὸ αὐτοῦ ἀνὴρ μικρὸν ἐσφάλλετο.",
      "glosses": [
        {
          "anchor": "ἐσφάλλετο",
          "note": "< σφάλλω (πρτ. μέσ.) = make to fall, overthrow",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Τὸ ὑγρὸν χεῖλος τοῦ πίλου κατέπιπτεν ἐπὶ τοὺς ὤμους πλὴν τοῦ πρόσθεν ὅπου ἀνέκειτο.",
      "glosses": [
        {
          "anchor": "κατέπιπτεν",
          "note": "= fell",
          "rank": 1
        },
        {
          "anchor": "πίλου",
          "note": "< πῖλος (γεν.) = anything made of felt",
          "rank": 1
        },
        {
          "anchor": "ἀνέκειτο",
          "note": "= be laid up",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Λάγυνον χαλαρῶς ἐν μιᾷ χειρὶ εἶχεν.",
      "glosses": [
        {
          "anchor": "χαλαρῶς",
          "note": "= slack, loose",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Ἄμεινον ἐκ τῆς ὁδοῦ μου ἐκστῆναι, ἔφη.",
      "glosses": []
    }
  ]
}