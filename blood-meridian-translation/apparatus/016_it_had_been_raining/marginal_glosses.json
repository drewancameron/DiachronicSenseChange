{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἑκκαίδεκα ἡμέρας ὗεν ὅτε τῷ Τοαδβίνῃ συνέβαλε καὶ ἔτι ὗεν.",
      "glosses": [
        {
          "anchor": "ὗεν",
          "note": "= ὑετὸς ἔπιπτεν",
          "rank": 1
        },
        {
          "anchor": "Τοαδβίνῃ",
          "note": "ὄνομα ἀνδρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ἔτι ἵστατο ἐν τῷ αὐτῷ καπηλείῳ καὶ κατεπεπώκει πᾶν τὸ ἀργύριον πλὴν δυοῖν στατήρων.",
      "glosses": [
        {
          "anchor": "κατεπεπώκει",
          "note": "< κατα·πίνω = διὰ πόσεως κατηνάλωκε",
          "rank": 1
        },
        {
          "anchor": "καπηλείῳ",
          "note": "= τόπος πώσεως καὶ ἐσθίσεως",
          "rank": 1
        },
        {
          "anchor": "στατήρων",
          "note": "γεν. πληθ. < στατήρ = νόμισμα ἀργυροῦν",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ ἡνίοχος ᾤχετο, τὸ οἴκημα σχεδὸν κενόν.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Ἡ θύρα ἀνέῳκτο καὶ ἦν ἰδεῖν τὸν ὑετὸν πίπτοντα εἰς τὸ κενὸν χωρίον ὄπισθεν τοῦ πανδοκείου.",
      "glosses": [
        {
          "anchor": "πανδοκείου",
          "note": "γεν. < πανδοκεῖον = τόπος ξένων καταγωγῆς",
          "rank": 1
        },
        {
          "anchor": "ἀνέῳκτο",
          "note": "< ἀν·οίγνυμι = ἠνοιγμένη ἦν",
          "rank": 1
        },
        {
          "anchor": "πίπτοντα",
          "note": "μετοχ. < πίπτω = καταβαίνοντα",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ἐξέπινε τὴν κύλικα καὶ ἐξῆλθεν.",
      "glosses": [
        {
          "anchor": "Ἐξέπινε",
          "note": "< ἐκ·πίνω = πᾶσαν κύλικα ἔπιε",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Σανίδες ἔκειντο διὰ τῆς ἰλύος καὶ εἵπετο τῇ ὠχρᾷ ταινίᾳ φωτὸς θυρῶν κάτω πρὸς τοὺς σανιδωτοὺς ἀφέδρωνας ἐν τῷ πυθμένι τοῦ χωρίου.",
      "glosses": [
        {
          "anchor": "σανιδωτοὺς",
          "note": "< σανίς = ἐκ σανίδων πεποιημένους",
          "rank": 1
        },
        {
          "anchor": "ἀφέδρωνας",
          "note": "= τόπους ἀποπατήσεως",
          "rank": 1
        },
        {
          "anchor": "ὠχρᾷ",
          "note": "= λευκῇ ὡς νοσοῦντος ↔ ἐρυθρᾷ",
          "rank": 1
        },
        {
          "anchor": "ταινίᾳ",
          "note": "= στενὸς δεσμὸς φωτός",
          "rank": 1
        },
        {
          "anchor": "πυθμένι",
          "note": "= τῷ κατωτάτῳ μέρει ↔ ἄκρῳ",
          "rank": 1
        },
        {
          "anchor": "Σανίδες",
          "note": "= στενὰ ξύλινα δοκάρια ὁδοῦ",
          "rank": 1
        },
        {
          "anchor": "ἰλύος",
          "note": "γεν. < ἰλύς = ὑγρὰ γῆ μετὰ ὕδατος",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Ἄλλος ἀνὴρ ἀνῄει ἐκ τῶν ἀφεδρώνων καὶ συνήντησαν μέσῳ ἐπὶ ταῖς στεναῖς σανίσιν.",
      "glosses": [
        {
          "anchor": "ἀφεδρώνων",
          "note": "γεν. πληθ. < ἀφεδρών = τόπος ἀποπατήσεως",
          "rank": 1
        },
        {
          "anchor": "στεναῖς",
          "note": "= μὴ πλατείαις ↔ εὐρείαις",
          "rank": 1
        },
        {
          "anchor": "σανίσιν",
          "note": "δοτ. πληθ. < σανίς = ξύλινα στενὰ δοκάρια",
          "rank": 1
        },
        {
          "anchor": "ἀνῄει",
          "note": "< ἄνειμι = πρὸς τὰ ἄνω ἐπορεύετο",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ὁ πρὸ αὐτοῦ ἀνὴρ μικρὸν ἐσφάλλετο.",
      "glosses": [
        {
          "anchor": "ἐσφάλλετο",
          "note": "= μικρὸν ἔπιπτεν, οὐκ εὖ ἵστατο",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Τὸ ὑγρὸν χεῖλος τοῦ πίλου κατέπιπτεν ἐπὶ τοὺς ὤμους πλὴν τοῦ πρόσθεν ὅπου ἀνέκειτο.",
      "glosses": [
        {
          "anchor": "κατέπιπτεν",
          "note": "< κατα·πίπτω = κάτω ἔπιπτε",
          "rank": 1
        },
        {
          "anchor": "πίλου",
          "note": "γεν. < πῖλος = περικεφαλαία ἐκ μαλλοῦ",
          "rank": 1
        },
        {
          "anchor": "ἀνέκειτο",
          "note": "< ἀνα·κεῖμαι = ἄνω ἐτέτακτο",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Λάγυνον χαλαρῶς ἐν μιᾷ χειρὶ εἶχεν.",
      "glosses": [
        {
          "anchor": "χαλαρῶς",
          "note": "= μὴ σφίγγων ↔ σφιγκτῶς",
          "rank": 1
        },
        {
          "anchor": "Λάγυνον",
          "note": "= στενόστομον ἀγγεῖον οἴνου",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Ἄμεινον ἐκ τῆς ὁδοῦ μου ἐκστῆναι, ἔφη.",
      "glosses": []
    }
  ]
}