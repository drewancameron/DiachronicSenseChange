{
  "sentences": [
    {
      "index": 0,
      "greek": "μετὰ ἐποίκων καὶ Τεξάνων καὶ Μεξικανῶν καὶ μετὰ δούλων καὶ Λιπὰν Ἰνδῶν καὶ πρεσβειῶν Καρανκάουα ὑψηλῶν καὶ σεμνῶν, πρόσωπα κυάνεα βεβαμμένων, χεῖρας περὶ ξύλα ἑξαπόδων δοράτων κλῃδωμένας.",
      "glosses": [
        {
          "anchor": "πρεσβειῶν",
          "note": "= deputations",
          "rank": 1
        },
        {
          "anchor": "ὑψηλῶν",
          "note": "= tall ↔ ταπεινός",
          "rank": 1
        },
        {
          "anchor": "σεμνῶν",
          "note": "= austere ↔ χαῦνος",
          "rank": 1
        },
        {
          "anchor": "κλῃδωμένας",
          "note": "= locked, barred",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "σχεδὸν γυμνοὶ βάρβαροι, οἳ χρωσὶ κεχρισμέναις καὶ γεύσει σαρκὸς ἀνθρωπείας ψιθυριζομένῃ δεινοὶ πάρεδροι ἐφαίνοντο καὶ ἐν ἐκείνῃ τῇ μυθώδει ὁμιλίᾳ.",
      "glosses": [
        {
          "anchor": "γυμνοὶ",
          "note": "= naked ↔ ὁπλιτοδρόμος",
          "rank": 1
        },
        {
          "anchor": "ψιθυριζομένῃ",
          "note": "= whispered",
          "rank": 1
        },
        {
          "anchor": "ἀνθρωπείας",
          "note": "= human ↔ θεῖος",
          "rank": 1
        },
        {
          "anchor": "δεινοὶ",
          "note": "= outrageous ↔ σοφός",
          "rank": 1
        },
        {
          "anchor": "μυθώδει",
          "note": "= fabled",
          "rank": 1
        },
        {
          "anchor": "ὁμιλίᾳ",
          "note": "= company ↔ βίᾳ",
          "rank": 1
        },
        {
          "anchor": "πάρεδροι",
          "note": "= seated beside, assessors",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "οἱ νεόλεκτοι ἤλαυνον ζῷα πυκνὰ χαλινωθέντα καὶ ἀνεστράφησαν παρὰ τὸ δικαστήριον καὶ παρὰ τείχη ὑψηλὰ τοῦ δεσμωτηρίου, ὕαλος συντετριμμένη ἐν ἀκροτάτῃ πλίνθῳ ἐμπεπηγυῖα.",
      "glosses": [
        {
          "anchor": "χαλινωθέντα",
          "note": "= reined",
          "rank": 1
        },
        {
          "anchor": "δεσμωτηρίου",
          "note": "= carcel",
          "rank": 1
        },
        {
          "anchor": "ὕαλος",
          "note": "= glass",
          "rank": 1
        },
        {
          "anchor": "πλίνθῳ",
          "note": "= course",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "ἐν τῇ κυρίᾳ ἀγορᾷ χορὸς συνειστήκει καὶ ἦσαν ἁρμόζοντες τὰ ὄργανα.",
      "glosses": [
        {
          "anchor": "ἁρμόζοντες",
          "note": "= tuning",
          "rank": 1
        },
        {
          "anchor": "ὄργανα",
          "note": "= instruments",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "οἱ ἱππόται κατεστράφησαν εἰς τὴν Σαλίνας ὁδὸν παρὰ μικρὰ κυβευτήρια καὶ καφὲ περίπτερα καὶ ἦσαν ἐν ταύτῃ τῇ ὁδῷ ἀριθμὸς Μεξικανῶν ἱμαντοποιῶν καὶ ἐμπόρων καὶ φυλάκων ἀλεκτόρων μαχητῶν καὶ σκυτοτόμων καὶ ὑποδηματοποιῶν ἐν μικραῖς φάτναις ἢ καταστήμασι πηλίνοις.",
      "glosses": [
        {
          "anchor": "ἱππόται",
          "note": "= riders",
          "rank": 1
        },
        {
          "anchor": "μικρὰ",
          "note": "= small ↔ μέγας",
          "rank": 1
        },
        {
          "anchor": "περίπτερα",
          "note": "= stands",
          "rank": 1
        },
        {
          "anchor": "σκυτοτόμων",
          "note": "= cobblers",
          "rank": 1
        },
        {
          "anchor": "φάτναις",
          "note": "= stalls",
          "rank": 1
        },
        {
          "anchor": "καταστήμασι",
          "note": "= shops",
          "rank": 1
        },
        {
          "anchor": "ἱμαντοποιῶν",
          "note": "= leather strap makers",
          "rank": 1
        },
        {
          "anchor": "μαχητῶν",
          "note": "= fighters, warriors",
          "rank": 1
        },
        {
          "anchor": "ὑποδηματοποιῶν",
          "note": "= shoemakers, cobblers",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "ὁ δεύτερος δεκαδάρχης ἦν ἀπὸ Τέξας καὶ ἐλάλει μικρὰ Ἱσπανικά, διενοεῖτο δὲ τὴν ἡμίονον ἀλλάξασθαι.",
