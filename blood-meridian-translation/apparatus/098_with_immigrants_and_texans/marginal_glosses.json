          "note": "= clean ↔ σκιά",
          "rank": 1
        },
        {
          "anchor": "χιτωνίσκους",
          "note": "= shirts",
          "rank": 1
        },
        {
          "anchor": "ἐσμηγμένοι",
          "note": "= anointed, rubbed with oil",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "ἕκαστος προορῶν νύκτα πόσεως, ἴσως ἔρωτος.",
      "glosses": [
