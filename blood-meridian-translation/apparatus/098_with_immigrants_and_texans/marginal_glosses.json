          "anchor": "ἕτερος",
          "note": "= other ↔ ἀμφοτέρως",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "ἦσαν ἐν ἀγαθοῖς θυμοῖς, ἐσμηγμένοι καὶ κτενισμένοι, χιτωνίσκους καθαροὺς πάντες.",
      "glosses": [
        {
          "anchor": "καθαροὺς",
          "note": "= scrubbed",
