        {
          "anchor": "δεύτερος",
          "note": "= second",
          "rank": 1
        },
        {
          "anchor": "Τέξας",
          "note": "= texas",
          "rank": 1
        },
        {
          "anchor": "ἐλάλει",
          "note": "= spoke",
          "rank": 1
        },
        {
          "anchor": "Ἱσπανικά",
          "note": "= spanish",
          "rank": 1
        },
        {
          "anchor": "ἡμίονον",
          "note": "= mule",
          "rank": 1
        },
        {
          "anchor": "δεκαδάρχης",
          "note": "= commander of ten",
          "rank": 1
        },
        {
          "anchor": "ἀλλάξασθαι",
          "note": "= to exchange, barter",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "ὁ ἕτερος παῖς ἦν ἀπὸ Μισσουρίου.",
      "glosses": [
