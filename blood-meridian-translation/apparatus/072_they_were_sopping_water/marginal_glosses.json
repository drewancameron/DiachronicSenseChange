      "glosses": []
    },
    {
      "index": 6,
      "greek": "Ἡμίονον ἀπώλεσα.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "Οἶμαι ταύτῃ ἐλθεῖν.",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "Ὁ μέλας τῷ ὄπισθεν τοῦ βραχίονος τὸ πρόσωπον ἀπέμαξεν.",
