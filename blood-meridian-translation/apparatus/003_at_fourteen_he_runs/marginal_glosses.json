{
  "sentences": [
    {
      "index": 0,
      "greek": "ἐν τέτταρσι καὶ δέκα ἔτεσιν ἀποδιδράσκει.",
      "glosses": [
        {
          "anchor": "ἀποδιδράσκει",
          "note": "= φεύγει κρύφα",
          "rank": 1
        },
        {
          "anchor": "τέτταρσι",
          "note": "= τέσσαρσι",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "οὐκέτι ὄψεται τὸν ψυχρὸν μαγειρικὸν οἶκον ἐν τῷ πρὸ ἕω σκότει.",
      "glosses": [
        {
          "anchor": "μαγειρικὸν",
          "note": "< μάγειρος = πρὸς μαγείρευσιν",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "τὰ ξύλα, τοὺς λουτῆρας.",
      "glosses": [
        {
          "anchor": "λουτῆρας",
          "note": "= σκεύη πρὸς λοῦσιν",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "πλανᾶται πρὸς ἑσπέραν μέχρι Μέμφιδος, μόνος μετανάστης ἐπὶ τῆς πεδινῆς καὶ ποιμενικῆς χώρας.",
      "glosses": [
        {
          "anchor": "μετανάστης",
          "note": "= ἐκ τόπου εἰς τόπον μεθιστάμενος",
          "rank": 1
        },
        {
          "anchor": "ποιμενικῆς",
          "note": "< ποιμήν = πρὸς ποίμνια",
          "rank": 1
        },
        {
          "anchor": "Μέμφιδος",
          "note": "= πόλις Αἰγύπτου",
          "rank": 1
        },
        {
          "anchor": "πεδινῆς",
          "note": "< πεδίον = ἐν πεδίῳ ↔ ὀρεινή",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "μέλανες ἐν τοῖς ἀγροῖς, ἰσχνοὶ καὶ κύπτοντες, οἱ δάκτυλοι αὐτῶν ἀραχνώδεις ἐν τοῖς κώδυσι τοῦ ἐρίου.",
      "glosses": [
        {
          "anchor": "ἰσχνοὶ",
          "note": "= λεπτοί ↔ παχεῖς",
          "rank": 1
        },
        {
          "anchor": "κύπτοντες",
          "note": "< κύπτω = κεφαλὴν κάτω κλίνοντες",
          "rank": 1
        },
        {
          "anchor": "ἀραχνώδεις",
          "note": "< ἀράχνη = ἀράχναις ὅμοιοι",
          "rank": 1
        },
        {
          "anchor": "κώδυσι",
          "note": "= μαλλοῖς προβάτων",
          "rank": 1
        },
        {
          "anchor": "ἐρίου",
          "note": "= μαλλὸς προβάτων",
          "rank": 1
        },
        {
          "anchor": "μέλανες",
          "note": "= μαῦροι ↔ λευκοί",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "σκιώδης ἀγωνία ἐν τῷ κήπῳ.",
      "glosses": [
        {
          "anchor": "σκιώδης",
          "note": "< σκιά = σκιὰς ἔχων ↔ λαμπρός",
          "rank": 1
        },
        {
          "anchor": "ἀγωνία",
          "note": "= φόβος καὶ λύπη",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "πρὸς τὸν δύνοντα ἥλιον σχήματα κινούμενα ἐν τῇ βραδυτέρᾳ κνέφῃ διὰ χαρτίνης γραμμῆς.",
      "glosses": [
        {
          "anchor": "κνέφῃ",
          "note": "= σκότος ἑσπερινόν ↔ ἕως",
          "rank": 1
        },
        {
          "anchor": "χαρτίνης",
          "note": "< χάρτης = ἐκ χάρτου πεποιημένης",
          "rank": 1
        },
        {
          "anchor": "βραδυτέρᾳ",
          "note": "< βραδύς = οὐ ταχεῖα ↔ ταχεῖα",
          "rank": 1
        },
        {
          "anchor": "δύνοντα",
          "note": "< δύνω = εἰς γῆν ἰόντα ↔ ἀνατέλλοντα",
          "rank": 1
        },
        {
          "anchor": "γραμμῆς",
          "note": "= γραπτὴ εὐθεῖα",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "εἷς σκοτεινὸς γεωργὸς διώκων ἡμίονον καὶ ἄροτρον κατὰ τῆς ὑετοπλήκτου πεδιάδος πρὸς νύκτα.",
      "glosses": [
        {
          "anchor": "ὑετοπλήκτου",
          "note": "ὑετο·πλήκτου = ὑετῷ βεβλαμμένης",
          "rank": 1
        },
        {
          "anchor": "πεδιάδος",
          "note": "= χώρα ὁμαλή ↔ ὄρος",
          "rank": 1
        },
        {
          "anchor": "σκοτεινὸς",
          "note": "< σκότος = σκότους πλήρης ↔ λαμπρός",
          "rank": 1
        }
      ]
    }
  ]
}