{
  "sentences": [
    {
      "index": 0,
      "greek": "ἐν τέτταρσι καὶ δέκα ἔτεσιν ἀποδιδράσκει.",
      "glosses": [
        {
          "anchor": "ἀποδιδράσκει",
          "note": "= run away, escape",
          "rank": 1
        },
        {
          "anchor": "τέτταρσι",
          "note": "= four",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "οὐκέτι ὄψεται τὸν ψυχρὸν μαγειρικὸν οἶκον ἐν τῷ πρὸ ἕω σκότει.",
      "glosses": [
        {
          "anchor": "μαγειρικὸν",
          "note": "< μαγειρικός = fit for a cook",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "τὰ ξύλα, τοὺς λουτῆρας.",
      "glosses": [
        {
          "anchor": "λουτῆρας",
          "note": "< λουτήρ = washing",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "πλανᾶται πρὸς ἑσπέραν μέχρι Μέμφιδος, μόνος μετανάστης ἐπὶ τῆς πεδινῆς καὶ ποιμενικῆς χώρας.",
      "glosses": [
        {
          "anchor": "μετανάστης",
          "note": "= one who has left his home, wanderer, migrant",
          "rank": 1
        },
        {
          "anchor": "ποιμενικῆς",
          "note": "< ποιμενικός = of",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "μέλανες ἐν τοῖς ἀγροῖς, ἰσχνοὶ καὶ κύπτοντες, οἱ δάκτυλοι αὐτῶν ἀραχνώδεις ἐν τοῖς κώδυσι τοῦ ἐρίου.",
      "glosses": [
        {
          "anchor": "ἰσχνοὶ",
          "note": "= dry, withered ↔ παχύς",
          "rank": 1
        },
        {
          "anchor": "κύπτοντες",
          "note": "< κύπτω (ἐνεστ. μτχ. ἐν.) = bend forward, stoop",
          "rank": 1
        },
        {
          "anchor": "ἀραχνώδεις",
          "note": "< ἀραχνώδης",
          "rank": 1
        },
        {
          "anchor": "ἐρίου",
          "note": "< ἔριον (γεν.) = wool",
          "rank": 1
        },
        {
          "anchor": "μέλανες",
          "note": "= black, dark ↔ λευκός",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "σκιώδης ἀγωνία ἐν τῷ κήπῳ.",
      "glosses": [
        {
          "anchor": "σκιώδης",
          "note": "< σκιώδης = dark, gloomy",
          "rank": 1
        },
        {
          "anchor": "ἀγωνία",
          "note": "= agony, anguish",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "πρὸς τὸν δύνοντα ἥλιον σχήματα κινούμενα ἐν τῇ βραδυτέρᾳ κνέφῃ διὰ χαρτίνης γραμμῆς.",
      "glosses": [
        {
          "anchor": "βραδυτέρᾳ",
          "note": "= slow ↔ ταχύς",
          "rank": 1
        },
        {
          "anchor": "δύνοντα",
          "note": "< δύω (ἐνεστ. μτχ. ἐν.) = cause to sink, sink, plunge in",
          "rank": 1
        },
        {
          "anchor": "γραμμῆς",
          "note": "= line across the course, starting- ↔ σκιά",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "εἷς σκοτεινὸς γεωργὸς διώκων ἡμίονον καὶ ἄροτρον κατὰ τῆς ὑετοπλήκτου πεδιάδος πρὸς νύκτα.",
      "glosses": [
        {
          "anchor": "πεδιάδος",
          "note": "= flat, level",
          "rank": 1
        },
        {
          "anchor": "σκοτεινὸς",
          "note": "= dark ↔ λαμπρός",
          "rank": 1
        }
      ]
    }
  ]
}