{
  "sentences": [
    {
      "index": 0,
      "greek": "Κροῦσον τὴν θύραν νῦν, ἔφη ὁ Τοαδβίνης.",
      "glosses": [
        {
          "anchor": "Κροῦσον",
          "note": "= κόπτε, τύπτε θύραν",
          "rank": 1
        },
        {
          "anchor": "Τοαδβίνης",
          "note": "ὄνομα ἀνδρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Ὁ παῖς ἀνέστη.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "Ὁ Τοαδβίνης ἀνέστη καὶ ἔμενεν.",
      "glosses": [
        {
          "anchor": "Τοαδβίνης",
          "note": "ὄνομα ἀνδρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἤκουον τὰς φλόγας κρατούσας ἔνδον τοῦ οἰκήματος.",
      "glosses": [
        {
          "anchor": "κρατούσας",
          "note": "< κρατέω = ἰσχυρῶς ἐχούσας",
          "rank": 1
        },
        {
          "anchor": "φλόγας",
          "note": "πυρὸς φῶτα κινούμενα",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ὁ παῖς ἔκρουσεν.",
      "glosses": [
        {
          "anchor": "ἔκρουσεν",
          "note": "< κρούω = ἔκοψε θύραν",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Μεῖζον κροῦε.",
      "glosses": [
        {
          "anchor": "κροῦε",
          "note": "= κόπτε, τύπτε",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Οὗτος ἀνὴρ πίνει τι.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "Συστρέψας τὴν πυγμὴν πεντάκις που τὴν θύραν ἔκοψεν.",
      "glosses": [
        {
          "anchor": "πυγμὴν",
          "note": "χεὶρ συνεσταλμένη πρὸς πλήγην",
          "rank": 1
        },
        {
          "anchor": "Συστρέψας",
          "note": "< συστρέφω = συναγαγών",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Πῦρ ᾅδου, ἔφη φωνή.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "Ἰδοὺ ἔρχεται.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "Ἔμενον.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "Θερμὲ υἱὲ κυνός, ἔφη ἡ φωνή.",
      "glosses": [
        {
          "anchor": "Θερμὲ",
          "note": "ἐνταῦθα = κακέ, μιαρέ",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Εἶτα ἡ βάλανος ἐστράφη καὶ ἡ θύρα ἠνοίχθη.",
      "glosses": [
        {
          "anchor": "βάλανος",
          "note": "κλεὶς θύρας",
          "rank": 1
        },
        {
          "anchor": "ἠνοίχθη",
          "note": "< ἀνοίγω = ἀνεῴχθη",
          "rank": 1
        }
      ]
    },
    {
      "index": 13,
      "greek": "Εἱστήκει ἐν τοῖς ὑποδύταις ἔχων ἐν τῇ χειρὶ τὸ χειρόμακτρον ᾧ τῆς βαλάνου ἥψατο.",
      "glosses": [
        {
          "anchor": "ὑποδύταις",
          "note": "ἱμάτια ἃ ὑπὸ τῶν ἄλλων φορεῖται",
          "rank": 1
        },
        {
          "anchor": "χειρόμακτρον",
          "note": "ῥάκος πρὸς καθαρισμὸν χειρῶν",
          "rank": 1
        },
        {
          "anchor": "βαλάνου",
          "note": "βάλανος = κλεὶς θύρας",
          "rank": 1
        }
      ]
    },
    {
      "index": 14,
      "greek": "Ἰδὼν αὐτοὺς ἐστράφη καὶ ἤρχετο πάλιν εἰς τὸ οἴκημα ἀλλ' ὁ Τοαδβίνης λαβόμενος τοῦ αὐχένος κατήνεγκεν αὐτὸν εἰς τὸ ἔδαφος καὶ κατέχων τῶν τριχῶν ἤρχετο ἐξορύττειν τὸν ὀφθαλμὸν τῷ ἀντίχειρι.",
      "glosses": [
        {
          "anchor": "Τοαδβίνης",
          "note": "ὄνομα ἀνδρός",
          "rank": 1
        },
        {
          "anchor": "ἐξορύττειν",
          "note": "= ἐκκόπτειν, ἐξαιρεῖν",
          "rank": 1
        },
        {
          "anchor": "ἀντίχειρι",
          "note": "ὁ παχὺς δάκτυλος τῆς χειρός",
          "rank": 1
        },
        {
          "anchor": "κατήνεγκεν",
          "note": "< καταφέρω = κάτω ἤνεγκεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 15,
      "greek": "Ὁ ἀνὴρ λαβόμενος τοῦ καρποῦ ἔδακεν.",
      "glosses": [
        {
          "anchor": "ἔδακεν",
          "note": "< δάκνω = τοῖς ὀδοῦσιν ἔβλαψεν",
          "rank": 1
        }
      ]
    }
  ]
}