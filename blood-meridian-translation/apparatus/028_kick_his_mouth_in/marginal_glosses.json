{
  "sentences": [
    {
      "index": 0,
      "greek": "Λάκτιζε αὐτοῦ τὸ στόμα, ἐκάλει ὁ Τοαδβίνης.",
      "glosses": [
        {
          "anchor": "Λάκτιζε",
          "note": "= κόπτε ποδί",
          "rank": 1
        },
        {
          "anchor": "Τοαδβίνης",
          "note": "= ὄνομα ἀνθρώπου",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Λάκτιζε.",
      "glosses": [
        {
          "anchor": "Λάκτιζε",
          "note": "= κόπτε ποδί",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὁ παῖς παρῆλθεν αὐτοὺς εἰς τὸ δωμάτιον καὶ στραφεὶς ἐλάκτισε τὸν ἄνθρωπον κατὰ τοῦ προσώπου.",
      "glosses": [
        {
          "anchor": "ἐλάκτισε",
          "note": "< λακτίζω = ἔκοψε ποδί",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ὁ Τοαδβίνης κατεῖχεν αὐτοῦ τὴν κεφαλὴν ὄπισθεν ταῖς θριξίν.",
      "glosses": [
        {
          "anchor": "Τοαδβίνης",
          "note": "= ὄνομα ἀνθρώπου",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Λάκτιζε αὐτόν, ἐκάλει.",
      "glosses": [
        {
          "anchor": "Λάκτιζε",
          "note": "= κόπτε ποδί",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ὦ, λάκτιζε αὐτόν, φίλε.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Ἐλάκτισεν.",
      "glosses": [
        {
          "anchor": "Ἐλάκτισεν",
          "note": "< λακτίζω = ἔκοψε ποδί",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Ὁ Τοαδβίνης περιήγαγε τὴν ᾑμαγμένην κεφαλὴν καὶ ἰδὼν αὐτὴν ἀφῆκε πεσεῖν χαμαὶ καὶ ἀναστὰς ἐλάκτισεν αὐτὸς τὸν ἄνθρωπον.",
      "glosses": [
        {
          "anchor": "Τοαδβίνης",
          "note": "= ὄνομα ἀνθρώπου",
          "rank": 1
        },
        {
          "anchor": "ἐλάκτισε",
          "note": "< λακτίζω = ἔκοψε ποδί",
          "rank": 1
        },
        {
          "anchor": "περιήγαγε",
          "note": "= κύκλῳ ἔστρεψε",
          "rank": 1
        },
        {
          "anchor": "ᾑμαγμένην",
          "note": "< αἷμα = αἵματι μεμιασμένην",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Δύο θεώμενοι εἱστήκεσαν ἐν τῷ διαδρόμῳ.",
      "glosses": [
        {
          "anchor": "διαδρόμῳ",
          "note": "διά·δρομος = ὁδὸς διὰ οἰκίας",
          "rank": 1
        },
        {
          "anchor": "εἱστήκεσαν",
          "note": "< ἵστημι = ἑστῶτες ἦσαν",
          "rank": 1
        },
        {
          "anchor": "θεώμενοι",
          "note": "< θεάομαι = βλέποντες",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Ἡ θύρα ὅλη κατεκαίετο καὶ μέρος τοῦ τοίχου καὶ τοῦ ὀρόφου.",
      "glosses": [
        {
          "anchor": "ὀρόφου",
          "note": "ὄροφος = τὸ ἄνω μέρος οἰκίας",
          "rank": 1
        },
        {
          "anchor": "κατεκαίετο",
          "note": "< καίω = πυρὶ ἐφθείρετο",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Ἐξῆλθον καὶ κατὰ τὸν διάδρομον.",
      "glosses": [
        {
          "anchor": "διάδρομον",
          "note": "διά·δρομος = ὁδὸν διὰ οἰκίας",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Ὁ γραμματεὺς ἀνέβαινε τοὺς ἀναβαθμοὺς δύο ὁμοῦ.",
      "glosses": [
        {
          "anchor": "ἀναβαθμοὺς",
          "note": "ἀνά·βαθμος = βαθμοὶ εἰς ἄνω",
          "rank": 1
        }
      ]
    }
  ]
}