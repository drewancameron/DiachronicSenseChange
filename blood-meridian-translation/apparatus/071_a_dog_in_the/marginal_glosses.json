          "rank": 1
        },
        {
          "anchor": "σκυθρωπῶς",
          "note": "< σκυθρωπός = μετὰ ὀργῆς βλέπων",
          "rank": 1
        },
        {
          "anchor": "ἐσάλευσεν",
