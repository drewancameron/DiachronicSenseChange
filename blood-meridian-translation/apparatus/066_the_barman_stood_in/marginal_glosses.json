{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὁ κάπηλος ἔστη ἐν μέσῳ τοῦ οἰκήματος.",
      "glosses": [
        {
          "anchor": "κάπηλος",
          "note": "= οἶνον πωλῶν",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Βαρέως ἔπνει καὶ ἐστράφη, τὰς κινήσεις τοῦ παιδὸς διώκων.",
      "glosses": [
        {
          "anchor": "ἔπνει",
          "note": "< πνέω = ἀέρα εἵλκε",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ὅτε ὁ παῖς αὐτῷ προσῆλθε τὸ ξύλον ἦρεν.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Ὁ παῖς κούφως μετὰ τῶν λαγύνων ἔκυψε καὶ ἐσχημάτισε καὶ εἶτα τὴν δεξιὰν κατὰ τῆς κεφαλῆς τοῦ ἀνδρὸς κατέαξεν.",
      "glosses": [
        {
          "anchor": "λαγύνων",
          "note": "λάγυνος = ἀγγεῖον οἴνου",
          "rank": 1
        },
        {
          "anchor": "ἐσχημάτισε",
          "note": "< σχῆμα = σχῆμα ἐποιήσατο",
          "rank": 1
        },
        {
          "anchor": "ἔκυψε",
          "note": "< κύπτω = κάτω ἔκλινεν",
          "rank": 1
        },
        {
          "anchor": "κατέαξεν",
          "note": "< ἄγνυμι = συνέτριψε",
          "rank": 1
        },
        {
          "anchor": "κούφως",
          "note": "< κοῦφος = ταχέως",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Αἷμα καὶ μέθυ ἐρράθη καὶ τὰ γόνατα τοῦ ἀνδρὸς ἐκλάσθη καὶ οἱ ὀφθαλμοὶ ἐστράφησαν.",
      "glosses": [
        {
          "anchor": "ἐρράθη",
          "note": "< ῥέω = ἐχύθη",
          "rank": 1
        },
        {
          "anchor": "ἐκλάσθη",
          "note": "< κλάω = συνετρίβη",
          "rank": 1
        },
        {
          "anchor": "ἐστράφησαν",
          "note": "< στρέφω = ἐκυκλώθησαν",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Ὁ παῖς ἤδη τὸν τράχηλον τῆς λαγύνου ἀφῆκε καὶ τὴν δευτέραν λάγυνον εἰς τὴν δεξιὰν χεῖρα ἔβαλεν ὁδοπόρου τρόπῳ πρὶν ἢ πρὸς τὸ ἔδαφος πεσεῖν καὶ τῇ χειρὶ τὴν δευτέραν λάγυνον διὰ τοῦ κρανίου τοῦ καπήλου ἤγαγε καὶ τὸ ὀξὺ λείψανον εἰς τὸν ὀφθαλμὸν αὐτοῦ ἐνέβαλεν πίπτοντος.",
      "glosses": [
        {
          "anchor": "ὁδοπόρου",
          "note": "ὁδο·πόρος = ὁδῷ βαδίζων",
          "rank": 1
        },
