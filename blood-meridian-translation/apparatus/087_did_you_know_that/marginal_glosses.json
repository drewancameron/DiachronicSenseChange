{
  "sentences": [
    {
      "index": 0,
      "greek": "ἦ γὰρ οἶσθ' ὅτι Δόνιφαν ὁ στρατηγὸς Χιουάουα πόλιν ἑλὼν χιλίους μὲν πολεμίων κατέκτανε, ἕνα δ' ἀπώλεσεν μόνον, κἀκεῖνον αὐτόχειρα σχεδόν;",
      "glosses": [
        {
          "anchor": "στρατηγὸς",
          "note": "= army ↔ οἱ",
          "rank": 1
        },
        {
          "anchor": "κατέκτανε",
          "note": "= he/she killed",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "στρατιῷ δ' ἀμίσθων ἀτάκτων, οἳ Βίλλον ἐκάλουν, ἡμίγυμνοι δ' ἦσαν, πεζῇ δ' ἐκ Μισσουρίου ἐστράτευσαν;",
      "glosses": [
        {
          "anchor": "Βίλλον",
          "note": "= bill",
          "rank": 1
        },
        {
          "anchor": "ἐστράτευσαν",
          "note": "= they campaigned/marched",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "οὔ, ὦ ἄναξ.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "ὁ δὲ ναύαρχος ἀνακλινθεὶς ξυνέπτυξε χεῖρας.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "πρὸς γένος τι, ἔφη, διαφθαρέντων πράττομεν.",
      "glosses": [
        {
          "anchor": "διαφθαρέντων",
          "note": "= having been corrupted/destroyed",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "μιξόφυλον γένος, Αἰθίοπων οὐ πολὺ βέλτιον.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "ἴσως δ' οὐδὲ βέλτιον.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "οὐκ ἔστιν ἀρχὴ ἐν Μεξίκῳ.",
      "glosses": []
    },
    {
      "index": 8,
      "greek": "μὰ Δί', οὐδὲ θεὸς ἐν Μεξίκῳ.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "οὐδ' ἔσται ποτέ.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "πρὸς δῆμον πράττομεν ὃς αὑτοῦ ἄρχειν φανερῶς ἀδύνατος.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "οἶσθα δὲ τί πάσχουσιν οἱ μὴ δυνάμενοι σφῶν αὐτῶν ἄρχειν;",
      "glosses": []
    },
    {
      "index": 12,
      "greek": "ὀρθῶς.",
      "glosses": []
    },
    {
      "index": 13,
      "greek": "ἄλλοι γὰρ ἥκουσιν ἄρξοντες αὐτῶν.",
      "glosses": []
    }
  ]
}