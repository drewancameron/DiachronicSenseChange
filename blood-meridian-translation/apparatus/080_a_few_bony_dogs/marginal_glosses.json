{
  "sentences": [
    {
      "index": 0,
      "greek": "κύνες ὀλίγοι λεπτόσαρκοι ἀπέδρασαν πρόσθεν.",
      "glosses": [
        {
          "anchor": "λεπτόσαρκοι",
          "note": "= thin-fleshed, slender",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "δι' ἀγορᾶς τῆς στρατιωτικῆς ἤλασαν, παρῆλθον δὲ στενωπὸν μικρόν, οὗ ὁ παῖς καὶ ὁ ἡμίονος τῇ προτέρᾳ νυκτὶ ἔπιον·",
      "glosses": [
        {
          "anchor": "μικρόν",
          "note": "= little ↔ μέγας",
          "rank": 1
        },
        {
          "anchor": "ἡμίονος",
          "note": "= mule",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "ὅρμαθοι δὲ γυναικῶν καὶ παίδων περὶ τὸ φρέαρ, πολλὰ δ' εἴδη ἀμφορέων πηλίνων γέρρᾳ κεκαλυμμένων περιεστῶτα.",
      "glosses": [
        {
          "anchor": "φρέαρ",
          "note": "= well",
          "rank": 1
        },
        {
          "anchor": "ἀμφορέων",
          "note": "= jars",
          "rank": 1
        },
        {
          "anchor": "γέρρᾳ",
          "note": "= wicker shield",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "οἰκίαν τινὰ μικρὰν παρῆλθον, ἔνδον γυναῖκες ᾤμωζον·",
      "glosses": [
        {
          "anchor": "ᾤμωζον",
          "note": "= wailed, lamented",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "ἡ δὲ νεκραγωγὸς μικρὰ πρὸς θύραις εἱστήκει, οἵ θ' ἵπποι ὑπομένοντες ἀκίνητοι ἐν καύματι καὶ μυίαις.",
      "glosses": [
        {
          "anchor": "ὑπομένοντες",
          "note": "= patient",
          "rank": 1
        },
        {
          "anchor": "νεκραγωγὸς",
          "note": "= summoner of the dead",
          "rank": 1
        }
      ]
    }
  ]
}