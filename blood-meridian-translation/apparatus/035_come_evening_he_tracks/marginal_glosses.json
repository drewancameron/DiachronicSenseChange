{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἐλθούσης ἑσπέρας ἰχνεύει καπνοῦ στῦλον ἀνιόντα λοξῶς ἐκ τῶν ταπεινῶν λόφων καὶ πρὸ σκότους καλεῖ πρὸς θύραις γέροντος ἐρημίτου ἐννεοττευμένου ἐν τῇ γῇ ὥσπερ βραδύπους.",
      "glosses": [
        {
          "anchor": "ἰχνεύει",
          "note": "< ἴχνος = κατὰ ἴχνη ζητεῖ",
          "rank": 1
        },
        {
          "anchor": "λοξῶς",
          "note": "< λοξός = οὐκ εὐθέως ↔ εὐθέως",
          "rank": 1
        },
        {
          "anchor": "ἐρημίτου",
          "note": "< ἔρημος = ἐν ἐρημίᾳ μόνος ζῶν",
          "rank": 1
        },
        {
          "anchor": "ἐννεοττευμένου",
          "note": "< νεοττός = ὡς νεοττὸς ἐν φωλεᾷ μένων",
          "rank": 1
        },
        {
          "anchor": "βραδύπους",
          "note": "βραδύ·πους = βραδέως πορευόμενος",
          "rank": 1
        },
        {
          "anchor": "ἀνιόντα",
          "note": "< ἀνίημι = ἄνω ἰόντα",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Μόνος, ἡμίμαινος, οἱ ὀφθαλμοὶ ἐρυθρόκυκλοι ὡς εἰ δεδεμένοι ἐν δεσμωτηρίοις διὰ πεπυρωμένων σιδήρων.",
      "glosses": [
        {
          "anchor": "ἡμίμαινος",
          "note": "ἡμι·μαίνομαι = μικρὸν μαινόμενος",
          "rank": 1
        },
        {
          "anchor": "ἐρυθρόκυκλοι",
          "note": "ἐρυθρό·κύκλιος = ἐρυθροὺς κύκλους ἔχων",
          "rank": 1
        },
        {
          "anchor": "δεσμωτηρίοις",
          "note": "< δεσμός = τόπος δεσμίων",
          "rank": 1
        },
        {
          "anchor": "πεπυρωμένων",
          "note": "< πυρόω = πυρὶ διακεκαυμένων",
          "rank": 1
        },
        {
          "anchor": "σιδήρων",
          "note": "= μέταλλον σκληρόν",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ἀλλὰ σῶμα βαρὺ ὅμως.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Ἐθεώρει ἄφωνος ὁ παῖς καταβαίνων σκληρῶς ἀπὸ τοῦ ἡμιόνου.",
      "glosses": [
        {
          "anchor": "ἡμιόνου",
          "note": "= ζῷον ἐξ ἵππου καὶ ὄνου",
          "rank": 1
        },
        {
          "anchor": "σκληρῶς",
          "note": "< σκληρός = οὐ μαλακῶς ↔ μαλακῶς",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Τραχὺς ἄνεμος ἔπνει καὶ τὰ ῥάκη αὐτοῦ περὶ αὐτὸν ἐσείετο.",
      "glosses": [
        {
          "anchor": "ἔπνει",
          "note": "< πνέω = ἄνεμος ἔρχεται",
          "rank": 1
        },
        {
          "anchor": "ἐσείετο",
          "note": "< σείω = κινεῖται ἔνθα κἀκεῖσε",
          "rank": 1
        },
        {
          "anchor": "ῥάκη",
          "note": "= παλαιὰ ἱμάτια διερρωγότα",
          "rank": 1
        }
      ]
    }
  ]
}