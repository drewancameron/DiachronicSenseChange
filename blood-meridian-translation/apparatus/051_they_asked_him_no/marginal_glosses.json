{
  "sentences": [
    {
      "index": 0,
      "greek": "Οὐδὲν ἠρώτων αὐτόν, αὐτοὶ ῥακώδης ὄχλος.",
      "glosses": [
        {
          "anchor": "ῥακώδης",
          "note": "< ῥάκος = σπουδαῖα ἱμάτια οὐκ ἔχων",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Μιγάδες τινές, ἐλεύθεροι Αἰθίοπες, Ἰνδός τις ἢ δύο.",
      "glosses": [
        {
          "anchor": "Ἰνδός",
          "note": "= ἄνθρωπος ἐκ χώρας τῆς πρὸς ἀνατολήν",
          "rank": 1
        },
        {
          "anchor": "Μιγάδες",
          "note": "= ἐκ διαφόρων ἐθνῶν ἄνθρωποι",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Τὰ σκεύη μου ἐκλάπη, ἔφη.",
      "glosses": [
        {
          "anchor": "ἐκλάπη",
          "note": "< κλέπτω = κρύφα ἐλήφθη",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἐνένευσαν ἐν τῷ φωτὶ τοῦ πυρός.",
      "glosses": [
        {
          "anchor": "Ἐνένευσαν",
          "note": "< νεύω = κεφαλὴν κάτω ἔκλιναν",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Πάντα ἃ εἶχον ἔλαβον.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Οὐδὲ μάχαιραν ἔχω.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Δύναιο ἂν σὺν ἡμῖν στρατεύεσθαι.",
      "glosses": [
        {
          "anchor": "Δύναιο",
          "note": "< δύναμαι = ἱκανὸς εἴης ἄν",
          "rank": 1
        }
      ]
    },
    {
      "index": 7,
      "greek": "Δύο ἄνδρας ἀπωλέσαμεν.",
      "glosses": [
        {
          "anchor": "ἀπωλέσαμεν",
          "note": "< ἀπόλλυμι = ἀπεβάλομεν",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Ἀπεστράφησαν εἰς Καλιφορνίαν ἰέναι.",
      "glosses": [
        {
          "anchor": "Καλιφορνίαν",
          "note": "= χώρα τις ἐν δυσμαῖς",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Ἐκεῖσε πορεύομαι.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "Οἶμαί σε αὐτὸν εἰς Καλιφορνίαν ἴσως πορεύεσθαι.",
      "glosses": [
        {
          "anchor": "Καλιφορνίαν",
          "note": "= χώρα τις ἐν δυσμαῖς",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Ἴσως.",
      "glosses": []
    },
    {
      "index": 12,
      "greek": "Οὔπω κέκρικα.",
      "glosses": [
        {
          "anchor": "κέκρικα",
          "note": "< κρίνω = κεκριμένως γινώσκω",
          "rank": 1
        }
      ]
    },
    {
      "index": 13,
      "greek": "Οἱ παῖδες ἐκεῖνοι οἱ μεθ' ἡμῶν ὄντες συνέμιξαν ὁμίλῳ τινὶ ἐξ Ἀρκανσᾶς.",
      "glosses": [
        {
          "anchor": "Ἀρκανσᾶς",
          "note": "= χώρα τις ἐν μεσογαίᾳ",
          "rank": 1
        },
        {
          "anchor": "συνέμιξαν",
          "note": "< συμμίγνυμι = μετὰ ἄλλων ἐγένοντο",
          "rank": 1
        }
      ]
    },
    {
      "index": 14,
      "greek": "Κατέβαινον εἰς Βέξαρ.",
      "glosses": [
        {
          "anchor": "Βέξαρ",
          "note": "= πόλις τις ἐν νότῳ",
          "rank": 1
        }
      ]
    },
    {
      "index": 15,
      "greek": "Ἐπὶ Μεξικὸν καὶ δύσιν ὁρμῶντες.",
      "glosses": [
        {
          "anchor": "Μεξικὸν",
          "note": "= χώρα τις πρὸς νότον",
          "rank": 1
        },
        {
          "anchor": "ὁρμῶντες",
          "note": "< ὁρμάω = πορεύεσθαι ἀρχόμενοι",
          "rank": 1
        }
      ]
    }
  ]
}