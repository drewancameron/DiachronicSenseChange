{
  "sentences": [
    {
      "index": 0,
      "greek": "Ὀπὴ ἐν τῇ ψάμμῳ λίθοι περὶ αὐτὴν σεσωρευμένοι.",
      "glosses": [
        {
          "anchor": "σεσωρευμένοι",
          "note": "< σωρεύω = εἰς σωρὸν τιθέντες",
          "rank": 1
        },
        {
          "anchor": "ψάμμῳ",
          "note": "= γῇ λεπτῇ παρὰ θάλασσαν",
          "rank": 1
        }
      ]
    },
    {
      "index": 1,
      "greek": "Τεμάχιον ξηρᾶς δορᾶς πρὸς κάλυμμα καὶ λίθος καταβαρῦναι αὐτό.",
      "glosses": [
        {
          "anchor": "Τεμάχιον",
          "note": "< τέμνω = μικρὸν τμῆμα",
          "rank": 1
        },
        {
          "anchor": "καταβαρῦναι",
          "note": "= βαρὺ ποιεῖν κάτω",
          "rank": 1
        },
        {
          "anchor": "δορᾶς",
          "note": "= δέρμα ζῴου",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Ἦν κάδος ὠμοδέρματος μετὰ λαβῆς ὠμοδερμάτου καὶ σχοινίον δέρματος λιπαροῦ.",
      "glosses": [
        {
          "anchor": "κάδος",
          "note": "= ἀγγεῖον ὕδατος",
          "rank": 1
        },
        {
          "anchor": "ὠμοδέρματος",
          "note": "= ὠμό·δέρματος = ἐκ δέρματος ὠμοῦ",
          "rank": 1
        },
        {
          "anchor": "ὠμοδερμάτου",
          "note": "= ὠμό·δέρματος = ἐκ δέρματος ὠμοῦ",
          "rank": 1
        },
        {
          "anchor": "λιπαροῦ",
          "note": "= λίπους ἔχοντος ↔ ξηροῦ",
          "rank": 1
        },
        {
          "anchor": "δέρματος",
          "note": "= δορὰ ζῴου",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Τῷ κάδῳ λίθος προσδεδεμένος τῇ λαβῇ βοηθεῖν αὐτὸν κλίνεσθαι καὶ πίμπλασθαι καὶ καθῆκεν αὐτὸν ἕως τὸ σχοινίον ἐν τῇ χειρὶ αὐτοῦ χαλαρὸν ἐγένετο τοῦ ἡμιόνου σκοποῦντος ὑπὲρ τοῦ ὤμου αὐτοῦ.",
      "glosses": [
        {
          "anchor": "κάδῳ",
          "note": "= ἀγγεῖον ὕδατος",
          "rank": 1
        },
        {
          "anchor": "προσδεδεμένος",
          "note": "< προσδέω = προσηρτημένος",
          "rank": 1
        },
        {
          "anchor": "κλίνεσθαι",
          "note": "= πλαγίως γίνεσθαι",
          "rank": 1
        },
        {
          "anchor": "χαλαρὸν",
          "note": "= μὴ τεταμένον ↔ σφιγκτόν",
          "rank": 1
        },
        {
          "anchor": "σκοποῦντος",
          "note": "< σκοπέω = βλέποντος",
          "rank": 1
        },
        {
          "anchor": "πίμπλασθαι",
          "note": "= πλήρη γίνεσθαι ↔ κενοῦσθαι",
          "rank": 1
        },
        {
          "anchor": "ἡμιόνου",
          "note": "= ζῷον ἐξ ἵππου καὶ ὄνου",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ἀνείλκυσε τρεῖς κάδους καὶ κατέσχεν αὐτοὺς ἵνα μὴ ὁ ἡμίονος ἐκχέῃ αὐτοὺς καὶ εἶτα ἐπέθηκε τὸ κάλυμμα πάλιν ἐπὶ τὸ φρέαρ καὶ ἤγαγε τὸν ἡμίονον πάλιν κάτω τὴν ἀτραπὸν πρὸς τὴν καλύβην.",
      "glosses": [
        {
          "anchor": "Ἀνείλκυσε",
          "note": "< ἀνέλκω = ἄνω εἵλκυσε",
          "rank": 1
        },
        {
          "anchor": "κάδους",
          "note": "= ἀγγεῖα ὕδατος",
          "rank": 1
        },
        {
          "anchor": "καλύβην",
          "note": "= οἰκίδιον μικρόν",
          "rank": 1
        },
        {
          "anchor": "ἐκχέῃ",
          "note": "< ἐκχέω = ἔξω χέῃ",
          "rank": 1
        }
      ]
    }
  ]
}