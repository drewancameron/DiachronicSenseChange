{
  "sentences": [
    {
      "index": 0,
      "greek": "Ἐπὶ τῷ ποταμῷ στήσουσιν, φησίν.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Ὁ δεύτερος λοχίας βλέπει παρ' ἑταίρους.",
      "glosses": [
        {
          "anchor": "δεύτερος",
          "note": "= second",
          "rank": 1
        },
        {
          "anchor": "βλέπει",
          "note": "= looks",
          "rank": 1
        },
        {
          "anchor": "ἑταίρους",
          "note": "= comrades",
          "rank": 1
        },
        {
          "anchor": "βλέπει",
          "note": "= looks",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Πρός μ' ἆρα λέγεις;",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Ἐπὶ τῷ ποταμῷ.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Ἴσθι.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Καθείρξουσιν ἅπαντας.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Τίνες;",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "Στρατὸς τῶν Ἡνωμένων Πολιτειῶν.",
      "glosses": [
        {
          "anchor": "Ἡνωμένων",
          "note": "= united",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Στρατηγὸς Οὖρθος.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "Οὐ μὰ Δία.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "Εὔχου γε.",
      "glosses": []
    },
    {
      "index": 11,
      "greek": "Βλέπει πρὸς ἑταίρους.",
      "glosses": []
    },
    {
      "index": 12,
      "greek": "Ῥέπει πρὸς τὸν Μεννονίτην.",
      "glosses": []
    },
    {
      "index": 13,
      "greek": "Τί τοῦτο σημαίνει, ὦ γέρον;",
      "glosses": [
        {
          "anchor": "σημαίνει",
          "note": "= mean",
          "rank": 1
        }
      ]
    },
    {
      "index": 14,
      "greek": "Ἐὰν διαβῆτε τὸν ποταμὸν μετὰ τοῦδε τοῦ λῃστοῦ ὡπλισμένοι, οὐ διαβήσεσθε πάλιν.",
      "glosses": [
        {
          "anchor": "διαβῆτε",
          "note": "= cross",
          "rank": 1
        },
        {
          "anchor": "λῃστοῦ",
          "note": "= robber, bandit",
          "rank": 1
        }
      ]
    },
    {
      "index": 15,
      "greek": "Οὐ βουλόμεθα διαβῆναι πάλιν.",
      "glosses": [
        {
          "anchor": "βουλόμεθα",
          "note": "= 'll",
          "rank": 1
        }
      ]
    },
    {
      "index": 16,
      "greek": "Εἰς Σονόραν πορευόμεθα.",
      "glosses": [
        {
          "anchor": "πορευόμεθα",
          "note": "= goin",
          "rank": 1
        }
      ]
    },
    {
      "index": 17,
      "greek": "Τί δὲ σοὶ μέλει, ὦ γέρον;",
      "glosses": []
    },
    {
      "index": 18,
      "greek": "Ὁ Μεννονίτης θεᾶται τὸ ἐσκιασμένον σκότος πρὸ αὐτῶν ὡς ἀντανακλᾶται αὐτῷ ἐν τῷ κατόπτρῳ ὑπὲρ τοῦ οἰνοπωλείου.",
      "glosses": [
        {
          "anchor": "οἰνοπωλείου",
          "note": "= wine shop",
          "rank": 1
        }
      ]
    },
    {
      "index": 19,
      "greek": "Στρέφεται πρὸς αὐτούς.",
      "glosses": []
    },
    {
      "index": 20,
      "greek": "Ὀφθαλμοὶ ὑγροί, λέγει βραδέως.",
      "glosses": []
    },
    {
      "index": 21,
      "greek": "Ὀργὴ θεοῦ καθεύδει.",
      "glosses": [
        {
          "anchor": "καθεύδει",
          "note": "= sleeping",
          "rank": 1
        }
      ]
    },
    {
      "index": 22,
      "greek": "Μυρία ἔτη πρὶν ἀνθρώπους γενέσθαι ἐκρύφθη, μόνοι δ' ἄνθρωποι δύνανται ἐγεῖραι.",
      "glosses": []
    },
    {
      "index": 23,
      "greek": "Ὁ ᾍδης οὐδὲ ἥμισυς πλήρης.",
      "glosses": [
        {
          "anchor": "ᾍδης",
          "note": "= hell",
          "rank": 1
        },
        {
          "anchor": "ἥμισυς",
          "note": "= half",
          "rank": 1
        },
        {
          "anchor": "πλήρης",
          "note": "= full ↔ κενός",
          "rank": 1
        }
      ]
    },
    {
      "index": 24,
      "greek": "Ἄκουέ μου.",
      "glosses": []
    },
    {
      "index": 25,
      "greek": "Φέρετε πόλεμον μαινομένου τέχνημα εἰς ἀλλοτρίαν γῆν.",
      "glosses": [
        {
          "anchor": "μαινομένου",
          "note": "= madman",
          "rank": 1
        },
        {
          "anchor": "τέχνημα",
          "note": "= clever trick, device",
          "rank": 1
        }
      ]
    },
    {
      "index": 26,
      "greek": "Πλείονα κυνῶν ἐγερεῖτε.",
      "glosses": []
    }
  ]
}