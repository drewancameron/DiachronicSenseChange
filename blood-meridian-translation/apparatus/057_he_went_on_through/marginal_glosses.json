{
  "sentences": [
    {
      "index": 0,
      "greek": "Προῆλθε διὰ τῆς πόλεως ἄγων τὸ κτῆνος.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Οὐδεὶς ἦν περί.",
      "glosses": []
    },
    {
      "index": 2,
      "greek": "Μετὰ μικρὸν εἰσῆλθεν εἰς ἀγορὰν καὶ ἠδύνατο ἀκούειν κιθάρας καὶ σάλπιγγα.",
      "glosses": [
        {
          "anchor": "σάλπιγγα",
          "note": "= ὄργανον μουσικὸν χάλκεον",
          "rank": 1
        }
      ]
    },
    {
      "index": 3,
      "greek": "Ἐπὶ τῷ ἐσχάτῳ τῆς ἀγορᾶς ἦσαν φῶτα ἐκ καπηλείου καὶ γέλως καὶ κραυγαὶ ὀξεῖαι.",
      "glosses": [
        {
          "anchor": "καπηλείου",
          "note": "= οἴκου οἰνοπώλου",
          "rank": 1
        },
        {
          "anchor": "ὀξεῖαι",
          "note": "= ἰσχυραὶ καὶ ὑψηλαί",
          "rank": 1
        },
        {
          "anchor": "κραυγαὶ",
          "note": "= φωναὶ μεγάλαι",
          "rank": 1
        }
      ]
    },
    {
      "index": 4,
      "greek": "Ἤγαγε τὸν ἡμίονον εἰς τὴν ἀγορὰν καὶ ἄνω τὴν πέραν πλευρὰν παρὰ στοὰν μακρὰν πρὸς τὰ φῶτα.",
      "glosses": []
    },
    {
      "index": 5,
      "greek": "Ἦν ὄχλος ὀρχηστῶν ἐν τῇ ὁδῷ καὶ ἐφόρουν ἐσθῆτας λαμπρὰς καὶ ἐβόων Ἰβηρικῶς.",
      "glosses": [
        {
          "anchor": "Ἰβηρικῶς",
          "note": "= κατὰ τὴν Ἰβήρων φωνήν",
          "rank": 1
        },
        {
          "anchor": "ὀρχηστῶν",
          "note": "< ὀρχέομαι = ὀρχουμένων ἀνδρῶν",
          "rank": 1
        },
        {
          "anchor": "ἐφόρουν",
          "note": "< φορέω = εἶχον ἐπὶ τῷ σώματι",
          "rank": 1
        }
      ]
    },
    {
      "index": 6,
      "greek": "Αὐτὸς καὶ ὁ ἡμίονος ἔστησαν παρὰ τὴν ἄκραν τῶν φώτων καὶ ἐθεώρουν.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "Γέροντες ἐκάθηντο παρὰ τὸν τοῖχον τοῦ καπηλείου καὶ παῖδες ἔπαιζον ἐν τῇ κόνει.",
      "glosses": [
        {
          "anchor": "καπηλείου",
          "note": "= οἴκου οἰνοπώλου",
          "rank": 1
        },
        {
          "anchor": "κόνει",
          "note": "= χώματι λεπτῷ",
          "rank": 1
        },
        {
          "anchor": "ἔπαιζον",
          "note": "< παίζω = παιδικὰ ἐποίουν",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "Ἐφόρουν ἐσθῆτας ἀλλοκότους πάντες, οἱ ἄνδρες ἐν πίλοις μέλασι πλατέσι, λευκοῖς χιτῶσι νυκτερινοῖς, ἀναξυρίσι τοῖς ἔξωθεν τοῦ σκέλους κομβουμένοις καὶ αἱ κόραι μετὰ προσώπων κεχρισμένων λαμπρῶς καὶ κτενῶν χελωνίνων ἐν ταῖς κυανομέλαιναις θριξίν.",
      "glosses": [
        {
          "anchor": "πίλοις",
          "note": "= περικεφαλαίοις ἐκ πίλου πεποιημένοις",
          "rank": 1
        },
        {
          "anchor": "μέλασι",
          "note": "= μαύροις ↔ λευκοῖς",
          "rank": 1
        },
        {
          "anchor": "πλατέσι",
          "note": "= εὐρέσι ↔ στενοῖς",
          "rank": 1
        },
        {
          "anchor": "νυκτερινοῖς",
          "note": "< νύξ = τῆς νυκτὸς οὖσι",
          "rank": 1
        },
        {
          "anchor": "κομβουμένοις",
          "note": "= δεσμοῖς συνεχομένοις",
          "rank": 1
        },
        {
          "anchor": "κεχρισμένων",
          "note": "< χρίω = μύροις κεκοσμημένων",
          "rank": 1
        },
        {
          "anchor": "κτενῶν",
          "note": "= ἐργαλείων πρὸς κόσμησιν τριχῶν",
          "rank": 1
        },
        {
          "anchor": "χελωνίνων",
          "note": "< χελώνη = ἐκ χελώνης πεποιημένων",
          "rank": 1
        },
        {
          "anchor": "κυανομέλαιναις",
          "note": "κυανο·μέλαινα = κυανοῦ καὶ μέλανος χρώματος",
          "rank": 1
        },
        {
          "anchor": "ἀναξυρίσι",
          "note": "= περισκελίσι βαρβαρικοῖς",
          "rank": 1
        },
        {
          "anchor": "σκέλους",
          "note": "= μέρους τοῦ σώματος πρὸς βάδισιν",
          "rank": 1
        },
        {
          "anchor": "κόραι",
          "note": "= παρθένοι νέαι",
          "rank": 1
        },
        {
          "anchor": "χιτῶσι",
          "note": "= ἱματίοις λεπτοῖς",
          "rank": 1
        },
        {
          "anchor": "ἀλλοκότους",
          "note": "= παραδόξους ↔ συνήθεις",
          "rank": 1
        }
      ]
    },
    {
      "index": 9,
      "greek": "Ὁ παῖς διέβη τὴν ὁδὸν μετὰ τοῦ ἡμιόνου καὶ ἔδησεν αὐτὸν καὶ εἰσῆλθεν εἰς τὸ καπηλεῖον.",
      "glosses": [
        {
          "anchor": "καπηλεῖον",
          "note": "= οἶκος οἰνοπώλου",
          "rank": 1
        },
        {
          "anchor": "ἡμιόνου",
          "note": "= ζῴου ἐξ ἵππου καὶ ὄνου",
          "rank": 1
        }
      ]
    },
    {
      "index": 10,
      "greek": "Ἄνδρες τινὲς εἱστήκεισαν πρὸς τῷ ἀβακίῳ καὶ ἐπαύσαντο λαλοῦντες ὅτε εἰσῆλθεν.",
      "glosses": [
        {
          "anchor": "ἀβακίῳ",
          "note": "= τραπέζῃ καπηλικῇ",
          "rank": 1
        },
        {
          "anchor": "εἱστήκεισαν",
          "note": "< ἵστημι = ἑστῶτες ἦσαν",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Διέβη τὸ κεχρισμένον πήλινον ἔδαφος παρὰ κύνα καθεύδοντα ὃς ἤνοιξεν ἕνα ὀφθαλμὸν καὶ εἶδεν αὐτὸν καὶ ἔστη πρὸς τῷ ἀβακίῳ καὶ ἔθηκεν ἀμφοτέρας τὰς χεῖρας ἐπὶ τοὺς πλίνθους.",
      "glosses": [
        {
          "anchor": "ἀβακίῳ",
          "note": "= τραπέζῃ καπηλικῇ",
          "rank": 1
        },
        {
          "anchor": "κεχρισμένον",
          "note": "< χρίω = μύρῳ ἠλειμμένον",
          "rank": 1
        },
        {
          "anchor": "πήλινον",
          "note": "< πηλός = ἐκ πηλοῦ πεποιημένον",
          "rank": 1
        },
        {
          "anchor": "πλίνθους",
          "note": "= λίθους τετραγώνους",
          "rank": 1
        },
        {
          "anchor": "καθεύδοντα",
          "note": "< καθεύδω = ὑπνοῦντα",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Ὁ κάπηλος ἔνευσεν αὐτῷ.",
      "glosses": [
        {
          "anchor": "ἔνευσεν",
          "note": "= τῇ κεφαλῇ σημεῖον ἔδωκεν",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "= οἰνοπώλης",
          "rank": 1
        }
      ]
    },
    {
      "index": 13,
      "greek": "Εἰπέ μοι, εἶπεν.",
      "glosses": []
    }
  ]
}