{
  "sentences": [
    {
      "index": 0,
      "greek": "Οἱ ἄνδρες παρὰ τῇ τραπέζῃ ἐθεώντο.",
      "glosses": []
    },
    {
      "index": 1,
      "greek": "Ὁ κάπηλος ἔβλεψεν εἰς τὸν παῖδα.",
      "glosses": [
        {
          "anchor": "ἔβλεψεν",
          "note": "< βλέπω = εἶδεν, ἐθεάσατο",
          "rank": 1
        },
        {
          "anchor": "κάπηλος",
          "note": "= ὁ οἶνον πωλῶν ἐν καπηλείῳ",
          "rank": 1
        }
      ]
    },
    {
      "index": 2,
      "greek": "Quiere trabajo, εἶπεν ὁ γέρων.",
      "glosses": []
    },
    {
      "index": 3,
      "greek": "Quien sabe.",
      "glosses": []
    },
    {
      "index": 4,
      "greek": "Ἐπέστρεψε πρὸς τὰ πεττὰ καὶ ἔπαιξεν ἄνευ πλείονος βουλῆς.",
      "glosses": [
        {
          "anchor": "πεττὰ",
          "note": "= παίγνια λίθινα ἐπὶ τραπέζης",
          "rank": 1
        },
        {
          "anchor": "ἔπαιξεν",
          "note": "< παίζω = παιδιὰν ἐποιήσατο",
          "rank": 1
        }
      ]
    },
    {
      "index": 5,
      "greek": "Quieres trabajar, εἶπέ τις τῶν ἀνδρῶν τῶν παρὰ τῇ τραπέζῃ.",
      "glosses": []
    },
    {
      "index": 6,
      "greek": "Ἤρξαντο γελᾶν.",
      "glosses": []
    },
    {
      "index": 7,
      "greek": "Τί γελᾶτε;",
      "glosses": [
        {
          "anchor": "γελᾶτε",
          "note": "< γελάω = γέλωτα ποιεῖτε",
          "rank": 1
        }
      ]
    },
    {
      "index": 8,
      "greek": "εἶπεν ὁ παῖς.",
      "glosses": []
    },
    {
      "index": 9,
      "greek": "Ἔσχον.",
      "glosses": []
    },
    {
      "index": 10,
      "greek": "Οἱ μὲν ἔβλεψαν αὐτόν, οἱ δὲ συνῆγον τὰ χείλη ἢ ἤρκεσαν τοὺς ὤμους.",
      "glosses": [
        {
          "anchor": "ἤρκεσαν",
          "note": "< αἴρω = ἦραν, ἐπῆραν",
          "rank": 1
        },
        {
          "anchor": "ἔβλεψαν",
          "note": "< βλέπω = εἶδον, ἐθεάσαντο",
          "rank": 1
        }
      ]
    },
    {
      "index": 11,
      "greek": "Ὁ παῖς ἐτράπη πρὸς τὸν κάπηλον.",
      "glosses": [
        {
          "anchor": "κάπηλον",
          "note": "κάπηλος = ὁ οἶνον πωλῶν",
          "rank": 1
        },
        {
          "anchor": "ἐτράπη",
          "note": "< τρέπω = ἐστράφη πρός",
          "rank": 1
        }
      ]
    },
    {
      "index": 12,
      "greek": "Ἔχεις τι ὃ ἂν δυναίμην πρᾶξαι ἀντὶ ποτῶν δυοῖν εὖ οἶδα.",
      "glosses": []
    }
  ]
}